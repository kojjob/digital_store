<script>
  // Mobile filter toggle functionality
  document.addEventListener('DOMContentLoaded', function() {
    const mobileFilterToggle = document.getElementById('mobile-filter-toggle');
    const mobileFilters = document.getElementById('mobile-filters');
    const closeMobileFilters = document.getElementById('close-mobile-filters');
    const mobileFiltersBackdrop = document.getElementById('mobile-filters-backdrop');
    
    if (mobileFilterToggle && mobileFilters && closeMobileFilters) {
      mobileFilterToggle.addEventListener('click', function() {
        mobileFilters.classList.remove('translate-x-full');
      });
      
      closeMobileFilters.addEventListener('click', function() {
        mobileFilters.classList.add('translate-x-full');
      });
      
      mobileFiltersBackdrop.addEventListener('click', function() {
        mobileFilters.classList.add('translate-x-full');
      });
    }
    
    // Carousel functionality
    const initCarousel = () => {
      // Select carousel elements
      const carousel = document.getElementById('hero-carousel');
      if (!carousel) return;
      
      const slides = carousel.querySelectorAll('.carousel-slide');
      if (!slides.length) return;
      
      const indicators = carousel.querySelectorAll('.carousel-indicator');
      const prevBtn = carousel.querySelector('.carousel-nav.prev');
      const nextBtn = carousel.querySelector('.carousel-nav.next');
      
      // Initialize state
      let currentSlide = 0;
      let isAnimating = false;
      let slideInterval;
      let touchStartX = 0;
      let touchEndX = 0;
      
      // Set up initial state
      const setupInitialState = () => {
        slides.forEach((slide, index) => {
          // Position all slides absolutely and set initial opacity/visibility
          slide.style.position = 'absolute';
          slide.style.top = '0';
          slide.style.left = '0';
          slide.style.width = '100%';
          slide.style.height = '100%';
          slide.setAttribute('aria-hidden', index === 0 ? 'false' : 'true');
          
          if (index !== 0) {
            slide.style.opacity = '0';
            slide.style.visibility = 'hidden';
          } else {
            slide.style.opacity = '1';
            slide.style.visibility = 'visible';
          }
        });
        
        // Set first indicator as active
        if (indicators.length > 0) {
          indicators[0].classList.add('opacity-100');
          indicators[0].setAttribute('aria-current', 'true');
        }
      };
      
      // Function to show a specific slide
      const showSlide = (index) => {
        if (isAnimating || index === currentSlide) return;
        isAnimating = true;
        
        // Stop the auto slide interval when user interacts
        clearInterval(slideInterval);
        
        // Update aria-hidden attributes
        slides[currentSlide].setAttribute('aria-hidden', 'true');
        slides[index].setAttribute('aria-hidden', 'false');
        
        // Hide current slide
        slides[currentSlide].style.opacity = '0';
        setTimeout(() => {
          slides[currentSlide].style.visibility = 'hidden';
          
          // Show new slide
          slides[index].style.visibility = 'visible';
          requestAnimationFrame(() => {
            slides[index].style.opacity = '1';
          });
        }, 300);
        
        // Update indicators
        if (indicators.length > 0) {
          indicators[currentSlide].classList.remove('opacity-100');
          indicators[currentSlide].setAttribute('aria-current', 'false');
          indicators[index].classList.add('opacity-100');
          indicators[index].setAttribute('aria-current', 'true');
        }
        
        // Update currentSlide and reset animation flag after transition
        currentSlide = index;
        setTimeout(() => {
          isAnimating = false;
          startSlideInterval();
        }, 600);
      };
      
      // Navigate to next slide
      const nextSlide = () => {
        const next = (currentSlide + 1) % slides.length;
        showSlide(next);
      };
      
      // Navigate to previous slide
      const prevSlide = () => {
        const prev = (currentSlide - 1 + slides.length) % slides.length;
        showSlide(prev);
      };
      
      // Function to start auto-slide interval
      const startSlideInterval = () => {
        clearInterval(slideInterval);
        slideInterval = setInterval(nextSlide, 5000);
      };
      
      // Set up event listeners
      const setupEventListeners = () => {
        // Next/prev button clicks
        if (prevBtn) {
          prevBtn.addEventListener('click', (e) => {
            e.preventDefault();
            if (!isAnimating) prevSlide();
          });
        }
        
        if (nextBtn) {
          nextBtn.addEventListener('click', (e) => {
            e.preventDefault();
            if (!isAnimating) nextSlide();
          });
        }
        
        // Indicator clicks
        indicators.forEach((indicator, index) => {
          indicator.addEventListener('click', () => {
            if (!isAnimating && index !== currentSlide) {
              showSlide(index);
            }
          });
        });
        
        // Keyboard navigation
        carousel.setAttribute('tabindex', '0');
        carousel.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowLeft') {
            e.preventDefault();
            if (!isAnimating) prevSlide();
          } else if (e.key === 'ArrowRight') {
            e.preventDefault();
            if (!isAnimating) nextSlide();
          }
        });
        
        // Touch events for swipe
        carousel.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        }, { passive: true });
        
        carousel.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          handleSwipe();
        }, { passive: true });
        
        // Pause autoplay on hover/focus
        carousel.addEventListener('mouseenter', () => {
          clearInterval(slideInterval);
        });
        
        carousel.addEventListener('mouseleave', () => {
          startSlideInterval();
        });
        
        carousel.addEventListener('focusin', () => {
          clearInterval(slideInterval);
        });
        
        carousel.addEventListener('focusout', () => {
          startSlideInterval();
        });
      };
      
      // Handle swipe gestures
      const handleSwipe = () => {
        const swipeThreshold = 50;
        if (touchEndX < touchStartX - swipeThreshold) {
          if (!isAnimating) nextSlide();
        } else if (touchEndX > touchStartX + swipeThreshold) {
          if (!isAnimating) prevSlide();
        }
      };
      
      // Initialize
      setupInitialState();
      setupEventListeners();
      startSlideInterval();
      
      // Window resize handling for responsiveness
      window.addEventListener('resize', () => {
        // Adjust any responsive behavior if needed
      });
      
      // Return public API for programmatic control
      return {
        next: nextSlide,
        prev: prevSlide,
        goTo: showSlide
      };
    };
    
    // Initialize carousel and store API
    const carouselAPI = initCarousel();
    
    // Handle country selector to prevent carousel from expanding
    document.querySelectorAll('.country-selector').forEach(link => {
      link.addEventListener('click', function(e) {
        // Show a loading indicator if needed instead of just preventing default
        // We'll use a subtle visual cue instead of preventing navigation
        const countryName = this.getAttribute('data-country');
        localStorage.setItem('selectedCountry', countryName);
        // Let the navigation continue naturally
      });
    });
    
    // Check if there was a previous country selection after page load
    const storedCountry = localStorage.getItem('selectedCountry');
    if (storedCountry) {
      // Could use this to preselect or perform any other actions
      localStorage.removeItem('selectedCountry'); // Clear it after use
    }
      
      // Update countdown timers
      const updateCountdowns = () => {
        document.querySelectorAll('.countdown-timer').forEach(timer => {
          if (!timer.getAttribute('data-initialized')) {
            // Initialize with random time between 10 minutes and 5 hours
            const minutes = parseInt(timer.getAttribute('data-minutes')) || Math.floor(Math.random() * 290) + 10;
            const seconds = parseInt(timer.getAttribute('data-seconds')) || Math.floor(Math.random() * 59);
            
            let totalSeconds = (minutes * 60) + seconds;
            timer.setAttribute('data-total-seconds', totalSeconds);
            timer.setAttribute('data-initialized', 'true');
          }
          
          let totalSeconds = parseInt(timer.getAttribute('data-total-seconds'));
          if (totalSeconds <= 0) {
            // Reset to a new random time when it reaches zero
            totalSeconds = Math.floor(Math.random() * 18000) + 600; // 10 minutes to 5 hours
          } else {
            totalSeconds--;
          }
          
          timer.setAttribute('data-total-seconds', totalSeconds);
          
          const hours = Math.floor(totalSeconds / 3600);
          const mins = Math.floor((totalSeconds % 3600) / 60);
          const secs = totalSeconds % 60;
          
          let timeStr = '';
          if (hours > 0) {
            timeStr += `${hours}h `;
          }
          timeStr += `${mins.toString().padStart(2, '0')}m ${secs.toString().padStart(2, '0')}s`;
          
          timer.textContent = `Offer ends in: ${timeStr}`;
          
          // Banner countdown update
          const bannerCountdown = document.getElementById('banner-countdown');
          if (bannerCountdown) {
            bannerCountdown.textContent = `Sale ends in: ${timeStr}`;
          }
        });
      };
      
      // Update countdowns every second
      setInterval(updateCountdowns, 1000);
      updateCountdowns(); // Initial call
    
    // Additional styles for toggle checkboxes
    const toggleCheckboxes = document.querySelectorAll('.toggle-checkbox');
    toggleCheckboxes.forEach(checkbox => {
      checkbox.addEventListener('change', function() {
        const label = this.nextElementSibling;
        if (this.checked) {
          label.classList.add('bg-blue-500');
          label.classList.remove('bg-gray-300');
        } else {
          label.classList.remove('bg-blue-500');
          label.classList.add('bg-gray-300');
        }
      });
    });
    
    // Add custom styles to pagination
    document.querySelectorAll('.paginate-wrapper a').forEach(link => {
      link.classList.add('relative', 'inline-flex', 'items-center', 'px-4', 'py-2', 'text-sm', 'font-medium', 'text-gray-700', 'bg-white', 'border', 'border-gray-300', 'hover:bg-gray-50');
    });
    
    document.querySelectorAll('.paginate-wrapper em.current').forEach(current => {
      current.classList.add('z-10', 'bg-blue-50', 'border-blue-500', 'text-blue-600', 'relative', 'inline-flex', 'items-center', 'px-4', 'py-2', 'text-sm', 'font-medium');
    });
    
    document.querySelectorAll('.paginate-wrapper span.gap').forEach(gap => {
      gap.classList.add('relative', 'inline-flex', 'items-center', 'px-4', 'py-2', 'border', 'border-gray-300', 'bg-white', 'text-sm', 'font-medium', 'text-gray-700');
    });
  });
</script>

<style>
  /* Custom styles for toggle checkboxes */
  .toggle-checkbox:checked {
    right: 0;
    border-color: #3B82F6;
  }
  .toggle-checkbox:checked + .toggle-label {
    background-color: #3B82F6;
  }
  
  /* Animation for the carousel */
  .carousel-slide {
    transition: opacity 0.4s ease-in-out, visibility 0.4s ease-in-out;
    opacity: 1;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    will-change: opacity, visibility;
  }
  
  #hero-carousel {
    position: relative;
    overflow: hidden;
  }
  
  /* Animations for blobs */
  @keyframes blob {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(10px, -10px) scale(1.05); }
    50% { transform: translate(0, 20px) scale(0.95); }
    75% { transform: translate(-10px, -5px) scale(1.05); }
  }
  
  .animate-blob {
    animation: blob 7s infinite;
  }
  
  .animation-delay-2000 {
    animation-delay: 2s;
  }
  
  .animation-delay-4000 {
    animation-delay: 4s;
  }
  
  /* Slow pulse animation */
  @keyframes pulse-slow {
    0%, 100% { opacity: 0.8; }
    50% { opacity: 0.6; }
  }
  
  .animate-pulse-slow {
    animation: pulse-slow 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  
  /* Animation for the discount badge */
  @keyframes pulse-scale {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }
  
  /* Apply the animation to discount badges */
  .bg-gradient-to-l {
    animation: pulse-scale 2s infinite;
  }
  
  /* Make price inputs look good */
  input[type=number]::-webkit-inner-spin-button,
  input[type=number]::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  
  /* Enhance focus states for better accessibility */
  .focus\:ring-blue-500:focus {
    --tw-ring-opacity: 0.5;
    --tw-ring-color: rgba(59, 130, 246, var(--tw-ring-opacity));
  }
  
  /* Z-pattern layout styling */
  .z-pattern-start {
    grid-column: 1;
  }
  
  .z-pattern-end {
    grid-column: -1;
  }
</style>
