                  <div class="pt-2">
                    <%= f.submit "Apply Filter", class: "w-full bg-blue-600 border border-transparent rounded-md py-2.5 px-4 text-sm font-medium text-white shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
