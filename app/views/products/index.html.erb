        <div class="h-full flex flex-col bg-white shadow-xl overflow-y-auto">
          <div class="py-6 px-4 bg-blue-600 sm:px-6">
            <div class="flex items-center justify-between">
              <h2 class="text-lg font-medium text-white">Filters</h2>
