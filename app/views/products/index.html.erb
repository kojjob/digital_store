<div class="bg-gradient-to-br from-white to-blue-50 min-h-screen">
  <div class="w-full pt-6">
    <!-- Hero carousel section - Z-pattern top horizontal line -->
    <div class="mb-8 relative overflow-hidden shadow-lg" style="height: 66vh; min-height: 500px;">
      <div id="hero-carousel" class="carousel-container relative h-full w-full">
        <!-- Banner 1: Seasonal promotion with aspirational lifestyle imagery -->
        <div class="carousel-slide bg-gradient-to-r from-blue-700 to-blue-500">
          <div class="relative w-full px-8 md:px-16 lg:px-24 flex flex-col md:flex-row justify-between items-center h-full">
            <div class="text-white mb-6 md:mb-0 z-10 max-w-xl">
              <h1 class="text-6xl font-bold mb-6 text-shadow-lg tracking-tight">Spring Collection</h1>
              <p class="text-xl text-blue-50 max-w-lg leading-relaxed text-shadow-sm mb-8">Discover fresh styles and exclusive deals from our finest artisans</p>
              <div class="mt-8">
                <a href="#featured-products" class="inline-flex items-center px-10 py-5 border border-transparent rounded-lg shadow-md text-xl font-medium text-blue-600 bg-white hover:bg-blue-50 transition-colors duration-150 ease-in-out">
                  Shop Now
                  <svg class="ml-3 h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                  </svg>
                </a>
              </div>
            </div>
            <div class="relative w-96 h-96 md:w-[28rem] md:h-[28rem] mt-6 md:mt-0 flex-shrink-0">
              <div class="absolute inset-0 bg-white/20 backdrop-blur-sm rounded-full animate-pulse-slow"></div>
              <img src="/assets/seasonal_collection.jpg" alt="Spring Collection" class="relative z-10 object-cover rounded-lg shadow-xl transform -rotate-3 hover:rotate-0 transition-transform duration-300">
            </div>
          </div>
        </div>
        
        <!-- Banner 2: Best-sellers showcase with subtle scarcity messaging -->
        <div class="carousel-slide bg-gradient-to-r from-orange-600 to-orange-400">
          <div class="relative w-full px-8 md:px-16 lg:px-24 flex flex-col md:flex-row justify-between items-center h-full">
            <div class="text-white mb-6 md:mb-0 z-10 max-w-xl">
              <div class="mb-4 inline-flex items-center px-4 py-2 bg-orange-700 bg-opacity-60 rounded-lg backdrop-blur-sm">
                <span class="text-sm font-bold uppercase tracking-wide">Top Rated</span>
              </div>
              <h1 class="text-6xl font-bold mb-6 text-shadow-lg tracking-tight">Best Sellers</h1>
              <p class="text-xl text-orange-50 max-w-lg leading-relaxed text-shadow-sm mb-8">Our most popular items are flying off the shelves</p>
              
              <div class="mt-5 mb-6 inline-flex items-center px-4 py-2 bg-orange-700 bg-opacity-60 rounded-lg backdrop-blur-sm">
                <svg class="mr-2 h-5 w-5 text-orange-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-base font-bold" id="banner-countdown">Sale ends in: 23:45:12</span>
              </div>
              
              <div class="mt-8">
                <a href="#best-sellers" class="inline-flex items-center px-10 py-5 border border-transparent rounded-lg shadow-md text-xl font-medium text-orange-600 bg-white hover:bg-orange-50 transition-colors duration-150 ease-in-out">
                  Shop Now
                </a>
              </div>
            </div>
            <div class="flex items-end space-x-6 mt-6 md:mt-0 flex-shrink-0">
              <div class="bg-white rounded-lg p-4 shadow-xl transform rotate-2 hover:rotate-0 transition-transform duration-300">
                <div class="relative">
                  <img src="/assets/bestseller_1.jpg" alt="Best Seller Product" class="h-40 w-40 object-cover rounded">
                  <div class="absolute -top-2 -right-2 bg-orange-500 text-white font-bold rounded-full h-8 w-8 flex items-center justify-center">
                    1
                  </div>
                </div>
              </div>
              <div class="bg-white rounded-lg p-4 shadow-xl transform -rotate-2 hover:rotate-0 transition-transform duration-300">
                <div class="relative">
                  <img src="/assets/bestseller_2.jpg" alt="Best Seller Product" class="h-40 w-40 object-cover rounded">
                  <div class="absolute -top-2 -right-2 bg-orange-400 text-white font-bold rounded-full h-8 w-8 flex items-center justify-center">
                    2
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Banner 3: New arrivals with curiosity-inducing partial product reveals -->
        <div class="carousel-slide bg-gradient-to-r from-blue-800 to-purple-600">
          <div class="relative w-full px-8 md:px-16 lg:px-24 flex flex-col md:flex-row justify-between items-center h-full">
            <div class="text-white mb-6 md:mb-0 z-10 max-w-xl">
              <div class="mb-4 inline-flex items-center px-4 py-2 bg-blue-900 bg-opacity-60 rounded-lg backdrop-blur-sm">
                <span class="text-sm font-bold uppercase tracking-wide">Just Arrived</span>
              </div>
              <h1 class="text-6xl font-bold mb-6 text-shadow-lg tracking-tight">New Arrivals</h1>
              <p class="text-xl text-blue-50 max-w-lg leading-relaxed text-shadow-sm mb-8">Be the first to discover our latest innovations</p>
              <div class="mt-8">
                <a href="#new-arrivals" class="inline-flex items-center px-10 py-5 border border-transparent rounded-lg shadow-md text-xl font-medium text-blue-800 bg-white hover:bg-blue-50 transition-colors duration-150 ease-in-out">
                  Explore Now
                </a>
              </div>
            </div>
            <!-- Partially revealed products for curiosity -->
            <div class="relative flex mt-6 md:mt-0 flex-shrink-0">
              <div class="absolute -left-10 top-5 w-32 h-32 bg-purple-200 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob"></div>
              <div class="absolute left-20 -top-10 w-32 h-32 bg-blue-200 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob animation-delay-2000"></div>
              <div class="absolute -bottom-10 left-10 w-32 h-32 bg-purple-300 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob animation-delay-4000"></div>
              <div class="relative h-64 w-64 overflow-hidden rounded-lg shadow-2xl">
                <!-- Partial reveal of new product -->
                <div class="relative h-full w-full">
                  <div class="absolute inset-0 bg-gradient-to-t from-blue-900 via-transparent to-transparent"></div>
                  <img src="/assets/new_arrival.jpg" alt="New Arrival Teaser" class="h-full w-full object-cover">
                  <div class="absolute bottom-3 left-3 right-3">
                    <span class="text-white text-lg font-bold">Coming This Week</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Banner 4: Limited edition or exclusive products -->
        <div class="carousel-slide bg-gradient-to-r from-red-700 to-red-500">
          <div class="relative w-full px-8 md:px-16 lg:px-24 flex flex-col md:flex-row justify-between items-center h-full">
            <div class="text-white mb-6 md:mb-0 z-10 max-w-xl">
              <div class="mb-4 inline-flex items-center px-4 py-2 bg-red-800 bg-opacity-60 rounded-lg backdrop-blur-sm">
                <span class="text-sm font-bold uppercase tracking-wide text-red-100">Exclusive</span>
              </div>
              <h1 class="text-6xl font-bold mb-6 text-shadow-lg tracking-tight">Limited Edition</h1>
              <p class="text-xl text-red-50 max-w-lg leading-relaxed text-shadow-sm mb-8">Handcrafted treasures with strictly limited availability</p>
              <div class="flex items-center mt-4 mb-8">
                <span class="text-white text-lg font-bold mr-3">Only 8 collections available</span>
                <div class="w-32 h-4 bg-red-800 bg-opacity-60 rounded-full overflow-hidden">
                  <div class="h-full w-1/3 bg-white rounded-full"></div>
                </div>
              </div>
              <div class="mt-8">
                <a href="#limited-edition" class="inline-flex items-center px-10 py-5 border border-transparent rounded-lg shadow-md text-xl font-medium text-red-700 bg-white hover:bg-red-50 transition-colors duration-150 ease-in-out">
                  Shop Exclusive
                </a>
              </div>
            </div>
            <div class="relative mt-6 md:mt-0 flex-shrink-0">
              <div class="absolute -inset-1 bg-white rounded-lg filter blur opacity-70"></div>
              <div class="relative bg-white rounded-lg p-4 shadow-xl transform rotate-3 hover:rotate-0 transition-transform duration-300">
                <div class="relative">
                  <img src="/assets/limited_edition.jpg" alt="Limited Edition Collection" class="h-64 w-64 object-cover rounded">
                  <div class="absolute -top-3 -right-3 bg-red-600 text-white font-bold rounded-full px-2 py-1 text-xs uppercase tracking-wider">
                    Limited
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Overlay gradient for better text readability -->
        <div class="absolute inset-0 bg-gradient-to-r from-black/50 to-transparent pointer-events-none"></div>
        
        <!-- Carousel navigation -->
        <button type="button" aria-label="Previous slide" class="carousel-nav prev absolute top-1/2 left-6 transform -translate-y-1/2 w-14 h-14 rounded-full bg-white/30 backdrop-blur-sm flex items-center justify-center hover:bg-white/50 transition-colors z-20 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 shadow-lg">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
        </button>
        <button type="button" aria-label="Next slide" class="carousel-nav next absolute top-1/2 right-6 transform -translate-y-1/2 w-14 h-14 rounded-full bg-white/30 backdrop-blur-sm flex items-center justify-center hover:bg-white/50 transition-colors z-20 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 shadow-lg">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </button>
        
        <div class="absolute bottom-4 left-1/2 transform -translate-x-1/2 flex space-x-3 z-20">
          <button type="button" aria-label="Go to slide 1" class="w-3 h-3 rounded-full bg-white opacity-60 hover:opacity-100 transition-opacity carousel-indicator active focus:outline-none" data-slide-index="0"></button>
          <button type="button" aria-label="Go to slide 2" class="w-3 h-3 rounded-full bg-white opacity-60 hover:opacity-100 transition-opacity carousel-indicator focus:outline-none" data-slide-index="1"></button>
          <button type="button" aria-label="Go to slide 3" class="w-3 h-3 rounded-full bg-white opacity-60 hover:opacity-100 transition-opacity carousel-indicator focus:outline-none" data-slide-index="2"></button>
          <button type="button" aria-label="Go to slide 4" class="w-3 h-3 rounded-full bg-white opacity-60 hover:opacity-100 transition-opacity carousel-indicator focus:outline-none" data-slide-index="3"></button>
        </div>
      </div>
    </div>

    <!-- Main content area -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Recently viewed items section - Creates psychological ownership -->
      <div id="recently-viewed" class="mb-8 bg-white rounded-xl shadow-sm border border-blue-100 p-6 transform transition-all duration-300 hover:shadow-md">
        <h2 class="text-xl font-semibold text-gray-800 mb-4 flex items-center">
          <svg class="w-5 h-5 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
          </svg>
          Recently Viewed
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
          <% 6.times do |i| %>
            <div class="bg-blue-50 rounded-lg overflow-hidden shadow-sm border border-blue-100 hover:shadow-md hover:border-blue-200 transition-all duration-300">
              <div class="aspect-w-1 aspect-h-1 w-full">
                <div class="flex h-full w-full items-center justify-center bg-blue-100">
                  <svg class="h-10 w-10 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              </div>
              <div class="p-3">
                <h3 class="text-sm font-medium text-gray-900 truncate group-hover:text-blue-700 transition-colors">
                  Recent Product
                </h3>
                <p class="text-sm font-bold text-gray-900 mt-1">
                  <%= params[:country] == 'nigeria' ? '₦' : '₵' %>1,299
                </p>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Breadcrumbs with enhanced styling - Z-pattern left -->
      <nav class="py-3 mb-4 flex items-center" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2">
          <li>
            <%= link_to root_path, class: "text-blue-600 hover:text-blue-700" do %>
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" />
              </svg>
            <% end %>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
              </svg>
              <% if @category %>
                <%= link_to "Products", products_path, class: "ml-2 text-gray-500 hover:text-blue-600" %>
              <% else %>
                <span class="ml-2 text-blue-700 font-medium">Products</span>
              <% end %>
            </div>
          </li>
          <% if @category %>
            <li>
              <div class="flex items-center">
                <svg class="h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                </svg>
                <span class="ml-2 text-blue-700 font-medium"><%= @category.name %></span>
              </div>
            </li>
          <% end %>
        </ol>
      </nav>

      <!-- Main content area with filters and products - Z-pattern bottom horizontal -->
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Mobile filter toggle - Z-pattern top left -->
        <div class="lg:hidden mb-4">
          <button type="button" id="mobile-filter-toggle" class="w-full flex items-center justify-center px-4 py-3 border border-blue-300 rounded-lg shadow-sm bg-white text-blue-700 hover:bg-blue-50 transition">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
            </svg>
            Filter Products
          </button>
        </div>

        <!-- Filters sidebar - Z-pattern bottom left -->
        <div id="filters-sidebar" class="lg:col-span-1 lg:block hidden">
          <div class="sticky top-4 space-y-6 bg-white rounded-xl shadow-sm border border-blue-100 p-6 transform transition-all duration-300 hover:shadow-md">
            <div class="mb-4 pb-4 border-b border-gray-100">
              <h2 class="text-xl font-semibold text-gray-800 flex items-center">
                <svg class="w-5 h-5 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>
                </svg>
                Filters
              </h2>
            </div>

            <!-- Categories filter with icons -->
            <div class="mb-6">
              <h3 class="text-lg font-medium text-gray-900 mb-3 flex items-center">
                <svg class="w-5 h-5 mr-2 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                </svg>
                Categories
              </h3>
              <ul class="space-y-2">
                <li class="transform transition-transform hover:translate-x-1">
                  <%= link_to products_path(country: params[:country]), 
                            class: "block py-1.5 px-2 rounded #{params[:category_id].blank? ? 'bg-blue-100 text-blue-700 font-medium' : 'text-gray-700 hover:text-blue-600'} transition duration-150" do %>
                    <span class="flex items-center">
                      <% if params[:category_id].blank? %>
                        <svg class="w-4 h-4 mr-2 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                        </svg>
                      <% end %>
                      All Products
                    </span>
                  <% end %>
                </li>
                <% @categories.each do |category| %>
                  <li class="transform transition-transform hover:translate-x-1">
                    <%= link_to products_path(category_id: category.id, country: params[:country]), 
                                class: "block py-1.5 px-2 rounded #{params[:category_id].to_i == category.id ? 'bg-blue-100 text-blue-700 font-medium' : 'text-gray-700 hover:text-blue-600'} transition duration-150" do %>
                      <span class="flex items-center">
                        <% if params[:category_id].to_i == category.id %>
                          <svg class="w-4 h-4 mr-2 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                          </svg>
                        <% end %>
                        <%= category.name %>
                      </span>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            </div>

            <!-- Price range filter with slider -->
            <div class="mb-6">
              <h3 class="text-lg font-medium text-gray-900 mb-3 flex items-center">
                <svg class="w-5 h-5 mr-2 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Price Range
              </h3>
              <%= form_with url: products_path, method: :get, class: "space-y-3", data: { controller: "filters" } do |f| %>
                <%= f.hidden_field :category_id, value: params[:category_id] %>
                <%= f.hidden_field :country, value: params[:country] %>
                
                <div class="flex items-center justify-between">
                  <div class="w-5/12">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Min</label>
                    <div class="relative rounded-md shadow-sm">
                      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <span class="text-gray-500 sm:text-sm"><%= params[:country] == 'nigeria' ? '₦' : '₵' %></span>
                      </div>
                      <%= f.number_field :min_price, value: params[:min_price], 
                                      class: "block w-full pl-8 pr-3 py-2 rounded-md border-gray-300 focus:ring-blue-500 focus:border-blue-500 sm:text-sm",
                                      placeholder: "0" %>
                    </div>
                  </div>
                  <div class="text-gray-400 pt-6">—</div>
                  <div class="w-5/12">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Max</label>
                    <div class="relative rounded-md shadow-sm">
                      <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <span class="text-gray-500 sm:text-sm"><%= params[:country] == 'nigeria' ? '₦' : '₵' %></span>
                      </div>
                      <%= f.number_field :max_price, value: params[:max_price], 
                                      class: "block w-full pl-8 pr-3 py-2 rounded-md border-gray-300 focus:ring-blue-500 focus:border-blue-500 sm:text-sm",
                                      placeholder: "1000" %>
                    </div>
                  </div>
                </div>
                
                <div class="pt-2">
                  <%= f.submit "Apply Filter", class: "w-full bg-gradient-to-r from-blue-600 to-blue-500 border border-transparent rounded-md py-2.5 px-4 text-sm font-medium text-white shadow-sm hover:from-blue-700 hover:to-blue-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transform transition hover:scale-[1.02]" %>
                </div>
              <% end %>
            </div>

            <!-- Availability filter with toggle switches -->
            <div class="mb-6">
              <h3 class="text-lg font-medium text-gray-900 mb-3 flex items-center">
                <svg class="w-5 h-5 mr-2 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Availability
              </h3>
              <%= form_with url: products_path, method: :get, id: "availability-form" do |f| %>
                <%= f.hidden_field :category_id, value: params[:category_id] %>
                <%= f.hidden_field :country, value: params[:country] %>
                <%= f.hidden_field :min_price, value: params[:min_price] %>
                <%= f.hidden_field :max_price, value: params[:max_price] %>
                <%= f.hidden_field :search, value: params[:search] %>
                
                <ul class="space-y-3">
