                                      onchange: "document.getElementById('availability-form').submit()" %>
                      <div class="toggle-label block overflow-hidden h-5 rounded-full bg-gray-300 cursor-pointer <%= params[:free_shipping] == '1' ? 'bg-blue-500' : '' %>"></div>
