                <%= form_with url: products_path, method: :get, id: "mobile-availability-form" do |f| %>
                  <%= f.hidden_field :category_id, value: params[:category_id] %>
                  <%= f.hidden_field :country, value: params[:country] %>
                  <%= f.hidden_field :min_price, value: params[:min_price] %>
                  <%= f.hidden_field :max_price, value: params[:max_price] %>
                  <%= f.hidden_field :search, value: params[:search] %>
                  
                  <ul class="space-y-3">
                    <li class="flex items-center p-2 rounded-md hover:bg-gray-50">
                      <%= check_box_tag 'in_stock', '1', params[:in_stock] == '1', 
                                    class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500",
                                    onchange: "document.getElementById('mobile-availability-form').submit()" %>
                      <label for="in_stock" class="ml-3 text-sm text-gray-700">In Stock Only</label>
                    </li>
                    <li class="flex items-center p-2 rounded-md hover:bg-gray-50">
                      <%= check_box_tag 'free_shipping', '1', params[:free_shipping] == '1', 
                                    class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500",
                                    onchange: "document.getElementById('mobile-availability-form').submit()" %>
