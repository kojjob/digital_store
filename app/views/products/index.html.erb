                        </div>
                        <%= f.number_field :max_price, value: params[:max_price], 
                                        class: "block w-full pl-7 pr-3 py-2 rounded-md border-gray-300 focus:ring-blue-500 focus:border-blue-500 sm:text-sm",
                                        placeholder: "1000" %>
