                <div class="text-center">
                  <button type="button" class="text-sm text-green-600 font-medium hover:text-green-800">
                    See all questions
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Seller Information with Enhanced Card Design -->
  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">About the Seller</h2>
      
      <div class="bg-white rounded-xl shadow-sm overflow-hidden border border-gray-100 hover:shadow-md transition-all duration-300">
        <div class="p-6">
          <div class="flex flex-col md:flex-row md:items-start">
            <div class="flex-shrink-0 mb-4 md:mb-0">
              <div class="w-20 h-20 md:w-24 md:h-24 rounded-xl bg-gradient-to-br from-green-500 to-emerald-600 flex items-center justify-center shadow-md">
                <% if @product.seller.user.profile_picture.present? %>
                  <%= image_tag @product.seller.user.profile_picture, class: "w-full h-full rounded-xl object-cover" %>
                <% else %>
                  <span class="text-3xl font-bold text-white"><%= @product.seller.business_name[0..1].upcase %></span>
                <% end %>
              </div>
            </div>
            
            <div class="md:ml-6 flex-1">
              <div class="flex flex-wrap items-center gap-2 mb-2">
                <h3 class="text-xl font-bold text-gray-900"><%= @product.seller.business_name %></h3>
                <% if @product.seller.verified %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    <svg class="mr-1 h-3 w-3 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                    Verified Seller
                  </span>
                <% end %>
              </div>
              
              <p class="text-sm text-gray-600 mb-4 max-w-3xl"><%= @product.seller.description %></p>
              
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-sm">
                <div class="bg-gray-50 p-3 rounded-lg">
                  <p class="text-gray-500 text-xs">Location</p>
                  <p class="font-medium text-gray-900 mt-1 flex items-center">
                    <svg class="h-4 w-4 mr-1 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                    <%= @product.seller.location %>, <%= @product.seller.country %>
                  </p>
                </div>
                
                <div class="bg-gray-50 p-3 rounded-lg">
                  <p class="text-gray-500 text-xs">Response Time</p>
                  <p class="font-medium text-gray-900 mt-1 flex items-center">
                    <svg class="h-4 w-4 mr-1 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <%= @product.seller.average_response_time %> hours
                  </p>
                </div>
                
                <div class="bg-gray-50 p-3 rounded-lg">
                  <p class="text-gray-500 text-xs">Acceptance Rate</p>
                  <p class="font-medium text-gray-900 mt-1 flex items-center">
                    <svg class="h-4 w-4 mr-1 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <%= number_to_percentage(@product.seller.acceptance_rate, precision: 0) %>
                  </p>
                </div>
                
                <div class="bg-gray-50 p-3 rounded-lg">
                  <p class="text-gray-500 text-xs">Seller Since</p>
                  <p class="font-medium text-gray-900 mt-1 flex items-center">
                    <svg class="h-4 w-4 mr-1 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                    <%= @product.seller.created_at.strftime("%B %Y") %>
                  </p>
                </div>
              </div>
              
              <div class="mt-6 flex">
                <a href="/sellers/<%= @product.seller.id %>" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-gradient-to-r from-green-600 to-green-500 hover:from-green-700 hover:to-green-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                  View Seller Profile
                </a>
                <button type="button" class="ml-3 inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                  Contact Seller
                </button>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Seller Product Cards Preview -->
        <div class="border-t border-gray-200 bg-gray-50 px-6 py-4">
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-sm font-medium text-gray-900">More from this seller</h3>
            <a href="/sellers/<%= @product.seller.id %>/products" class="text-sm font-medium text-green-600 hover:text-green-800">
              View all
            </a>
          </div>
          
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
            <% 5.times do |i| %>
              <div class="bg-white rounded-lg shadow-sm overflow-hidden hover:shadow-md transition-all duration-300">
                <div class="h-24 bg-gray-200"></div>
                <div class="p-2">
                  <h4 class="text-xs font-medium text-gray-900 truncate">Similar Product <%= i + 1 %></h4>
                  <p class="text-xs text-green-600 font-medium">$<%= [19.99, 24.99, 14.50, 29.99, 18.75][i] %></p>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Related Products with Enhanced Card Design -->
  <section id="related-products" class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">You May Also Like</h2>
      
      <div class="relative">
        <!-- Navigation Arrows -->
        <button type="button" class="absolute -left-4 top-1/2 transform -translate-y-1/2 bg-white rounded-full p-2 shadow-md z-10 hidden md:block focus:outline-none hover:bg-gray-50">
          <svg class="h-6 w-6 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
        </button>
        <button type="button" class="absolute -right-4 top-1/2 transform -translate-y-1/2 bg-white rounded-full p-2 shadow-md z-10 hidden md:block focus:outline-none hover:bg-gray-50">
          <svg class="h-6 w-6 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </button>
        
        <!-- Products Carousel -->
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 md:gap-6" data-controller="related-products">
          <% 4.times do |i| %>
            <div class="bg-white rounded-xl shadow-sm overflow-hidden border border-gray-100 hover:shadow-md transition-all duration-300 transform hover:-translate-y-1 group"
                data-related-products-target="item">
              <div class="aspect-w-1 aspect-h-1 relative overflow-hidden">
                <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200"></div>
                <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-10 transition-all duration-300 flex items-center justify-center opacity-0 group-hover:opacity-100">
                  <button type="button" class="bg-white rounded-full p-3 shadow-lg transform scale-90 group-hover:scale-100 transition-all duration-300">
                    <svg class="h-6 w-6 text-gray-900" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                    </svg>
                  </button>
                </div>
              </div>
              <div class="p-4">
                <h3 class="font-medium text-gray-900 mb-1 group-hover:text-green-700 transition-colors">Similar Product <%= i + 1 %></h3>
                <div class="flex justify-between items-end">
                  <p class="text-green-600 font-bold">$<%= [24.99, 19.99, 29.99, 22.50][i] %></p>
                  <button type="button" class="text-gray-400 hover:text-gray-700">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Recently Viewed Products Section with Local Storage -->
  <section class="py-8 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Recently Viewed</h2>
      
      <div id="recently-viewed-container" class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-6 gap-4" data-recently-viewed-target="container">
        <!-- This section will be populated by JavaScript based on localStorage -->
        <div class="bg-white rounded-lg shadow-sm overflow-hidden hover:shadow-md transition-all duration-300 group transform hover:-translate-y-1 flex items-center justify-center h-40 text-gray-400 text-sm">
          <p>Browse more products to see your history</p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Size Guide Modal -->
  <div id="sizeGuideModal" class="fixed inset-0 bg-black bg-opacity-75 z-50 hidden flex items-center justify-center">
    <div class="bg-white rounded-lg max-w-2xl w-full mx-4 overflow-hidden shadow-xl">
      <div class="px-6 py-4 bg-gray-100 flex items-center justify-between">
        <h3 class="text-lg font-medium text-gray-900">Size Guide</h3>
        <button type="button" id="closeSizeGuide" class="text-gray-400 hover:text-gray-500">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <div class="p-6">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Size</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Chest (cm)</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Waist (cm)</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Hip (cm)</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">S</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">86-91</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">71-76</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">86-91</td>
              </tr>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">M</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">91-97</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">76-81</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">91-97</td>
              </tr>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">L</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">97-102</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">81-86</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">97-102</td>
              </tr>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">XL</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">102-107</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">86-91</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">102-107</td>
              </tr>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">XXL</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">107-112</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">91-97</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">107-112</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="mt-4 text-sm text-gray-600">
          <p>All measurements are in centimeters. Please measure yourself carefully before selecting a size.</p>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Sticky Add to Cart Bar (appears on scroll) -->
  <div id="sticky-cart" class="fixed bottom-0 left-0 right-0 bg-white shadow-lg border-t border-gray-200 z-50 transform translate-y-full transition-transform duration-300 py-3 px-4">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
      <div class="flex items-center">
        <div class="w-12 h-12 bg-gray-200 rounded-md mr-3 flex-shrink-0 overflow-hidden">
          <% if @product.product_images.any? %>
            <%= image_tag url_for(@product.product_images.first), class: "w-full h-full object-cover" %>
          <% end %>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-900 truncate max-w-xs"><%= @product.name %></p>
          <p class="text-sm font-bold text-green-600">
            <% if @product.discounted_price && @product.discounted_price < @product.price %>
              <%= @product.currency == 'NGN' ? '₦' : '₵' %><%= @product.discounted_price %>
            <% else %>
              <%= @product.currency == 'NGN' ? '₦' : '₵' %><%= @product.price %>
            <% end %>
          </p>
        </div>
      </div>
      
      <div class="flex items-center space-x-2">
        <div class="flex items-center border border-gray-300 rounded-md shadow-sm bg-white">
          <button type="button" class="w-8 h-8 flex items-center justify-center text-gray-500">−</button>
          <input type="number" class="w-10 h-8 text-center border-x border-gray-300" value="1" min="1" max="<%= @product.stock_quantity %>">
          <button type="button" class="w-8 h-8 flex items-center justify-center text-gray-500">+</button>
        </div>
        
        <button type="button" class="px-4 py-2 bg-gradient-to-r from-green-600 to-green-500 text-white rounded-md shadow-sm text-sm font-medium hover:from-green-700 hover:to-green-600">
          Add to Cart
        </button>
      </div>
    </div>
  </div>
</div>


