<!-- Advanced, Sleek Product Show Page -->
<div class="product-detail bg-gradient-to-b from-white via-gray-50 to-white min-h-screen" 
     data-controller="product-gallery product-quantity recently-viewed"
     data-product-id="<%= @product.id %>"
     data-recently-viewed-product-name="<%= @product.name %>"
     data-recently-viewed-product-image="<%= @product.product_images.any? ? url_for(@product.product_images.first) : '' %>"
     data-recently-viewed-product-price="<%= @product.discounted? ? @product.discounted_price : @product.price %>"
     data-recently-viewed-product-url="<%= product_path(@product) %>">

  <!-- Hero section with breadcrumb and back navigation -->
  <div class="relative overflow-hidden bg-gradient-to-r from-green-600 to-emerald-500">
    <!-- Animated wave background -->
    <div class="absolute inset-0 opacity-20">
      <svg class="h-full w-full" viewBox="0 0 1920 1080" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 891C126.667 853.667 253.333 835 380 835C633.333 835 760 939.5 1013 939.5C1139.67 939.5 1266.33 911.333 1393 855L1393 1080H0V891Z" fill="white" fill-opacity="0.3" />
        <path d="M0 986C126.667 928 253.333 899 380 899C633.333 899 760 1010.5 1013 1010.5C1139.67 1010.5 1266.33 950.333 1393 830V1080H0V986Z" fill="white" fill-opacity="0.3" />
      </svg>
    </div>
    
    <!-- Enhanced Breadcrumb -->
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <nav class="flex items-center space-x-1 text-sm text-white/80" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition flex items-center">
          <svg class="h-5 w-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
          </svg>
        </a>
        <span class="text-white/60">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </span>
        <a href="/categories/<%= @product.category.slug %>" class="hover:text-white transition">
          <%= @product.category.name %>
        </a>
        <span class="text-white/60">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </span>
        <span class="font-medium text-white truncate max-w-xs"><%= @product.name %></span>
      </nav>
      
      <!-- Back Button -->
      <div class="mt-2">
        <a href="javascript:history.back()" class="inline-flex items-center text-white/80 hover:text-white transition group">
          <svg class="h-5 w-5 mr-1 transform transition group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Back to results
        </a>
      </div>
    </div>
  </div>

  <!-- Main Product Section with 3D-like card design -->
  <section class="relative z-10 -mt-10 mb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-xl shadow-xl overflow-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-2">
          
          <!-- Left side: Product Gallery -->
          <div class="product-gallery p-6 lg:p-10 bg-gradient-to-br from-gray-50 to-white" data-controller="image-zoom">
            <!-- Discount badge (if applicable) -->
            <% if @product.discounted_price && @product.discounted_price < @product.price %>
              <div class="absolute top-6 right-6 z-20">
                <div class="relative">
                  <div class="absolute inset-0 rounded-full bg-red-500 shadow-lg animate-pulse opacity-30"></div>
                  <div class="relative bg-gradient-to-r from-red-600 to-pink-500 text-white font-bold py-2 px-4 rounded-full shadow-md">
                    <%= number_to_percentage(100 - (@product.discounted_price / @product.price * 100), precision: 0) %>% OFF
                  </div>
                </div>
              </div>
            <% end %>
            
            <!-- Stock countdown -->
            <% if @product.stock_quantity > 0 && @product.stock_quantity <= 5 %>
              <div class="absolute top-6 left-6 z-20">
                <div class="bg-amber-100 text-amber-800 px-3 py-1.5 rounded-md font-medium text-sm shadow-md flex items-center animate-pulse">
                  <svg class="w-4 h-4 mr-1.5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                  </svg>
                  Only <%= @product.stock_quantity %> left!
                </div>
              </div>
            <% end %>
            
            <!-- Main Image with zoom feature -->
            <div class="relative mb-6 bg-white rounded-xl overflow-hidden shadow-sm aspect-w-1 aspect-h-1 border border-gray-100"
                 data-product-gallery-target="mainImageContainer">
              <% if @product.product_images.any? %>
                <div class="absolute inset-0 group" 
                     data-product-gallery-target="mainImage"
                     data-image-zoom-target="zoomable">
                  <%= image_tag url_for(@product.product_images.first), 
                                class: "w-full h-full object-cover transition duration-700 ease-out group-hover:scale-110",
                                alt: @product.product_images.first.alt_text || @product.name %>
                  
                  <!-- Zoom lens indicator -->
                  <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition duration-300">
                    <div class="bg-black bg-opacity-60 text-white px-4 py-2 rounded-full flex items-center shadow-lg">
                      <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"></path>
                      </svg>
                      <span class="text-sm font-medium">Click to zoom</span>
                    </div>
                  </div>
                </div>
              <% else %>
                <div class="h-full w-full flex items-center justify-center bg-gray-100">
                  <svg class="h-24 w-24 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                </div>
              <% end %>
            </div>
            
            <!-- Thumbnail carousel with 3D hover effect -->
            <div class="relative">
              <div class="flex space-x-2 overflow-x-auto pb-2 scrollbar-thin scrollbar-thumb-gray-300 scrollbar-track-gray-100" 
                   data-product-gallery-target="thumbnails">
                <% if @product.product_images.any? %>
                  <% @product.product_images.each_with_index do |image, index| %>
                    <button class="w-20 h-20 rounded-lg overflow-hidden shadow-sm border-2 transition-all duration-300 transform hover:-translate-y-1 hover:shadow-md <%= index == 0 ? 'border-green-500 shadow-green-100' : 'border-transparent' %>"
                            data-product-gallery-target="thumbnail"
                            data-action="product-gallery#changeImage"
                            data-index="<%= index %>">
                      <%= image_tag url_for(image), 
                                   class: "w-full h-full object-cover", 
                                   alt: image.alt_text || "#{@product.name} - Image #{index + 1}" %>
                    </button>
                  <% end %>
                <% end %>
              </div>
              
              <!-- Arrows for navigating thumbnails on mobile -->
              <button class="absolute left-0 top-1/2 transform -translate-y-1/2 bg-white/80 backdrop-blur-sm rounded-full p-1 shadow-md lg:hidden focus:outline-none">
                <svg class="w-5 h-5 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
              </button>
              <button class="absolute right-0 top-1/2 transform -translate-y-1/2 bg-white/80 backdrop-blur-sm rounded-full p-1 shadow-md lg:hidden focus:outline-none">
                <svg class="w-5 h-5 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </button>
            </div>
            
            <!-- Product Quick Stats (Mobile Only) -->
            <div class="mt-6 p-4 bg-gray-50 rounded-lg shadow-sm border border-gray-100 lg:hidden">
              <div class="flex items-center justify-between">
                <div class="flex items-center">
                  <div class="<%= @product.stock_quantity > 0 ? 'bg-green-500' : 'bg-red-500' %> h-3 w-3 rounded-full"></div>
                  <span class="ml-2 text-sm font-medium <%= @product.stock_quantity > 0 ? 'text-green-700' : 'text-red-700' %>">
                    <%= @product.stock_quantity > 0 ? 'In Stock' : 'Out of Stock' %>
                  </span>
                </div>
                <div class="text-sm text-gray-600">
                  Ships from <%= @product.country_of_origin %>
                </div>
              </div>
            </div>
            
            <!-- Enhanced Image Zoom Modal (hidden by default) -->
            <div id="imageZoomModal" class="fixed inset-0 bg-black bg-opacity-90 flex items-center justify-center z-50 hidden">
              <button class="absolute top-4 right-4 text-white focus:outline-none">
                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
              <div class="relative w-full max-w-4xl max-h-screen p-4">
                <img id="zoomedImage" class="max-w-full max-h-full mx-auto" src="" alt="Zoomed product image">
                
                <!-- Zoom controls -->
                <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 bg-black/60 rounded-full flex items-center p-2 space-x-4">
                  <button class="text-white p-2 rounded-full hover:bg-white/20">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM13 10H7"></path>
                    </svg>
                  </button>
                  <button class="text-white p-2 rounded-full hover:bg-white/20">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"></path>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Right side: Product Info with Clean Layout -->
          <div class="product-info p-6 lg:p-10 flex flex-col h-full">
            <div class="flex-1">
              <!-- Brand & Badges -->
              <div class="flex flex-wrap items-center gap-2 mb-4">
                <% if @product.brand.present? %>
                  <span class="px-3 py-1.5 text-sm bg-gray-100 text-gray-800 rounded-lg font-medium">
                    <%= @product.brand %>
                  </span>
                <% end %>
                
                <% if @product.featured %>
                  <span class="px-3 py-1.5 text-sm bg-amber-100 text-amber-800 rounded-lg font-medium flex items-center">
                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                    </svg>
                    Featured
                  </span>
                <% end %>
                
                <% if @product.condition.present? %>
                  <span class="px-3 py-1.5 text-sm bg-blue-100 text-blue-800 rounded-lg font-medium">
                    <%= @product.condition %>
                  </span>
                <% end %>
              </div>
              
              <!-- Product Title with Typography -->
              <h1 class="text-3xl font-bold text-gray-900 mb-4 leading-tight"><%= @product.name %></h1>
              
              <!-- Pricing with better visual hierarchy -->
              <div class="mb-6">
                <% if @product.discounted_price && @product.discounted_price < @product.price %>
                  <div class="flex flex-wrap items-end gap-3">
                    <span class="text-3xl font-bold text-green-600">
                      <%= @product.currency == 'NGN' ? '₦' : '₵' %><%= @product.discounted_price %>
                    </span>
                    <span class="text-lg text-gray-500 line-through">
                      <%= @product.currency == 'NGN' ? '₦' : '₵' %><%= @product.price %>
                    </span>
                    <span class="text-sm text-green-600 font-medium">
                      Save <%= @product.currency == 'NGN' ? '₦' : '₵' %><%= (@product.price - @product.discounted_price).round(2) %>
                    </span>
                  </div>
                <% else %>
                  <span class="text-3xl font-bold text-gray-900">
                    <%= @product.currency == 'NGN' ? '₦' : '₵' %><%= @product.price %>
                  </span>
                <% end %>
              </div>

              <!-- Color/Size Variant Selector (if applicable) -->
              <div class="space-y-5 mb-8">
                <!-- Color selector -->
                <div data-controller="product-variants">
                  <h3 class="text-sm font-medium text-gray-900 mb-3">Color</h3>
                  <div class="flex flex-wrap gap-2">
                    <% ['Black', 'Red', 'Blue', 'Green', 'Yellow'].each_with_index do |color, index| %>
                      <% bg_color = color.downcase %>
                      <% bg_class = case color
                                     when 'Black' then 'bg-gray-900'
                                     when 'Red' then 'bg-red-600'
                                     when 'Blue' then 'bg-blue-600'
                                     when 'Green' then 'bg-green-600'
                                     when 'Yellow' then 'bg-yellow-400'
                                     end %>
                      <button 
                        type="button" 
                        class="group relative h-10 w-10 rounded-full border <%= index == 0 ? 'ring-2 ring-offset-2 ring-green-500' : 'border-gray-200' %> focus:outline-none"
                        data-action="product-variants#selectColor"
                        data-product-variants-color-param="<%= color %>">
                        <span class="sr-only"><%= color %></span>
                        <span class="h-full w-full rounded-full <%= bg_class %> transition-transform group-hover:scale-110"></span>
                        <% if index == 0 %>
                          <span class="absolute -right-1 -top-1 h-5 w-5 rounded-full bg-green-600 flex items-center justify-center">
                            <svg class="h-3 w-3 text-white" fill="currentColor" viewBox="0 0 24 24">
                              <path d="M20.285 2l-11.285 11.567-5.286-5.011-3.714 3.716 9 8.728 15-15.285z"/>
                            </svg>
                          </span>
                        <% end %>
                      </button>
                    <% end %>
                  </div>
                </div>

                <!-- Size selector -->
                <div data-controller="product-variants">
                  <div class="flex items-center justify-between">
                    <h3 class="text-sm font-medium text-gray-900">Size</h3>
                    <button type="button" class="text-sm font-medium text-green-600 hover:text-green-500" data-action="product-variants#openSizeChart">
                      Size guide
                    </button>
                  </div>
                  <div class="grid grid-cols-5 gap-2 mt-3">
                    <% ['S', 'M', 'L', 'XL', 'XXL'].each_with_index do |size, index| %>
                      <button 
                        type="button" 
                        class="flex items-center justify-center rounded-md border py-2 px-3 text-sm font-medium <%= index == 1 ? 'border-green-500 bg-green-50 text-green-700' : 'border-gray-200 text-gray-900 hover:bg-gray-50' %>"
                        data-action="product-variants#selectSize"
                        data-product-variants-size-param="<%= size %>">
                        <%= size %>
                      </button>
                    <% end %>
                  </div>
                </div>
              </div>
              
              <!-- Product key features - visually enhanced -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
                <div class="bg-gradient-to-br from-green-50 to-emerald-50 p-4 rounded-lg border border-green-100">
                  <div class="flex items-start">
                    <div class="flex-shrink-0 bg-green-100 rounded-full p-2">
                      <svg class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                    </div>
                    <div class="ml-3">
                      <h3 class="text-sm font-medium text-gray-900">Availability</h3>
                      <p class="mt-1 text-sm text-gray-600">
                        <% if @product.stock_quantity > 0 %>
                          <span class="font-medium text-green-700">In Stock</span> - <%= @product.stock_quantity %> available
                        <% else %>
                          <span class="font-medium text-red-700">Out of Stock</span>
                        <% end %>
                      </p>
                    </div>
                  </div>
                </div>
                
                <div class="bg-gradient-to-br from-blue-50 to-indigo-50 p-4 rounded-lg border border-blue-100">
                  <div class="flex items-start">
                    <div class="flex-shrink-0 bg-blue-100 rounded-full p-2">
                      <svg class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path>
                      </svg>
                    </div>
                    <div class="ml-3">
                      <h3 class="text-sm font-medium text-gray-900">Shipping</h3>
                      <p class="mt-1 text-sm text-gray-600">
                        <%= @product.shipping_time %> from <%= @product.country_of_origin %>
                      </p>
                    </div>
                  </div>
                </div>
                
                <div class="bg-gradient-to-br from-amber-50 to-yellow-50 p-4 rounded-lg border border-amber-100">
                  <div class="flex items-start">
                    <div class="flex-shrink-0 bg-amber-100 rounded-full p-2">
                      <svg class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                    </div>
                    <div class="ml-3">
                      <h3 class="text-sm font-medium text-gray-900">Origin</h3>
                      <p class="mt-1 text-sm text-gray-600">
                        Ships from <%= @product.country_of_origin %>
                      </p>
                    </div>
                  </div>
                </div>
                
                <div class="bg-gradient-to-br from-purple-50 to-violet-50 p-4 rounded-lg border border-purple-100">
                  <div class="flex items-start">
                    <div class="flex-shrink-0 bg-purple-100 rounded-full p-2">
                      <svg class="h-5 w-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      </svg>
                    </div>
                    <div class="ml-3">
                      <h3 class="text-sm font-medium text-gray-900">Available In</h3>
                      <p class="mt-1 text-sm text-gray-600">
                        <% if @product.available_in_ghana && @product.available_in_nigeria %>
                          Ghana & Nigeria
                        <% elsif @product.available_in_ghana %>
                          Ghana Only
                        <% elsif @product.available_in_nigeria %>
                          Nigeria Only
                        <% end %>
                      </p>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- Return Policy Summary -->
              <div class="mb-8 p-4 bg-green-50 rounded-lg border border-green-100">
                <div class="flex">
                  <div class="flex-shrink-0">
                    <svg class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                  </div>
                  <div class="ml-3">
                    <h3 class="text-sm font-medium text-green-800">30-Day Money-Back Guarantee</h3>
                    <div class="mt-1 text-sm text-green-700">
                      <p>If you're not satisfied with your purchase, return it for a full refund within 30 days.</p>
                    </div>
                    <div class="mt-2">
                      <a href="/return-policy" class="text-sm font-medium text-green-600 hover:text-green-500">
                        View Full Return Policy →
                      </a>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- Purchase Options with vibrant UI -->
              <div class="space-y-6">
                <% if @product.stock_quantity > 0 %>
                  <!-- Modern Quantity Selector -->
                  <div class="flex flex-wrap items-center gap-4">
                    <label for="quantity" class="text-sm font-medium text-gray-700">Quantity:</label>
                    <div class="flex items-center border border-gray-200 rounded-lg shadow-sm bg-white overflow-hidden">
                      <button type="button" 
                              class="w-10 h-10 flex items-center justify-center text-gray-500 hover:bg-gray-50 transition"
                              data-action="product-quantity#decrease"
                              aria-label="Decrease quantity">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path>
                        </svg>
                      </button>
                      <input type="number" 
                             id="quantity" 
                             name="quantity" 
                             min="1" 
                             max="<%= @product.stock_quantity %>" 
                             value="1"
                             class="w-12 h-10 text-center border-x border-gray-200 focus:outline-none focus:ring-0 text-gray-700"
                             data-product-quantity-target="input">
                      <button type="button" 
                              class="w-10 h-10 flex items-center justify-center text-gray-500 hover:bg-gray-50 transition"
                              data-action="product-quantity#increase"
                              aria-label="Increase quantity">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                        </svg>
                      </button>
                    </div>
                    
                    <!-- Max quantity indicator -->
                    <div class="text-sm text-gray-500">
                      <%= @product.stock_quantity %> available
                    </div>
                  </div>
                  
                  <!-- Dynamic Call-to-Action Buttons -->
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <!-- Add to Cart Button with enhanced animation -->
                    <%= form_with url: "/cart/add", method: :post, data: { controller: "button-animation", turbo: false } do |f| %>
                      <%= f.hidden_field :product_id, value: @product.id %>
                      <%= f.hidden_field :quantity, value: 1, data: { product_quantity_target: "outputField" } %>
                      
                      <button type="submit" 
                              class="group relative w-full flex justify-center py-4 px-4 border border-transparent rounded-xl shadow-sm text-lg font-medium text-white bg-gradient-to-r from-green-600 to-green-500 hover:from-green-700 hover:to-green-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 overflow-hidden transition-all duration-300 transform hover:scale-[1.02]"
                              data-action="button-animation#animate">
                        <!-- Default state -->
                        <span class="flex items-center" data-button-animation-target="defaultText">
                          <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
                          </svg>
                          Add to Cart
                        </span>
                        
                        <!-- Success state -->
                        <span class="absolute inset-0 flex items-center justify-center opacity-0 transform translate-y-8 transition-all duration-500" data-button-animation-target="successText">
                          <svg class="h-6 w-6 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                          </svg>
                          Added to Cart!
                        </span>
                      </button>
                    <% end %>
                    
                    <!-- Buy Now Button -->
                    <button type="button" 
                            class="relative w-full flex justify-center py-4 px-4 border border-gray-300 rounded-xl shadow-sm text-lg font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-all duration-300 transform hover:scale-[1.02]">
                      <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                      </svg>
                      Buy Now
                    </button>
                  </div>
                  
                  <!-- Social Sharing Integration -->
                  <div class="pt-4">
                    <h3 class="text-sm font-medium text-gray-900 mb-3">Share this product</h3>
                    <div class="flex space-x-4">
                      <button type="button" class="flex items-center justify-center w-10 h-10 rounded-full bg-green-500 hover:bg-green-600 transition-colors" data-action="social-share#shareWhatsApp">
                        <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M17.498 15.598c-.197-.099-1.175-.578-1.353-.644-.196-.097-.34-.144-.48.145-.143.29-.55.643-.671.778-.122.126-.244.145-.44.048-.6-.297-1.008-.542-1.415-1.231-.262-.453-.446-.982-.476-1.154-.03-.168.03-.33.115-.437.32-.38.67-.101.97-.126.31-.021.67.020.84.049.26.038.44.29.63.145.3.198.3.643.21.778-.09.134-.48.8-.48.989s.63.456.42.58c-.21.144.29.989.669 1.426.461.559.927.647 1.242.685.196.025.418.003.578-.123.242-.191.414-.364.534-.61.121-.245.062-.455-.03-.578-.09-.134-.48-.325-.48-.489-.09-.164-.16-.338.02-.515.181-.175.81-.458.81-.986 0-.528-.27-.81-.363-.905-.09-.094-.242-.094-.44-.094h-.418zm-5.076-8.098a8.93 8.93 0 00-6.33 15.267l-1.09 3.954 4.082-1.05a8.96 8.96 0 004.283 1.09c4.932 0 8.932-4 8.932-8.931s-4-8.932-8.932-8.932a8.93 8.93 0 00-.93-.098zm0 16.337a7.43 7.43 0 01-3.792-1.042l-.275-.162-2.8.735.756-2.763-.18-.286a7.36 7.36 0 01-1.115-3.933c0-4.083 3.318-7.4 7.402-7.4 1.967 0 3.818.772 5.206 2.16a7.31 7.31 0 012.165 5.206c-.002 4.088-3.326 7.405-7.407 7.405z"/>
                        </svg>
                      </button>
                      <button type="button" class="flex items-center justify-center w-10 h-10 rounded-full bg-blue-600 hover:bg-blue-700 transition-colors" data-action="social-share#shareFacebook">
                        <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M18.77 7.465H14.54v-1.96c0-.8.066-1.333 1.242-1.333h2.675V.015S16.659 0 14.932 0C11.318 0 8.91 2.08 8.91 5.86v1.605H5v4.99h3.91V22h5.63v-9.545h3.888l.58-4.99z"/>
                        </svg>
                      </button>
                      <button type="button" class="flex items-center justify-center w-10 h-10 rounded-full bg-blue-400 hover:bg-blue-500 transition-colors" data-action="social-share#shareTwitter">
                        <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.95.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                        </svg>
                      </button>
                      <button type="button" class="flex items-center justify-center w-10 h-10 rounded-full bg-indigo-600 hover:bg-indigo-700 transition-colors" data-action="social-share#copyLink">
                        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                        </svg>
                      </button>
                    </div>
                  </div>
                <% else %>
                  <!-- Out of Stock Experience -->
                  <div class="space-y-4">
                    <div class="bg-red-50 border border-red-100 rounded-lg p-4 flex items-start">
                      <div class="flex-shrink-0">
                        <svg class="h-5 w-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                      </div>
                      <div class="ml-3 flex-1">
                        <h3 class="text-sm font-medium text-red-800">Out of Stock</h3>
                        <div class="mt-1 text-sm text-red-700">
                          <p>This product is currently unavailable. Enter your email to be notified when it's back in stock.</p>
                        </div>
                      </div>
                    </div>
                    
                    <!-- Notify Me Form -->
                    <%= form_with url: "/notify/stock", method: :post, class: "relative", data: { controller: "notify-form", turbo_frame: "notification_form" } do |f| %>
                      <%= f.hidden_field :product_id, value: @product.id %>
                      
                      <div class="flex">
                        <input type="email" 
                               name="email" 
                               placeholder="Enter your email" 
                               class="block w-full rounded-l-lg border-gray-300 shadow-sm focus:border-green-500 focus:ring-green-500 sm:text-sm"
                               required
                               data-notify-form-target="email">
                        <button type="submit" 
                                class="relative inline-flex items-center px-6 py-3 border border-transparent rounded-r-lg shadow-sm text-white bg-gradient-to-r from-green-600 to-green-500 hover:from-green-700 hover:to-green-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 font-medium text-sm"
                                data-action="notify-form#submit"
                                data-notify-form-target="button">
                          Notify Me
                        </button>
                      </div>
                      
                      <!-- Success message - hidden by default -->
                      <div class="mt-3 text-sm text-green-600 hidden animate-fade-in" data-notify-form-target="success">
                        <div class="flex items-center">
                          <svg class="h-5 w-5 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                          </svg>
                          We'll notify you when this product is back in stock!
                        </div>
                      </div>
                    <% end %>
                    
                    <!-- Similar products suggestion -->
                    <div class="mt-6">
                      <a href="#related-products" class="inline-flex items-center text-green-600 hover:text-green-800 transition">
                        <span>View similar products</span>
                        <svg class="ml-1 h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
                        </svg>
                      </a>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
            
            <!-- Trust badges and payment methods -->
            <div class="mt-8 space-y-4">
              <div class="flex justify-between items-center py-4 border-t border-gray-200">
                <h3 class="text-sm font-medium text-gray-900">Secure Checkout</h3>
                <div class="flex space-x-3">
                  <div class="h-8 w-12 bg-gradient-to-r from-blue-600 to-blue-800 rounded-md shadow-sm flex items-center justify-center text-white font-bold text-xs">VISA</div>
                  <div class="h-8 w-12 bg-gradient-to-r from-red-600 to-orange-600 rounded-md shadow-sm flex items-center justify-center text-white font-bold text-xs">M.Card</div>
                  <div class="h-8 w-16 bg-gradient-to-br from-yellow-400 to-yellow-600 rounded-md shadow-sm flex items-center justify-center text-white font-bold text-xs">MoMo Pay</div>
                  <div class="h-8 w-14 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-md shadow-sm flex items-center justify-center text-white font-bold text-xs">PayPal</div>
                </div>
              </div>
              
              <div class="grid grid-cols-3 gap-4 py-3">
                <div class="flex flex-col items-center text-center">
                  <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center mb-2">
                    <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                  </div>
                  <span class="text-xs text-gray-600">Secure Payment</span>
                </div>
                <div class="flex flex-col items-center text-center">
                  <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center mb-2">
                    <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                  </div>
                  <span class="text-xs text-gray-600">Buyer Protection</span>
                </div>
                <div class="flex flex-col items-center text-center">
                  <div class="w-10 h-10 bg-amber-100 rounded-full flex items-center justify-center mb-2">
                    <svg class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                    </svg>
                  </div>
                  <span class="text-xs text-gray-600">30-Day Returns</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Frequently Bought Together Section -->
  <section class="mb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-xl shadow-sm overflow-hidden border border-gray-100">
        <div class="p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-4">Frequently Bought Together</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Bundle preview -->
            <div class="flex items-center justify-between col-span-2">
              <div class="flex flex-col md:flex-row items-center space-y-4 md:space-y-0 md:space-x-4">
                <!-- Main product -->
                <div class="relative w-24 h-24 bg-gray-100 rounded-lg overflow-hidden shadow-sm">
                  <% if @product.product_images.any? %>
                    <%= image_tag url_for(@product.product_images.first), class: "h-full w-full object-cover" %>
                  <% else %>
                    <div class="flex h-full w-full items-center justify-center bg-gray-200">
                      <svg class="h-8 w-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    </div>
                  <% end %>
                </div>
                
                <div class="flex items-center">
                  <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                  </svg>
                </div>
                
                <!-- Complementary product 1 -->
                <div class="relative w-24 h-24 bg-gray-100 rounded-lg overflow-hidden shadow-sm">
                  <div class="h-full w-full bg-gray-200"></div>
                  <div class="absolute top-0 right-0">
                    <input type="checkbox" checked class="h-4 w-4 border-gray-300 rounded text-green-600 focus:ring-green-500">
                  </div>
                </div>
                
                <div class="flex items-center">
                  <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                  </svg>
                </div>
                
                <!-- Complementary product 2 -->
                <div class="relative w-24 h-24 bg-gray-100 rounded-lg overflow-hidden shadow-sm">
                  <div class="h-full w-full bg-gray-200"></div>
                  <div class="absolute top-0 right-0">
                    <input type="checkbox" class="h-4 w-4 border-gray-300 rounded text-green-600 focus:ring-green-500">
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Bundle price -->
            <div class="flex flex-col justify-center space-y-3">
              <div>
                <p class="text-sm text-gray-500">Bundle Price:</p>
                <p class="text-xl font-bold text-gray-900"><%= @product.currency == 'NGN' ? '₦' : '₵' %><%= (@product.price * 0.9).round(2) %></p>
                <p class="text-sm text-green-600">Save <%= @product.currency == 'NGN' ? '₦' : '₵' %><%= (@product.price * 0.1).round(2) %></p>
              </div>
              
              <button type="button" class="w-full inline-flex justify-center items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-gradient-to-r from-green-600 to-green-500 hover:from-green-700 hover:to-green-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
                Add Bundle to Cart
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Product Details Accordion for Mobile / Tab Panels for Desktop -->
  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white shadow-sm rounded-xl overflow-hidden border border-gray-100">
        <!-- Desktop Tabs -->
        <div class="hidden md:block" data-controller="tabs">
          <div class="border-b border-gray-200">
            <nav class="flex -mb-px px-6">
              <button class="whitespace-nowrap py-4 px-6 border-b-2 border-green-600 font-medium text-green-600 focus:outline-none"
                      data-tabs-target="tab"
                      data-index="0"
                      data-action="tabs#switchTab">
                Description
              </button>
              <button class="whitespace-nowrap py-4 px-6 border-b-2 border-transparent font-medium text-gray-500 hover:text-gray-700 hover:border-gray-300 focus:outline-none"
                      data-tabs-target="tab"
                      data-index="1"
                      data-action="tabs#switchTab">
                Specifications
              </button>
              <button class="whitespace-nowrap py-4 px-6 border-b-2 border-transparent font-medium text-gray-500 hover:text-gray-700 hover:border-gray-300 focus:outline-none"
                      data-tabs-target="tab"
                      data-index="2"
                      data-action="tabs#switchTab">
                Shipping
              </button>
              <button class="whitespace-nowrap py-4 px-6 border-b-2 border-transparent font-medium text-gray-500 hover:text-gray-700 hover:border-gray-300 focus:outline-none"
                      data-tabs-target="tab"
                      data-index="3"
                      data-action="tabs#switchTab">
                Reviews
              </button>
              <button class="whitespace-nowrap py-4 px-6 border-b-2 border-transparent font-medium text-gray-500 hover:text-gray-700 hover:border-gray-300 focus:outline-none"
                      data-tabs-target="tab"
                      data-index="4"
                      data-action="tabs#switchTab">
                Q&A
              </button>
            </nav>
          </div>
          
          <!-- Tab Panels -->
          <div class="p-6" data-tabs-target="panel" data-index="0">
            <div class="prose prose-green max-w-none">
              <%= sanitize @product.description %>
            </div>
          </div>
          
          <div class="p-6 hidden" data-tabs-target="panel" data-index="1">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <% if @product.weight.present? || @product.dimensions.present? %>
                <div class="bg-gradient-to-br from-gray-50 to-gray-100 p-5 rounded-xl">
                  <h3 class="text-lg font-medium text-gray-900 mb-4">Physical Specifications</h3>
                  <dl class="space-y-4">
                    <% if @product.weight.present? %>
                      <div class="flex justify-between">
                        <dt class="text-sm font-medium text-gray-600">Weight</dt>
                        <dd class="text-sm font-semibold text-gray-900"><%= @product.weight %> kg</dd>
                      </div>
                    <% end %>
                    
                    <% if @product.dimensions.present? %>
                      <div class="flex justify-between">
                        <dt class="text-sm font-medium text-gray-600">Dimensions</dt>
                        <dd class="text-sm font-semibold text-gray-900"><%= @product.dimensions %></dd>
                      </div>
                    <% end %>
                  </dl>
                </div>
              <% end %>
              
              <div class="bg-gradient-to-br from-gray-50 to-gray-100 p-5 rounded-xl">
                <h3 class="text-lg font-medium text-gray-900 mb-4">Product Information</h3>
                <dl class="space-y-4">
                  <% if @product.brand.present? %>
                    <div class="flex justify-between">
                      <dt class="text-sm font-medium text-gray-600">Brand</dt>
                      <dd class="text-sm font-semibold text-gray-900"><%= @product.brand %></dd>
                    </div>
                  <% end %>
                  
                  <% if @product.condition.present? %>
                    <div class="flex justify-between">
                      <dt class="text-sm font-medium text-gray-600">Condition</dt>
                      <dd class="text-sm font-semibold text-gray-900"><%= @product.condition %></dd>
                    </div>
                  <% end %>
                  
                  <% if @product.sku.present? %>
                    <div class="flex justify-between">
                      <dt class="text-sm font-medium text-gray-600">SKU</dt>
                      <dd class="text-sm font-semibold text-gray-900"><%= @product.sku %></dd>
                    </div>
                  <% end %>
                  
                  <% if @product.barcode.present? %>
                    <div class="flex justify-between">
                      <dt class="text-sm font-medium text-gray-600">Barcode</dt>
                      <dd class="text-sm font-semibold text-gray-900"><%= @product.barcode %></dd>
                    </div>
                  <% end %>
                </dl>
              </div>
            </div>
          </div>
          
          <div class="p-6 hidden" data-tabs-target="panel" data-index="2">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="bg-gradient-to-br from-blue-50 to-blue-100 p-5 rounded-xl">
                <div class="flex items-start">
                  <div class="flex-shrink-0 mt-1">
                    <svg class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <div class="ml-4">
                    <h3 class="text-lg font-medium text-gray-900">Shipping Information</h3>
                    <p class="mt-2 text-sm text-gray-700">
                      This product ships from <%= @product.country_of_origin %> with an estimated delivery time of <%= @product.shipping_time %>.
