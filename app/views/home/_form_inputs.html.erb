<%# Enhanced Form Input Styles %>
<style>
  /* Input enhancements */
  .enhanced-input {
    @apply w-full px-4 py-3 border-2 border-gray-300 rounded-lg;
    @apply focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500;
    @apply text-gray-800 placeholder-gray-500;
    @apply transition-all duration-200;
    @apply shadow-sm hover:shadow;
    @apply bg-white;
  }
  
  .enhanced-input:focus {
    @apply transform scale-[1.01];
  }
  
  .enhanced-label {
    @apply block text-sm font-medium text-gray-700 mb-1;
  }
  
  .input-group {
    @apply mb-4;
  }
  
  .form-button {
    @apply w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium;
    @apply py-3 px-4 rounded-lg transition duration-200 shadow;
    @apply border border-transparent;
    @apply flex justify-center items-center;
  }
  
  .form-button:hover {
    @apply shadow-md transform scale-[1.01];
  }
  
  .checkbox-container {
    @apply flex items-start my-3;
  }
  
  .checkbox-input {
    @apply h-5 w-5 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded mt-0.5;
  }
  
  .checkbox-label {
    @apply ml-2 block text-sm text-gray-700;
  }
</style>
