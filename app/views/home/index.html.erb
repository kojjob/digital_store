<!-- Hero Section with Animation -->
<section class="relative overflow-hidden bg-gradient-to-br from-indigo-600 via-indigo-700 to-purple-800 py-20 md:py-28">
  <!-- Decorative elements -->
  <div class="absolute top-0 left-0 w-72 h-72 bg-white rounded-full mix-blend-multiply filter blur-3xl opacity-10 -translate-x-1/2 -translate-y-1/2"></div>
  <div class="absolute bottom-0 right-0 w-72 h-72 bg-pink-400 rounded-full mix-blend-multiply filter blur-3xl opacity-10 translate-x-1/3"></div>
  <div class="absolute top-1/4 right-0 w-40 h-40 bg-yellow-300 rounded-full mix-blend-multiply filter blur-3xl opacity-10"></div>
  
  <!-- Animated dots -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-1/4 left-1/4 w-2 h-2 bg-white rounded-full opacity-30 animate-ping" style="animation-duration: 3s;"></div>
    <div class="absolute top-1/3 right-1/3 w-2 h-2 bg-white rounded-full opacity-30 animate-ping" style="animation-duration: 4s; animation-delay: 1s;"></div>
    <div class="absolute bottom-1/4 left-1/2 w-2 h-2 bg-white rounded-full opacity-30 animate-ping" style="animation-duration: 5s; animation-delay: 2s;"></div>
  </div>
  
  <div class="container mx-auto px-4 relative z-10">
    <div class="flex flex-col items-center text-center max-w-4xl mx-auto">
      <!-- Social Proof Pill -->
      <div class="inline-flex items-center bg-white/10 backdrop-blur-sm rounded-full py-2 px-4 mb-6">
        <div class="flex -space-x-1 mr-2">
          <div class="w-5 h-5 rounded-full bg-green-400 ring-2 ring-indigo-700"></div>
          <div class="w-5 h-5 rounded-full bg-blue-400 ring-2 ring-indigo-700"></div>
          <div class="w-5 h-5 rounded-full bg-amber-400 ring-2 ring-indigo-700"></div>
        </div>
        <span class="text-white text-sm font-medium">Join 10,000+ creators across Africa</span>
      </div>
      
      <h1 class="text-4xl md:text-6xl font-extrabold text-white leading-tight mb-6">
        Discover & Download <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-yellow-200">Premium Digital Products</span>
      </h1>
      
      <p class="text-xl text-white/90 mb-8">
        Africa's leading marketplace for digital products created by talented designers, developers, and content creators.
      </p>
      
      <!-- Search Bar -->
      <div class="w-full max-w-2xl mx-auto mb-12">
        <form class="relative">
          <input type="text" placeholder="Search for templates, ebooks, graphics, and more..." class="w-full px-5 py-4 pl-12 pr-36 rounded-full text-gray-800 bg-white shadow-lg focus:outline-none focus:ring-2 focus:ring-indigo-500">
          <svg class="absolute left-4 top-1/2 transform -translate-y-1/2 h-6 w-6 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <button type="submit" class="absolute right-2 top-1/2 transform -translate-y-1/2 px-6 py-2 bg-indigo-600 text-white font-medium rounded-full hover:bg-indigo-700 transition duration-200">
            Search
          </button>
        </form>
      </div>
      
      <!-- Popular Categories Pills -->
      <div class="flex flex-wrap justify-center gap-2 mb-8">
        <a href="#" class="inline-flex items-center px-4 py-2 bg-white/10 hover:bg-white/20 backdrop-blur-sm rounded-full text-white text-sm font-medium transition duration-200">
          Website Templates
        </a>
        <a href="#" class="inline-flex items-center px-4 py-2 bg-white/10 hover:bg-white/20 backdrop-blur-sm rounded-full text-white text-sm font-medium transition duration-200">
          E-books
        </a>
        <a href="#" class="inline-flex items-center px-4 py-2 bg-white/10 hover:bg-white/20 backdrop-blur-sm rounded-full text-white text-sm font-medium transition duration-200">
          Graphics & UI Kits
        </a>
        <a href="#" class="inline-flex items-center px-4 py-2 bg-white/10 hover:bg-white/20 backdrop-blur-sm rounded-full text-white text-sm font-medium transition duration-200">
          Online Courses
        </a>
        <a href="#" class="inline-flex items-center px-4 py-2 bg-white/10 hover:bg-white/20 backdrop-blur-sm rounded-full text-white text-sm font-medium transition duration-200">
          Stock Photos
        </a>
      </div>
      
      <!-- Statistics -->
      <div class="flex flex-wrap justify-center gap-8 text-center">
        <div>
          <div class="text-3xl font-bold text-white">10K+</div>
          <div class="text-indigo-200 text-sm">Digital Products</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-white">5K+</div>
          <div class="text-indigo-200 text-sm">Creators</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-white">50K+</div>
          <div class="text-indigo-200 text-sm">Customers</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-white">97%</div>
          <div class="text-indigo-200 text-sm">Satisfaction</div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Wave Shape -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 60" class="w-full">
      <path fill="#ffffff" fill-opacity="1" d="M0,0L60,5.3C120,11,240,21,360,21.3C480,21,600,11,720,16C840,21,960,43,1080,48C1200,53,1320,43,1380,37.3L1440,32L1440,60L1380,60C1320,60,1200,60,1080,60C960,60,840,60,720,60C600,60,480,60,360,60C240,60,120,60,60,60L0,60Z"></path>
    </svg>
  </div>
</section>

<!-- Featured Products Section - ENHANCED -->
<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="flex justify-between items-center mb-10">
      <div>
        <div class="inline-flex items-center bg-indigo-50 px-3 py-1 rounded-full">
          <span class="bg-indigo-600 h-2 w-2 rounded-full mr-2"></span>
          <span class="text-indigo-700 text-xs font-semibold uppercase tracking-wider">Handpicked for you</span>
        </div>
        <h2 class="text-3xl font-bold text-gray-900 mt-2">Featured Products</h2>
        <p class="text-gray-600 mt-1">Premium digital products curated by our team</p>
      </div>
      <a href="#" class="group inline-flex items-center text-indigo-600 font-medium hover:text-indigo-700 transition-colors">
        <span>View all products</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-1 transform group-hover:translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
    
    <!-- Featured Products Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <% product_data = [
        {
          category: "UI Templates",
          title: "Premium Dashboard UI Kit",
          description: "Complete package with all the components you need to build a professional admin dashboard.",
          price: 49.99,
          rating: 4.9,
          seller_initials: "KM",
          seller_country: "Ghana",
          image_class: "from-indigo-100 to-indigo-200",
          badge: "Bestseller"
        },
        {
          category: "E-books",
          title: "Business Growth Blueprint",
          description: "Step-by-step guide to scaling your business in the African market with proven strategies.",
          price: 24.99,
          rating: 4.8,
          seller_initials: "JD",
          seller_country: "Nigeria",
          image_class: "from-amber-100 to-amber-200",
          badge: "New"
        },
        {
          category: "Graphics Pack",
          title: "Social Media Bundle 2023",
          description: "Over 200 templates for Instagram, Facebook, and Twitter to boost your social media presence.",
          price: 34.99,
          rating: 4.7,
          seller_initials: "TN",
          seller_country: "Kenya",
          image_class: "from-purple-100 to-purple-200",
          badge: "Trending"
        },
        {
          category: "Courses",
          title: "Complete Web Development",
          description: "From beginner to professional: master HTML, CSS, JavaScript, React and more in this comprehensive course.",
          price: 59.99,
          rating: 4.9,
          seller_initials: "RL",
          seller_country: "South Africa",
          image_class: "from-green-100 to-green-200",
          badge: "Bestseller"
        }
      ] %>
      
      <% if @featured_products&.any? %>
        <% @featured_products.limit(4).each_with_index do |product, index| %>
          <!-- Dynamic Product Card -->
          <div class="group bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col h-full" data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
            <div class="relative overflow-hidden h-48">
              <% if product.respond_to?(:images) && product.images.attached? && product.images.first.present? %>
                <%= image_tag product.images.first, class: "w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" %>
              <% elsif product.respond_to?(:image_url) && product.image_url.present? %>
                <img src="<%= product.image_url %>" alt="<%= product.name %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
              <% else %>
                <div class="w-full h-full bg-gradient-to-br <%= product_data[index % 4][:image_class] %> flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              <% end %>
              
              <!-- Badge -->
              <div class="absolute top-3 left-3">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
                  <% if product.respond_to?(:flag) && product.flag.present? %>
                    <%= product.flag %>
                  <% else %>
                    <%= ["Bestseller", "New", "Trending", "Featured"].sample %>
                  <% end %>
                </span>
              </div>
              
              <!-- Overlay with action buttons -->
              <div class="absolute inset-0 bg-black bg-opacity-40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center gap-2">
                <button class="bg-white rounded-full p-2.5 shadow-lg hover:bg-gray-100 transition-all duration-200 transform translate-y-2 group-hover:translate-y-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-800" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                  </svg>
                </button>
                <button class="bg-indigo-600 rounded-full p-2.5 shadow-lg hover:bg-indigo-700 transition-all duration-200 transform translate-y-2 group-hover:translate-y-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                  </svg>
                </button>
              </div>
            </div>
            
            <div class="p-5 flex flex-col flex-grow">
              <div class="flex items-center mb-3">
                <span class="text-xs font-semibold px-2 py-0.5 bg-gray-100 text-gray-600 rounded-full">
                  <% if product.respond_to?(:category) && product.category.present? %>
                    <%= product.category %>
                  <% else %>
                    <%= product_data[index % 4][:category] %>
                  <% end %>
                </span>
                <div class="ml-auto flex items-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                  <span class="ml-1 text-xs text-gray-600 font-medium">
                    <% if product.respond_to?(:rating) && product.rating.present? %>
                      <%= product.rating %>
                    <% else %>
                      <%= product_data[index % 4][:rating] %>
                    <% end %>
                  </span>
                </div>
              </div>
              
              <h3 class="font-bold text-gray-900 mb-2 text-lg leading-tight group-hover:text-indigo-600 transition-colors duration-200">
                <% if product.respond_to?(:name) && product.name.present? %>
                  <%= product.name %>
                <% else %>
                  <%= product_data[index % 4][:title] %>
                <% end %>
              </h3>
              
              <p class="text-sm text-gray-600 mb-4 line-clamp-2 flex-grow">
                <% if product.respond_to?(:description) && product.description.present? %>
                  <%= product.description %>
                <% else %>
                  <%= product_data[index % 4][:description] %>
                <% end %>
              </p>
              
              <div class="flex items-center justify-between mt-auto pt-3 border-t border-gray-100">
                <div class="flex items-center">
                  <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-xs font-bold text-indigo-800 mr-2">
                    <% if product.respond_to?(:seller) && product.seller.respond_to?(:initials) && product.seller.initials.present? %>
                      <%= product.seller.initials %>
                    <% else %>
                      <%= product_data[index % 4][:seller_initials] %>
                    <% end %>
                  </div>
                  <span class="text-sm text-gray-600">
                    <% if product.respond_to?(:seller) && product.seller.respond_to?(:country) && product.seller.country.present? %>
                      <%= product.seller.country %>
                    <% else %>
                      <%= product_data[index % 4][:seller_country] %>
                    <% end %>
                  </span>
                </div>
                <div class="font-bold text-lg text-indigo-700">
                  <% if product.respond_to?(:price) && product.price.present? %>
                    $<%= sprintf('%.2f', product.price) %>
                  <% else %>
                    $<%= sprintf('%.2f', product_data[index % 4][:price]) %>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <% product_data.each_with_index do |product, index| %>
          <!-- Fallback Product Card -->
          <div class="group bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col h-full" data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
            <div class="relative overflow-hidden h-48">
              <div class="w-full h-full bg-gradient-to-br <%= product[:image_class] %> flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
              
              <!-- Badge -->
              <div class="absolute top-3 left-3">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
                  <%= product[:badge] %>
                </span>
              </div>
              
              <!-- Overlay with action buttons -->
              <div class="absolute inset-0 bg-black bg-opacity-40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center gap-2">
                <button class="bg-white rounded-full p-2.5 shadow-lg hover:bg-gray-100 transition-all duration-200 transform translate-y-2 group-hover:translate-y-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-800" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                  </svg>
                </button>
                <button class="bg-indigo-600 rounded-full p-2.5 shadow-lg hover:bg-indigo-700 transition-all duration-200 transform translate-y-2 group-hover:translate-y-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                  </svg>
                </button>
              </div>
            </div>
            
            <div class="p-5 flex flex-col flex-grow">
              <div class="flex items-center mb-3">
                <span class="text-xs font-semibold px-2 py-0.5 bg-gray-100 text-gray-600 rounded-full">
                  <%= product[:category] %>
                </span>
                <div class="ml-auto flex items-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                  <span class="ml-1 text-xs text-gray-600 font-medium"><%= product[:rating] %></span>
                </div>
              </div>
              
              <h3 class="font-bold text-gray-900 mb-2 text-lg leading-tight group-hover:text-indigo-600 transition-colors duration-200">
                <%= product[:title] %>
              </h3>
              
              <p class="text-sm text-gray-600 mb-4 line-clamp-2 flex-grow">
                <%= product[:description] %>
              </p>
              
              <div class="flex items-center justify-between mt-auto pt-3 border-t border-gray-100">
                <div class="flex items-center">
                  <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-xs font-bold text-indigo-800 mr-2">
                    <%= product[:seller_initials] %>
                  </div>
                  <span class="text-sm text-gray-600"><%= product[:seller_country] %></span>
                </div>
                <div class="font-bold text-lg text-indigo-700">$<%= sprintf('%.2f', product[:price]) %></div>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

