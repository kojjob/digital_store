        {
          category: "E-books",
          title: "Digital Marketing Mastery",
          description: "Step-by-step guide to master digital marketing in the African market",
          price: 29.99,
          sales: 187,
          color: "from-amber-500 to-orange-500",
          change: "+42%"
        },
        {
          category: "Graphics Pack",
          title: "Social Media Bundle 2023",
          description: "Over 200 templates for Instagram, Facebook, and Twitter designed for African businesses",
          price: 39.99,
          sales: 215,
          color: "from-purple-500 to-pink-500",
          change: "+15%"
        }
      ] %>
      
      <% trending_data.each_with_index do |item, index| %>
        <div class="relative group" data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
