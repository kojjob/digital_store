            <!-- Card Header with Gradient -->
            <div class="h-32 bg-gradient-to-r <%= item[:color] %> p-6 flex items-end">
              <div class="text-white">
                <span class="text-xs font-semibold px-2 py-1 bg-white/20 backdrop-blur-sm rounded-full">
                  <%= item[:category] %>
                </span>
                <h3 class="font-bold text-2xl mt-2"><%= item[:title] %></h3>
              </div>
            </div>
            
            <!-- Card Body -->
            <div class="p-6 flex-grow flex flex-col">
              <p class="text-gray-600 text-sm mb-4 flex-grow"><%= item[:description] %></p>
              
              <!-- Statistics -->
              <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                <div>
                  <div class="flex items-center">
                    <div class="text-2xl font-bold text-gray-900">$<%= sprintf('%.2f', item[:price]) %></div>
