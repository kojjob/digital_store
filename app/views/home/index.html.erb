      <svg class="absolute w-full h-full" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320" preserveAspectRatio="none">
        <path fill="#f9fafb" fill-opacity="1" d="M0,64L40,96C80,128,160,192,240,202.7C320,213,400,171,480,165.3C560,160,640,192,720,186.7C800,181,880,139,960,122.7C1040,107,1120,117,1200,133.3C1280,149,1360,171,1400,181.3L1440,192L1440,320L1400,320C1360,320,1280,320,1200,320C1120,320,1040,320,960,320C880,320,800,320,720,320C640,320,560,320,480,320C400,320,320,320,240,320C160,320,80,320,40,320L0,320Z"></path>
      </svg>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="bg-gradient-to-b from-gray-50 to-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="inline-block px-3 py-1 text-sm font-semibold text-indigo-800 bg-indigo-100 rounded-full mb-4">Core Features</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Everything you need for digital products</h2>
        <p class="text-xl text-gray-600">Our platform offers a seamless experience from discovery to download, with features designed for your convenience.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8" data-controller="features">
        <!-- Feature 1: Instant Delivery -->
        <div class="bg-white p-8 rounded-2xl shadow-xl border border-gray-100 transform transition-all duration-300 hover:-translate-y-2" data-features-target="feature">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-xl bg-indigo-100 text-indigo-600 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-4">Instant Delivery</h3>
          <p class="text-gray-600">Receive your digital product instantly after purchase, with no waiting time.</p>
        </div>
        
        <!-- Feature 2: Mobile Payments -->
        <div class="bg-white p-8 rounded-2xl shadow-xl border border-gray-100 transform transition-all duration-300 hover:-translate-y-2" data-features-target="feature">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-xl bg-indigo-100 text-indigo-600 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-4">Seamless Mobile Payments</h3>
          <p class="text-gray-600">Direct integration with Ghana and Nigeria's mobile money systems for easy transactions.</p>
        </div>
        
        <!-- Feature 3: Secure & Trusted -->
        <div class="bg-white p-8 rounded-2xl shadow-xl border border-gray-100 transform transition-all duration-300 hover:-translate-y-2" data-features-target="feature">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-xl bg-indigo-100 text-indigo-600 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-4">Secure & Trusted</h3>
          <p class="text-gray-600">Top-notch security for all transactions, powered by industry standards.</p>
        </div>
        
        <!-- Feature 4: 24/7 Support -->
        <div class="bg-white p-8 rounded-2xl shadow-xl border border-gray-100 transform transition-all duration-300 hover:-translate-y-2" data-features-target="feature">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-xl bg-indigo-100 text-indigo-600 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-4">24/7 Support</h3>
          <p class="text-gray-600">We're here to help any time you need it, with responsive customer service.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Products Preview Section -->
  <section id="products" class="py-20 bg-gradient-to-b from-white to-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="inline-block px-3 py-1 text-sm font-semibold text-indigo-800 bg-indigo-100 rounded-full mb-4">Featured Products</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Handpicked resources for you</h2>
        <p class="text-xl text-gray-600">Browse our selection of premium digital products designed to elevate your projects.</p>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8" data-controller="products">
        <!-- Product cards will be rendered here using Hotwire -->
        <div data-products-target="container">
          <%= render partial: "product_card", collection: @featured_products, as: :product %>
        </div>
      </div>
      
      <div class="mt-12 text-center">
        <a href="/products" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-lg text-indigo-700 bg-indigo-100 hover:bg-indigo-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
          View all products
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section id="how-it-works" class="py-20 bg-gradient-to-b from-gray-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-20">
        <span class="inline-block px-3 py-1 text-sm font-semibold text-indigo-800 bg-indigo-100 rounded-full mb-4">Simple Process</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">How It Works</h2>
        <p class="text-xl text-gray-600">Get started with our digital products in four simple steps.</p>
      </div>
      
      <div class="relative">
        <!-- Connection Line (Desktop) -->
        <div class="hidden lg:block absolute top-1/2 left-0 w-full h-1 bg-indigo-100 -translate-y-1/2"></div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 relative z-10">
          <!-- Step 1 -->
          <div class="relative flex flex-col items-center">
            <div class="w-20 h-20 flex items-center justify-center rounded-full bg-white text-indigo-600 border-2 border-indigo-100 shadow-xl mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
            <div class="flex items-center justify-center w-8 h-8 rounded-full bg-indigo-600 text-white font-semibold absolute top-6 -right-3">1</div>
            <h3 class="text-xl font-semibold text-gray-900 mb-2 text-center">Browse & Select</h3>
            <p class="text-gray-600 text-center">Explore our collection and choose your digital product.</p>
          </div>
          
          <!-- Step 2 -->
          <div class="relative flex flex-col items-center">
            <div class="w-20 h-20 flex items-center justify-center rounded-full bg-white text-indigo-600 border-2 border-indigo-100 shadow-xl mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
