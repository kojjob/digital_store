<!-- app/views/pages/landing.html.erb -->
<div class="bg-gradient-to-b from-gray-50 to-white">
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <!-- Background Pattern -->
    <div class="absolute inset-0 z-0">
      <svg class="absolute inset-0 h-full w-full" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
        <defs>
          <pattern id="hero-pattern" width="100" height="100" patternUnits="userSpaceOnUse">
            <path d="M0 0L20 10L40 0L60 10L80 0L100 10L100 20L80 30L100 40L80 50L100 60L80 70L100 80L80 90L100 100L80 100L60 90L40 100L20 90L0 100L0 90L20 80L0 70L20 60L0 50L20 40L0 30L20 20L0 10Z" fill="none" stroke="rgba(99, 102, 241, 0.05)" stroke-width="2"></path>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#hero-pattern)"></rect>
      </svg>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-24 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Hero Content -->
        <div class="space-y-8 text-center lg:text-left">
          <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-indigo-50 border border-indigo-100">
            <span class="h-2 w-2 rounded-full bg-indigo-600"></span>
            <span class="ml-2 text-sm font-medium text-indigo-800">Premium Digital Products</span>
          </div>
          
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-gray-900 leading-tight">
            Instant Digital Products. <span class="text-indigo-600">Seamless Payments.</span> Unmatched Simplicity.
          </h1>
          
          <p class="text-xl text-gray-600 max-w-2xl">
            Discover our curated collection of digital products and experience effortless transactions via direct mobile money integration and secure card payments.
          </p>
          
          <div class="flex flex-col sm:flex-row justify-center lg:justify-start gap-4 mt-8">
            <a href="#products" class="inline-flex justify-center items-center px-6 py-3.5 border border-transparent text-lg font-medium rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 shadow-lg shadow-indigo-500/30 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-600">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
                <path d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3zM16 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM6.5 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3z" />
              </svg>
              Browse Products
            </a>
            <a href="#how-it-works" class="inline-flex justify-center items-center px-6 py-3.5 border border-gray-300 text-lg font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 shadow-md transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">
              Get Started
            </a>
          </div>
        </div>
        
        <!-- Hero Image -->
        <div class="relative h-96 sm:h-[450px] lg:h-[550px] rounded-2xl overflow-hidden shadow-2xl transform -rotate-1 transition-all duration-300 hover:rotate-0">
          <img src="https://images.unsplash.com/photo-1498050108023-c5249f4df085" alt="Digital workspace" class="absolute inset-0 w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/20 to-purple-600/30"></div>

          <!-- Floating Elements Animation -->
          <div class="absolute top-1/4 left-1/4 w-16 h-16 bg-white/20 backdrop-blur-xl rounded-2xl transform rotate-12 animate-float"></div>
          <div class="absolute bottom-1/3 right-1/4 w-12 h-12 bg-indigo-500/20 backdrop-blur-xl rounded-full animate-float-delayed"></div>
          <div class="absolute top-2/3 right-1/3 w-8 h-8 bg-purple-500/20 backdrop-blur-xl rounded-lg transform -rotate-12 animate-float-slow"></div>
        </div>
      </div>

      <!-- Trusted By Section -->
      <div class="mt-24 text-center">
        <p class="text-sm font-medium text-gray-500 uppercase tracking-wider mb-6">Trusted by forward-thinking companies</p>
        <div class="flex flex-wrap justify-center gap-x-12 gap-y-8">
          <!-- Replace with actual logos or use placeholder logos -->
