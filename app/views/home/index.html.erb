<!-- Newsletter Section -->
<section class="py-16 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto bg-white rounded-2xl shadow-xl overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-2">
        <div class="p-8 md:p-12">
          <div class="inline-flex items-center bg-indigo-50 px-3 py-1 rounded-full mb-4">
            <span class="bg-indigo-600 h-2 w-2 rounded-full mr-2"></span>
            <span class="text-indigo-700 text-xs font-semibold uppercase tracking-wider">Newsletter</span>
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">Stay in the Loop</h2>
          <p class="text-gray-600 mb-6">Subscribe to our newsletter to get notified about new products, special offers, and digital marketplace tips.</p>
          
          <form class="space-y-4">
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email address</label>
              <input type="email" id="email" placeholder="Enter your email" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
            </div>
            <div class="flex items-start">
              <input id="terms" type="checkbox" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded mt-1">
              <label for="terms" class="ml-2 block text-sm text-gray-500">
                I agree to receive emails about product updates and promotions
              </label>
            </div>
            <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-3 px-4 rounded-lg transition duration-200 shadow">
              Subscribe
            </button>
          </form>
        </div>
        <div class="hidden md:block relative bg-gradient-to-br from-indigo-500 to-purple-600 p-12">
          <div class="absolute inset-0 opacity-20">
            <svg width="100%" height="100%" viewBox="0 0 100 100" preserveAspectRatio="none">
              <defs>
                <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
                  <path d="M 10 0 L 0 0 0 10" fill="none" stroke="white" stroke-width="0.5" />
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#grid)" />
            </svg>
          </div>
          <div class="relative z-10 h-full flex flex-col justify-center">
            <div class="text-white text-lg font-light mb-4">Join <span class="font-bold">5,000+</span> subscribers</div>
            <div class="bg-white/10 backdrop-blur-sm rounded-lg p-4 border border-white/20">
              <div class="flex items-center mb-4">
                <img src="https://randomuser.me/api/portraits/women/45.jpg" alt="Subscriber" class="w-10 h-10 rounded-full object-cover mr-3">
                <div>
                  <div class="text-white font-medium">Aisha M.</div>
                  <div class="text-white/70 text-sm">Just subscribed</div>
                </div>
              </div>
              <p class="text-white/90 text-sm">"The weekly newsletter helps me discover new digital products I wouldn't have found otherwise!"</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Bottom CTA Banner -->
<section class="bg-gradient-to-r from-indigo-600 to-indigo-700 py-10">
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row items-center justify-between">
      <div class="mb-6 md:mb-0">
        <h3 class="text-xl font-bold text-white mb-2">Ready to find the perfect digital product?</h3>
        <p class="text-indigo-100">Browse our marketplace or create an account to save your favorites.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4">
        <%= link_to products_path, class: "inline-flex items-center justify-center px-6 py-3 border border-transparent rounded-lg shadow-lg text-base font-medium text-indigo-700 bg-white hover:bg-indigo-50 transition duration-300" do %>
          Browse Products
        <% end %>
        
        <%= link_to new_user_registration_path, class: "inline-flex items-center justify-center px-6 py-3 border border-white rounded-lg text-base font-medium text-white hover:bg-white/10 transition duration-300" do %>
          Create Account
        <% end %>
      </div>
    </div>
  </div>
</section>

<!-- Initialize AOS animations -->
<% content_for :page_scripts do %>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof AOS !== 'undefined') {
      AOS.init({
        duration: 800,
        once: true,
        offset: 100
      });
    }
  });
</script>
<% end %>
