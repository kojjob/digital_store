        </blockquote>
        
        <div class="flex items-center">
          <img src="https://randomuser.me/api/portraits/women/54.jpg" alt="Customer" class="w-12 h-12 rounded-full object-cover mr-4 border-2 border-white shadow">
          <div>
            <div class="text-gray-900 font-bold">Grace Afolabi</div>
            <div class="text-gray-500 text-sm">Business Owner, Nigeria</div>
          </div>
        </div>
      </div>
      
      <!-- Testimonial 3 -->
      <div class="bg-gray-50 rounded-xl p-6 shadow-sm hover:shadow-md transition-all duration-300" data-aos="fade-up" data-aos-delay="200">
        <div class="flex text-yellow-400 mb-4">
          <% 5.times do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
