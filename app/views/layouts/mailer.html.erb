<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <style>
      body {
        font-family: Arial, sans-serif;
        margin: 0;
        padding: 0;
        color: #333333;
        background-color: #f7f7f7;
      }
      .email-container {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
        background-color: #ffffff;
      }
      .header {
        background-color: #4f46e5;
        padding: 20px;
        text-align: center;
      }
      .header h1 {
        color: white;
        margin: 0;
        font-size: 24px;
      }
      .content {
        padding: 20px;
        line-height: 1.5;
      }
      .footer {
        background-color: #f0f0f0;
        padding: 15px;
        text-align: center;
        font-size: 12px;
        color: #666666;
      }
      .button {
        display: inline-block;
        background-color: #4f46e5;
        color: white !important;
        text-decoration: none;
        padding: 12px 20px;
        border-radius: 4px;
        margin: 20px 0;
        font-weight: bold;
      }
      .button:hover {
        background-color: #4338ca;
      }
      .order-detail {
        margin: 20px 0;
        border: 1px solid #e0e0e0;
        border-radius: 4px;
        overflow: hidden;
      }
      .order-header {
        background-color: #f0f0f0;
        padding: 10px 15px;
        border-bottom: 1px solid #e0e0e0;
      }
      .order-content {
        padding: 15px;
      }
      .product-row {
        display: flex;
        border-bottom: 1px solid #e0e0e0;
        padding: 10px 0;
      }
      .product-info {
        flex: 1;
      }
      .product-price {
        text-align: right;
        min-width: 80px;
      }
      .order-total {
        text-align: right;
        padding: 10px 0;
        font-weight: bold;
      }
      .download-info {
        background-color: #f0f9ff;
        border: 1px solid #bae6fd;
        border-radius: 4px;
        padding: 15px;
        margin: 20px 0;
      }
      .expiry-warning {
        color: #dc2626;
        font-weight: bold;
      }
    </style>
  </head>

  <body>
    <div class="email-container">
      <div class="header">
        <h1>Digital Store</h1>
      </div>
      <div class="content">
        <%= yield %>
      </div>
      <div class="footer">
        <p>© <%= Date.today.year %> Digital Store. All rights reserved.</p>
        <p>If you have any questions, please contact our support team at support@digitalstore.com.</p>
      </div>
    </div>
  </body>
</html>