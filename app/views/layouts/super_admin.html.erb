<!DOCTYPE html>
<html class="h-full bg-gray-100">
<head>
  <title>Digital Store Super Admin</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  
  <!-- Add Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body class="h-full">
  <div class="min-h-full">
    <!-- Navigation bar -->
    <nav class="bg-red-700">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <div class="flex items-center">
                <img class="h-8 w-auto" src="<%= asset_path('logo.svg') %>" alt="Digital Store">
                <span class="ml-2 text-xl font-bold text-white">SUPER ADMIN</span>
              </div>
            </div>
            <div class="hidden md:block">
              <div class="ml-10 flex items-baseline space-x-4">
                <%= link_to "Dashboard", super_admin_dashboard_path, class: "#{current_page?(super_admin_dashboard_path) ? 'bg-red-800 text-white' : 'text-white hover:bg-red-600 hover:bg-opacity-75'} rounded-md px-3 py-2 text-sm font-medium" %>
                <%= link_to "Financial", super_admin_finance_path, class: "#{current_page?(super_admin_finance_path) ? 'bg-red-800 text-white' : 'text-white hover:bg-red-600 hover:bg-opacity-75'} rounded-md px-3 py-2 text-sm font-medium" %>
                <%= link_to "Users", super_admin_users_path, class: "#{controller_name == 'users' ? 'bg-red-800 text-white' : 'text-white hover:bg-red-600 hover:bg-opacity-75'} rounded-md px-3 py-2 text-sm font-medium" %>
                <%= link_to "System", super_admin_system_path, class: "#{controller_name == 'system' ? 'bg-red-800 text-white' : 'text-white hover:bg-red-600 hover:bg-opacity-75'} rounded-md px-3 py-2 text-sm font-medium" %>
                <%= link_to "Admin Dashboard", admin_dashboard_path, class: "text-white hover:bg-red-600 hover:bg-opacity-75 rounded-md px-3 py-2 text-sm font-medium" %>
                <%= link_to "Store Front", root_path, class: "text-white hover:bg-red-600 hover:bg-opacity-75 rounded-md px-3 py-2 text-sm font-medium" %>
              </div>
            </div>
          </div>
          <div class="hidden md:block">
            <div class="ml-4 flex items-center md:ml-6">
              <% if session[:admin_id].present? %>
                <!-- Impersonation warning -->
                <div class="bg-yellow-500 text-white px-3 py-1 rounded-md mr-4">
                  <div class="flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                    <span>Impersonating</span>
                  </div>
                  <%= button_to "Stop", stop_impersonation_super_admin_users_path, method: :post, class: "text-xs underline" %>
                </div>
              <% end %>
              
              <!-- Profile dropdown -->
              <div class="relative ml-3">
                <div>
                  <button type="button" class="flex max-w-xs items-center rounded-full bg-red-700 text-sm focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-red-700" id="user-menu-button" aria-expanded="false" aria-haspopup="true">
                    <span class="sr-only">Open user menu</span>
                    <% if current_user.profile_picture.attached? %>
                      <%= image_tag current_user.profile_picture.variant(resize_to_fill: [32, 32]), class: "h-8 w-8 rounded-full" %>
                    <% else %>
                      <span class="inline-block h-8 w-8 overflow-hidden rounded-full bg-gray-100">
                        <svg class="h-full w-full text-gray-300" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" />
                        </svg>
                      </span>
                    <% end %>
                  </button>
                </div>
              </div>
              <!-- Logout button -->
              <div class="ml-3">
                <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "rounded bg-red-800 px-2 py-1 text-sm font-semibold text-white shadow-sm hover:bg-red-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-700" %>
              </div>
            </div>
          </div>
          <div class="-mr-2 flex md:hidden">
            <!-- Mobile menu button -->
            <button type="button" class="inline-flex items-center justify-center rounded-md bg-red-700 p-2 text-red-200 hover:bg-red-600 hover:bg-opacity-75 hover:text-white focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-red-700" aria-controls="mobile-menu" aria-expanded="false">
              <span class="sr-only">Open main menu</span>
              <svg class="block h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
              </svg>
              <svg class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile menu, show/hide based on menu state. -->
      <div class="md:hidden" id="mobile-menu">
        <div class="space-y-1 px-2 pb-3 pt-2 sm:px-3">
          <%= link_to "Dashboard", super_admin_dashboard_path, class: "#{current_page?(super_admin_dashboard_path) ? 'bg-red-800 text-white' : 'text-white hover:bg-red-600 hover:bg-opacity-75'} block rounded-md px-3 py-2 text-base font-medium" %>
          <%= link_to "Financial", super_admin_finance_path, class: "#{current_page?(super_admin_finance_path) ? 'bg-red-800 text-white' : 'text-white hover:bg-red-600 hover:bg-opacity-75'} block rounded-md px-3 py-2 text-base font-medium" %>
          <%= link_to "Users", super_admin_users_path, class: "#{controller_name == 'users' ? 'bg-red-800 text-white' : 'text-white hover:bg-red-600 hover:bg-opacity-75'} block rounded-md px-3 py-2 text-base font-medium" %>
          <%= link_to "System", super_admin_system_path, class: "#{controller_name == 'system' ? 'bg-red-800 text-white' : 'text-white hover:bg-red-600 hover:bg-opacity-75'} block rounded-md px-3 py-2 text-base font-medium" %>
          <%= link_to "Admin Dashboard", admin_dashboard_path, class: "text-white hover:bg-red-600 hover:bg-opacity-75 block rounded-md px-3 py-2 text-base font-medium" %>
          <%= link_to "Store Front", root_path, class: "text-white hover:bg-red-600 hover:bg-opacity-75 block rounded-md px-3 py-2 text-base font-medium" %>
        </div>
        <div class="border-t border-red-800 pb-3 pt-4">
          <div class="flex items-center px-5">
            <div class="flex-shrink-0">
              <% if current_user.profile_picture.attached? %>
                <%= image_tag current_user.profile_picture.variant(resize_to_fill: [40, 40]), class: "h-10 w-10 rounded-full" %>
              <% else %>
                <span class="inline-block h-10 w-10 overflow-hidden rounded-full bg-gray-100">
                  <svg class="h-full w-full text-gray-300" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" />
                  </svg>
                </span>
              <% end %>
            </div>
            <div class="ml-3">
              <div class="text-base font-medium text-white"><%= current_user.full_name %></div>
              <div class="text-sm font-medium text-red-300"><%= current_user.email %></div>
            </div>
          </div>
          <div class="mt-3 space-y-1 px-2">
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "block rounded-md px-3 py-2 text-base font-medium text-white hover:bg-red-600 hover:bg-opacity-75" %>
          </div>
        </div>
      </div>
    </nav>

    <% if flash.any? %>
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mt-4">
        <% flash.each do |type, message| %>
          <div class="<%= type == 'notice' ? 'bg-green-50 text-green-800' : 'bg-red-50 text-red-800' %> p-4 rounded-md mb-4">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <% if type == 'notice' %>
                  <svg class="h-5 w-5 text-green-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                <% else %>
                  <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                  </svg>
                <% end %>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium"><%= message %></p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <main>
      <div class="mx-auto max-w-7xl py-6 sm:px-6 lg:px-8">
        <%= yield %>
      </div>
    </main>
  </div>
</body>
</html>