<% content_for :title, "Search Results: #{@query}" %>
<% content_for :meta_description, "Search results for '#{@query}' in our digital store" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Hero section with search form -->
  <div class="relative bg-gradient-to-r from-indigo-600 to-purple-600 rounded-xl overflow-hidden shadow-lg mb-8">
    <div class="absolute inset-0 opacity-20">
      <svg class="h-full w-full" viewBox="0 0 1920 1080" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 891C126.667 853.667 253.333 835 380 835C633.333 835 760 939.5 1013 939.5C1139.67 939.5 1266.33 911.333 1393 855L1393 1080H0V891Z" fill="white" fill-opacity="0.3" />
        <path d="M0 986C126.667 928 253.333 899 380 899C633.333 899 760 1010.5 1013 1010.5C1139.67 1010.5 1266.33 950.333 1393 830V1080H0V986Z" fill="white" fill-opacity="0.3" />
      </svg>
    </div>
    <div class="relative py-8 px-8">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold text-white mb-6">Search Results</h1>
        
        <%= form_with url: search_path, method: :get, class: "flex w-full" do |f| %>
          <div class="relative flex-grow">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
            <%= f.text_field :query, value: @query, class: "block w-full pl-10 pr-3 py-3 border border-transparent rounded-l-md leading-5 bg-white placeholder-gray-500 focus:outline-none focus:placeholder-gray-400 focus:ring-0 focus:border-white sm:text-sm", placeholder: "Search for products, categories, and more..." %>
          </div>
          <%= f.submit "Search", class: "inline-flex items-center px-6 py-3 border border-transparent rounded-r-md shadow-sm text-sm font-medium text-white bg-indigo-800 hover:bg-indigo-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
        <% end %>
      </div>
    </div>
  </div>

  <% if @query.blank? %>
    <!-- Empty search prompt -->
    <div class="text-center py-16">
      <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-16 w-16 text-indigo-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <h3 class="mt-4 text-lg font-medium text-gray-900">Enter a search term</h3>
      <p class="mt-2 text-sm text-gray-500 max-w-md mx-auto">
        Type in the search box above to find products, categories, and more in our digital store.
      </p>
    </div>
  <% else %>
    <!-- Search summary -->
    <div class="bg-white shadow-sm rounded-lg p-4 mb-8 flex items-center justify-between">
      <div>
        <h2 class="text-sm text-gray-500">
          <% total_count = @products.try(:total_count) || 0 %>
          <% if total_count > 0 %>
            Found <span class="font-medium text-gray-900"><%= total_count %></span> results for 
          <% else %>
            No results found for 
          <% end %>
          <span class="font-medium text-indigo-600">"<%= @query %>"</span>
        </h2>
      </div>
      
      <% if @categories.any? %>
        <div class="flex items-center text-sm">
          <span class="text-gray-500 mr-2">Filter by:</span>
          <div class="flex flex-wrap gap-2">
            <% @categories.each do |category| %>
              <%= link_to products_path(category_id: category.id, search: @query), class: "inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800 hover:bg-indigo-200 transition-colors" do %>
                <%= category.name %>
                <span class="ml-1 text-indigo-500">(<%= category.products.count %>)</span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <% if @products.any? %>
      <!-- Products grid -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <% @products.each do |product| %>
          <%= link_to product_path(product), class: "group" do %>
            <div class="bg-white rounded-lg shadow-sm overflow-hidden hover:shadow-md transition-all duration-300">
              <div class="relative aspect-w-1 aspect-h-1 bg-gray-100 overflow-hidden">
                <% if product.product_images.any? %>
                  <div class="absolute inset-0 transform group-hover:scale-110 transition-transform duration-500">
                    <img src="<%= product.product_images.first.image.url %>" alt="<%= product.name %>" class="w-full h-full object-cover">
                  </div>
                <% else %>
                  <div class="w-full h-full flex items-center justify-center text-gray-400">
                    <svg class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                  </div>
                <% end %>
                
                <% if product.discounted_price && product.discounted_price < product.price %>
                  <div class="absolute top-2 right-2 bg-red-500 text-white text-xs font-bold px-2 py-1 rounded-full">
                    <%= number_to_percentage(100 - (product.discounted_price / product.price * 100), precision: 0) %> OFF
                  </div>
                <% end %>
              </div>
              <div class="p-4">
                <div class="flex items-center justify-between mb-2">
                  <p class="text-xs text-indigo-600 font-medium"><%= product.category&.name %></p>
                  <div class="flex items-center text-xs text-gray-500">
                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                      <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
                    </svg>
                    <%= product.country_of_origin %>
                  </div>
                </div>
                <h3 class="font-bold text-gray-900 text-sm mb-2 group-hover:text-indigo-600 line-clamp-2"><%= product.name %></h3>
                <div class="flex items-center justify-between">
                  <div>
                    <% if product.discounted_price && product.discounted_price < product.price %>
                      <span class="text-gray-400 line-through text-xs"><%= product.currency %><%= product.price %></span>
                      <span class="text-gray-900 font-bold ml-1"><%= product.currency %><%= product.discounted_price %></span>
                    <% else %>
                      <span class="text-gray-900 font-bold"><%= product.currency %><%= product.price %></span>
                    <% end %>
                  </div>
                  <% if product.condition.present? %>
                    <span class="text-xs px-1.5 py-0.5 bg-gray-100 text-gray-800 rounded">
                      <%= product.condition %>
                    </span>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
      
      <!-- Pagination -->
      <div class="mt-12 flex items-center justify-between border-t border-gray-200 pt-6">
        <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
          <div>
            <p class="text-sm text-gray-700">
              Showing <span class="font-medium"><%= @products.offset_value + 1 %></span> to 
              <span class="font-medium"><%= [@products.offset_value + @products.length, @products.total_count].min %></span> of 
              <span class="font-medium"><%= @products.total_count %></span> results
            </p>
          </div>
          <div>
            <%= paginate @products %>
          </div>
        </div>
      </div>
    <% else %>
      <!-- No results -->
      <div class="text-center py-16">
        <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-16 w-16 text-indigo-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="mt-4 text-lg font-medium text-gray-900">No results found</h3>
        <p class="mt-2 text-sm text-gray-500 max-w-md mx-auto">
          We couldn't find any products matching "<%= @query %>". Try checking your spelling or using more general terms.
        </p>
        <div class="mt-6">
          <%= link_to products_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
            Browse All Products
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>

<style>
  /* Line clamp utility for multi-line text truncation */
  .line-clamp-2 {
    overflow: hidden;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }
</style>
