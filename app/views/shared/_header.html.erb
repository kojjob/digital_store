<header class="sticky top-0 w-full z-50 bg-white shadow-sm" data-controller="navbar">
  <div class="relative">
    <!-- Top strip with announcement and secondary links -->
    <div class="bg-indigo-700 text-white py-2 text-sm px-4 sm:px-6 lg:px-8">
      <div class="max-w-7xl mx-auto flex flex-wrap items-center justify-between">
        <div class="w-0 flex-1 flex items-center">
          <span class="hidden sm:inline-flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
            </svg>
            Free shipping on orders over $50
          </span>
          <marquee scrollamount="3" class="sm:hidden">🔥 Free shipping on orders over $50 • 30-day money-back guarantee • New products added weekly</marquee>
        </div>

        <div class="flex items-center space-x-4 text-xs">
          <%= link_to "Help", help_path, class: "hover:text-indigo-100 hidden sm:block" %>
          <%= link_to "Contact", contact_path, class: "hover:text-indigo-100 hidden sm:block" %>
          <div class="relative" data-controller="simple-dropdown">
            <button type="button" class="flex items-center hover:text-indigo-100 focus:outline-none" data-action="simple-dropdown#toggle" data-simple-dropdown-target="button">
              <span>English</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="origin-top-right absolute right-0 mt-2 w-48 rounded-lg shadow-lg py-1 bg-white focus:outline-none hidden opacity-0 translate-y-1 z-10 transition-all duration-200" data-simple-dropdown-target="menu">
              <a href="#" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dropdown-item-no-border" data-action="simple-dropdown#select">English</a>
              <a href="#" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dropdown-item-no-border" data-action="simple-dropdown#select">French</a>
              <a href="#" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dropdown-item-no-border" data-action="simple-dropdown#select">Spanish</a>
              <a href="#" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dropdown-item-no-border" data-action="simple-dropdown#select">German</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Main navbar with logo, search, and user actions -->
    <nav class="bg-white border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <!-- Logo and toggle button for mobile -->
          <div class="flex items-center">
            <!-- Mobile menu button -->
            <button type="button" class="inline-flex items-center justify-center p-2 rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-indigo-500 md:hidden" data-action="navbar#toggleMobileMenu">
              <span class="sr-only">Open main menu</span>
              <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" data-navbar-target="menuOpen">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
              <svg class="h-6 w-6 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" data-navbar-target="menuClose">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>

      <!-- Logo -->
        <%= link_to root_path, class: "flex items-center" do %>
          <div class="h-10 w-10 rounded-xl bg-amber-100 flex items-center justify-center mr-3 shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
            </svg>
          </div>
          <span class="text-2xl font-bold text-gray-900">DigitalStore</span>
        <% end %>
      </div>

          <!-- Desktop main navigation -->
          <div class="hidden md:flex md:items-center md:justify-between flex-1 ml-10">
            <div class="flex space-x-4 xl:space-x-8">
              <!-- Home -->
              <%= link_to root_path, class: "flex items-center text-sm font-medium text-gray-800 hover:text-indigo-600 px-3 py-2 rounded-md hover:bg-gray-50 transition duration-150 ease-in-out" do %>
                Home
              <% end %>

              <!-- Products Dropdown -->
              <div class="relative" data-controller="simple-dropdown">
                <button type="button" class="group inline-flex items-center text-sm font-medium text-gray-800 hover:text-indigo-600 px-3 py-2 rounded-md hover:bg-gray-50 transition duration-150 ease-in-out" data-action="simple-dropdown#toggle" data-simple-dropdown-target="button">
                  Products
                  <svg class="ml-1 h-4 w-4 text-gray-400 group-hover:text-indigo-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>

                <!-- Mega dropdown menu -->
                <div class="absolute z-10 inset-x-0 left-1/2 transform -translate-x-1/2 mt-3 px-2 w-screen max-w-7xl sm:px-0 hidden opacity-0 translate-y-1 z-10 transition-all duration-200" data-simple-dropdown-target="menu">
                  <div class="rounded-lg shadow-lg overflow-hidden transition-all duration-200">
                  <div class="relative grid gap-6 bg-white px-5 py-6 sm:gap-8 sm:p-8 lg:grid-cols-1">
                      <%= link_to products_path, class: "-m-3 p-3 flex items-start rounded-lg hover:bg-gray-50 transition ease-in-out duration-150" do %>
                        <div class="ml-4">
                          <p class="text-base font-medium text-gray-900">All Products</p>
                          <p class="mt-1 text-sm text-gray-500">Browse our complete collection of digital products</p>
                        </div>
                      <% end %>
                      <!-- Categories moved from header to dedicated page -->
                      <%= link_to categories_path, class: "-m-3 p-3 flex items-start rounded-lg hover:bg-gray-50 transition ease-in-out duration-150" do %>
                        <div class="ml-4">
                          <p class="text-base font-medium text-gray-900">Categories</p>
                          <p class="mt-1 text-sm text-gray-500">Browse products by category</p>
                        </div>
                      <% end %>
                    </div>
                    <div class="bg-gradient-to-br from-indigo-50 to-blue-50 px-5 py-5 sm:px-8 sm:py-6">
                      <div class="flex items-center justify-between">
                        <h3 class="text-sm tracking-wide font-semibold text-indigo-700 uppercase flex items-center">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                          </svg>
                          Featured Products
                        </h3>
                        <%= link_to products_path, class: "flex items-center font-medium text-xs text-indigo-600 hover:text-indigo-700 transition duration-150 ease-in-out" do %>
                          View all
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                          </svg>
                        <% end %>
                      </div>
                      
                      <div class="mt-5 grid grid-cols-3 gap-5">
                        <% if @featured_products.present? && @featured_products.any? %>
                          <% @featured_products.limit(3).each do |product| %>
                            <%= link_to product_path(product), class: "group block" do %>
                              <div class="relative overflow-hidden rounded-lg bg-white shadow-md h-32 mb-2">
                                <div class="absolute inset-0 bg-gray-200 flex items-center justify-center">
                                  <% if product.images.attached? && product.images.first.present? %>
                                    <%= image_tag product.images.first, class: "w-full h-full object-cover group-hover:scale-105 transition duration-200", alt: product.name %>
                                  <% elsif product.product_images.any? && product.product_images.first.respond_to?(:has_image?) && product.product_images.first.has_image? %>
                                    <%= image_tag product.product_images.first.image, class: "w-full h-full object-cover group-hover:scale-105 transition duration-200", alt: product.product_images.first.safe_alt_text %>
                                  <% else %>
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                    </svg>
                                  <% end %>
                                </div>
                                <div class="absolute top-0 right-0 mt-2 mr-2">
                                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-600 text-white">
                                    Featured
                                  </span>
                                </div>
                              </div>
                              <h4 class="text-sm font-medium text-gray-900 group-hover:text-indigo-600 truncate"><%= product.name %></h4>
                              <div class="flex justify-between items-center mt-1">
                                <p class="text-sm font-bold text-indigo-700">$<%= number_with_precision(product.price, precision: 2) %></p>
                                <div class="text-xs text-gray-500"><%= product.category %></div>
                              </div>
                            <% end %>
                          <% end %>
                        <% else %>
                          <!-- Static featured products as placeholders -->
                          <%= link_to products_path, class: "group block" do %>
                            <div class="relative overflow-hidden rounded-lg bg-white shadow-md h-32 mb-2">
                              <div class="absolute inset-0 bg-blue-100 flex items-center justify-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
                                </svg>
                              </div>
                              <div class="absolute top-0 right-0 mt-2 mr-2">
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-600 text-white">
                                  Featured
                                </span>
                              </div>
                            </div>
                            <h4 class="text-sm font-medium text-gray-900 group-hover:text-indigo-600 truncate">Premium Admin Dashboard</h4>
                            <div class="flex justify-between items-center mt-1">
                              <p class="text-sm font-bold text-indigo-700">$49.99</p>
                              <div class="text-xs text-gray-500">UI Templates</div>
                            </div>
                          <% end %>
                          
                          <%= link_to products_path, class: "group block" do %>
                            <div class="relative overflow-hidden rounded-lg bg-white shadow-md h-32 mb-2">
                              <div class="absolute inset-0 bg-amber-100 flex items-center justify-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                                </svg>
                              </div>
                              <div class="absolute top-0 right-0 mt-2 mr-2">
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-600 text-white">
                                  New
                                </span>
                              </div>
                            </div>
                            <h4 class="text-sm font-medium text-gray-900 group-hover:text-indigo-600 truncate">Essential Icon Pack</h4>
                            <div class="flex justify-between items-center mt-1">
                              <p class="text-sm font-bold text-indigo-700">$24.99</p>
                              <div class="text-xs text-gray-500">Icon Sets</div>
                            </div>
                          <% end %>
                          
                          <%= link_to products_path, class: "group block" do %>
                            <div class="relative overflow-hidden rounded-lg bg-white shadow-md h-32 mb-2">
                              <div class="absolute inset-0 bg-green-100 flex items-center justify-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                              </div>
                              <div class="absolute top-0 right-0 mt-2 mr-2">
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-600 text-white">
                                  Featured
                                </span>
                              </div>
                            </div>
                            <h4 class="text-sm font-medium text-gray-900 group-hover:text-indigo-600 truncate">Modern UI Illustrations</h4>
                            <div class="flex justify-between items-center mt-1">
                              <p class="text-sm font-bold text-indigo-700">$29.99</p>
                              <div class="text-xs text-gray-500">Graphic Assets</div>
                            </div>
                          <% end %>
                        <% end %>
                      </div>
                    </div>
                  </div>
        </div>
      </div>

              <!-- Features -->
              <%= link_to about_path, class: "flex items-center text-sm font-medium text-gray-800 hover:text-indigo-600 px-3 py-2 rounded-md hover:bg-gray-50 transition duration-150 ease-in-out" do %>
                About
              <% end %>

              <!-- Categories link removed for streamlined navigation -->

              <!-- Resources Dropdown -->
              <div class="relative" data-controller="simple-dropdown">
                <button type="button" class="group inline-flex items-center text-sm font-medium text-gray-800 hover:text-indigo-600 px-3 py-2 rounded-md hover:bg-gray-50 transition duration-150 ease-in-out" data-action="simple-dropdown#toggle" data-simple-dropdown-target="button">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                  </svg>
                  Resources
                  <svg class="ml-1 h-4 w-4 text-gray-400 group-hover:text-indigo-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>

                <!-- Dropdown menu -->
                <div class="absolute z-10 left-0 mt-3 px-2 w-screen max-w-xs sm:px-0 hidden opacity-0 translate-y-1 z-10 transition-all duration-200" data-simple-dropdown-target="menu">
                  <div class="rounded-lg shadow-lg overflow-hidden transition-all duration-200">
                    <div class="relative grid gap-1 bg-white px-3 py-3">
                      <%= link_to help_path, class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 rounded-md dropdown-item-no-border" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Help Center
                      <% end %>
                      <%= link_to contact_path, class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 rounded-md dropdown-item-no-border" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                        Contact Us
                      <% end %>
                      <%= link_to seller_info_path, class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 rounded-md dropdown-item-no-border" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                        Sell on DigitalStore
                      <% end %>
                      <%= link_to dashboard_path, class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 rounded-md dropdown-item-no-border" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1h2a1 1 0 001-1V10m-6 4a1 1 0 001-1V3a1 1 0 00-1-1H9a1 1 0 00-1 1v6a1 1 0 001 1h2z" />
                        </svg>
                        Dashboard
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Right section with search, cart, and user account -->
          <div class="flex items-center space-x-6">
            <!-- Search -->
            <div class="relative flex-1 flex max-w-xs md:max-w-md lg:max-w-lg" data-controller="search-overlay">
              <button class="p-1 text-gray-400 hover:text-gray-500 lg:hidden" data-action="search-overlay#open">
                <span class="sr-only">Search</span>
                <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              </button>

              <!-- Desktop search input -->
              <div class="hidden lg:flex items-center relative w-full">
                <%= form_with url: products_path, method: :get, class: "relative w-full", data: { controller: "search-autocomplete" } do |f| %>
                  <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                    <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                  </div>
                  <%= f.text_field :search, class: "block w-full pl-10 pr-12 py-2 border border-gray-300 rounded-lg leading-5 bg-white placeholder-gray-500 focus:outline-none focus:placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm transition duration-150 ease-in-out", placeholder: "Search for products...", data: { search_autocomplete_target: "input", action: "input->search-autocomplete#search" } %>
                  <button type="button" class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-400 hover:text-gray-500">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </button>

                  <!-- Search suggestions dropdown -->
                  <div class="absolute z-10 mt-1 w-full bg-white shadow-lg rounded-lg ring-1 ring-black ring-opacity-5 overflow-hidden hidden" data-search-autocomplete-target="results">
                    <!-- Results will be loaded here via AJAX -->
                  </div>
                <% end %>
              </div>
            </div>

            <!-- Shopping cart -->
            <div class="relative" data-controller="cart-preview">
              <a href="/cart" class="flex items-center group" data-action="click->cart-preview#toggle mouseover->cart-preview#show mouseout->cart-preview#hide">
                <div class="relative">
                  <%= render 'shared/icon', name: "cart", size: "sm", color: "green" %>
                  <% if @cart_count && @cart_count > 0 %>
                    <span class="absolute -top-1 -right-1 flex items-center justify-center h-5 w-5 rounded-full bg-indigo-600 text-white text-xs" data-cart-counter><%= @cart_count %></span>
                  <% else %>
                    <span class="absolute -top-1 -right-1 flex items-center justify-center h-5 w-5 rounded-full bg-indigo-600 text-white text-xs hidden" data-cart-counter>0</span>
                  <% end %>
                </div>
                <span class="ml-2 text-sm font-medium text-gray-700 group-hover:text-indigo-600 hidden lg:block">Cart</span>
              </a>

              <!-- Cart preview -->
              <div class="absolute right-0 mt-3 w-80 bg-white rounded-lg shadow-lg focus:outline-none hidden opacity-0 translate-y-1 z-10 transition-all duration-200" data-cart-preview-target="preview">
                <div class="p-4">
                  <h3 class="text-sm font-semibold text-gray-900 mb-2">Your Cart</h3>
                  <% if @current_cart&.cart_items&.any? %>
                    <div class="space-y-4 max-h-72 overflow-y-auto">
                      <% @current_cart.cart_items.includes(:product).each do |item| %>
                        <div class="flex py-2">
                          <div class="flex-shrink-0 w-14 h-14 rounded bg-gray-100 overflow-hidden">
                            <% if item.product.respond_to?(:image_url) && item.product.image_url.present? %>
                              <img src="<%= item.product.image_url %>" alt="<%= item.product.name %>" class="w-full h-full object-cover">
                            <% else %>
                              <div class="w-full h-full flex items-center justify-center bg-gray-200">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                              </div>
                            <% end %>
                          </div>
                          <div class="ml-3 flex-1">
                            <div class="text-sm font-medium text-gray-900"><%= item.product.name %></div>
                            <div class="flex justify-between mt-1">
                              <div class="text-xs text-gray-500">Qty: <%= item.quantity %></div>
                              <div class="text-sm font-medium text-gray-900">$<%= number_with_precision(item.product.price * item.quantity, precision: 2) %></div>
                            </div>
                          </div>
                        </div>
                      <% end %>
                    </div>
                    <div class="mt-4 pt-4 border-t border-gray-200">
                      <div class="flex justify-between items-center">
                        <span class="text-sm font-medium text-gray-900">Subtotal</span>
                        <span class="text-sm font-bold text-indigo-600">$<%= number_with_precision(@current_cart.total, precision: 2) %></span>
                      </div>
                      <div class="mt-4 flex space-x-2">
                        <%= link_to "/cart", class: "flex-1 flex justify-center py-2 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition duration-150 ease-in-out" do %>
                          View Cart
                        <% end %>
                        <%= link_to "/checkout", class: "flex-1 flex justify-center py-2 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-indigo-800 hover:bg-indigo-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition duration-150 ease-in-out" do %>
                          Checkout
                        <% end %>
                      </div>
                    </div>
                  <% else %>
                    <div class="py-6 text-center">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mx-auto text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                      </svg>
                      <p class="mt-2 text-sm text-gray-500">Your cart is empty</p>
                      <%= link_to products_path, class: "mt-4 inline-block text-sm text-indigo-600 hover:text-indigo-500 transition duration-150 ease-in-out" do %>
                        Shop now <span aria-hidden="true">&rarr;</span>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>

            <!-- User account -->
            <% if current_user %>
              <div class="relative" data-controller="simple-dropdown">
                <button type="button" class="flex items-center focus:outline-none" data-action="simple-dropdown#toggle" data-simple-dropdown-target="button">
                  <div class="relative">
                    <% if current_user.respond_to?(:profile_picture) && current_user.profile_picture.present? %>
                      <%= image_tag current_user.profile_picture, class: "h-8 w-8 rounded-full object-cover" %>
                    <% else %>
                      <div class="h-8 w-8 rounded-full bg-indigo-500 flex items-center justify-center text-white font-medium">
                        <%= current_user.respond_to?(:first_name) ? current_user.first_name[0]&.upcase : current_user.email[0]&.upcase %>
                        <%= current_user.respond_to?(:last_name) ? current_user.last_name[0]&.upcase : '' %>
                      </div>
                    <% end %>
                    <span class="ml-2 text-sm font-medium text-gray-700 hidden lg:block">
                      <%= current_user.respond_to?(:first_name) && current_user.first_name.present? ? current_user.first_name : current_user.email.split('@').first %>
                    </span>
                  </div>
                  <svg class="ml-1 h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>

                <!-- User dropdown -->
                <div class="absolute right-0 mt-3 w-64 bg-white rounded-lg shadow-lg focus:outline-none hidden opacity-0 translate-y-1 z-10 transition-all duration-200" data-simple-dropdown-target="menu">
                  <div class="py-1">
                    <div class="px-4 py-3">
                      <div class="text-sm font-medium text-gray-900">
                        <%= current_user.respond_to?(:full_name) ? current_user.full_name : current_user.email %>
                      </div>
                      <div class="text-xs text-gray-500 mt-1">
                        <%= current_user.email %>
                      </div>
                      <div class="text-xs text-gray-500 mt-1">
                        Member since <%= current_user.created_at.strftime("%b %Y") %>
                      </div>
                    </div>
                    <%= link_to "/account", class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 rounded-md transition duration-150 ease-in-out" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      Your Account
                    <% end %>
                    <%= link_to "/account/orders", class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 rounded-md transition duration-150 ease-in-out" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                      </svg>
                      Orders
                    <% end %>
                    <%= link_to downloads_path, class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 rounded-md transition duration-150 ease-in-out" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                      </svg>
                      Downloads
                    <% end %>
                    <%= link_to "/account/wishlist", class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 rounded-md transition duration-150 ease-in-out" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                      </svg>
                      Wishlist
                    <% end %>
                    <% if current_user.respond_to?(:admin?) && current_user.admin? %>
                      <%= link_to "/admin", class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 rounded-md transition duration-150 ease-in-out" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        Admin Dashboard
                      <% end %>
                    <% end %>
                    <%= button_to destroy_user_session_path, method: :delete, class: "w-full text-left flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 rounded-md transition duration-150 ease-in-out" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                      </svg>
                      Sign Out
                    <% end %>
                  </div>
                </div>
              </div>
            <% else %>
              <div class="flex items-center space-x-2">
                <%= link_to new_user_session_path, class: "text-sm font-medium text-gray-700 hover:text-indigo-600 transition duration-150 ease-in-out" do %>
                  Sign in
                <% end %>
                <span class="hidden lg:inline-block text-gray-300">/</span>
                <%= link_to new_user_registration_path, class: "hidden lg:inline-block text-sm font-medium text-indigo-600 hover:text-indigo-700 transition duration-150 ease-in-out" do %>
                  Sign up
                <% end %>
                <%= link_to new_user_registration_path, class: "lg:hidden inline-flex items-center justify-center p-1.5 text-indigo-600 hover:text-indigo-700" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                  </svg>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Mobile menu -->
    <div class="md:hidden bg-white shadow-lg overflow-hidden transition-all duration-300 max-h-0 rounded-b-lg" data-navbar-target="mobileMenu">
      <div class="px-2 pt-2 pb-3 space-y-1">
        <%= link_to root_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50" do %>
          Home
        <% end %>
        
        <!-- Mobile accordion menus -->
        <div data-controller="accordion">
          <button class="w-full flex justify-between items-center px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50" data-action="accordion#toggle">
            <span>Products</span>
            <svg class="h-5 w-5 text-gray-500" data-accordion-target="icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          
          <div class="bg-gray-50 px-4 py-2 space-y-1 max-h-0 overflow-hidden transition-all duration-300" data-accordion-target="content">
            <%= link_to products_path, class: "block pl-3 pr-4 py-2 text-base font-medium text-gray-600 hover:text-indigo-600 hover:bg-gray-100 rounded-md" do %>
              All Products
            <% end %>
            <%= link_to categories_path, class: "block pl-3 pr-4 py-2 text-base font-medium text-gray-600 hover:text-indigo-600 hover:bg-gray-100 rounded-md" do %>
              Categories
            <% end %>
          </div>
        </div>
        
        <%= link_to about_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50" do %>
          About
        <% end %>
        
        <!-- Categories link removed from mobile menu for consistency -->
        
        <div data-controller="accordion">
          <button class="w-full flex justify-between items-center px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50" data-action="accordion#toggle">
            <span>Resources</span>
            <svg class="h-5 w-5 text-gray-500" data-accordion-target="icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          
          <div class="bg-gray-50 px-4 py-2 space-y-1 max-h-0 overflow-hidden transition-all duration-300" data-accordion-target="content">
            <%= link_to help_path, class: "block pl-3 pr-4 py-2 text-base font-medium text-gray-600 hover:text-indigo-600 hover:bg-gray-100 rounded-md" do %>
              Help Center
            <% end %>
            <%= link_to contact_path, class: "block pl-3 pr-4 py-2 text-base font-medium text-gray-600 hover:text-indigo-600 hover:bg-gray-100 rounded-md" do %>
              Contact Us
            <% end %>
            <%= link_to seller_info_path, class: "block pl-3 pr-4 py-2 text-base font-medium text-gray-600 hover:text-indigo-600 hover:bg-gray-100 rounded-md" do %>
              Sell on DigitalStore
            <% end %>
            <%= link_to dashboard_path, class: "block pl-3 pr-4 py-2 text-base font-medium text-gray-600 hover:text-indigo-600 hover:bg-gray-100 rounded-md" do %>
              Dashboard
            <% end %>
          </div>
        </div>
      </div>
      
      <div class="pt-4 pb-3 border-t border-gray-200">
        <% if current_user %>
          <div class="px-4 flex items-center">
            <div class="flex-shrink-0">
              <% if current_user.respond_to?(:profile_picture) && current_user.profile_picture.attached? %>
                <%= image_tag current_user.profile_picture, class: "h-10 w-10 rounded-full object-cover" %>
              <% else %>
                <div class="h-10 w-10 rounded-full bg-indigo-500 flex items-center justify-center text-white font-medium">
                  <%= current_user.respond_to?(:first_name) ? current_user.first_name[0]&.upcase : current_user.email[0]&.upcase %>
                  <%= current_user.respond_to?(:last_name) ? current_user.last_name[0]&.upcase : '' %>
                </div>
              <% end %>
            </div>
            <div class="ml-3">
              <div class="text-base font-medium text-gray-800">
                <%= current_user.respond_to?(:full_name) ? current_user.full_name : current_user.email %>
              </div>
              <div class="text-sm font-medium text-gray-500"><%= current_user.email %></div>
            </div>
          </div>
          <div class="mt-3 px-2 space-y-1">
            <%= link_to "/account", class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 transition duration-150 ease-in-out" do %>
              Your Account
            <% end %>
            <%= link_to "/account/orders", class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 transition duration-150 ease-in-out" do %>
              Orders
            <% end %>
            <%= link_to downloads_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 transition duration-150 ease-in-out" do %>
              Downloads
            <% end %>
            <%= link_to "/account/wishlist", class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 transition duration-150 ease-in-out" do %>
              Wishlist
            <% end %>
            <% if current_user.respond_to?(:admin?) && current_user.admin? %>
              <%= link_to "/admin", class: "block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 transition duration-150 ease-in-out" do %>
                Admin Dashboard
              <% end %>
            <% end %>
            <%= button_to destroy_user_session_path, method: :delete, class: "w-full block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-indigo-600 hover:bg-gray-50 text-left transition duration-150 ease-in-out" do %>
              Sign Out
            <% end %>
          </div>
        <% else %>
          <div class="px-4 py-2 grid grid-cols-2 gap-4">
            <%= link_to new_user_session_path, class: "block text-center px-4 py-2 border border-transparent rounded-lg shadow-sm text-base font-medium text-indigo-600 bg-gray-50 hover:bg-gray-100 transition duration-150 ease-in-out" do %>
              Sign in
            <% end %>
            <%= link_to new_user_registration_path, class: "block text-center px-4 py-2 border border-transparent rounded-lg shadow-sm text-base font-medium text-white bg-indigo-600 hover:bg-indigo-700 transition duration-150 ease-in-out" do %>
              Sign up
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Full-screen search overlay for mobile -->
    <div class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden transition-opacity duration-300" data-controller="search-overlay" data-search-overlay-target="overlay">
      <div class="h-full flex flex-col bg-white">
        <div class="p-4 flex items-center border-b border-gray-200">
          <button type="button" class="mr-2 text-gray-400 hover:text-gray-500" data-action="search-overlay#close">
            <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
          <%= form_with url: products_path, method: :get, class: "w-full relative" do |f| %>
            <%= f.text_field :search, class: "block w-full border-0 text-gray-900 placeholder-gray-500 focus:outline-none focus:placeholder-gray-400 focus:ring-0 text-base", placeholder: "Search for products...", data: { controller: "search-autocomplete", search_autocomplete_target: "input", action: "input->search-autocomplete#search" } %>
            
            <!-- Search results area -->
            <div class="mt-2 divide-y divide-gray-200 max-h-full overflow-y-auto" data-search-autocomplete-target="results">
              <!-- Results will be loaded here via AJAX -->
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</header>
