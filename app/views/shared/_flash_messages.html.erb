<%# Flash Messages Container %>
<div class="fixed inset-x-0 bottom-0 z-50 flex flex-col items-center space-y-4 pointer-events-none sm:items-end sm:pr-6 sm:pb-6" 
     data-controller="flash-messages"
     aria-live="polite"
     aria-atomic="true">
  
  <%# Iterate through flash messages %>
  <% 
    # Skip metadata key from rendering
    flash_entries = flash.to_h.reject { |k, _| k.to_s == '_flash_metadata' }
    
    flash_entries.each do |type, message| %>
    <% 
      # Get any metadata for this flash message
      metadata = flash[:_flash_metadata].try(:[], type) || {}
      custom_timeout = metadata[:timeout]
      
      # Map flash types to visual styles
      flash_classes = case type.to_s
        when "notice", "success"
          "bg-green-50 border-green-400 text-green-800"
        when "alert", "error", "danger"
          "bg-red-50 border-red-400 text-red-800"
        when "warning"
          "bg-amber-50 border-amber-400 text-amber-800"
        when "info"
          "bg-blue-50 border-blue-400 text-blue-800"
        else
          "bg-gray-50 border-gray-400 text-gray-800"
        end

      # Map flash types to icons
      icon_classes = case type.to_s
        when "notice", "success"
          "text-green-500"
        when "alert", "error", "danger"
          "text-red-500"
        when "warning"
          "text-amber-500"
        when "info"
          "text-blue-500"
        else
          "text-gray-500"
        end
    %>
    
    <%# Individual Flash Message %>
    <div class="w-full max-w-sm overflow-hidden border rounded-lg shadow-lg pointer-events-auto sm:max-w-md <%= flash_classes %> border-l-4"
         data-flash-messages-target="message"
         data-flash-messages-duration="<%= custom_timeout || (type.to_s == 'error' || type.to_s == 'danger' ? 8000 : 5000) %>"
         data-transition-enter-from="opacity-0 translate-y-2 sm:translate-y-0 sm:translate-x-2"
         data-transition-enter-to="opacity-100 translate-y-0 sm:translate-x-0"
         data-transition-leave-from="opacity-100 translate-y-0 sm:translate-x-0"
         data-transition-leave-to="opacity-0 translate-y-2 sm:translate-y-0 sm:translate-x-2"
         role="alert"
         aria-labelledby="flash-message-<%= type %>">
      <div class="p-4">
        <div class="flex items-start">
          <div class="flex-shrink-0">
            <% case type.to_s %>
            <% when "notice", "success" %>
              <svg class="w-5 h-5 <%= icon_classes %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
            <% when "alert", "error", "danger" %>
              <svg class="w-5 h-5 <%= icon_classes %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
            <% when "warning" %>
              <svg class="w-5 h-5 <%= icon_classes %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
            <% when "info" %>
              <svg class="w-5 h-5 <%= icon_classes %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
              </svg>
            <% else %>
              <svg class="w-5 h-5 <%= icon_classes %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
              </svg>
            <% end %>
          </div>
          <div class="ml-3 w-0 flex-1 pt-0.5">
            <p id="flash-message-<%= type %>" class="text-sm font-medium"><%= sanitize(message) %></p>
          </div>
          <div class="flex flex-shrink-0 ml-4">
            <button class="inline-flex text-gray-500 transition duration-150 ease-in-out focus:outline-none focus:text-gray-600 hover:text-gray-700"
                    data-action="click->flash-messages#close"
                    aria-label="Dismiss message">
              <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
