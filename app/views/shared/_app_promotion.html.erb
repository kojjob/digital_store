<section class="py-16 bg-gradient-to-r from-purple-700 to-indigo-800 text-white">
  <div class="container mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center">
      <div class="md:w-1/2 mb-10 md:mb-0">
        <h2 class="text-3xl font-bold mb-4">Shop On The Go</h2>
        <p class="text-xl mb-8 text-indigo-100">Download our mobile app for a seamless shopping experience with real-time notifications and exclusive mobile-only deals.</p>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#" class="flex items-center bg-black rounded-lg px-4 py-2 hover:bg-gray-900 transition-colors">
            <svg class="w-7 h-7 mr-3" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.566 11.991c-.008-1.569.64-3.182 1.937-4.358-1.16-1.722-2.94-2.714-4.775-2.714-2.007-.211-3.954 1.21-4.971 1.21-1.048 0-2.629-1.18-4.335-1.146-2.229.035-4.295 1.338-5.453 3.4-2.352 4.133-.599 10.214 1.658 13.557 1.13 1.641 2.46 3.464 4.207 3.399 1.7-.072 2.335-1.09 4.384-1.09 2.024 0 2.618 1.09 4.385 1.049 1.821-.028 2.968-1.628 4.07-3.281.844-1.241 1.458-2.596 1.748-4.021-2.103-.824-3.578-2.963-3.855-5.005zM14.914 3.108c.991-1.254 1.495-2.851 1.32-4.448-1.598.128-3.086.912-4.169 2.157-.988 1.195-1.569 2.821-1.393 4.471 1.66.035 3.203-.788 4.242-2.18z"></path>
            </svg>
            <div>
              <div class="text-xs">Download on the</div>
              <div class="text-xl font-semibold font-sans -mt-1">App Store</div>
            </div>
          </a>
          
          <a href="#" class="flex items-center bg-black rounded-lg px-4 py-2 hover:bg-gray-900 transition-colors">
            <svg class="w-7 h-7 mr-3" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3.609 1.814L13.792 12 3.609 22.186c-.181.181-.29.423-.29.679V1.135c0 .256.109.498.29.679zm1.856-.759l10.661 7.292-2.988 2.988-7.673-10.28zm13.143 8.051L15.357 12l3.252 3.252L6.464 22.944l12.144-13.838zm-2.482-7.292l7.673 10.28-2.988-2.988-4.685-7.292z"></path>
            </svg>
            <div>
              <div class="text-xs">GET IT ON</div>
              <div class="text-xl font-semibold font-sans -mt-1">Google Play</div>
            </div>
          </a>
        </div>
        
        <div class="mt-6 flex items-center">
          <div class="flex -space-x-2">
            <% 5.times do |i| %>
              <div class="w-8 h-8 rounded-full border-2 border-indigo-800 bg-indigo-600 overflow-hidden">
                <!-- This would be user avatars -->
              </div>
            <% end %>
          </div>
          <div class="ml-4 text-sm">
            <strong>4.8★</strong> from over 10,000+ reviews
          </div>
        </div>
      </div>
      
      <div class="md:w-1/2 flex justify-center">
        <div class="relative w-64 h-96">
          <!-- Phone mockup with app screenshot -->
          <div class="absolute w-full h-full rounded-3xl border-8 border-gray-800 bg-white overflow-hidden shadow-2xl z-10">
            <!-- App screenshot would go here -->
            <div class="absolute w-1/2 h-6 top-0 left-1/4 bg-gray-800 rounded-b-lg"></div>
          </div>
          <div class="absolute w-full h-full rounded-3xl border-8 border-indigo-600 bg-white overflow-hidden shadow-2xl transform rotate-6 translate-x-4 -translate-y-4">
            <!-- Second phone for visual effect -->
          </div>
        </div>
      </div>
    </div>
  </div>
</section>