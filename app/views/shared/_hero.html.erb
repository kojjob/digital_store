  </div>
  
  <!-- Hero Content - Left Side -->
  <div class="container mx-auto px-6 py-20 md:py-32 relative z-10 flex flex-col md:flex-row items-center">
    <div class="md:w-1/2 md:pr-12 mb-12 md:mb-0">
      <!-- Small Accent -->
      <div class="inline-block relative mb-4 animate-fade-in-down" data-hero-animation-target="subtitle">
        <div class="px-3 py-1 text-xs font-semibold tracking-wider text-white bg-white/20 rounded-full backdrop-blur-sm">
          INNOVATING AFRICAN COMMERCE
        </div>
      </div>
      
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight tracking-tight animate-fade-in" data-hero-animation-target="title">
        <span class="block">The Digital <span class="relative">
          Marketplace
          <svg class="absolute bottom-1 left-0 w-full h-2 text-yellow-400 opacity-70" viewBox="0 0 200 8" preserveAspectRatio="none">
            <path d="M0,5 Q40,2 80,5 T160,5 T200,5" stroke="currentColor" stroke-width="4" fill="none"/>
          </svg>
        </span></span>
        <span class="block mt-1">for Africa's Future</span>
      </h1>
      
      <p class="text-xl md:text-2xl text-indigo-100 mb-10 max-w-xl animate-fade-in-up" data-hero-animation-target="description">
        Connect, sell, and shop across Ghana and Nigeria with our cutting-edge digital platform designed for Africa's unique markets.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up" data-hero-animation-target="buttons">
        <a href="#services" class="btn-hero-primary group">
          <span class="relative z-10">Explore Our Platform</span>
          <span class="absolute inset-0 w-full h-full rounded-md bg-gradient-to-r from-indigo-800 to-purple-700 group-hover:from-indigo-700 group-hover:to-purple-600 transition-colors duration-300 z-0"></span>
        </a>
        <%= link_to become_a_seller_path, class: "btn-hero-secondary group" do %>
          <span>Become a Seller</span>
          <svg class="h-5 w-5 ml-2 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        <% end %>
      </div>
      
      <!-- Trust Indicators -->
      <div class="mt-12 flex items-center space-x-8 text-indigo-200 animate-fade-in-up delay-300" data-hero-animation-target="trust">
        <div class="flex items-center">
          <svg class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span>Secure Payments</span>
        </div>
        <div class="flex items-center">
          <svg class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
            <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd" />
          </svg>
          <span>Verified Sellers</span>
        </div>
      </div>
    </div>
    
    <!-- Hero Image - Right Side -->
    <div class="md:w-1/2 relative">
      <!-- Floating Product Cards with Animation -->
      <div class="relative w-full h-96 md:h-[32rem]">
        <!-- Main Featured Product -->
        <div class="absolute top-0 right-0 w-72 md:w-80 bg-white rounded-xl shadow-2xl overflow-hidden transform rotate-3 translate-y-8 animate-float-slow z-30">
          <div class="relative aspect-w-4 aspect-h-3 bg-gray-100">
            <!-- Sample product image - replace with actual image -->
            <img src="/api/placeholder/400/300" alt="Featured product" class="object-cover" />
            <div class="absolute top-3 right-3 bg-red-500 text-white text-xs font-bold px-2 py-1 rounded-full">
              -25%
            </div>
          </div>
          <div class="p-4">
            <h3 class="font-bold text-gray-900 truncate">Premium Bluetooth Speaker</h3>
            <div class="flex items-center justify-between mt-2">
              <div>
                <span class="text-gray-400 line-through text-sm">$120</span>
                <span class="text-gray-900 font-bold ml-1">$89.99</span>
              </div>
              <div class="flex">
                <span class="text-yellow-400">★★★★</span><span class="text-gray-300">★</span>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Secondary Product Cards -->
        <div class="absolute bottom-10 right-24 w-64 bg-white rounded-xl shadow-xl overflow-hidden transform -rotate-6 translate-x-12 animate-float z-10">
          <div class="relative aspect-w-1 aspect-h-1 bg-gray-100">
            <img src="/api/placeholder/300/300" alt="Another product" class="object-cover" />
          </div>
          <div class="p-3">
            <h3 class="font-bold text-gray-900 text-sm truncate">Wireless Earbuds</h3>
            <div class="flex items-center justify-between mt-1">
              <span class="text-gray-900 font-bold text-sm">$45.99</span>
              <div class="flex">
                <span class="text-yellow-400 text-sm">★★★★★</span>
              </div>
            </div>
          </div>
        </div>
        
        <div class="absolute top-10 left-0 w-60 bg-white rounded-xl shadow-xl overflow-hidden transform -rotate-3 -translate-x-5 animate-float-delay z-20">
          <div class="relative aspect-w-1 aspect-h-1 bg-gray-100">
            <img src="/api/placeholder/300/300" alt="Third product" class="object-cover" />
          </div>
          <div class="p-3">
            <h3 class="font-bold text-gray-900 text-sm truncate">Smart Watch</h3>
            <div class="flex items-center justify-between mt-1">
              <span class="text-gray-900 font-bold text-sm">$79.99</span>
              <div class="flex">
                <span class="text-yellow-400 text-sm">★★★★</span><span class="text-gray-300 text-sm">★</span>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Decorative Elements -->
        <div class="absolute -bottom-6 -left-6 w-24 h-24 bg-yellow-400 rounded-full opacity-60 animate-pulse"></div>
        <div class="absolute top-1/4 right-0 w-12 h-12 bg-purple-500 rounded-full opacity-50 animate-ping-slow"></div>
        
        <!-- Shopping Icons -->
        <div class="absolute bottom-0 left-1/4 w-10 h-10 rounded-full bg-white shadow-lg flex items-center justify-center animate-bounce-slow">
          <svg class="h-5 w-5 text-indigo-600" viewBox="0 0 20 20" fill="currentColor">
            <path d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3zM16 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM6.5 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3z" />
          </svg>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Bottom Wave Separator -->
  <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none">
    <svg class="relative block w-full h-12 md:h-16" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
      <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" class="fill-white"></path>
    </svg>
  </div>
</section>

<!-- Custom CSS to add to your application.tailwind.css file -->
<style>
  @keyframes float {
    0% {
      transform: translateY(0px) rotate(3deg);
    }
    50% {
      transform: translateY(-15px) rotate(5deg);
    }
    100% {
      transform: translateY(0px) rotate(3deg);
    }
  }
  
  @keyframes float-delay {
    0% {
      transform: translateY(0px) rotate(-3deg);
    }
    50% {
      transform: translateY(-20px) rotate(-1deg);
    }
    100% {
      transform: translateY(0px) rotate(-3deg);
    }
  }
  
  @keyframes float-slow {
    0% {
      transform: translateY(8px) rotate(3deg);
    }
    50% {
      transform: translateY(-8px) rotate(4deg);
    }
    100% {
      transform: translateY(8px) rotate(3deg);
    }
  }
  
  @keyframes ping-slow {
    0% {
      transform: scale(1);
      opacity: 0.5;
    }
    50% {
      transform: scale(1.2);
      opacity: 0.3;
    }
    100% {
      transform: scale(1);
      opacity: 0.5;
    }
  }
  
  @keyframes bounce-slow {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-15px);
    }
  }
  
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  .animate-float-delay {
    animation: float-delay 7s ease-in-out infinite;
  }
  
  .animate-float-slow {
    animation: float-slow 8s ease-in-out infinite;
  }
  
  .animate-ping-slow {
    animation: ping-slow 3s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
  
  .animate-bounce-slow {
    animation: bounce-slow 3s infinite;
  }
  
  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }
  
  .animate-fade-in-up {
    animation: fadeInUp 1s ease-out forwards;
  }
  
  .animate-fade-in-down {
    animation: fadeInDown 0.7s ease-out forwards;
  }
  
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .delay-300 {
    animation-delay: 300ms;
  }
  
  .btn-hero-primary {
    @apply relative flex items-center justify-center px-6 py-4 text-base md:text-lg font-semibold text-white rounded-md shadow-lg overflow-hidden;
  }
  
  .btn-hero-secondary {
