<script>
  // app/javascript/controllers/hero_animation_controller.js
  import { Controller } from "@hotwired/stimulus"
  
  export default class extends Controller {
    static targets = ["container", "title", "subtitle", "description", "buttons", "trust"]
    
    connect() {
      // Controller now handles animations via CSS classes
      // You could add additional JS animations here if needed
      
      // Optional: Add scroll-based parallax effect
      window.addEventListener('scroll', this.handleScroll.bind(this))
    }
    
    disconnect() {
      window.removeEventListener('scroll', this.handleScroll.bind(this))
    }
    
    handleScroll() {
      // Simple parallax effect on scroll
      const scrollPosition = window.scrollY
      
      if (scrollPosition < 600) {
        const translateY = scrollPosition * 0.2
        this.containerTarget.style.backgroundPosition = `center ${translateY}px`
      }
    }
  }
</script>