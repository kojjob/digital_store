<section class="relative bg-gradient-to-r from-indigo-600 to-purple-700 text-white overflow-hidden"
         data-controller="animation"
         data-animation-target="element"
         data-animation-class="opacity-100 translate-y-0"
         data-animation-initial-class="opacity-0 translate-y-4">
  
  <!-- Decorative background elements -->
  <div class="absolute top-0 left-0 w-full h-full">
    <div class="absolute w-64 h-64 rounded-full bg-indigo-500 opacity-20 -top-10 -left-10"></div>
    <div class="absolute w-96 h-96 rounded-full bg-purple-500 opacity-10 bottom-0 right-0"></div>
  </div>
  
  <div class="container mx-auto px-6 py-24 md:py-32 relative z-10">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-6xl font-extrabold mb-6 transition-all duration-700"
          data-animation-target="element"
          data-animation-delay="200">
        Innovative Tech Solutions for Africa's Digital Future
      </h1>
      
      <p class="text-xl md:text-2xl mb-10 text-indigo-100 transition-all duration-700"
         data-animation-target="element"
         data-animation-delay="400">
        Connecting Ghana and Nigeria with cutting-edge digital marketplace technology
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 transition-all duration-700"
           data-animation-target="element"
           data-animation-delay="600">
        <a href="#services" class="btn-primary">
          Explore Our Services
        </a>
        <%= link_to "Become a Seller", become_a_seller_path, class: "btn-secondary" %>
      </div>
    </div>
  </div>
</section>