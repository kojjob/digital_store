<section class="py-20 bg-gray-50" data-controller="product-carousel">
  <div class="container mx-auto px-6">
    <div class="flex justify-between items-center mb-12">
      <h2 class="text-3xl font-bold">Featured Products</h2>
      
      <div class="flex space-x-2">
        <button class="p-2 rounded-full bg-white shadow-sm border border-gray-200 text-indigo-700 hover:bg-indigo-50"
                data-action="product-carousel#previous">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
        </button>
        <button class="p-2 rounded-full bg-white shadow-sm border border-gray-200 text-indigo-700 hover:bg-indigo-50"
                data-action="product-carousel#next">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
          </svg>
        </button>
      </div>
    </div>
    
    <div class="relative overflow-hidden" data-product-carousel-target="container">
      <div class="flex space-x-6 transition-transform duration-500" data-product-carousel-target="track">
        <% @featured_products&.each do |product| %>
          <div class="flex-shrink-0 w-64 md:w-72">
            <div class="bg-white rounded-lg shadow-sm overflow-hidden hover:shadow-md transition-shadow duration-300">
              <div class="h-48 bg-gray-200 relative">
                <% 
                  # Check if product has any product_images
                  has_image = product.product_images.present? && 
                             # If using Active Storage for product_images
                             (defined?(product.product_images.first&.image&.attached?) ? 
                              product.product_images.first&.image&.attached? : 
                              # Fallback if image field is unknown
                              product.product_images.exists?)
                %>
                
                <% if has_image %>
                  <% 
                    # Get the first image - adapt this to match your model structure
                    image = if defined?(product.product_images.first&.image)
                              product.product_images.first.image
                            else
                              # Fallback for direct Active Storage on ProductImage
                              product.product_images.first
                            end
                  %>
                  <%= image_tag url_for(image), class: "w-full h-full object-cover" %>
                <% else %>
                  <div class="flex items-center justify-center h-full text-gray-400">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                <% end %>
                <% if product.discounted_price && product.discounted_price < product.price %>
                  <div class="absolute top-2 right-2 bg-red-500 text-white text-xs font-bold px-2 py-1 rounded">
                    <%= number_to_percentage((1 - product.discounted_price / product.price) * 100, precision: 0) %> OFF
                  </div>
                <% end %>
              </div>
              <div class="p-4">
                <p class="text-sm text-indigo-600 font-medium mb-1"><%= product.category.name %></p>
                <h3 class="font-bold text-gray-900 mb-2 truncate"><%= product.name %></h3>
                <div class="flex items-center justify-between">
                  <div>
                    <% if product.discounted_price && product.discounted_price < product.price %>
                      <span class="text-gray-400 line-through text-sm"><%= product.currency %><%= product.price %></span>
                      <span class="text-gray-900 font-bold ml-1"><%= product.currency %><%= product.discounted_price %></span>
                    <% else %>
                      <span class="text-gray-900 font-bold"><%= product.currency %><%= product.price %></span>
                    <% end %>
                  </div>
                  <div class="text-xs px-2 py-1 bg-gray-100 rounded text-gray-800">
                    <%= product.country_of_origin %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
    
    <div class="mt-8 text-center">
      <a href="/products" class="text-indigo-600 font-medium hover:text-indigo-800 flex items-center justify-center">
        View all products
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-1" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
</section>