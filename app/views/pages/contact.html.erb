<div class="bg-gray-50 min-h-screen pt-4">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
      <h1 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">Contact Us</h1>
      <p class="mt-4 text-lg text-gray-500 max-w-2xl mx-auto">
        Have questions or need assistance? We're here to help. Fill out the form below or use our contact information to get in touch with our team.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
      <!-- Contact Form -->
      <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <style>
          #contact-form input:not([type="checkbox"]), 
          #contact-form textarea, 
          #contact-form select {
            border: 2px solid #4f46e5 !important;
            background-color: #ffffff !important;
            padding: 0.75rem !important; 
            color: #000000 !important;
            opacity: 1 !important;
            box-shadow: 0 2px 4px rgba(79, 70, 229, 0.1) !important;
            -webkit-box-shadow: 0 0 0px 1000px #ffffff inset !important;
            -webkit-text-fill-color: #000000 !important;
            font-size: 16px !important;
          }
          #contact-form input::placeholder, 
          #contact-form textarea::placeholder {
            color: #718096 !important;
            opacity: 1 !important;
            -webkit-text-fill-color: #718096 !important;
          }
          #contact-form .checkbox-container {
            border: 2px solid #4f46e5 !important;
            background-color: #ffffff !important;
          }
        </style>
        <div class="px-6 py-8">
          <h2 class="text-xl font-bold text-gray-900 mb-6">Send Us a Message</h2>
          
          <%= form_with(url: contact_submit_path, method: :post, local: true, class: "space-y-6", id: "contact-form", data: { controller: "contact-form", action: "submit->contact-form#submit" }) do |form| %>
            
            <% if flash[:notice] %>
              <div class="rounded-md bg-green-50 p-4 mb-6">
                <div class="flex">
                  <div class="flex-shrink-0">
                    <%= render 'shared/icon', name: "check", size: "sm", color: "green" %>
                  </div>
                  <div class="ml-3">
                    <p class="text-sm font-medium text-green-800"><%= flash[:notice] %></p>
                  </div>
                </div>
              </div>
            <% end %>
            
            <% if flash[:alert] %>
              <div class="rounded-md bg-red-50 p-4 mb-6">
                <div class="flex">
                  <div class="flex-shrink-0">
                    <%= render 'shared/icon', name: "alert", size: "sm", color: "red" %>
                  </div>
                  <div class="ml-3">
                    <p class="text-sm font-medium text-red-800"><%= flash[:alert] %></p>
                  </div>
                </div>
              </div>
            <% end %>
            
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700">Name</label>
              <div class="mt-1">
                <%= form.text_field :name, id: "name", class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-2 border-gray-400 bg-white rounded-md p-3", required: true, placeholder: "Your name" %>
              </div>
            </div>
            
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700">Email</label>
              <div class="mt-1">
                <%= form.email_field :email, id: "email", class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-2 border-gray-400 bg-white rounded-md p-3", required: true, placeholder: "your.email@example.com" %>
              </div>
            </div>
            
            <div>
              <label for="subject" class="block text-sm font-medium text-gray-700">Subject</label>
              <div class="mt-1">
                <%= form.select :subject, [
                  ["General Inquiry", "general"],
                  ["Product Support", "product"],
                  ["Order Issue", "order"],
                  ["Technical Support", "technical"],
                  ["Feedback", "feedback"],
                  ["Other", "other"]
                ], { include_blank: "Select a subject" }, { class: "mt-1 block w-full pl-3 pr-10 py-3 text-base border-2 border-gray-400 bg-white focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md appearance-none", required: true } %>
              </div>
            </div>
            
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700">Message</label>
              <div class="mt-1">
                <%= form.text_area :message, id: "message", rows: 5, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-2 border-gray-400 bg-white rounded-md p-3", required: true, placeholder: "How can we help you?" %>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="flex items-center h-5 checkbox-container p-1 bg-white border border-indigo-500 rounded">
                <%= form.check_box :terms, id: "terms", class: "focus:ring-indigo-500 h-5 w-5 text-indigo-600 border border-indigo-500 rounded appearance-none checked:bg-indigo-600 checked:border-transparent", required: true %>
              </div>
              <div class="ml-3 text-sm">
                <label for="terms" class="font-medium text-gray-700">I agree to the privacy policy</label>
                <p class="text-gray-500">By submitting this form, you agree that we may process your information in accordance with our privacy policy.</p>
              </div>
            </div>
            
            <div class="text-right">
              <%= form.submit "Send Message", class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500", data: { disable_with: "Sending..." } %>
            </div>
          <% end %>
        </div>
      </div>
      
      <!-- Contact Information -->
      <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <div class="px-6 py-8">
          <h2 class="text-xl font-bold text-gray-900 mb-6">Contact Information</h2>
          
          <div class="space-y-6">
            <div class="flex items-start">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-12 w-12 rounded-md bg-indigo-100 text-indigo-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
              </div>
              <div class="ml-4">
                <h3 class="text-lg font-medium text-gray-900">Phone</h3>
                <p class="mt-2 text-base text-gray-500">
                  <a href="tel:+11234567890" class="hover:text-indigo-600">+1 (123) 456-7890</a>
                </p>
                <p class="mt-1 text-sm text-gray-500">
                  Monday-Friday, 9am-6pm EST
                </p>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-12 w-12 rounded-md bg-indigo-100 text-indigo-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
              </div>
              <div class="ml-4">
                <h3 class="text-lg font-medium text-gray-900">Email</h3>
                <p class="mt-2 text-base text-gray-500">
                  <a href="mailto:support@digitalstore.com" class="hover:text-indigo-600">support@digitalstore.com</a>
                </p>
                <p class="mt-1 text-sm text-gray-500">
                  We aim to respond within 24 hours
                </p>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-12 w-12 rounded-md bg-indigo-100 text-indigo-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
              </div>
              <div class="ml-4">
                <h3 class="text-lg font-medium text-gray-900">Office Address</h3>
                <p class="mt-2 text-base text-gray-500">
                  15 Independence Avenue<br>
                  Cantonments<br>
                  Accra, Ghana
                </p>
              </div>
            </div>
          </div>
          
          <div class="mt-10">
            <h3 class="text-lg font-medium text-gray-900 mb-4">Connect With Us</h3>
            <div class="flex space-x-4">
              <a href="#" class="text-gray-400 hover:text-gray-500">
                <span class="sr-only">Facebook</span>
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
                </svg>
              </a>
              
              <a href="#" class="text-gray-400 hover:text-gray-500">
                <span class="sr-only">Instagram</span>
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
                </svg>
              </a>
              
              <a href="#" class="text-gray-400 hover:text-gray-500">
                <span class="sr-only">Twitter</span>
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84" />
                </svg>
              </a>
              
              <a href="#" class="text-gray-400 hover:text-gray-500">
                <span class="sr-only">LinkedIn</span>
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- FAQ Section -->
    <div class="mt-10 mb-16">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-gray-900">Frequently Asked Questions</h2>
        <p class="mt-4 text-lg text-gray-500 max-w-2xl mx-auto">
          Find quick answers to common questions about our products and services.
        </p>
      </div>
      
      <div class="max-w-3xl mx-auto bg-white rounded-lg shadow-md overflow-hidden">
        <dl class="divide-y divide-gray-200" data-controller="accordion">
          <!-- FAQ Item 1 -->
          <div class="px-6 py-4" data-accordion-target="item" data-index="0">
            <dt class="text-lg">
              <button class="group text-left w-full flex justify-between items-center focus:outline-none" data-action="click->accordion#toggle">
                <span class="font-medium text-gray-900">How long does shipping take?</span>
                <span class="ml-6 flex-shrink-0" data-accordion-target="icon">
                  <svg class="h-5 w-5 text-gray-400 group-hover:text-gray-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </span>
              </button>
            </dt>
            <dd class="mt-4 pr-12 overflow-hidden transition-all duration-300 ease-in-out" style="max-height: 0px;" data-accordion-target="content">
              <p class="text-base text-gray-500">
                For digital products, delivery is instant after payment. For physical items, shipping typically takes 3-5 business days for domestic orders and 7-14 business days for international orders.
              </p>
            </dd>
          </div>
          
          <!-- FAQ Item 2 -->
          <div class="px-6 py-4" data-accordion-target="item" data-index="1">
            <dt class="text-lg">
              <button class="group text-left w-full flex justify-between items-center focus:outline-none" data-action="click->accordion#toggle">
                <span class="font-medium text-gray-900">What is your return policy?</span>
                <span class="ml-6 flex-shrink-0" data-accordion-target="icon">
                  <svg class="h-5 w-5 text-gray-400 group-hover:text-gray-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </span>
              </button>
            </dt>
            <dd class="mt-4 pr-12 overflow-hidden transition-all duration-300 ease-in-out" style="max-height: 0px;" data-accordion-target="content">
              <p class="text-base text-gray-500">
                We offer a 30-day money-back guarantee for most of our products. If you're not satisfied with your purchase, please contact our support team to initiate a return process. Please note that custom or personalized items may not be eligible for return.
              </p>
            </dd>
          </div>
          
          <!-- FAQ Item 3 -->
          <div class="px-6 py-4" data-accordion-target="item" data-index="2">
            <dt class="text-lg">
              <button class="group text-left w-full flex justify-between items-center focus:outline-none" data-action="click->accordion#toggle">
                <span class="font-medium text-gray-900">Do you offer bulk discounts?</span>
                <span class="ml-6 flex-shrink-0" data-accordion-target="icon">
                  <svg class="h-5 w-5 text-gray-400 group-hover:text-gray-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </span>
              </button>
            </dt>
            <dd class="mt-4 pr-12 overflow-hidden transition-all duration-300 ease-in-out" style="max-height: 0px;" data-accordion-target="content">
              <p class="text-base text-gray-500">
                Yes, we offer discounts for bulk purchases. The discount rate depends on the quantity and type of products. Please contact our sales team at sales@digitalstore.com for a customized quote based on your specific requirements.
              </p>
            </dd>
          </div>
          
          <!-- FAQ Item 4 -->
          <div class="px-6 py-4" data-accordion-target="item" data-index="3">
            <dt class="text-lg">
              <button class="group text-left w-full flex justify-between items-center focus:outline-none" data-action="click->accordion#toggle">
                <span class="font-medium text-gray-900">How can I track my order?</span>
                <span class="ml-6 flex-shrink-0" data-accordion-target="icon">
                  <svg class="h-5 w-5 text-gray-400 group-hover:text-gray-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </span>
              </button>
            </dt>
            <dd class="mt-4 pr-12 overflow-hidden transition-all duration-300 ease-in-out" style="max-height: 0px;" data-accordion-target="content">
              <p class="text-base text-gray-500">
                Once your order is shipped, you'll receive a confirmation email with a tracking number. You can use this tracking number on our website under "Order Tracking" or directly on the carrier's website. You can also check the status of your order in your account dashboard.
              </p>
            </dd>
          </div>
          
          <!-- FAQ Item 5 -->
          <div class="px-6 py-4" data-accordion-target="item" data-index="4">
            <dt class="text-lg">
              <button class="group text-left w-full flex justify-between items-center focus:outline-none" data-action="click->accordion#toggle">
                <span class="font-medium text-gray-900">Do you ship internationally?</span>
                <span class="ml-6 flex-shrink-0" data-accordion-target="icon">
                  <svg class="h-5 w-5 text-gray-400 group-hover:text-gray-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </span>
              </button>
            </dt>
            <dd class="mt-4 pr-12 overflow-hidden transition-all duration-300 ease-in-out" style="max-height: 0px;" data-accordion-target="content">
              <p class="text-base text-gray-500">
                Yes, we ship to most countries worldwide. International shipping rates and delivery times vary depending on the destination. Please note that customers are responsible for any customs duties, taxes, or import fees that may apply to international orders.
              </p>
            </dd>
          </div>
        </dl>
      </div>
    </div>
    
    <!-- Map Section -->
    <div class="mt-12 mb-16 bg-white rounded-lg shadow-md overflow-hidden">
      <div class="px-6 py-6 md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
          <h2 class="text-xl font-bold text-gray-900">Visit Our Ghana Office</h2>
          <p class="mt-1 text-sm text-gray-500">
            We're located in the heart of Accra's business district.
          </p>
        </div>
      </div>
      <div class="h-96 w-full">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d254222.31206183518!2d-0.266994!3d5.591787499999999!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xfdf9084b2b7a773%3A0xbed14ed8650e2dd3!2sAccra%2C%20Ghana!5e0!3m2!1sen!2sus!4v1711455362865!5m2!1sen!2sus"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Digital Store Ghana Office Location"
          class="border-0"
        ></iframe>
      </div>
    </div>
  </div>
</div>

<% content_for :page_scripts do %>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Debug and force form inputs to be visible
    const inputs = document.querySelectorAll('input, textarea, select');
    inputs.forEach(input => {
      input.style.border = '2px solid #4f46e5';
      input.style.backgroundColor = '#ffffff';
      input.style.padding = '0.75rem';
      input.style.color = '#000000';
      input.style.opacity = '1';
      console.log('Applying direct styles to input:', input);
    });
    if (typeof window.Stimulus !== 'undefined') {
      // Make sure the accordion controller is registered
      console.log('Contact page loaded - accordion controller should be applied');
      
      // Contact form controller
      window.Stimulus.register('contact-form', class extends window.Stimulus.Controller {
        connect() {
          console.log('Contact form controller connected');
        }
        
        submit(event) {
          // Optional: Add client-side validation or form handling logic here
          // You can prevent the default form submission and handle it via AJAX if desired
          
          // Example of form validation:
          const form = event.target;
          const nameField = form.querySelector('#name');
          const emailField = form.querySelector('#email');
          const messageField = form.querySelector('#message');
          const termsCheckbox = form.querySelector('#terms');
          
          let valid = true;
          
          if (!nameField.value.trim()) {
            nameField.classList.add('border-red-500');
            valid = false;
          } else {
            nameField.classList.remove('border-red-500');
          }
          
          if (!emailField.value.trim() || !this.validateEmail(emailField.value)) {
            emailField.classList.add('border-red-500');
            valid = false;
          } else {
            emailField.classList.remove('border-red-500');
          }
          
          if (!messageField.value.trim()) {
            messageField.classList.add('border-red-500');
            valid = false;
          } else {
            messageField.classList.remove('border-red-500');
          }
          
          if (!termsCheckbox.checked) {
            termsCheckbox.closest('div').classList.add('border-red-500');
            valid = false;
          } else {
            termsCheckbox.closest('div').classList.remove('border-red-500');
          }
          
          if (!valid) {
            event.preventDefault();
          }
        }
        
        validateEmail(email) {
          const re = /^(([^<>()\[\]\\.,;:\s@"]+(\.[^<>()\[\]\\.,;:\s@"]+)*)|(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;
          return re.test(String(email).toLowerCase());
        }
      });
    }
  });
</script>
<% end %>
