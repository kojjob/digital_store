<!-- Benefits Section - Authority + Social Proof -->
<section class="py-16 bg-gray-50">
  <div class="container px-4 mx-auto max-w-7xl">
    <div class="text-center mb-16" data-aos="fade-up">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Why Creators Choose Us</h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Our platform is built specifically for African creators, with features that help you succeed.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <% @seller_benefits.each_with_index do |benefit, index| %>
        <div class="bg-white p-8 rounded-xl shadow-md hover:shadow-lg transition duration-300" data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
          <div class="w-14 h-14 rounded-xl bg-primary-100 flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3"><%= benefit[:title] %></h3>
          <p class="text-gray-600 mb-4"><%= benefit[:description] %></p>
          
          <!-- Add relevant testimonial snippet -->
          <div class="mt-auto pt-4 border-t border-gray-100">
            <div class="flex items-center">
              <div class="text-xs font-medium text-gray-500">
                <%= ["David, Ghana", "Amina, Nigeria", "Kofi, Tanzania", "Fatima, Kenya", "John, Uganda", "Sarah, Ethiopia"].sample %>
              </div>
              <div class="ml-auto flex">
                <% 5.times do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- How It Works - Clarity + Process -->
<section id="how-it-works" class="py-16 bg-white">
  <div class="container px-4 mx-auto max-w-7xl">
    <div class="text-center mb-16" data-aos="fade-up">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">Start Earning in 4 Simple Steps</h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Our streamlined process makes it easy to get started and start earning.
      </p>
    </div>
    
    <div class="relative max-w-5xl mx-auto" data-aos="fade-up">
      <!-- Timeline line -->
      <div class="hidden md:block absolute left-1/2 transform -translate-x-1/2 h-full w-1 bg-primary-100"></div>
      
      <!-- Step 1 -->
      <div class="flex flex-col md:flex-row items-center mb-12 md:mb-24">
        <div class="md:w-1/2 md:pr-12 md:text-right order-2 md:order-1" data-aos="fade-right">
          <div class="bg-white p-6 rounded-xl shadow-md md:ml-auto md:mr-0 max-w-md border-t-4 border-primary-500">
            <h3 class="text-2xl font-bold mb-3 text-primary-700">Create Your Account</h3>
            <p class="text-gray-600 mb-4">Sign up for a free seller account and complete your profile with your business information. Verification is simple and fast.</p>
            <div class="text-sm text-gray-500">Average completion time: <span class="font-medium text-primary-600">5 minutes</span></div>
          </div>
        </div>
        <div class="md:w-0 flex justify-center my-6 md:my-0 order-1 md:order-2">
          <div class="w-12 h-12 bg-primary-600 text-white rounded-full flex items-center justify-center z-10 text-xl font-bold shadow-md">1</div>
        </div>
        <div class="md:w-1/2 md:pl-12 hidden md:block order-3"></div>
      </div>
      
      <!-- Step 2 -->
      <div class="flex flex-col md:flex-row items-center mb-12 md:mb-24">
        <div class="md:w-1/2 md:pr-12 hidden md:block order-1"></div>
        <div class="md:w-0 flex justify-center my-6 md:my-0 order-2">
          <div class="w-12 h-12 bg-primary-600 text-white rounded-full flex items-center justify-center z-10 text-xl font-bold shadow-md">2</div>
        </div>
        <div class="md:w-1/2 md:pl-12 order-3" data-aos="fade-left">
          <div class="bg-white p-6 rounded-xl shadow-md md:mr-auto md:ml-0 max-w-md border-t-4 border-purple-500">
            <h3 class="text-2xl font-bold mb-3 text-purple-700">Upload Your Products</h3>
            <p class="text-gray-600 mb-4">Add your digital products with descriptions, images, and set your pricing. Our platform supports various file types and provides secure hosting.</p>
            <div class="text-sm text-gray-500">Average time to first sale: <span class="font-medium text-purple-600">24-48 hours</span></div>
          </div>
        </div>
      </div>
      
      <!-- Step 3 -->
      <div class="flex flex-col md:flex-row items-center mb-12 md:mb-24">
        <div class="md:w-1/2 md:pr-12 md:text-right order-2 md:order-1" data-aos="fade-right">
          <div class="bg-white p-6 rounded-xl shadow-md md:ml-auto md:mr-0 max-w-md border-t-4 border-amber-500">
            <h3 class="text-2xl font-bold mb-3 text-amber-700">Promote Your Store</h3>
            <p class="text-gray-600 mb-4">Share your custom store URL and product links with your audience. We also promote top sellers across our platform for additional exposure.</p>
            <div class="text-sm text-gray-500">Marketing tools included: <span class="font-medium text-amber-600">Social media assets, email templates</span></div>
          </div>
        </div>
        <div class="md:w-0 flex justify-center my-6 md:my-0 order-1 md:order-2">
          <div class="w-12 h-12 bg-primary-600 text-white rounded-full flex items-center justify-center z-10 text-xl font-bold shadow-md">3</div>
        </div>
        <div class="md:w-1/2 md:pl-12 hidden md:block order-3"></div>
      </div>
      
      <!-- Step 4 -->
      <div class="flex flex-col md:flex-row items-center">
        <div class="md:w-1/2 md:pr-12 hidden md:block order-1"></div>
        <div class="md:w-0 flex justify-center my-6 md:my-0 order-2">
          <div class="w-12 h-12 bg-primary-600 text-white rounded-full flex items-center justify-center z-10 text-xl font-bold shadow-md">4</div>
        </div>
        <div class="md:w-1/2 md:pl-12 order-3" data-aos="fade-left">
          <div class="bg-white p-6 rounded-xl shadow-md md:mr-auto md:ml-0 max-w-md border-t-4 border-green-500">
            <h3 class="text-2xl font-bold mb-3 text-green-700">Get Paid</h3>
            <p class="text-gray-600 mb-4">Receive payments directly to your mobile money account or bank account. We handle all payment processing and security.</p>
            <div class="text-sm text-gray-500">Payment schedule: <span class="font-medium text-green-600">Weekly payouts, no minimum</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

