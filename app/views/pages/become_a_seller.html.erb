      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Everything you need to know about selling on our platform
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <% @faq_items.each_with_index do |faq, index| %>
        <div class="bg-white p-6 rounded-xl shadow-md border-l-4 border-primary-500" data-aos="fade-up" data-aos-delay="<%= index * 50 %>">
          <h3 class="text-xl font-bold mb-3 text-gray-800"><%= faq[:question] %></h3>
          <p class="text-gray-600"><%= faq[:answer] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

