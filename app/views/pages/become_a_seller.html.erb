<!-- Hero Section with Social Proof -->
<section class="hero-pattern relative overflow-hidden py-16 md:py-24">
  <!-- Decorative elements -->
  <div class="absolute top-0 left-0 w-64 h-64 bg-primary-400 opacity-20 rounded-full filter blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
  <div class="absolute bottom-0 right-0 w-80 h-80 bg-purple-400 opacity-20 rounded-full filter blur-3xl translate-x-1/4 translate-y-1/4"></div>
  
  <div class="container px-4 mx-auto max-w-7xl relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div data-aos="fade-right">
        <!-- Social proof pill - Scarcity -->
        <div class="inline-flex items-center bg-white/10 backdrop-blur-sm rounded-full py-2 px-4 mb-6 border border-white/20">
          <span class="inline-block w-2 h-2 bg-green-500 rounded-full mr-2 animate-pulse"></span>
          <span class="text-white text-sm font-medium">Limited time: First 3 months commission-free</span>
        </div>
        
        <h1 class="text-4xl md:text-6xl font-extrabold text-white leading-tight mb-6">
          Turn Your Digital <span class="text-yellow-300">Skills</span> Into <span class="text-yellow-300">Income</span>
        </h1>
        
        <p class="text-xl text-white/90 mb-8 leading-relaxed">
          Join thousands of creators across Africa earning <span class="font-semibold">$500-$5,000 monthly</span> by selling digital products on our trusted marketplace.
        </p>
        
        <!-- Social proof stats -->
        <div class="flex flex-wrap gap-6 mb-8">
          <div class="bg-white/10 backdrop-blur-sm rounded-lg px-4 py-3 border border-white/20">
            <div class="text-3xl font-bold text-white">10K+</div>
            <div class="text-white/70 text-sm">Sellers</div>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-lg px-4 py-3 border border-white/20">
            <div class="text-3xl font-bold text-white">97%</div>
            <div class="text-white/70 text-sm">Satisfaction</div>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-lg px-4 py-3 border border-white/20">
            <div class="text-3xl font-bold text-white">$2.5M</div>
            <div class="text-white/70 text-sm">Monthly Payouts</div>
          </div>
        </div>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <%= link_to new_seller_path, class: "btn-shine inline-flex items-center justify-center px-6 py-4 font-medium text-primary-700 bg-white rounded-lg hover:bg-gray-100 transition duration-300 shadow-lg text-lg" do %>
            Start Selling Now
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          <% end %>
          
          <a href="#how-it-works" class="inline-flex items-center justify-center px-6 py-4 border border-white rounded-lg text-white hover:bg-white/10 transition duration-300 font-medium text-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd" />
            </svg>
            How It Works
          </a>
        </div>
      </div>
      
      <div class="relative" data-aos="fade-left">
        <!-- Hero Image -->
        <div class="relative">
          <% if File.exist?(Rails.root.join('app', 'assets', 'images', 'seller-hero.png')) %>
            <%= image_tag "seller-hero1.png", alt: "Seller earning income", class: "w-full h-auto rounded-2xl shadow-2xl z-10 relative" %>
          <% else %>
            <div class="blob-shape bg-gradient-to-br from-white/90 to-white/70 backdrop-blur-sm p-6 lg:p-10 shadow-2xl">
              <!-- Featured Seller Testimonial -->
              <div class="bg-white rounded-xl shadow-lg p-6 max-w-md mx-auto">
                <div class="flex items-center mb-4">
                  <div class="w-16 h-16 rounded-full bg-primary-100 flex items-center justify-center text-primary-600 font-bold mr-4">
                    DO
                  </div>
                  <div>
                    <div class="flex items-center">
                      <h3 class="font-bold text-xl">David Osei</h3>
                      <div class="ml-2 px-2 py-1 bg-green-100 text-green-800 text-xs rounded-full font-medium">Top Seller</div>
                    </div>
                    <p class="text-gray-500">Digital Artist, Ghana</p>
                  </div>
                </div>
                <p class="text-gray-600 mb-4 font-medium italic">"I started selling my digital art as a side hustle, now it's my full-time income. Last month I made $3,200 from just 14 products!"</p>
                
                <div class="border-t border-gray-100 pt-4 mt-4">
                  <div class="text-sm text-gray-500 mb-2">Monthly Sales (Last 6 months)</div>
                  <div class="h-10 flex space-x-1">
                    <div class="w-1/6 bg-primary-100 rounded-t-md relative overflow-hidden">
                      <div class="absolute bottom-0 w-full bg-primary-500 rounded-t-md" style="height: 40%"></div>
                    </div>
                    <div class="w-1/6 bg-primary-100 rounded-t-md relative overflow-hidden">
                      <div class="absolute bottom-0 w-full bg-primary-500 rounded-t-md" style="height: 55%"></div>
                    </div>
                    <div class="w-1/6 bg-primary-100 rounded-t-md relative overflow-hidden">
                      <div class="absolute bottom-0 w-full bg-primary-500 rounded-t-md" style="height: 45%"></div>
                    </div>
                    <div class="w-1/6 bg-primary-100 rounded-t-md relative overflow-hidden">
                      <div class="absolute bottom-0 w-full bg-primary-500 rounded-t-md" style="height: 60%"></div>
                    </div>
                    <div class="w-1/6 bg-primary-100 rounded-t-md relative overflow-hidden">
                      <div class="absolute bottom-0 w-full bg-primary-500 rounded-t-md" style="height: 75%"></div>
                    </div>
                    <div class="w-1/6 bg-primary-100 rounded-t-md relative overflow-hidden">
                      <div class="absolute bottom-0 w-full bg-primary-500 rounded-t-md" style="height: 100%"></div>
                    </div>
                  </div>
                  <div class="text-right text-primary-600 font-bold mt-1">+137% growth</div>
                </div>
              </div>
              
              <!-- Floating elements -->
              <div class="absolute -top-6 -left-6 bg-yellow-400 rounded-lg shadow-lg p-3 rotate-3 floating">
                <div class="flex items-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-yellow-700" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M12 7a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0V8.414l-4.293 4.293a1 1 0 01-1.414 0L8 10.414l-4.293 4.293a1 1 0 01-1.414-1.414l5-5a1 1 0 011.414 0L11 10.586 14.586 7H12z" clip-rule="evenodd" />
                  </svg>
                  <div class="ml-2">
                    <div class="text-sm font-bold text-yellow-800">$1,248</div>
                    <div class="text-xs text-yellow-800">Last week earnings</div>
                  </div>
                </div>
              </div>
              
              <div class="absolute -bottom-4 -right-4 bg-green-500 rounded-lg shadow-lg p-3 -rotate-6 floating" style="animation-delay: 1s;">
                <div class="flex items-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M5 2a1 1 0 011 1v1h1a1 1 0 010 2H6v1a1 1 0 01-2 0V6H3a1 1 0 010-2h1V3a1 1 0 011-1zm0 10a1 1 0 011 1v1h1a1 1 0 110 2H6v1a1 1 0 11-2 0v-1H3a1 1 0 110-2h1v-1a1 1 0 011-1zM12 2a1 1 0 01.967.744L14.146 7.2 17.5 9.134a1 1 0 010 1.732l-3.354 1.935-1.18 4.455a1 1 0 01-1.933 0L9.854 12.8 6.5 10.866a1 1 0 010-1.732l3.354-1.935 1.18-4.455A1 1 0 0112 2z" clip-rule="evenodd" />
                  </svg>
                  <div class="ml-2">
                    <div class="text-sm font-bold text-white">New Sale!</div>
                    <div class="text-xs text-white">Just now</div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Product Types Section - Loss Aversion -->
