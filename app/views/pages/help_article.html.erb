<div class="bg-gray-50 min-h-screen pt-4">
  <!-- Breadcrumb -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-4">
    <nav class="flex" aria-label="Breadcrumb">
      <ol role="list" class="flex items-center space-x-4">
        <li>
          <div>
            <a href="<%= root_path %>" class="text-gray-400 hover:text-gray-500">
              <svg class="h-5 w-5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" />
              </svg>
              <span class="sr-only">Home</span>
            </a>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M5.555 17.776l8-16 .894.448-8 16-.894-.448z" />
            </svg>
            <a href="<%= help_path %>" class="ml-4 text-sm font-medium text-gray-500 hover:text-gray-700">Help Center</a>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M5.555 17.776l8-16 .894.448-8 16-.894-.448z" />
            </svg>
            <a href="<%= help_category_path(@category) %>" class="ml-4 text-sm font-medium text-gray-500 hover:text-gray-700"><%= @category_info[:name] %></a>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M5.555 17.776l8-16 .894.448-8 16-.894-.448z" />
            </svg>
            <span class="ml-4 text-sm font-medium text-gray-700 truncate" aria-current="page"><%= @article_content[:title] %></span>
          </div>
        </li>
      </ol>
    </nav>
  </div>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Sidebar -->
      <div class="md:col-span-1">
        <div class="bg-white shadow rounded-lg overflow-hidden sticky top-24">
          <div class="px-6 py-5 border-b border-gray-200">
            <h3 class="text-lg font-medium text-gray-900">On this page</h3>
          </div>
          <nav class="px-3 py-4 overflow-y-auto" aria-label="Article sections" data-controller="article-nav">
            <div class="space-y-2 text-sm">
              <a href="#getting-started" class="text-gray-600 hover:text-indigo-600 block px-3 py-2 rounded-md hover:bg-gray-50">Getting Started</a>
              <a href="#step-by-step" class="text-gray-600 hover:text-indigo-600 block px-3 py-2 rounded-md hover:bg-gray-50">Step-by-Step Instructions</a>
              <a href="#advanced-tips" class="text-gray-600 hover:text-indigo-600 block px-3 py-2 rounded-md hover:bg-gray-50">Advanced Tips</a>
              <a href="#troubleshooting" class="text-gray-600 hover:text-indigo-600 block px-3 py-2 rounded-md hover:bg-gray-50">Troubleshooting</a>
            </div>
          </nav>
        </div>
        
        <div class="mt-8 bg-blue-50 rounded-lg p-6">
          <h3 class="text-lg font-medium text-blue-800">Was this helpful?</h3>
          <p class="mt-2 text-sm text-blue-600">
            Let us know if this article solved your issue or if you need more help.
          </p>
          <div class="mt-4 flex space-x-3">
            <button type="button" class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-full shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" data-controller="feedback" data-action="feedback#helpful">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5" />
              </svg>
              Yes, it helped!
            </button>
            <button type="button" class="inline-flex items-center px-3 py-1.5 border border-gray-300 shadow-sm text-xs font-medium rounded-full text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" data-controller="feedback" data-action="feedback#notHelpful">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14H5.236a2 2 0 01-1.789-2.894l3.5-7A2 2 0 018.736 3h4.018a2 2 0 01.485.06l3.76.94m-7 10v5a2 2 0 002 2h.096c.5 0 .905-.405.905-.904 0-.715.211-1.413.608-2.008L17 13V4m-7 10h2" />
              </svg>
              No, I need more help
            </button>
          </div>
        </div>
      </div>

      <!-- Article Content -->
      <div class="md:col-span-3">
        <div class="bg-white shadow rounded-lg overflow-hidden">
          <div class="px-6 py-5 border-b border-gray-200">
            <div class="flex items-center justify-between">
              <h1 class="text-2xl font-bold text-gray-900"><%= @article_content[:title] %></h1>
              <div class="flex items-center text-sm text-gray-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                Updated <%= time_ago_in_words(@article_content[:updated_at]) %> ago
              </div>
            </div>
          </div>

          <div class="prose prose-indigo max-w-none px-6 py-5" data-controller="article-content">
            <div id="article-body">
              <%= @article_content[:content].html_safe %>
            </div>
            
            <div class="mt-10 pt-10 border-t border-gray-200">
              <div class="flex items-center justify-between">
                <div class="inline-flex items-center text-sm text-gray-500">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  Last updated: <%= @article_content[:updated_at].strftime('%B %d, %Y') %>
                </div>
                
                <div class="flex space-x-3">
                  <a href="#" class="text-gray-400 hover:text-gray-500">
                    <span class="sr-only">Share on Facebook</span>
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M20 10c0-5.523-4.477-10-10-10S0 4.477 0 10c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V10h2.54V7.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V10h2.773l-.443 2.89h-2.33v6.988C16.343 19.128 20 14.991 20 10z" clip-rule="evenodd" />
                    </svg>
                  </a>

                  <a href="#" class="text-gray-400 hover:text-gray-500">
                    <span class="sr-only">Share on Twitter</span>
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path d="M6.29 18.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0020 3.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.073 4.073 0 01.8 7.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 010 16.407a11.616 11.616 0 006.29 1.84" />
                    </svg>
                  </a>

                  <a href="#" class="text-gray-400 hover:text-gray-500">
                    <span class="sr-only">Share on LinkedIn</span>
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.338 16.338H13.67V12.16c0-.995-.017-2.277-1.387-2.277-1.39 0-1.601 1.086-1.601 2.207v4.248H8.014v-8.59h2.559v1.174h.037c.356-.675 1.227-1.387 2.526-1.387 2.703 0 3.203 1.778 3.203 4.092v4.711zM5.005 6.575a1.548 1.548 0 11-.003-3.096 1.548 1.548 0 01.003 3.096zm-1.337 9.763H6.34v-8.59H3.667v8.59zM17.668 1H2.328C1.595 1 1 1.581 1 2.298v15.403C1 18.418 1.595 19 2.328 19h15.34c.734 0 1.332-.582 1.332-1.299V2.298C19 1.581 18.402 1 17.668 1z" clip-rule="evenodd" />
                    </svg>
                  </a>

                  <button type="button" class="text-gray-400 hover:text-gray-500" data-action="click->article-content#copyLink">
                    <span class="sr-only">Copy link</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Related Articles -->
        <div class="mt-8 bg-white shadow rounded-lg overflow-hidden">
          <div class="px-6 py-5 border-b border-gray-200">
            <h3 class="text-lg font-medium text-gray-900">Related Articles</h3>
          </div>
          <ul role="list" class="divide-y divide-gray-200">
            <% @related_articles.each do |article| %>
              <li>
                <a href="<%= help_article_path(@category, article[:slug]) %>" class="block hover:bg-gray-50">
                  <div class="px-6 py-4">
                    <div class="flex items-center">
                      <p class="text-sm font-medium text-gray-900 truncate flex-grow"><%= article[:title] %></p>
                      <div class="ml-2 flex-shrink-0 flex">
                        <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                          <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                        </svg>
                      </div>
                    </div>
                  </div>
                </a>
              </li>
            <% end %>
          </ul>
        </div>
        
        <!-- Contact Support -->
        <div class="mt-8 bg-indigo-50 rounded-lg p-6">
          <div class="flex items-start">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-indigo-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-lg font-medium text-indigo-800">Still need help?</h3>
              <p class="mt-2 text-sm text-indigo-600">
                Can't find what you're looking for or need personalized assistance? Our support team is here to help.
              </p>
              <div class="mt-4">
                <a href="<%= contact_path %>" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                  Contact Support
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<% content_for :page_scripts do %>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof window.Stimulus !== 'undefined') {
      // Article navigation controller
      window.Stimulus.register('article-nav', class extends window.Stimulus.Controller {
        connect() {
          console.log('Article navigation controller connected');
          this.highlightCurrentSection();
          window.addEventListener('scroll', this.highlightCurrentSection.bind(this));
        }
        
        highlightCurrentSection() {
          const sections = document.querySelectorAll('h2, h3');
          const navLinks = this.element.querySelectorAll('a');
          
          let currentSectionId = '';
          sections.forEach(section => {
            const sectionTop = section.offsetTop - 100;
            if (window.scrollY >= sectionTop) {
              currentSectionId = section.getAttribute('id');
            }
          });
          
          navLinks.forEach(link => {
            if (link.getAttribute('href').includes(currentSectionId)) {
              link.classList.add('text-indigo-600', 'bg-gray-50');
              link.classList.remove('text-gray-600');
            } else {
              link.classList.remove('text-indigo-600', 'bg-gray-50');
              link.classList.add('text-gray-600');
            }
          });
        }
      });
      
      // Article content controller
      window.Stimulus.register('article-content', class extends window.Stimulus.Controller {
        connect() {
          console.log('Article content controller connected');
          this.addIdsToHeadings();
        }
        
        addIdsToHeadings() {
          const headings = this.element.querySelectorAll('h2, h3, h4');
          headings.forEach((heading, index) => {
            if (!heading.id) {
              let id = heading.textContent.toLowerCase().replace(/[^\w]+/g, '-');
              
              // Handle duplicate IDs
              if (document.getElementById(id)) {
                id = `${id}-${index}`;
              }
              
              heading.id = id;
            }
          });
        }
        
        copyLink(event) {
          event.preventDefault();
          const url = window.location.href;
          navigator.clipboard.writeText(url).then(() => {
            // Show a success message
            const button = event.currentTarget;
            const originalHTML = button.innerHTML;
            
            button.innerHTML = `
              <span class="sr-only">Copied!</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            `;
            
            setTimeout(() => {
              button.innerHTML = originalHTML;
            }, 2000);
          });
        }
      });
      
      // Feedback controller
      window.Stimulus.register('feedback', class extends window.Stimulus.Controller {
        helpful(event) {
          const button = event.currentTarget;
          button.classList.remove('bg-blue-600', 'hover:bg-blue-700');
          button.classList.add('bg-green-600', 'hover:bg-green-700');
          button.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Thanks for your feedback!
          `;
          
          // Here you would typically send the feedback to your server
          console.log('Article was helpful');
        }
        
        notHelpful(event) {
          // Show a form or redirect to contact page
          window.location.href = '<%= contact_path %>';
        }
      });
    }
  });
</script>
<% end %>
