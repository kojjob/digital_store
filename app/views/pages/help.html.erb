<div class="min-h-screen">
  <!-- Hero Section with Search - Gradient Background -->
  <div class="bg-gradient-to-r from-indigo-600 via-purple-600 to-indigo-700 py-20 relative overflow-hidden">
    <!-- Decorative circles -->
    <div class="absolute top-0 left-0 w-96 h-96 bg-white opacity-10 rounded-full -translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 right-0 w-64 h-64 bg-white opacity-10 rounded-full translate-x-1/4 translate-y-1/4"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl drop-shadow-md">
        How can we help you?
      </h1>
      <p class="mt-4 text-xl text-white max-w-2xl mx-auto">
        Find answers to your questions about DigitalStore products, services, and account.
      </p>
      <div class="mt-10 max-w-3xl mx-auto">
        <form action="/help" method="get" class="mx-auto max-w-xl flex rounded-xl shadow-lg" data-controller="help-search">
          <div class="relative flex items-center w-full">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
              </svg>
            </div>
            <input type="text" name="q" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full py-5 pl-10 pr-10 text-base border-none rounded-l-xl" placeholder="Search for answers..." data-help-search-target="input">
          </div>
          <button type="submit" class="relative inline-flex items-center space-x-2 px-8 py-5 border border-transparent text-sm font-medium rounded-r-xl text-white bg-indigo-900 hover:bg-indigo-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all duration-200 shadow-md">
            <span>Search</span>
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Popular Topics - Card Design with Gradient Accent -->
  <div class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:text-center mb-12">
        <h2 class="text-base text-indigo-600 font-semibold tracking-wide uppercase">Quick Links</h2>
        <p class="mt-2 text-4xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-5xl bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-purple-600">
          Popular Help Topics
        </p>
        <p class="mt-4 max-w-2xl text-xl text-gray-500 lg:mx-auto">
          Find answers to commonly asked questions and get the support you need.
        </p>
      </div>

      <div class="mt-12">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <% @popular_articles.each do |article| %>
            <a href="<%= help_article_path(article[:category], article[:slug]) %>" class="bg-white hover:bg-gray-50 p-8 rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 block border border-gray-100">
              <div class="w-12 h-1 bg-gradient-to-r from-purple-400 to-indigo-500 rounded-full mb-6"></div>
              <h3 class="text-xl font-bold text-gray-900"><%= article[:title] %></h3>
              <div class="mt-4 text-sm text-gray-500 flex items-center">
                <span class="text-indigo-600 mr-2 font-medium">Read article</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </div>
            </a>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Help Categories - Visual Cards with Icons -->
  <div class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:text-center mb-12">
        <h2 class="text-base text-indigo-600 font-semibold tracking-wide uppercase">Browse by Category</h2>
        <p class="mt-2 text-4xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-5xl bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-purple-600">
          Help Center Categories
        </p>
        <p class="mt-4 max-w-2xl text-xl text-gray-500 lg:mx-auto">
          Find detailed information organized by topic
        </p>
      </div>

      <div class="mt-12">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <% @help_categories.each do |category| %>
            <a href="<%= help_category_path(category[:slug]) %>" class="group bg-white shadow-md hover:shadow-xl rounded-xl overflow-hidden transition-all duration-300 flex flex-col h-full border border-gray-100 transform hover:-translate-y-1">
              <div class="p-8">
                <div class="flex items-center">
                  <div class="flex-shrink-0">
                    <div class="flex items-center justify-center h-14 w-14 rounded-lg bg-gradient-to-br from-<%= category[:color] %>-500 to-<%= category[:color] %>-600 text-white shadow-md group-hover:shadow-lg transition-all duration-300">
                      <%= render 'shared/icon', name: category[:icon], size: "md", color: "white" %>
                    </div>
                  </div>
                  <div class="ml-5">
                    <h3 class="text-xl font-bold text-gray-900 group-hover:text-<%= category[:color] %>-600 transition-colors duration-200"><%= category[:name] %></h3>
                  </div>
                </div>
                <div class="mt-5">
                  <p class="text-base text-gray-500"><%= category[:description] %></p>
                </div>
              </div>
              <div class="bg-gray-50 px-8 py-4 mt-auto border-t border-gray-100 group-hover:bg-<%= category[:color] %>-50 transition-colors duration-300">
                <div class="text-sm font-medium text-<%= category[:color] %>-600 flex items-center">
                  <span>Browse category</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-4 w-4 transform group-hover:translate-x-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              </div>
            </a>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- FAQs - Interactive Accordion -->
  <div class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:text-center mb-12">
        <h2 class="text-base text-indigo-600 font-semibold tracking-wide uppercase">Frequently Asked Questions</h2>
        <p class="mt-2 text-4xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-5xl bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-purple-600">
          Common Questions
        </p>
        <p class="mt-4 max-w-2xl text-xl text-gray-500 lg:mx-auto">
          Quick answers to the most common questions we receive
        </p>
      </div>

      <div class="mt-12 max-w-3xl mx-auto">
        <dl class="space-y-8 divide-y divide-gray-200" data-controller="accordion">
          <% @faqs.each_with_index do |faq, index| %>
            <div class="pt-6" data-controller="accordion-item" id="faq-<%= index %>">
              <dt class="text-lg">
                <button class="text-left w-full flex justify-between items-center text-gray-900 focus:outline-none focus:ring-indigo-500 hover:text-indigo-600 transition-colors duration-200" data-action="click->accordion-item#toggle">
                  <span class="font-bold"><%= faq[:question] %></span>
                  <span class="ml-6 flex-shrink-0 bg-indigo-100 rounded-full p-1.5 transition-all duration-300" data-accordion-item-target="icon">
                    <svg class="h-6 w-6 text-indigo-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                  </span>
                </button>
              </dt>
              <dd class="mt-6 pr-12 hidden transform transition-all duration-300" data-accordion-item-target="content">
                <p class="text-base text-gray-600 bg-white p-6 rounded-xl shadow-sm"><%= faq[:answer] %></p>
              </dd>
            </div>
          <% end %>
        </dl>
      </div>
    </div>
  </div>

  <!-- Community Help - Card Design with Visual Elements -->
  <div class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:text-center mb-12">
        <h2 class="text-base text-indigo-600 font-semibold tracking-wide uppercase">Community Support</h2>
        <p class="mt-2 text-4xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-5xl bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-purple-600">
          Other Ways to Get Help
        </p>
        <p class="mt-4 max-w-2xl text-xl text-gray-500 lg:mx-auto">
          Connect with our team and community for additional support
        </p>
      </div>

      <div class="mt-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Contact Support -->
          <div class="bg-white shadow-lg rounded-xl overflow-hidden hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 border border-gray-100">
            <div class="h-3 bg-gradient-to-r from-indigo-400 to-indigo-600"></div>
            <div class="px-6 py-8">
              <div class="text-center">
                <div class="mx-auto flex items-center justify-center h-20 w-20 rounded-full bg-indigo-100 shadow-inner">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <h3 class="mt-6 text-xl font-bold text-gray-900">Email Support</h3>
                <p class="mt-4 text-base text-gray-600">
                  Get personalized help from our support team for complex issues.
                </p>
                <div class="mt-8">
                  <a href="<%= contact_path %>" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-lg shadow-md text-white bg-gradient-to-r from-indigo-500 to-indigo-600 hover:from-indigo-600 hover:to-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all duration-200">
                    Contact Support
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Community Forum -->
          <div class="bg-white shadow-lg rounded-xl overflow-hidden hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 border border-gray-100">
            <div class="h-3 bg-gradient-to-r from-green-400 to-green-600"></div>
            <div class="px-6 py-8">
              <div class="text-center">
                <div class="mx-auto flex items-center justify-center h-20 w-20 rounded-full bg-green-100 shadow-inner">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
                  </svg>
                </div>
                <h3 class="mt-6 text-xl font-bold text-gray-900">Community Forum</h3>
                <p class="mt-4 text-base text-gray-600">
                  Connect with other users to share tips and solve problems together.
                </p>
                <div class="mt-8">
                  <a href="#" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-lg shadow-md text-white bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-all duration-200">
                    Visit Forum
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Live Chat -->
          <div class="bg-white shadow-lg rounded-xl overflow-hidden hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 border border-gray-100">
            <div class="h-3 bg-gradient-to-r from-amber-400 to-amber-600"></div>
            <div class="px-6 py-8">
              <div class="text-center">
                <div class="mx-auto flex items-center justify-center h-20 w-20 rounded-full bg-amber-100 shadow-inner">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                  </svg>
                </div>
                <h3 class="mt-6 text-xl font-bold text-gray-900">Live Chat</h3>
                <p class="mt-4 text-base text-gray-600">
                  Chat with our support team in real-time during business hours.
                </p>
                <div class="mt-8">
                  <button type="button" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-lg shadow-md text-white bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-600 hover:to-amber-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber-500 transition-all duration-200">
                    Start Chat
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Still Need Help Call-to-Action - Wave Pattern Background -->
  <div class="bg-gradient-to-br from-indigo-700 to-purple-700 py-16 relative overflow-hidden">
    <!-- Decorative elements -->
    <div class="absolute top-0 left-0 right-0 h-8 bg-white opacity-10" style="clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 0%);"></div>
    <div class="absolute bottom-0 left-0 right-0 h-8 bg-white opacity-10" style="clip-path: polygon(0% 100%, 100% 0%, 100% 100%, 0% 100%);"></div>
    
    <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8 lg:flex lg:items-center lg:justify-between relative z-10">
      <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        <span class="block">Still need help?</span>
        <span class="block text-indigo-200 mt-1">Our team is here for you.</span>
      </h2>
      <div class="mt-8 flex flex-col sm:flex-row lg:mt-0 lg:flex-shrink-0 space-y-4 sm:space-y-0 sm:space-x-4">
        <div class="inline-flex">
          <a href="<%= contact_path %>" class="inline-flex items-center justify-center px-6 py-4 border border-transparent text-base font-medium rounded-lg text-indigo-600 bg-white hover:bg-indigo-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all duration-200 shadow-lg">
            Contact Us
          </a>
        </div>
        <div class="inline-flex">
          <a href="tel:+11234567890" class="inline-flex items-center justify-center px-6 py-4 border border-transparent text-base font-medium rounded-lg text-white bg-indigo-900 bg-opacity-50 hover:bg-opacity-70 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all duration-200 shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call Support
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<% content_for :page_scripts do %>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof window.Stimulus !== 'undefined') {
      // Accordion controller for FAQ section
      window.Stimulus.register('accordion-item', class extends window.Stimulus.Controller {
        static targets = ['content', 'icon'];
        
        connect() {
          console.log('Accordion item controller connected');
        }
        
        toggle() {
          if (this.contentTarget.classList.contains('hidden')) {
            // Show content with smooth animation
            this.contentTarget.classList.remove('hidden');
            this.contentTarget.classList.add('animate-fadeIn');
            
            this.iconTarget.innerHTML = `
              <svg class="h-6 w-6 text-indigo-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 12H6" />
              </svg>
            `;
            this.iconTarget.classList.add('bg-indigo-200');
            this.iconTarget.classList.remove('bg-indigo-100');
          } else {
            // Hide content
            this.contentTarget.classList.add('hidden');
            this.contentTarget.classList.remove('animate-fadeIn');
            
            this.iconTarget.innerHTML = `
              <svg class="h-6 w-6 text-indigo-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
              </svg>
            `;
            this.iconTarget.classList.remove('bg-indigo-200');
            this.iconTarget.classList.add('bg-indigo-100');
          }
        }
      });
      
      // Help search controller with enhanced functionality
      window.Stimulus.register('help-search', class extends window.Stimulus.Controller {
        static targets = ['input'];
        
        connect() {
          console.log('Help search controller connected');
          this.inputTarget.addEventListener('focus', this.handleFocus.bind(this));
          this.inputTarget.addEventListener('blur', this.handleBlur.bind(this));
        }
        
        handleFocus(event) {
          event.target.parentElement.parentElement.classList.add('ring-2', 'ring-indigo-300', 'ring-opacity-50');
        }
        
        handleBlur(event) {
          event.target.parentElement.parentElement.classList.remove('ring-2', 'ring-indigo-300', 'ring-opacity-50');
        }
      });
    }
  });
</script>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .animate-fadeIn {
    animation: fadeIn 0.3s ease-out forwards;
  }
</style>
<% end %>
