<!-- Join Our Team - Gradient Background -->
<section class="py-24 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-r from-purple-700 via-indigo-600 to-blue-700"></div>
  
  <div class="container mx-auto px-6 relative z-10 text-center">
    <div class="p-12 max-w-3xl mx-auto bg-white/10 rounded-3xl shadow-2xl">
      <h2 class="text-4xl md:text-5xl font-bold mb-6 text-white leading-tight">Join Our Team</h2>
      <p class="text-xl text-white/90 mb-10 leading-relaxed">
        We're looking for passionate individuals who believe in our mission to empower 
        African digital creators. Check out our open positions.
      </p>
      <a href="#" class="inline-flex items-center px-8 py-4 text-lg font-bold rounded-xl bg-white text-indigo-700 hover:bg-indigo-50 shadow-lg">
        View Open Positions
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>

<!-- Contact CTA -->
<section class="py-24 bg-gray-50">
  <div class="container mx-auto px-6">
    <div class="bg-white rounded-3xl shadow-2xl p-12 max-w-4xl mx-auto overflow-hidden relative">
      <!-- Decorative elements -->
      <div class="absolute -top-32 -right-32 w-96 h-96 bg-indigo-100 rounded-full opacity-50"></div>
      <div class="absolute -bottom-32 -left-32 w-96 h-96 bg-pink-100 rounded-full opacity-50"></div>
      
      <div class="relative z-10">
        <div class="text-center mb-10">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Have Questions?</h2>
          <p class="text-xl text-gray-600">We'd love to hear from you. Reach out to our team.</p>
        </div>
        <div class="flex flex-col sm:flex-row justify-center gap-6">
          <%= link_to contact_path, class: "inline-flex justify-center items-center px-8 py-4 text-base font-semibold rounded-xl bg-indigo-600 text-white hover:bg-indigo-700 shadow-lg" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Contact Us
          <% end %>
          <%= link_to help_path, class: "inline-flex justify-center items-center px-8 py-4 text-base font-semibold rounded-xl border-2 border-indigo-600 text-indigo-600 hover:bg-indigo-50" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Visit Help Center
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
