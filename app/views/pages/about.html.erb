<!-- Hero section with gradient background -->
<div class="relative overflow-hidden min-h-[60vh] flex items-center">
  <!-- Gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-indigo-600 via-purple-700 to-pink-600"></div>
  
  <!-- Content -->
  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-5xl md:text-7xl font-extrabold mb-6 text-white tracking-tight leading-tight">
        About <span class="text-amber-300">DigitalStore</span>
      </h1>
      <p class="text-2xl font-light text-white mb-10">Connecting digital creators and buyers across Africa</p>
      <div class="w-24 h-1 bg-amber-300 mx-auto mb-10 rounded-full"></div>
      <a href="#mission" class="inline-block">
        <svg class="w-10 h-10 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </a>
    </div>
  </div>
</div>

<!-- Mission Section -->
<section id="mission" class="py-24 bg-white">
  <div class="container mx-auto px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <span class="inline-block py-1 px-3 rounded-full bg-indigo-100 text-indigo-700 text-sm font-semibold mb-4">OUR MISSION</span>
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 leading-tight">Empowering Africa's<br>Digital Economy</h2>
        <div class="w-24 h-1 mx-auto bg-indigo-600 rounded-full mb-8"></div>
        <p class="text-xl text-gray-700 leading-relaxed font-light">
          We're building Africa's premier digital marketplace, connecting talented creators with buyers around the world.
          Our platform empowers local talent, enables seamless transactions with mobile money integration, and showcases 
          the incredible digital products created across the continent.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <div class="bg-white rounded-2xl shadow-xl p-8">
          <div class="w-16 h-16 bg-indigo-500 rounded-xl flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
            </svg>
          </div>
          <h3 class="font-bold text-2xl text-gray-800 mb-4">Empower Creators</h3>
          <p class="text-gray-600 leading-relaxed">Supporting African digital creators by providing a platform to showcase and monetize their work in global markets.</p>
        </div>
        
        <div class="bg-white rounded-2xl shadow-xl p-8">
          <div class="w-16 h-16 bg-pink-500 rounded-xl flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          </div>
          <h3 class="font-bold text-2xl text-gray-800 mb-4">Innovative Payments</h3>
          <p class="text-gray-600 leading-relaxed">Pioneering mobile money integration for Ghana and Nigeria, making digital purchases accessible to everyone, everywhere.</p>
        </div>
        
        <div class="bg-white rounded-2xl shadow-xl p-8">
          <div class="w-16 h-16 bg-amber-500 rounded-xl flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-2xl text-gray-800 mb-4">Grow Communities</h3>
          <p class="text-gray-600 leading-relaxed">Building a community of African digital creators, connecting talent and fostering collaboration across the continent.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Our Story Section -->
<section class="py-24 bg-gray-50 relative overflow-hidden">
  <div class="container mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
      <div class="md:col-span-5 order-2 md:order-1">
        <div class="relative">
          <% begin %>
            <%= image_tag "team-together.png", alt: "Our team working together", class: "rounded-2xl shadow-2xl w-full relative z-10" %>
          <% rescue Propshaft::MissingAssetError %>
            <div class="rounded-2xl shadow-2xl bg-gradient-to-br from-indigo-500 via-purple-600 to-indigo-700 h-96 flex items-center justify-center relative z-10">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24 text-white/70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
          <% end %>
          <div class="absolute -bottom-6 -left-6 w-full h-full bg-indigo-200 rounded-2xl transform rotate-3"></div>
        </div>
      </div>
      
      <div class="md:col-span-7 order-1 md:order-2">
        <span class="inline-block py-1 px-3 rounded-full bg-indigo-100 text-indigo-700 text-sm font-semibold mb-4">OUR STORY</span>
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 leading-tight">From Vision to Reality</h2>
        <div class="w-24 h-1 bg-pink-500 rounded-full mb-8"></div>
        <div class="space-y-6 text-gray-600 leading-relaxed">
          <p class="text-lg">
            Founded in 2023, our marketplace was born from a simple observation: despite abundant talent across Africa, 
            digital creators struggled to monetize their work due to payment and platform barriers.
          </p>
          <p class="text-lg">
            We built this platform to solve these challenges by creating a marketplace specifically designed for African 
            digital creators and customers, with integrated mobile money payments for Ghana and Nigeria, plus global payment options.
          </p>
          <p class="text-lg">
            What started as a small initiative has grown into a thriving marketplace connecting talented designers, developers, 
            artists, and content creators with customers around the world who value their unique skills and perspectives.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

