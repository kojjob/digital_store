<div class="bg-gray-50 min-h-screen pt-4">
  <!-- Hero Section -->
  <div class="bg-indigo-700 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <div class="flex items-center justify-center h-16 w-16 rounded-md bg-<%= @category_info[:color] %>-100 text-<%= @category_info[:color] %>-600">
            <%= render 'shared/icon', name: @category_info[:icon], size: "lg", color: @category_info[:color] %>
          </div>
        </div>
        <div class="ml-6">
          <h1 class="text-3xl font-extrabold text-white sm:text-4xl">
            <%= @category_info[:name] %>
          </h1>
          <p class="mt-2 text-lg text-indigo-100 max-w-3xl">
            Find helpful articles, guides, and resources about <%= @category_info[:name].downcase %>.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Breadcrumb -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-4">
    <nav class="flex" aria-label="Breadcrumb">
      <ol role="list" class="flex items-center space-x-4">
        <li>
          <div>
            <a href="<%= root_path %>" class="text-gray-400 hover:text-gray-500">
              <svg class="h-5 w-5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" />
              </svg>
              <span class="sr-only">Home</span>
            </a>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M5.555 17.776l8-16 .894.448-8 16-.894-.448z" />
            </svg>
            <a href="<%= help_path %>" class="ml-4 text-sm font-medium text-gray-500 hover:text-gray-700">Help Center</a>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M5.555 17.776l8-16 .894.448-8 16-.894-.448z" />
            </svg>
            <span class="ml-4 text-sm font-medium text-gray-700" aria-current="page"><%= @category_info[:name] %></span>
          </div>
        </li>
      </ol>
    </nav>
  </div>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Sidebar Categories -->
      <div class="md:col-span-1">
        <div class="bg-white shadow rounded-lg overflow-hidden sticky top-24">
          <div class="px-6 py-5 border-b border-gray-200">
            <h3 class="text-lg font-medium text-gray-900">Help Categories</h3>
          </div>
          <nav class="px-3 py-4" aria-label="Help categories">
            <div class="space-y-2">
              <% @category_info = {
                "getting-started" => { name: "Getting Started", icon: "template", color: "blue" },
                "account" => { name: "Account & Profile", icon: "user", color: "amber" },
                "purchases" => { name: "Purchases & Downloads", icon: "cart", color: "green" },
                "payments" => { name: "Payments & Billing", icon: "lightning", color: "peach" },
                "licensing" => { name: "Product Licensing", icon: "book", color: "blue" },
                "technical" => { name: "Technical Support", icon: "code", color: "green" }
              } %>
              <% @category_info.each do |slug, info| %>
                <a href="<%= help_category_path(slug) %>" class="<%= slug == @category ? 'bg-indigo-50 text-indigo-600' : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900' %> flex items-center px-3 py-2 text-sm font-medium rounded-md">
                  <span class="truncate"><%= info[:name] %></span>
                </a>
              <% end %>
            </div>
          </nav>
        </div>
        
        <div class="mt-8 bg-blue-50 rounded-lg p-6">
          <h3 class="text-lg font-medium text-blue-800">Need more help?</h3>
          <p class="mt-2 text-sm text-blue-600">
            Can't find what you're looking for? Our support team is here to assist you.
          </p>
          <div class="mt-6">
            <a href="<%= contact_path %>" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
              Contact Support
            </a>
          </div>
        </div>
      </div>

      <!-- Articles List -->
      <div class="md:col-span-2 space-y-6">
        <div class="bg-white shadow rounded-lg overflow-hidden">
          <div class="px-6 py-5 border-b border-gray-200">
            <h2 class="text-xl font-medium text-gray-900">Popular Articles</h2>
          </div>
          <ul role="list" class="divide-y divide-gray-200">
            <% @articles.each do |article| %>
              <li class="relative bg-white hover:bg-gray-50 focus-within:ring-2 focus-within:ring-inset focus-within:ring-indigo-500">
                <div class="px-6 py-5">
                  <div class="group relative flex justify-between items-center">
                    <a href="<%= help_article_path(@category, article[:slug]) %>" class="block focus:outline-none">
                      <p class="text-base font-medium text-gray-900 truncate"><%= article[:title] %></p>
                      <p class="mt-1 text-sm text-gray-600 line-clamp-2"><%= article[:excerpt] %></p>
                    </a>
                    <div class="ml-2 flex-shrink-0 flex">
                      <a href="<%= help_article_path(@category, article[:slug]) %>" class="p-2 text-indigo-600 hover:text-indigo-900">
                        <span class="sr-only">View article</span>
                        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                          <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                        </svg>
                      </a>
                    </div>
                  </div>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
        
        <!-- Related Resources -->
        <div class="bg-white shadow rounded-lg overflow-hidden">
          <div class="px-6 py-5 border-b border-gray-200">
            <h2 class="text-xl font-medium text-gray-900">Related Resources</h2>
          </div>
          <div class="px-6 py-5">
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
              <div class="bg-indigo-50 p-4 rounded-lg">
                <h3 class="text-base font-medium text-indigo-800">Video Tutorials</h3>
                <p class="mt-1 text-sm text-indigo-600">Watch step-by-step video guides for visual learners.</p>
                <a href="#" class="mt-3 text-sm font-medium text-indigo-700 hover:text-indigo-500 flex items-center">
                  View tutorials
                  <svg class="ml-1 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </a>
              </div>
              <div class="bg-green-50 p-4 rounded-lg">
                <h3 class="text-base font-medium text-green-800">Community Forum</h3>
                <p class="mt-1 text-sm text-green-600">Get answers from other users and share your experiences.</p>
                <a href="#" class="mt-3 text-sm font-medium text-green-700 hover:text-green-500 flex items-center">
                  Join discussion
                  <svg class="ml-1 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
