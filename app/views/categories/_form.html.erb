<%= form_with(model: category) do |form| %>
  <% if category.errors.any? %>
    <div id="error_explanation" class="mb-6 rounded-md bg-red-50 p-4 border border-red-200">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(category.errors.count, "error") %> prohibited this category from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% category.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="space-y-6">
      <div>
        <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.text_field :name, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md", placeholder: "e.g. UI Templates" %>
        </div>
        <p class="mt-1 text-sm text-gray-500">Enter a descriptive name for your category</p>
      </div>

      <div>
        <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.text_area :description, rows: 4, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md", placeholder: "Describe what kind of products will be in this category..." %>
        </div>
        <p class="mt-1 text-sm text-gray-500">A clear description helps customers understand what products to expect</p>
      </div>

      <div>
        <%= form.label :slug, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.text_field :slug, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md", placeholder: "e.g. ui-templates" %>
        </div>
        <p class="mt-1 text-sm text-gray-500">The URL-friendly version of the name (lowercase, hyphens instead of spaces)</p>
      </div>
    </div>

    <div class="space-y-6">
      <div>
        <%= form.label :parent_id, "Parent Category", class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.collection_select :parent_id, 
                        Category.selectable_parents(category.id),
                        :id, :name, 
                        { include_blank: "No parent (top-level category)" }, 
                        { class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" } %>
        </div>
        <p class="mt-1 text-sm text-gray-500">Select a parent category if this is a subcategory</p>
      </div>

      <div>
        <%= form.label :position, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.number_field :position, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md", placeholder: "e.g. 1" %>
        </div>
        <p class="mt-1 text-sm text-gray-500">Order in which the category appears (lower numbers appear first)</p>
      </div>
      
      <div>
        <%= form.label :icon_name, "Icon", class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.select :icon_name,
                options_for_select([
                  ["Book", "book"],
                  ["Code", "code"],
                  ["Template", "template"],
                  ["Star", "star"],
                  ["Image", "image"],
                  ["Font", "font"],
                  ["Chart", "chart"],
                  ["Lightning", "lightning"],
                  ["Globe", "globe"],
                  ["Cart", "cart"],
                  ["User", "user"],
                  ["Category", "category"]
                ], category.icon_name),
                { include_blank: "Auto (Based on Name)" },
                { class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" } %>
        </div>
        <p class="mt-1 text-sm text-gray-500">Choose an icon to represent this category</p>
      </div>
      
      <div>
        <%= form.label :icon_color, "Icon Color", class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.select :icon_color,
                options_for_select([
                  ["Blue", "blue"],
                  ["Green", "green"],
                  ["Amber", "amber"],
                  ["Peach", "peach"]
                ], category.icon_color),
                {},
                { class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" } %>
        </div>
        <p class="mt-1 text-sm text-gray-500">Choose a color for the category icon</p>
      </div>

      <div class="flex items-start mt-6">
        <div class="flex items-center h-5">
          <%= form.check_box :visible, class: "focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded" %>
        </div>
        <div class="ml-3 text-sm">
          <%= form.label :visible, class: "font-medium text-gray-700" %>
          <p class="text-gray-500">Make this category visible to customers</p>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-8 border-t border-gray-200 pt-6">
    <div class="flex justify-end">
      <button type="submit" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-gradient-to-r from-indigo-600 to-indigo-500 hover:from-indigo-700 hover:to-indigo-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all duration-200 transform hover:scale-[1.02]">
        <% if category.new_record? %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
          </svg>
          Create Category
        <% else %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Save Changes
        <% end %>
      </button>
    </div>
  </div>
<% end %>
