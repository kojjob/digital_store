<div class="card shadow mb-4">
  <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
    <h6 class="m-0 font-weight-bold text-primary">Download Links</h6>
    <div>
      <% if @order.product.digital_file.attached? && (@download_links.nil? || @download_links.empty?) %>
        <%= link_to generate_download_admin_payment_path(@order), method: :post, class: "btn btn-sm btn-success" do %>
          <i class="fas fa-plus fa-sm"></i> Generate New Link
        <% end %>
      <% end %>
    </div>
  </div>
  <div class="card-body">
    <% if @download_links&.any? %>
      <div class="table-responsive">
        <table class="table table-bordered" width="100%" cellspacing="0">
          <thead>
            <tr>
              <th>Link ID</th>
              <th>Created</th>
              <th>Expires</th>
              <th>Downloads</th>
              <th>Limit</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @download_links.each do |link| %>
              <tr>
                <td><%= link.id %></td>
                <td><%= link.created_at.strftime("%Y-%m-%d %H:%M") %></td>
                <td><%= link.expires_at.strftime("%Y-%m-%d %H:%M") %></td>
                <td><%= link.download_count %></td>
                <td><%= link.download_limit %></td>
                <td>
                  <% if link.expires_at < Time.current %>
                    <span class="badge badge-danger">Expired</span>
                  <% elsif link.download_count >= link.download_limit %>
                    <span class="badge badge-warning">Limit Reached</span>
                  <% else %>
                    <span class="badge badge-success">Active</span>
                  <% end %>
                </td>
                <td>
                  <div class="btn-group">
                    <%= link_to reset_download_admin_payment_path(@order, link_id: link.id), method: :post, class: "btn btn-sm btn-info", data: { confirm: "Reset download count and extend expiry date?" } do %>
                      <i class="fas fa-sync-alt"></i>
                    <% end %>
                    <%= link_to email_download_admin_payment_path(@order, link_id: link.id), method: :post, class: "btn btn-sm btn-primary" do %>
                      <i class="fas fa-envelope"></i>
                    <% end %>
                    <%= link_to revoke_download_admin_payment_path(@order, link_id: link.id), method: :delete, class: "btn btn-sm btn-danger", data: { confirm: "Are you sure you want to revoke this download link?" } do %>
                      <i class="fas fa-ban"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="alert alert-info">
        <% if @order.product.digital_file.attached? %>
          No download links have been generated for this order yet.
        <% else %>
          This product doesn't have a digital file attached.
        <% end %>
      </div>
    <% end %>
    
    <% if @order.product.digital_file.attached? %>
      <div class="mt-4">
        <h6 class="font-weight-bold">File Information</h6>
        <div class="row">
          <div class="col-md-6">
            <p><strong>Filename:</strong> <%= @order.product.digital_file.filename %></p>
            <p><strong>Size:</strong> <%= number_to_human_size(@order.product.digital_file.byte_size) %></p>
          </div>
          <div class="col-md-6">
            <p><strong>Content Type:</strong> <%= @order.product.digital_file.content_type %></p>
            <p><strong>Upload Date:</strong> <%= @order.product.digital_file.created_at.strftime("%Y-%m-%d %H:%M") %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
