<div class="p-4 sm:p-6 lg:p-8">
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-2xl font-semibold text-gray-900">Order Details #<%= @order.id %></h1>
      <p class="mt-2 text-sm text-gray-700">
        Complete information about this order and its payment status.
      </p>
    </div>
    <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
      <a href="<%= admin_payments_path %>" class="inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 sm:w-auto">
        Back to Payments
      </a>
    </div>
  </div>

  <!-- Order and Payment Info -->
  <div class="mt-8 overflow-hidden bg-white shadow sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg font-medium leading-6 text-gray-900">Order Information</h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">Order details and payment information.</p>
    </div>
    <div class="border-t border-gray-200 px-4 py-5 sm:p-0">
      <dl class="sm:divide-y sm:divide-gray-200">
        <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Order ID</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
            #<%= @order.id %>
          </dd>
        </div>
        <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Customer</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
            <%= @order.user.full_name %> (<%= @order.user.email %>)
          </dd>
        </div>
        <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Product</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
            <%= @order.product.name %>
            <% if @order.product.is_digital? %>
              <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                Digital
              </span>
            <% end %>
          </dd>
        </div>
        <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Total Amount</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
            $<%= number_with_precision(@order.total_amount, precision: 2) %>
          </dd>
        </div>
        <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Payment Processor</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
            <%= @order.payment_processor&.capitalize || 'Unknown' %>
          </dd>
        </div>
        <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Payment ID</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
            <code class="px-2 py-1 bg-gray-100 rounded"><%= @order.payment_id %></code>
          </dd>
        </div>
        <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Status</dt>
          <dd class="mt-1 text-sm sm:col-span-2 sm:mt-0">
            <span class="inline-flex rounded-full px-2 text-xs font-semibold leading-5 
                <%= @order.status == 'paid' ? 'bg-green-100 text-green-800' : 
                  @order.status == 'pending' ? 'bg-yellow-100 text-yellow-800' : 
                  @order.status == 'failed' ? 'bg-red-100 text-red-800' : 
                  'bg-gray-100 text-gray-800' %>">
                <%= @order.status&.capitalize || 'Unknown' %>
            </span>
          </dd>
        </div>
        <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Payment Status</dt>
          <dd class="mt-1 text-sm sm:col-span-2 sm:mt-0">
            <span class="inline-flex rounded-full px-2 text-xs font-semibold leading-5 
                <%= @order.payment_status == 'paid' ? 'bg-green-100 text-green-800' : 
                  @order.payment_status == 'pending' ? 'bg-yellow-100 text-yellow-800' : 
                  @order.payment_status == 'failed' ? 'bg-red-100 text-red-800' : 
                  'bg-gray-100 text-gray-800' %>">
                <%= @order.payment_status&.capitalize || 'Unknown' %>
            </span>
          </dd>
        </div>
        <% if @order.payment_details.present? %>
          <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:py-5 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Payment Details</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
              <div class="bg-gray-50 rounded p-3">
                <pre class="whitespace-pre-wrap"><%= JSON.pretty_generate(JSON.parse(@order.payment_details)) rescue @order.payment_details %></pre>
              </div>
            </dd>
          </div>
        <% end %>
        <% if @order.notes.present? %>
          <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:py-5 sm:px-6">
            <dt class="text-sm font-medium text-gray-500">Notes</dt>
            <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
              <%= @order.notes %>
            </dd>
          </div>
        <% end %>
        <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Created At</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
            <%= @order.created_at.strftime("%B %d, %Y at %I:%M %p") %>
            (<%= time_ago_in_words(@order.created_at) %> ago)
          </dd>
        </div>
        <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Last Updated</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
            <%= @order.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
            (<%= time_ago_in_words(@order.updated_at) %> ago)
          </dd>
        </div>
      </dl>
    </div>
  </div>

  <!-- Update Order Status -->
  <div class="mt-8 overflow-hidden bg-white shadow sm:rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <h3 class="text-lg font-medium leading-6 text-gray-900">Update Order Status</h3>
      <div class="mt-2 max-w-xl text-sm text-gray-500">
        <p>Manually update the status of this order. This should only be done in exceptional circumstances.</p>
      </div>
      <div class="mt-5">
        <%= form_with model: [:admin, @order], url: admin_payment_path(@order), method: :patch, local: true, class: "space-y-5" do |f| %>
          <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
            <div class="sm:col-span-3">
              <%= f.label :status, class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1">
                <%= f.select :status, 
                  options_for_select([
                    ['Pending', 'pending'],
                    ['Paid', 'paid'],
                    ['Failed', 'failed'],
                    ['Cancelled', 'cancelled']
                  ], @order.status),
                  {}, { class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" } %>
              </div>
            </div>

            <div class="sm:col-span-3">
              <%= f.label :payment_status, class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1">
                <%= f.select :payment_status, 
                  options_for_select([
                    ['Pending', 'pending'],
                    ['Paid', 'paid'],
                    ['Failed', 'failed'],
                    ['Cancelled', 'cancelled']
                  ], @order.payment_status),
                  {}, { class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" } %>
              </div>
            </div>
            
            <div class="sm:col-span-6">
              <%= f.label :notes, class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1">
                <%= f.text_area :notes, rows: 3, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md", placeholder: "Add notes about this order or why you're changing its status" %>
              </div>
            </div>
          </div>

          <div class="flex justify-end">
            <%= f.submit "Update Order", class: "ml-3 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Download Links (if digital product) -->
  <% if @order.product.is_digital? %>
    <div class="mt-8 overflow-hidden bg-white shadow sm:rounded-lg">
      <div class="px-4 py-5 sm:px-6">
        <h3 class="text-lg font-medium leading-6 text-gray-900">Download Links</h3>
        <p class="mt-1 max-w-2xl text-sm text-gray-500">Download links associated with this order.</p>
      </div>
      <div class="border-t border-gray-200">
        <% if @download_links && @download_links.any? %>
          <ul role="list" class="divide-y divide-gray-200">
            <% @download_links.each do |link| %>
              <li class="px-4 py-4 sm:px-6">
                <div class="flex items-center justify-between">
                  <div class="text-sm font-medium text-indigo-600">
                    <a href="<%= admin_download_path(link) %>" class="hover:underline">
                      <%= link.file_name %>
                    </a>
                  </div>
                  <div class="ml-2 flex flex-shrink-0">
                    <span class="inline-flex rounded-full px-2 text-xs font-semibold leading-5 
                      <%= link.valid_for_download? ? 'bg-green-100 text-green-800' : 
                        link.expired? ? 'bg-red-100 text-red-800' : 
                        link.download_limit_reached? ? 'bg-yellow-100 text-yellow-800' : 
                        'bg-gray-100 text-gray-800' %>">
                      <%= link.valid_for_download? ? 'Active' : 
                        link.expired? ? 'Expired' : 
                        link.download_limit_reached? ? 'Limit Reached' : 
                        'Inactive' %>
                    </span>
                  </div>
                </div>
                <div class="mt-2 sm:flex sm:justify-between">
                  <div class="sm:flex">
                    <p class="flex items-center text-sm text-gray-500">
                      <svg class="mr-1.5 h-5 w-5 flex-shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
                      </svg>
                      <%= link.download_count %> / <%= link.download_limit.zero? ? '∞' : link.download_limit %>
                    </p>
                    <p class="mt-2 flex items-center text-sm text-gray-500 sm:mt-0 sm:ml-6">
                      <svg class="mr-1.5 h-5 w-5 flex-shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                      </svg>
                      <%= link.expiration_in_words %>
                    </p>
                  </div>
                  <div class="mt-2 flex items-center text-sm text-gray-500 sm:mt-0">
                    <a href="<%= admin_download_path(link) %>" class="text-indigo-600 hover:text-indigo-900">
                      Manage
                    </a>
                  </div>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="px-4 py-4 sm:px-6 text-sm text-gray-500 italic">
            No download links have been created for this order.
            <% if @order.status == 'paid' && @order.product.digital_file.attached? %>
              <div class="mt-4">
                <button type="button" class="inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-indigo-700 bg-indigo-100 hover:bg-indigo-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                  Generate Download Link
                </button>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>