<!-- Order Details Page with Modern UI -->
<div class="min-h-screen bg-gray-50" data-controller="order-tabs">
  <!-- Page Header -->
  <div class="bg-gradient-to-r from-blue-600 to-indigo-700 mb-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
          <div class="flex items-center">
            <div class="bg-blue-800 bg-opacity-30 rounded-lg p-2 mr-4">
              <svg class="h-8 w-8 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
              </svg>
            </div>
            <h1 class="text-2xl font-bold leading-7 text-white sm:text-3xl sm:truncate">
              Order #<%= @order.id %>
              <span class="inline-flex items-center ml-2 px-3 py-0.5 rounded-full text-sm font-medium
                <%= @order.status == 'paid' ? 'bg-green-100 text-green-800' : 
                   @order.status == 'pending' ? 'bg-yellow-100 text-yellow-800' : 
                   'bg-red-100 text-red-800' %>">
                <%= @order.status.capitalize %>
              </span>
            </h1>
          </div>
          <p class="mt-1 text-sm text-blue-100">
            <%= @order.created_at.strftime("%B %d, %Y at %I:%M %p") %> • <%= @order.user.email %>
          </p>
        </div>
        <div class="mt-4 flex md:mt-0 md:ml-4 space-x-3">
          <%= link_to admin_payments_path, class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-800 bg-opacity-30 hover:bg-opacity-40 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
            <svg class="-ml-1 mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Orders
          <% end %>
          
          <% if @order.status == "paid" %>
            <button type="button" data-action="click->order-tabs#openModal" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-800 bg-opacity-30 hover:bg-opacity-40 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
              <svg class="-ml-1 mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              Send Receipt
            </button>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Tab Navigation -->
    <div class="mb-6 bg-white shadow rounded-lg">
      <div class="px-4 sm:px-6 lg:px-8">
        <nav class="-mb-px flex space-x-8">
          <button 
            type="button"
            data-order-tabs-target="tab" 
            data-tab="details"
            data-action="order-tabs#switchTab"
            class="<%= @active_tab == 'details' ? 'border-blue-500 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' %> whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm"
          >
            Order Details
          </button>
          
          <% if @order.product.is_digital? %>
            <button 
              type="button"
              data-order-tabs-target="tab" 
              data-tab="downloads"
              data-action="order-tabs#switchTab"
              class="<%= @active_tab == 'downloads' ? 'border-blue-500 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' %> whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm"
            >
              Downloads
            </button>
          <% end %>
          
          <button 
            type="button"
            data-order-tabs-target="tab" 
            data-tab="audit"
            data-action="order-tabs#switchTab"
            class="<%= @active_tab == 'audit' ? 'border-blue-500 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' %> whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm flex items-center"
          >
            Audit Log
            <% if @audit_logs.where(event_type: 'signature_invalid').any? %>
              <span class="ml-2 inline-flex items-center justify-center h-5 w-5 rounded-full bg-red-100">
                <span class="text-xs font-medium text-red-600">!</span>
              </span>
            <% end %>
          </button>
        </nav>
      </div>
    </div>

    <!-- Tab Content -->
    <div class="tab-content mb-8">
      <!-- Order Details Tab -->
      <div 
        data-order-tabs-target="tabContent" 
        data-tab="details"
        class="<%= @active_tab == 'details' ? '' : 'hidden' %>"
      >
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
          <!-- Order Summary Card -->
          <div class="lg:col-span-2">
            <div class="bg-white shadow rounded-lg overflow-hidden">
              <div class="px-4 py-5 sm:p-6">
                <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Order Summary</h3>
                
                <div class="flex items-center p-4 bg-gray-50 rounded-lg mb-4">
                  <div class="flex-shrink-0 h-16 w-16 rounded-md bg-gray-200 overflow-hidden mr-4">
                    <% if @order.product.primary_image.present? && @order.product.primary_image.attached? %>
                      <%= image_tag @order.product.primary_image, class: "h-full w-full object-cover" %>
                    <% else %>
                      <div class="flex items-center justify-center h-full w-full bg-gray-200">
                        <svg class="h-8 w-8 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                      </div>
                    <% end %>
                  </div>
                  <div>
                    <h4 class="text-lg font-medium text-gray-900"><%= @order.product.name %></h4>
                    <p class="text-sm text-gray-500">
                      <%= @order.product.is_digital? ? "Digital Product" : "Physical Product" %> •
                      Seller: <%= @order.product.seller.user.full_name %>
                    </p>
                  </div>
                  <div class="ml-auto text-right">
                    <span class="text-xl font-bold text-gray-900">$<%= @order.total_amount %></span>
                    <p class="text-sm text-gray-500">Qty: 1</p>
                  </div>
                </div>
                
                <div class="border-t border-gray-200 mt-6 pt-4">
                  <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2">
                    <div class="sm:col-span-1">
                      <dt class="text-sm font-medium text-gray-500">Payment Method</dt>
                      <dd class="mt-1 text-sm text-gray-900 flex items-center">
                        <svg class="h-5 w-5 mr-1.5 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                        </svg>
                        <%= @order.payment_method || "Credit Card" %>
                      </dd>
                    </div>
                    <div class="sm:col-span-1">
                      <dt class="text-sm font-medium text-gray-500">Transaction ID</dt>
                      <dd class="mt-1 text-sm text-gray-900"><%= @order.transaction_id || "N/A" %></dd>
                    </div>
                    <div class="sm:col-span-1">
                      <dt class="text-sm font-medium text-gray-500">Purchase Date</dt>
                      <dd class="mt-1 text-sm text-gray-900"><%= @order.created_at.strftime("%B %d, %Y") %></dd>
                    </div>
                    <div class="sm:col-span-1">
                      <dt class="text-sm font-medium text-gray-500">Purchase Time</dt>
                      <dd class="mt-1 text-sm text-gray-900"><%= @order.created_at.strftime("%I:%M %p") %></dd>
                    </div>
                  </dl>
                </div>
              </div>
            </div>
          </div>

          <!-- Customer Information Card -->
          <div class="lg:col-span-1">
            <div class="bg-white shadow rounded-lg overflow-hidden">
              <div class="px-4 py-5 sm:p-6">
                <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Customer Information</h3>
                
                <div class="flex items-center mb-4">
                  <div class="flex-shrink-0">
                    <% if @order.user.profile_picture.attached? %>
                      <%= image_tag @order.user.profile_picture.variant(resize_to_fill: [40, 40]), class: "h-10 w-10 rounded-full" %>
                    <% else %>
                      <span class="inline-block h-10 w-10 rounded-full overflow-hidden bg-gray-100">
                        <svg class="h-full w-full text-gray-300" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" />
                        </svg>
                      </span>
                    <% end %>
                  </div>
                  <div class="ml-3">
                    <h4 class="text-sm font-medium text-gray-900"><%= @order.user.full_name %></h4>
                    <p class="text-sm text-gray-500"><%= @order.user.email %></p>
                  </div>
                </div>
                
                <dl class="mt-4 space-y-3">
                  <div>
                    <dt class="text-sm font-medium text-gray-500">Account Created</dt>
                    <dd class="mt-1 text-sm text-gray-900"><%= @order.user.created_at.strftime("%B %d, %Y") %></dd>
                  </div>
                  <div>
                    <dt class="text-sm font-medium text-gray-500">Total Orders</dt>
                    <dd class="mt-1 text-sm text-gray-900"><%= @order.user.orders.count %></dd>
                  </div>
                  <div>
                    <dt class="text-sm font-medium text-gray-500">Total Spent</dt>
                    <dd class="mt-1 text-sm text-gray-900">$<%= @order.user.orders.sum(:total_amount) %></dd>
                  </div>
                </dl>
                
                <div class="mt-5">
                  <%= link_to super_admin_user_path(@order.user), class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 w-full justify-center" do %>
                    View Customer Profile
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Order Timeline -->
        <div class="mt-6">
          <div class="bg-white shadow rounded-lg overflow-hidden">
            <div class="px-4 py-5 sm:p-6">
              <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Order Timeline</h3>
              
              <div class="flow-root">
                <ul class="-mb-8">
                  <li>
                    <div class="relative pb-8">
                      <span class="absolute top-4 left-4 -ml-px h-full w-0.5 bg-gray-200" aria-hidden="true"></span>
                      <div class="relative flex space-x-3">
                        <div>
                          <span class="h-8 w-8 rounded-full bg-green-400 flex items-center justify-center ring-8 ring-white">
                            <svg class="h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                            </svg>
                          </span>
                        </div>
                        <div class="min-w-0 flex-1 pt-1.5 flex justify-between space-x-4">
                          <div>
                            <p class="text-sm text-gray-500">Order created</p>
                          </div>
                          <div class="text-right text-sm whitespace-nowrap text-gray-500">
                            <%= @order.created_at.strftime("%b %d, %Y") %>
                          </div>
                        </div>
                      </div>
                    </div>
                  </li>
                  
                  <li>
                    <div class="relative pb-8">
                      <% if @order.status == "paid" %>
                        <span class="absolute top-4 left-4 -ml-px h-full w-0.5 bg-gray-200" aria-hidden="true"></span>
                      <% end %>
                      <div class="relative flex space-x-3">
                        <div>
                          <span class="h-8 w-8 rounded-full <%= @order.status == "paid" ? "bg-green-400" : "bg-gray-300" %> flex items-center justify-center ring-8 ring-white">
                            <svg class="h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                              <path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
                            </svg>
                          </span>
                        </div>
                        <div class="min-w-0 flex-1 pt-1.5 flex justify-between space-x-4">
                          <div>
                            <p class="text-sm text-gray-500">Payment <%= @order.status == "paid" ? "processed" : "pending" %></p>
                          </div>
                          <div class="text-right text-sm whitespace-nowrap text-gray-500">
                            <%= @order.paid_at&.strftime("%b %d, %Y") || "Pending" %>
                          </div>
                        </div>
                      </div>
                    </div>
                  </li>
                  
                  <% if @order.status == "paid" && @order.product.is_digital? %>
                    <li>
                      <div class="relative">
                        <div class="relative flex space-x-3">
                          <div>
                            <span class="h-8 w-8 rounded-full bg-blue-400 flex items-center justify-center ring-8 ring-white">
                              <svg class="h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
                              </svg>
                            </span>
                          </div>
                          <div class="min-w-0 flex-1 pt-1.5 flex justify-between space-x-4">
                            <div>
                              <p class="text-sm text-gray-500">Digital delivery enabled</p>
                            </div>
                            <div class="text-right text-sm whitespace-nowrap text-gray-500">
                              <%= @order.paid_at&.strftime("%b %d, %Y") || "N/A" %>
                            </div>
                          </div>
                        </div>
                      </div>
                    </li>
                  <% end %>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Downloads Tab -->
      <% if @order.product.is_digital? %>
        <div 
          data-order-tabs-target="tabContent" 
          data-tab="downloads"
          class="<%= @active_tab == 'downloads' ? '' : 'hidden' %>"
        >
          <%= render 'admin/payments/tabs/downloads' %>
        </div>
      <% end %>
      
      <!-- Audit Log Tab -->
      <div 
        data-order-tabs-target="tabContent" 
        data-tab="audit"
        class="<%= @active_tab == 'audit' ? '' : 'hidden' %>"
      >
        <%= render 'admin/payments/tabs/audit_log' %>
      </div>
    </div>
  </div>
  
  <!-- Email Modal -->
  <div data-order-tabs-target="modal" class="fixed inset-0 overflow-y-auto hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
      <!-- Background overlay -->
      <div data-order-tabs-target="modalOverlay" data-action="click->order-tabs#closeModal" class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"></div>

      <!-- Modal panel -->
      <div class="inline-block align-bottom bg-white rounded-lg px-4 pt-5 pb-4 text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full sm:p-6">
        <div class="sm:flex sm:items-start">
          <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-blue-100 sm:mx-0 sm:h-10 sm:w-10">
            <svg class="h-6 w-6 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left">
            <h3 class="text-lg leading-6 font-medium text-gray-900" id="modal-title">
              Send Receipt
            </h3>
            <div class="mt-2">
              <p class="text-sm text-gray-500">
                Send a receipt email for this order. You can customize the recipient and include an additional message.
              </p>
            </div>
          </div>
        </div>
        
        <%= form_tag resend_receipt_admin_payment_path(@order), method: :post, class: "mt-5" do %>
          <div class="mb-4">
            <label for="recipient" class="block text-sm font-medium text-gray-700">Email Address</label>
            <input type="email" name="recipient" id="recipient" value="<%= @order.user.email %>" required class="mt-1 focus:ring-blue-500 focus:border-blue-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md">
          </div>
          <div class="mb-4">
            <label for="message" class="block text-sm font-medium text-gray-700">Additional Message (Optional)</label>
            <textarea id="message" name="message" rows="3" class="mt-1 focus:ring-blue-500 focus:border-blue-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md"></textarea>
          </div>
          
          <div class="mt-5 sm:mt-4 sm:flex sm:flex-row-reverse">
            <button type="submit" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:ml-3 sm:w-auto sm:text-sm">
              Send Receipt
            </button>
            <button type="button" data-action="order-tabs#closeModal" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:mt-0 sm:w-auto sm:text-sm">
              Cancel
            </button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>