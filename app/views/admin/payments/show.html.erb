<div class="container-fluid">
  <!-- Page Heading -->
  <div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Order #<%= @order.id %></h1>
    <div>
      <%= link_to admin_payments_path, class: "btn btn-sm btn-secondary" do %>
        <i class="fas fa-arrow-left fa-sm text-white-50 mr-2"></i>Back to Orders
      <% end %>
      
      <% if @order.status == "paid" %>
        <%= link_to "#", class: "btn btn-sm btn-primary ml-2", data: { toggle: "modal", target: "#emailModal" } do %>
          <i class="fas fa-envelope fa-sm text-white-50 mr-2"></i>Send Receipt
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Tab Navigation -->
  <div class="mb-4">
    <ul class="nav nav-tabs" id="orderTabs" role="tablist">
      <li class="nav-item">
        <a class="nav-link <%= @active_tab == 'details' ? 'active' : '' %>" id="details-tab" data-toggle="tab" href="#details" role="tab" aria-controls="details" aria-selected="<%= @active_tab == 'details' ? 'true' : 'false' %>">
          Order Details
        </a>
      </li>
      
      <% if @order.product.is_digital? %>
        <li class="nav-item">
          <a class="nav-link <%= @active_tab == 'downloads' ? 'active' : '' %>" id="downloads-tab" data-toggle="tab" href="#downloads" role="tab" aria-controls="downloads" aria-selected="<%= @active_tab == 'downloads' ? 'true' : 'false' %>">
            Downloads
          </a>
        </li>
      <% end %>
      
      <li class="nav-item">
        <a class="nav-link <%= @active_tab == 'audit' ? 'active' : '' %>" id="audit-tab" data-toggle="tab" href="#audit" role="tab" aria-controls="audit" aria-selected="<%= @active_tab == 'audit' ? 'true' : 'false' %>">
          Audit Log <% if @audit_logs.where(event_type: 'signature_invalid').any? %><span class="badge badge-danger">!</span><% end %>
        </a>
      </li>
    </ul>
  </div>

  <!-- Tab Content -->
  <div class="tab-content" id="orderTabContent">
    <!-- Order Details Tab -->
    <div class="tab-pane fade <%= @active_tab == 'details' ? 'show active' : '' %>" id="details" role="tabpanel" aria-labelledby="details-tab">
      <%= render 'admin/payments/tabs/details' %>
    </div>
    
    <!-- Downloads Tab -->
    <% if @order.product.is_digital? %>
      <div class="tab-pane fade <%= @active_tab == 'downloads' ? 'show active' : '' %>" id="downloads" role="tabpanel" aria-labelledby="downloads-tab">
        <%= render 'admin/payments/tabs/downloads' %>
      </div>
    <% end %>
    
    <!-- Audit Log Tab -->
    <div class="tab-pane fade <%= @active_tab == 'audit' ? 'show active' : '' %>" id="audit" role="tabpanel" aria-labelledby="audit-tab">
      <%= render 'admin/payments/tabs/audit_log' %>
    </div>
  </div>
</div>

<!-- Email Modal -->
<div class="modal fade" id="emailModal" tabindex="-1" role="dialog" aria-labelledby="emailModalLabel" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="emailModalLabel">Send Receipt</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <%= form_tag resend_receipt_admin_payment_path(@order), method: :post do %>
          <div class="form-group">
            <label for="recipient">Email Address</label>
            <input type="email" class="form-control" id="recipient" name="recipient" value="<%= @order.user.email %>" required>
          </div>
          <div class="form-group">
            <label for="message">Additional Message (Optional)</label>
            <textarea class="form-control" id="message" name="message" rows="3"></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Send Receipt</button>
        <% end %>
      </div>
    </div>
  </div>
</div>
