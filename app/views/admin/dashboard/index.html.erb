<div class="p-4 sm:p-6 lg:p-8">
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-2xl font-semibold text-gray-900">Admin Dashboard</h1>
      <p class="mt-2 text-sm text-gray-700">Overview of store performance, digital downloads, and payment activity.</p>
    </div>
    <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
      <a href="<%= admin_analytics_path %>" class="inline-flex items-center justify-center rounded-md border border-transparent bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 sm:w-auto">
        View Analytics
      </a>
    </div>
  </div>

  <!-- Stats Overview -->
  <div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
    <div class="overflow-hidden rounded-lg bg-white shadow">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="truncate text-sm font-medium text-gray-500">Total Revenue</dt>
              <dd class="text-lg font-medium text-gray-900">$<%= number_with_precision(@total_revenue, precision: 2) %></dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <a href="<%= admin_payments_path %>" class="font-medium text-indigo-700 hover:text-indigo-900">View all payments</a>
        </div>
      </div>
    </div>

    <div class="overflow-hidden rounded-lg bg-white shadow">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="truncate text-sm font-medium text-gray-500">Orders Today</dt>
              <dd class="text-lg font-medium text-gray-900"><%= @orders_today %></dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <a href="<%= admin_payments_path(filter: 'today') %>" class="font-medium text-indigo-700 hover:text-indigo-900">View today's orders</a>
        </div>
      </div>
    </div>

    <div class="overflow-hidden rounded-lg bg-white shadow">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="truncate text-sm font-medium text-gray-500">Downloads Today</dt>
              <dd class="text-lg font-medium text-gray-900"><%= @downloads_today %></dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <a href="<%= admin_downloads_path %>" class="font-medium text-indigo-700 hover:text-indigo-900">View all downloads</a>
        </div>
      </div>
    </div>

    <div class="overflow-hidden rounded-lg bg-white shadow">
      <div class="p-5">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="truncate text-sm font-medium text-gray-500">Expiring Links</dt>
              <dd class="text-lg font-medium text-gray-900"><%= @expiring_links.count %></dd>
            </dl>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 px-5 py-3">
        <div class="text-sm">
          <a href="<%= admin_downloads_path(filter: 'expiring') %>" class="font-medium text-indigo-700 hover:text-indigo-900">View expiring links</a>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">
    <!-- Recent Orders -->
    <div class="overflow-hidden bg-white shadow sm:rounded-md">
      <div class="px-4 py-5 sm:px-6">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-medium leading-6 text-gray-900">Recent Orders</h2>
          <a href="<%= admin_payments_path %>" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">View all</a>
        </div>
      </div>
      <ul role="list" class="divide-y divide-gray-200">
        <% @recent_orders.each do |order| %>
          <li>
            <a href="<%= admin_payment_path(order) %>" class="block hover:bg-gray-50">
              <div class="px-4 py-4 sm:px-6">
                <div class="flex items-center justify-between">
                  <p class="truncate text-sm font-medium text-indigo-600">Order #<%= order.id %></p>
                  <div class="ml-2 flex flex-shrink-0">
                    <p class="inline-flex rounded-full px-2 text-xs font-semibold leading-5 
                        <%= order.status == 'paid' ? 'bg-green-100 text-green-800' : 
                          order.status == 'pending' ? 'bg-yellow-100 text-yellow-800' : 
                          'bg-red-100 text-red-800' %>">
                      <%= order.status.capitalize %>
                    </p>
                  </div>
                </div>
                <div class="mt-2 flex justify-between">
                  <div class="sm:flex">
                    <p class="flex items-center text-sm text-gray-500">
                      <svg class="mr-1.5 h-5 w-5 flex-shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                      </svg>
                      <%= order.user.email %>
                    </p>
                    <p class="mt-2 flex items-center text-sm text-gray-500 sm:mt-0 sm:ml-6">
                      <svg class="mr-1.5 h-5 w-5 flex-shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z" />
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd" />
                      </svg>
                      $<%= order.total_amount %>
                    </p>
                  </div>
                  <div class="flex items-center text-sm text-gray-500">
                    <svg class="mr-1.5 h-5 w-5 flex-shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                    </svg>
                    <p><%= time_ago_in_words(order.created_at) %> ago</p>
                  </div>
                </div>
              </div>
            </a>
          </li>
        <% end %>
      </ul>
    </div>

    <!-- Recent Downloads -->
    <div class="overflow-hidden bg-white shadow sm:rounded-md">
      <div class="px-4 py-5 sm:px-6">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-medium leading-6 text-gray-900">Recent Downloads</h2>
          <a href="<%= admin_downloads_path %>" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">View all</a>
        </div>
      </div>
      <ul role="list" class="divide-y divide-gray-200">
        <% @recent_downloads.each do |download| %>
          <li>
            <a href="<%= admin_download_path(download) %>" class="block hover:bg-gray-50">
              <div class="px-4 py-4 sm:px-6">
                <div class="flex items-center justify-between">
                  <p class="truncate text-sm font-medium text-indigo-600"><%= download.product.name %></p>
                  <div class="ml-2 flex flex-shrink-0">
                    <p class="inline-flex rounded-full px-2 text-xs font-semibold leading-5 
                        <%= download.valid_for_download? ? 'bg-green-100 text-green-800' : 
                          download.expired? ? 'bg-red-100 text-red-800' : 
                          download.download_limit_reached? ? 'bg-yellow-100 text-yellow-800' : 
                          'bg-gray-100 text-gray-800' %>">
                      <%= download.valid_for_download? ? 'Active' : 
                        download.expired? ? 'Expired' : 
                        download.download_limit_reached? ? 'Limit Reached' : 
                        'Inactive' %>
                    </p>
                  </div>
                </div>
                <div class="mt-2 flex justify-between">
                  <div class="sm:flex">
                    <p class="flex items-center text-sm text-gray-500">
                      <svg class="mr-1.5 h-5 w-5 flex-shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                      </svg>
                      <%= download.user.email %>
                    </p>
                    <p class="mt-2 flex items-center text-sm text-gray-500 sm:mt-0 sm:ml-6">
                      <svg class="mr-1.5 h-5 w-5 flex-shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
                      </svg>
                      <%= download.download_count %> / <%= download.download_limit.zero? ? '∞' : download.download_limit %>
                    </p>
                  </div>
                  <div class="flex items-center text-sm text-gray-500">
                    <svg class="mr-1.5 h-5 w-5 flex-shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                    </svg>
                    <p><%= download.expiration_in_words %></p>
                  </div>
                </div>
              </div>
            </a>
          </li>
        <% end %>
      </ul>
    </div>
  </div>

  <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">
    <!-- Payment Methods Chart -->
    <div class="overflow-hidden bg-white shadow sm:rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg font-medium leading-6 text-gray-900">Payment Methods</h3>
        <div class="mt-5">
          <div class="overflow-hidden rounded-lg bg-gray-50 shadow">
            <div class="px-4 py-5 sm:p-6">
              <% @payment_methods.each do |processor, count| %>
                <div class="flex items-center justify-between py-1">
                  <div class="flex items-center">
                    <span class="text-sm font-medium text-gray-900">
                      <%= processor&.capitalize || 'Unknown' %>
                    </span>
                  </div>
                  <div class="text-sm text-gray-500">
                    <%= count %> orders
                  </div>
                </div>
                <div class="mt-1 w-full rounded-full bg-gray-200">
                  <div class="h-2 rounded-full <%= processor == 'stripe' ? 'bg-indigo-600' : processor == 'paypal' ? 'bg-green-500' : 'bg-gray-500' %>" style="width: <%= (count.to_f / @payment_methods.values.sum * 100).round %>%"></div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Popular Products -->
    <div class="overflow-hidden bg-white shadow sm:rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg font-medium leading-6 text-gray-900">Popular Products</h3>
        <div class="mt-5 flow-root">
          <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
            <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
              <table class="min-w-full divide-y divide-gray-300">
                <thead>
                  <tr>
                    <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-0">Product</th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Price</th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Sales</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                  <% @popular_products.each do |product| %>
                    <tr>
                      <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm sm:pl-0">
                        <div class="flex items-center">
                          <div class="h-10 w-10 flex-shrink-0">
                            <% if product.respond_to?(:primary_image_url) && product.primary_image_url.present? %>
                              <img class="h-10 w-10 rounded-full" src="<%= product.primary_image_url %>" alt="">
                            <% else %>
                              <div class="h-10 w-10 rounded-full bg-gray-200 flex items-center justify-center">
                                <svg class="h-6 w-6 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                              </div>
                            <% end %>
                          </div>
                          <div class="ml-4">
                            <div class="font-medium text-gray-900"><%= product.name %></div>
                            <div class="text-gray-500"><%= product.is_digital? ? 'Digital' : 'Physical' %></div>
                          </div>
                        </div>
                      </td>
                      <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">$<%= product.price %></td>
                      <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500"><%= product.sales_count %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>