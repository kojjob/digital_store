<!-- Redesigned Super Admin Dashboard with Stimulus Integration -->
<div data-controller="dashboard" class="flex h-screen bg-gray-50">
  <!-- Sidebar navigation -->
  <div data-dashboard-target="sidebar" class="hidden lg:flex lg:flex-shrink-0">
    <div class="flex flex-col w-64 border-r border-gray-200 bg-white">
      <div class="flex items-center h-16 flex-shrink-0 px-4 border-b border-gray-200">
        <h2 class="text-lg font-medium text-red-600">Digital Store</h2>
      </div>
      <div class="flex flex-col flex-grow overflow-y-auto">
        <nav class="flex-1 px-2 py-4 space-y-1">
          <a href="<%= super_admin_dashboard_path %>" class="flex items-center px-2 py-2 text-sm font-medium text-red-600 bg-red-50 rounded-md group">
            <svg class="mr-3 h-6 w-6 text-red-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            Dashboard
          </a>
          <a href="<%= super_admin_users_path %>" class="flex items-center px-2 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50 hover:text-gray-900 rounded-md group">
            <svg class="mr-3 h-6 w-6 text-gray-400 group-hover:text-gray-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            Users
          </a>
          <a href="<%= super_admin_finance_path %>" class="flex items-center px-2 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50 hover:text-gray-900 rounded-md group">
            <svg class="mr-3 h-6 w-6 text-gray-400 group-hover:text-gray-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Finances
          </a>
          <a href="<%= admin_payments_path %>" class="flex items-center px-2 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50 hover:text-gray-900 rounded-md group">
            <svg class="mr-3 h-6 w-6 text-gray-400 group-hover:text-gray-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            Orders
          </a>
          <a href="<%= super_admin_products_path rescue '#' %>" class="flex items-center px-2 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50 hover:text-gray-900 rounded-md group">
            <svg class="mr-3 h-6 w-6 text-gray-400 group-hover:text-gray-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            Products
          </a>
        </nav>
      </div>
    </div>
  </div>

  <!-- Main content area -->
  <div class="flex flex-col flex-1 overflow-hidden">
    <!-- Top navbar -->
    <div class="relative z-10 flex-shrink-0 flex h-16 bg-white border-b border-gray-200">
      <button 
        type="button" 
        data-dashboard-target="sidebarToggle" 
        data-action="dashboard#toggleSidebar" 
        class="lg:hidden px-4 text-gray-500 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-red-500"
      >
        <span class="sr-only">Open sidebar</span>
        <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
        </svg>
      </button>
      <div class="flex-1 px-4 flex justify-between">
        <div class="flex-1 flex">
          <h1 class="text-2xl font-bold text-gray-900 self-center">Super Admin Portal</h1>
        </div>
        <div class="ml-4 flex items-center md:ml-6">
          <button type="button" class="bg-white p-1 rounded-full text-gray-400 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
            <span class="sr-only">View notifications</span>
            <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
            </svg>
          </button>

          <!-- Profile dropdown -->
          <div class="ml-3 relative">
            <div>
              <button type="button" class="max-w-xs bg-white rounded-full flex items-center text-sm focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" id="user-menu-button">
                <span class="sr-only">Open user menu</span>
                <span class="inline-block h-8 w-8 rounded-full overflow-hidden bg-gray-100">
                  <svg class="h-full w-full text-gray-300" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" />
                  </svg>
                </span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Main content -->
    <div class="flex-1 relative z-0 overflow-y-auto focus:outline-none">
      <!-- Hero section -->
      <div class="bg-gradient-to-r from-red-700 to-red-500 h-64 flex flex-col justify-center px-8 relative">
        <div class="text-white z-10">
          <h1 class="text-3xl md:text-4xl font-bold mb-2">Digital Store Dashboard</h1>
          <p class="text-red-100 max-w-3xl">Complete system overview with full control over all aspects of the application.</p>
        </div>
        
        <!-- Quick action buttons -->
        <div class="absolute bottom-0 right-0 p-4">
          <a href="<%= super_admin_finance_path %>" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-red-600 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
            Financial Dashboard
          </a>
        </div>
      </div>

      <!-- Dashboard tabs -->
      <div class="bg-white shadow">
        <div class="px-4 sm:px-6 lg:px-8">
          <div class="border-b border-gray-200">
            <nav class="-mb-px flex space-x-8">
              <button 
                type="button" 
                data-dashboard-target="tab" 
                data-tab="overview" 
                data-action="dashboard#switchTab" 
                class="border-red-500 text-red-600 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm"
              >
                Overview
              </button>
              <button 
                type="button" 
                data-dashboard-target="tab" 
                data-tab="users" 
                data-action="dashboard#switchTab" 
                class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm"
              >
                Users
              </button>
              <button 
                type="button" 
                data-dashboard-target="tab" 
                data-tab="products" 
                data-action="dashboard#switchTab" 
                class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm"
              >
                Products
              </button>
              <button 
                type="button" 
                data-dashboard-target="tab" 
                data-tab="orders" 
                data-action="dashboard#switchTab" 
                class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm"
              >
                Orders
              </button>
              <button 
                type="button" 
                data-dashboard-target="tab" 
                data-tab="analytics" 
                data-action="dashboard#switchTab" 
                class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm"
              >
                Analytics
              </button>
            </nav>
          </div>
        </div>
      </div>

      <!-- Overview Tab Content -->
      <div data-dashboard-target="tabContent" data-tab="overview" class="py-6">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
          <h2 class="text-lg font-medium text-gray-900 mb-4">Key Metrics</h2>
          
          <!-- Key metrics grid -->
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
            <!-- Total Users Card - Blue theme -->
            <div class="bg-gradient-to-br from-blue-500 to-blue-600 overflow-hidden rounded-lg shadow">
              <div class="px-4 py-5 sm:p-6">
                <div class="flex items-center">
                  <div class="flex-shrink-0 bg-blue-100 rounded-md p-3">
                    <svg class="h-6 w-6 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                    </svg>
                  </div>
                  <div class="ml-5 w-0 flex-1">
                    <dl>
                      <dt class="text-sm font-medium text-blue-100 truncate">Total Users</dt>
                      <dd class="flex items-baseline">
                        <div class="text-2xl font-semibold text-white"><%= @total_users %></div>
                        <% if @user_trend != 0 %>
                          <div class="ml-2 flex items-baseline text-sm font-semibold <%= @user_trend > 0 ? 'text-green-100' : 'text-red-100' %>">
                            <svg class="self-center flex-shrink-0 h-5 w-5 text-white" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                              <path fill-rule="evenodd" d="<%= @user_trend > 0 ? 'M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z' : 'M14.707 10.293a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L9 12.586V5a1 1 0 012 0v7.586l2.293-2.293a1 1 0 011.414 0z' %>" clip-rule="evenodd" />
                            </svg>
                            <%= @user_trend.abs %>%
                          </div>
                        <% end %>
                      </dd>
                    </dl>
                  </div>
                </div>
              </div>
              <div class="bg-blue-700 px-4 py-3">
                <div class="text-sm">
                  <a href="<%= super_admin_users_path %>" class="font-medium text-white hover:text-blue-100">View all users</a>
                </div>
              </div>
            </div>

            <!-- Admin Users Card - Green theme -->
            <div class="bg-gradient-to-br from-green-500 to-green-600 overflow-hidden rounded-lg shadow">
              <div class="px-4 py-5 sm:p-6">
                <div class="flex items-center">
                  <div class="flex-shrink-0 bg-green-100 rounded-md p-3">
                    <svg class="h-6 w-6 text-green-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4" />
                    </svg>
                  </div>
                  <div class="ml-5 w-0 flex-1">
                    <dl>
                      <dt class="text-sm font-medium text-green-100 truncate">Admin Users</dt>
                      <dd class="flex items-baseline">
                        <div class="text-2xl font-semibold text-white"><%= @admin_users %></div>
                      </dd>
                    </dl>
                  </div>
                </div>
              </div>
              <div class="bg-green-700 px-4 py-3">
                <div class="text-sm">
                  <a href="<%= super_admin_users_path(role: 'admin') %>" class="font-medium text-white hover:text-green-100">View admin users</a>
                </div>
              </div>
            </div>

            <!-- Super Admin Users Card - Purple theme -->
            <div class="bg-gradient-to-br from-purple-500 to-purple-600 overflow-hidden rounded-lg shadow">
              <div class="px-4 py-5 sm:p-6">
                <div class="flex items-center">
                  <div class="flex-shrink-0 bg-purple-100 rounded-md p-3">
                    <svg class="h-6 w-6 text-purple-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                  </div>
                  <div class="ml-5 w-0 flex-1">
                    <dl>
                      <dt class="text-sm font-medium text-purple-100 truncate">Super Admins</dt>
                      <dd class="flex items-baseline">
                        <div class="text-2xl font-semibold text-white"><%= @super_admin_users %></div>
                      </dd>
                    </dl>
                  </div>
                </div>
              </div>
              <div class="bg-purple-700 px-4 py-3">
                <div class="text-sm">
                  <a href="<%= super_admin_users_path(role: 'super_admin') %>" class="font-medium text-white hover:text-purple-100">View super admins</a>
                </div>
              </div>
            </div>

            <!-- Active Sellers Card - Yellow theme -->
            <div class="bg-gradient-to-br from-yellow-500 to-yellow-600 overflow-hidden rounded-lg shadow">
              <div class="px-4 py-5 sm:p-6">
                <div class="flex items-center">
                  <div class="flex-shrink-0 bg-yellow-100 rounded-md p-3">
                    <svg class="h-6 w-6 text-yellow-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <div class="ml-5 w-0 flex-1">
                    <dl>
                      <dt class="text-sm font-medium text-yellow-100 truncate">Active Sellers</dt>
                      <dd class="flex items-baseline">
                        <div class="text-2xl font-semibold text-white"><%= User.sellers.count %></div>
                      </dd>
                    </dl>
                  </div>
                </div>
              </div>
              <div class="bg-yellow-700 px-4 py-3">
                <div class="text-sm">
                  <a href="<%= super_admin_users_path(role: 'seller') %>" class="font-medium text-white hover:text-yellow-100">View sellers</a>
                </div>
              </div>
            </div>
          </div>

          <!-- Business Metrics -->
          <h2 class="text-lg font-medium text-gray-900 mt-8 mb-4">Business Metrics</h2>
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
            <!-- Total Products Card - Teal theme -->
            <div class="bg-gradient-to-br from-teal-500 to-teal-600 overflow-hidden rounded-lg shadow">
              <div class="px-4 py-5 sm:p-6">
                <div class="flex items-center">
                  <div class="flex-shrink-0 bg-teal-100 rounded-md p-3">
                    <svg class="h-6 w-6 text-teal-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                    </svg>
                  </div>
                  <div class="ml-5 w-0 flex-1">
                    <dl>
                      <dt class="text-sm font-medium text-teal-100 truncate">Total Products</dt>
                      <dd class="flex items-baseline">
                        <div class="text-2xl font-semibold text-white"><%= @total_products %></div>
                        <% if @product_trend != 0 %>
                          <div class="ml-2 flex items-baseline text-sm font-semibold <%= @product_trend > 0 ? 'text-green-100' : 'text-red-100' %>">
                            <svg class="self-center flex-shrink-0 h-5 w-5 text-white" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                              <path fill-rule="evenodd" d="<%= @product_trend > 0 ? 'M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z' : 'M14.707 10.293a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L9 12.586V5a1 1 0 012 0v7.586l2.293-2.293a1 1 0 011.414 0z' %>" clip-rule="evenodd" />
                            </svg>
                            <%= @product_trend.abs %>%
                          </div>
                        <% end %>
                      </dd>
                    </dl>
                  </div>
                </div>
              </div>
              <div class="bg-teal-700 px-4 py-3">
                <div class="text-sm text-white">
                  <%= @digital_products %> digital / <%= @physical_products %> physical
                </div>
              </div>
            </div>

            <!-- Total Orders Card - Orange theme -->
            <div class="bg-gradient-to-br from-orange-500 to-orange-600 overflow-hidden rounded-lg shadow">
              <div class="px-4 py-5 sm:p-6">
                <div class="flex items-center">
                  <div class="flex-shrink-0 bg-orange-100 rounded-md p-3">
                    <svg class="h-6 w-6 text-orange-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                  </div>
                  <div class="ml-5 w-0 flex-1">
                    <dl>
                      <dt class="text-sm font-medium text-orange-100 truncate">Total Orders</dt>
                      <dd class="flex items-baseline">
                        <div class="text-2xl font-semibold text-white"><%= @total_orders %></div>
                        <% if @order_trend != 0 %>
                          <div class="ml-2 flex items-baseline text-sm font-semibold <%= @order_trend > 0 ? 'text-green-100' : 'text-red-100' %>">
                            <svg class="self-center flex-shrink-0 h-5 w-5 text-white" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                              <path fill-rule="evenodd" d="<%= @order_trend > 0 ? 'M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z' : 'M14.707 10.293a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L9 12.586V5a1 1 0 012 0v7.586l2.293-2.293a1 1 0 011.414 0z' %>" clip-rule="evenodd" />
                            </svg>
                            <%= @order_trend.abs %>%
                          </div>
                        <% end %>
                      </dd>
                    </dl>
                  </div>
                </div>
              </div>
              <div class="bg-orange-700 px-4 py-3">
                <div class="text-sm">
                  <a href="<%= admin_payments_path %>" class="font-medium text-white hover:text-orange-100">View orders</a>
                </div>
              </div>
            </div>

            <!-- Total Revenue Card - Pink theme -->
            <div class="bg-gradient-to-br from-pink-500 to-pink-600 overflow-hidden rounded-lg shadow">
              <div class="px-4 py-5 sm:p-6">
                <div class="flex items-center">
                  <div class="flex-shrink-0 bg-pink-100 rounded-md p-3">
                    <svg class="h-6 w-6 text-pink-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                  <div class="ml-5 w-0 flex-1">
                    <dl>
                      <dt class="text-sm font-medium text-pink-100 truncate">Total Revenue</dt>
                      <dd class="flex items-baseline">
                        <div class="text-2xl font-semibold text-white">$<%= number_with_precision(@total_revenue, precision: 2) %></div>
                        <% if @revenue_trend != 0 %>
                          <div class="ml-2 flex items-baseline text-sm font-semibold <%= @revenue_trend > 0 ? 'text-green-100' : 'text-red-100' %>">
                            <svg class="self-center flex-shrink-0 h-5 w-5 text-white" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                              <path fill-rule="evenodd" d="<%= @revenue_trend > 0 ? 'M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z' : 'M14.707 10.293a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L9 12.586V5a1 1 0 012 0v7.586l2.293-2.293a1 1 0 011.414 0z' %>" clip-rule="evenodd" />
                            </svg>
                            <%= @revenue_trend.abs %>%
                          </div>
                        <% end %>
                      </dd>
                    </dl>
                  </div>
                </div>
              </div>
              <div class="bg-pink-700 px-4 py-3">
                <div class="text-sm">
                  <a href="<%= super_admin_finance_path %>" class="font-medium text-white hover:text-pink-100">View analytics</a>
                </div>
              </div>
            </div>
          </div>

          <!-- Charts section -->
          <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">
            <!-- Platform Activity Chart -->
            <div class="bg-white rounded-lg shadow p-6">
              <h3 class="text-lg font-medium text-gray-900 mb-4">Platform Activity</h3>
              <div class="relative h-80">
                <canvas 
                  data-dashboard-target="platformActivityChart"
                  data-months="<%= raw @chart_months.to_json %>"
                  data-users="<%= raw @user_data.to_json %>"
                  data-orders="<%= raw @order_data.to_json %>"
                ></canvas>
              </div>
            </div>
            
            <!-- Revenue Chart -->
            <div class="bg-white rounded-lg shadow p-6">
              <h3 class="text-lg font-medium text-gray-900 mb-4">Monthly Revenue</h3>
              <div class="relative h-80">
                <canvas 
                  data-dashboard-target="revenueChart"
                  data-months="<%= raw @chart_months.to_json %>"
                  data-revenue="<%= raw @revenue_data.to_json %>"
                ></canvas>
              </div>
            </div>
          </div>

          <!-- Recent activity section -->
          <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">
            <!-- Recent Users -->
            <div class="bg-white shadow overflow-hidden rounded-lg">
              <div class="px-4 py-5 border-b border-gray-200 sm:px-6 flex justify-between items-center">
                <h3 class="text-lg font-medium text-gray-900">Recent Users</h3>
                <a href="<%= super_admin_users_path %>" class="text-sm font-medium text-red-600 hover:text-red-500">View all</a>
              </div>
              <ul class="divide-y divide-gray-200">
                <% @recent_users.each do |user| %>
                  <li>
                    <a href="<%= super_admin_user_path(user) %>" class="block hover:bg-gray-50">
                      <div class="px-4 py-4 sm:px-6">
                        <div class="flex items-center justify-between">
                          <div class="flex items-center">
                            <div class="flex-shrink-0">
                              <% if user.profile_picture.attached? %>
                                <%= image_tag user.profile_picture.variant(resize_to_fill: [40, 40]), class: "h-10 w-10 rounded-full" %>
                              <% else %>
                                <span class="inline-block h-10 w-10 rounded-full overflow-hidden bg-gray-100">
                                  <svg class="h-full w-full text-gray-300" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" />
                                  </svg>
                                </span>
                              <% end %>
                            </div>
                            <div class="ml-4">
                              <div class="text-sm font-medium text-red-600"><%= user.email %></div>
                              <div class="text-sm text-gray-500"><%= user.full_name %></div>
                            </div>
                          </div>
                          <div class="flex items-center">
                            <div>
                              <% if user.super_admin? %>
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Super Admin</span>
                              <% elsif user.admin? %>
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">Admin</span>
                              <% elsif user.seller? %>
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Seller</span>
                              <% else %>
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Buyer</span>
                              <% end %>
                            </div>
                            <div class="ml-2 flex items-center text-sm text-gray-500">
                              <svg class="flex-shrink-0 mr-1.5 h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                              </svg>
                              <%= time_ago_in_words(user.created_at) %> ago
                            </div>
                          </div>
                        </div>
                      </div>
                    </a>
                  </li>
                <% end %>
              </ul>
            </div>

            <!-- Recent Orders -->
            <div class="bg-white shadow overflow-hidden rounded-lg">
              <div class="px-4 py-5 border-b border-gray-200 sm:px-6 flex justify-between items-center">
                <h3 class="text-lg font-medium text-gray-900">Recent Orders</h3>
                <a href="<%= admin_payments_path %>" class="text-sm font-medium text-red-600 hover:text-red-500">View all</a>
              </div>
              <ul class="divide-y divide-gray-200">
                <% @recent_orders.each do |order| %>
                  <li>
                    <a href="<%= admin_payment_path(order) %>" class="block hover:bg-gray-50">
                      <div class="px-4 py-4 sm:px-6">
                        <div class="flex items-center justify-between">
                          <div class="flex items-center">
                            <div class="flex-shrink-0">
                              <span class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-red-100">
                                <span class="font-medium text-red-800">#<%= order.id %></span>
                              </span>
                            </div>
                            <div class="ml-4">
                              <div class="text-sm font-medium text-gray-900"><%= order.user.email %></div>
                              <div class="text-sm text-gray-500">$<%= order.total_amount %></div>
                            </div>
                          </div>
                          <div class="flex items-center">
                            <span class="px-2.5 py-0.5 rounded-full text-xs font-medium
                              <%= order.status == 'paid' ? 'bg-green-100 text-green-800' : 
                                order.status == 'pending' ? 'bg-yellow-100 text-yellow-800' : 
                                'bg-red-100 text-red-800' %>">
                              <%= order.status.capitalize %>
                            </span>
                            <div class="ml-2 flex items-center text-sm text-gray-500">
                              <svg class="flex-shrink-0 mr-1.5 h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                              </svg>
                              <%= time_ago_in_words(order.created_at) %> ago
                            </div>
                          </div>
                        </div>
                      </div>
                    </a>
                  </li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- Users Tab Content -->
      <div data-dashboard-target="tabContent" data-tab="users" class="py-6 hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
          <h2 class="text-lg font-medium text-gray-900 mb-4">User Management</h2>
          <p class="text-gray-500 mb-6">View and manage all system users, including admins, buyers, and sellers.</p>
          
          <div class="flex justify-end mb-4">
            <a href="<%= super_admin_users_path %>" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
              Go to User Management
            </a>
          </div>

          <div class="bg-white shadow overflow-hidden sm:rounded-md">
            <ul class="divide-y divide-gray-200">
              <% @recent_users.take(10).each do |user| %>
                <li>
                  <a href="<%= super_admin_user_path(user) %>" class="block hover:bg-gray-50">
                    <div class="px-4 py-4 sm:px-6">
                      <div class="flex items-center justify-between">
                        <div class="flex items-center">
                          <div class="flex-shrink-0">
                            <% if user.profile_picture.attached? %>
                              <%= image_tag user.profile_picture.variant(resize_to_fill: [40, 40]), class: "h-10 w-10 rounded-full" %>
                            <% else %>
                              <span class="inline-block h-10 w-10 rounded-full overflow-hidden bg-gray-100">
                                <svg class="h-full w-full text-gray-300" fill="currentColor" viewBox="0 0 24 24">
                                  <path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" />
                                </svg>
                              </span>
                            <% end %>
                          </div>
                          <div class="ml-4">
                            <div class="text-sm font-medium text-red-600"><%= user.full_name %></div>
                            <div class="text-sm text-gray-500"><%= user.email %></div>
                          </div>
                        </div>
                        <div class="flex items-center">
                          <% if user.super_admin? %>
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Super Admin</span>
                          <% elsif user.admin? %>
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">Admin</span>
                          <% elsif user.seller? %>
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Seller</span>
                          <% else %>
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Buyer</span>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  </a>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>

      <!-- Products Tab Content -->
      <div data-dashboard-target="tabContent" data-tab="products" class="py-6 hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
          <h2 class="text-lg font-medium text-gray-900 mb-4">Product Management</h2>
          <p class="text-gray-500 mb-6">View and manage all products in the system, including digital and physical items.</p>
          
          <div class="flex justify-end mb-4">
            <a href="<%= super_admin_products_path rescue '#' %>" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
              Go to Product Management
            </a>
          </div>

          <div class="bg-white shadow overflow-hidden rounded-lg">
            <div class="px-4 py-5 sm:px-6">
              <h3 class="text-lg leading-6 font-medium text-gray-900">Product Stats</h3>
              <p class="mt-1 max-w-2xl text-sm text-gray-500">Digital: <%= @digital_products %> | Physical: <%= @physical_products %></p>
            </div>
            <div class="border-t border-gray-200 px-4 py-5 sm:p-6">
              <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                <div>
                  <h4 class="text-base font-medium text-gray-900">Product Distribution</h4>
                  <div class="mt-4 h-40 bg-gray-50 rounded-lg flex items-center justify-center">
                    <p class="text-gray-500 text-sm">Product distribution chart would go here</p>
                  </div>
                </div>
                <div>
                  <h4 class="text-base font-medium text-gray-900">Top Categories</h4>
                  <div class="mt-4 h-40 bg-gray-50 rounded-lg flex items-center justify-center">
                    <p class="text-gray-500 text-sm">Top categories chart would go here</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Orders Tab Content -->
      <div data-dashboard-target="tabContent" data-tab="orders" class="py-6 hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
          <h2 class="text-lg font-medium text-gray-900 mb-4">Order Management</h2>
          <p class="text-gray-500 mb-6">View and manage all orders, process payments, and track fulfillment status.</p>
          
          <div class="flex justify-end mb-4">
            <a href="<%= admin_payments_path %>" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
              Go to Order Management
            </a>
          </div>

          <div class="bg-white shadow overflow-hidden sm:rounded-md">
            <ul class="divide-y divide-gray-200">
              <% @recent_orders.take(10).each do |order| %>
                <li>
                  <a href="<%= admin_payment_path(order) %>" class="block hover:bg-gray-50">
                    <div class="px-4 py-4 sm:px-6">
                      <div class="flex items-center justify-between">
                        <div class="flex items-center">
                          <div class="flex-shrink-0">
                            <span class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-red-100">
                              <span class="font-medium text-red-800">#<%= order.id %></span>
                            </span>
                          </div>
                          <div class="ml-4">
                            <div class="text-sm font-medium text-red-600">Order #<%= order.id %></div>
                            <div class="text-sm text-gray-500"><%= order.user.email %></div>
                          </div>
                        </div>
                        <div class="flex items-center">
                          <div class="text-sm text-gray-900 mr-4">
                            $<%= order.total_amount %>
                          </div>
                          <span class="px-2.5 py-0.5 rounded-full text-xs font-medium
                            <%= order.status == 'paid' ? 'bg-green-100 text-green-800' : 
                              order.status == 'pending' ? 'bg-yellow-100 text-yellow-800' : 
                              'bg-red-100 text-red-800' %>">
                            <%= order.status.capitalize %>
                          </span>
                        </div>
                      </div>
                    </div>
                  </a>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>

      <!-- Analytics Tab Content -->
      <div data-dashboard-target="tabContent" data-tab="analytics" class="py-6 hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
          <h2 class="text-lg font-medium text-gray-900 mb-4">Analytics Dashboard</h2>
          <p class="text-gray-500 mb-6">Detailed analytics and reports about platform performance and sales trends.</p>
          
          <div class="flex justify-end mb-4">
            <a href="<%= super_admin_finance_path %>" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
              Go to Financial Dashboard
            </a>
          </div>

          <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
            <div class="bg-white shadow overflow-hidden rounded-lg">
              <div class="px-4 py-5 sm:px-6">
                <h3 class="text-lg leading-6 font-medium text-gray-900">Sales Distribution</h3>
              </div>
              <div class="border-t border-gray-200 px-4 py-5 sm:p-6">
                <div class="h-64 bg-gray-50 rounded-lg flex items-center justify-center">
                  <p class="text-gray-500 text-sm">Sales distribution chart would go here</p>
                </div>
              </div>
            </div>

            <div class="bg-white shadow overflow-hidden rounded-lg">
              <div class="px-4 py-5 sm:px-6">
                <h3 class="text-lg leading-6 font-medium text-gray-900">User Growth</h3>
              </div>
              <div class="border-t border-gray-200 px-4 py-5 sm:p-6">
                <div class="h-64 bg-gray-50 rounded-lg flex items-center justify-center">
                  <p class="text-gray-500 text-sm">User growth chart would go here</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>