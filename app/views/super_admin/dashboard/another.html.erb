<%# Redesigned Super Admin Dashboard - index.html.erb %>

<div class="bg-gray-100 min-h-screen">
  <!-- Top Navigation Bar -->
  <div class="bg-white border-b border-gray-200 sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16">
        <div class="flex items-center">
          <div class="flex-shrink-0 flex items-center">
            <h1 class="text-xl font-bold text-red-600">Digital Store</h1>
          </div>
          <div class="ml-10 flex space-x-8">
            <a href="<%= super_admin_dashboard_path %>" class="border-red-500 text-gray-900 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">
              Dashboard
            </a>
            <a href="<%= super_admin_users_path %>" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">
              Users
            </a>
            <a href="<%= super_admin_products_path %>" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">
              Products
            </a>
            <a href="<%= admin_payments_path %>" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">
              Orders
            </a>
          </div>
        </div>
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <a href="<%= super_admin_finance_path %>" class="relative inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
              Financial Dashboard
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
    <!-- Dashboard Header -->
    <div class="md:flex md:items-center md:justify-between mb-8">
      <div class="flex-1 min-w-0">
        <h2 class="text-2xl font-semibold leading-7 text-gray-900 sm:text-3xl sm:truncate">
          Super Admin Dashboard
        </h2>
        <p class="mt-1 text-sm text-gray-500">
          Platform-wide analytics and management overview
        </p>
      </div>
      <div class="mt-4 flex md:mt-0 md:ml-4 space-x-3">
        <div class="relative inline-block text-left">
          <select class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-red-500 focus:border-red-500 sm:text-sm rounded-md">
            <option>Last 7 days</option>
            <option>Last 30 days</option>
            <option>Last 90 days</option>
            <option>Year to date</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Tab Navigation -->
    <div class="border-b border-gray-200 mb-8">
      <nav class="-mb-px flex space-x-8" aria-label="Tabs">
        <a href="#" class="border-red-500 text-red-600 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
          Overview
        </a>
        <a href="#" class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
          Users
        </a>
        <a href="#" class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
          Products
        </a>
        <a href="#" class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
          Orders
        </a>
        <a href="#" class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
          Revenue
        </a>
      </nav>
    </div>

    <!-- KPI Cards Row -->
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Total Users KPI -->
      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-red-100 rounded-md p-3">
              <svg class="h-6 w-6 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Total Users</dt>
                <dd>
                  <div class="text-3xl font-semibold text-gray-900"><%= @total_users %></div>
                  <% if @user_trend != 0 %>
                    <div class="flex items-baseline text-sm font-semibold <%= @user_trend > 0 ? 'text-green-600' : 'text-red-600' %>">
                      <svg class="self-center flex-shrink-0 h-5 w-5 <%= @user_trend > 0 ? 'text-green-500' : 'text-red-500' %>" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                        <path fill-rule="evenodd" d="<%= @user_trend > 0 ? 'M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z' : 'M14.707 10.293a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L9 12.586V5a1 1 0 012 0v7.586l2.293-2.293a1 1 0 011.414 0z' %>" clip-rule="evenodd" />
                      </svg>
                      <span class="ml-1"><%= @user_trend.abs %>% from last period</span>
                    </div>
                  <% end %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 px-4 py-3 sm:px-6">
          <div class="text-sm">
            <a href="<%= super_admin_users_path %>" class="font-medium text-red-600 hover:text-red-500">View all users <span aria-hidden="true">&rarr;</span></a>
          </div>
        </div>
      </div>

      <!-- Total Revenue KPI -->
      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-green-100 rounded-md p-3">
              <svg class="h-6 w-6 text-green-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Total Revenue</dt>
                <dd>
                  <div class="text-3xl font-semibold text-gray-900">$<%= number_with_precision(@total_revenue, precision: 2) %></div>
                  <% if @revenue_trend != 0 %>
                    <div class="flex items-baseline text-sm font-semibold <%= @revenue_trend > 0 ? 'text-green-600' : 'text-red-600' %>">
                      <svg class="self-center flex-shrink-0 h-5 w-5 <%= @revenue_trend > 0 ? 'text-green-500' : 'text-red-500' %>" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                        <path fill-rule="evenodd" d="<%= @revenue_trend > 0 ? 'M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z' : 'M14.707 10.293a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L9 12.586V5a1 1 0 012 0v7.586l2.293-2.293a1 1 0 011.414 0z' %>" clip-rule="evenodd" />
                      </svg>
                      <span class="ml-1"><%= @revenue_trend.abs %>% from last period</span>
                    </div>
                  <% end %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 px-4 py-3 sm:px-6">
          <div class="text-sm">
            <a href="<%= super_admin_finance_path %>" class="font-medium text-red-600 hover:text-red-500">View financial details <span aria-hidden="true">&rarr;</span></a>
          </div>
        </div>
      </div>

      <!-- Total Products KPI -->
      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-blue-100 rounded-md p-3">
              <svg class="h-6 w-6 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Total Products</dt>
                <dd>
                  <div class="text-3xl font-semibold text-gray-900"><%= @total_products %></div>
                  <div class="text-sm text-gray-500">
                    <span class="font-medium text-blue-600"><%= @digital_products %></span> digital / 
                    <span class="font-medium text-indigo-600"><%= @physical_products %></span> physical
                  </div>
                </dd>
              </dl>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 px-4 py-3 sm:px-6">
          <div class="text-sm">
            <a href="<%= super_admin_products_path %>" class="font-medium text-red-600 hover:text-red-500">View all products <span aria-hidden="true">&rarr;</span></a>
          </div>
        </div>
      </div>

      <!-- Total Orders KPI -->
      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-purple-100 rounded-md p-3">
              <svg class="h-6 w-6 text-purple-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Total Orders</dt>
                <dd>
                  <div class="text-3xl font-semibold text-gray-900"><%= @total_orders %></div>
                  <% if @order_trend != 0 %>
                    <div class="flex items-baseline text-sm font-semibold <%= @order_trend > 0 ? 'text-green-600' : 'text-red-600' %>">
                      <svg class="self-center flex-shrink-0 h-5 w-5 <%= @order_trend > 0 ? 'text-green-500' : 'text-red-500' %>" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                        <path fill-rule="evenodd" d="<%= @order_trend > 0 ? 'M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z' : 'M14.707 10.293a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L9 12.586V5a1 1 0 012 0v7.586l2.293-2.293a1 1 0 011.414 0z' %>" clip-rule="evenodd" />
                      </svg>
                      <span class="ml-1"><%= @order_trend.abs %>% from last period</span>
                    </div>
                  <% end %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 px-4 py-3 sm:px-6">
          <div class="text-sm">
            <a href="<%= admin_payments_path %>" class="font-medium text-red-600 hover:text-red-500">View all orders <span aria-hidden="true">&rarr;</span></a>
          </div>
        </div>
      </div>
    </div>

    <!-- User Role Stats Row -->
    <div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-3">
      <!-- Admin Users Card -->
      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-yellow-100 rounded-md p-3">
              <svg class="h-6 w-6 text-yellow-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Admin Users</dt>
                <dd class="text-3xl font-semibold text-gray-900"><%= @admin_users %></dd>
              </dl>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 px-4 py-3 sm:px-6">
          <div class="text-sm">
            <a href="<%= super_admin_users_path(role: 'admin') %>" class="font-medium text-red-600 hover:text-red-500">Manage admins <span aria-hidden="true">&rarr;</span></a>
          </div>
        </div>
      </div>

      <!-- Super Admin Users Card -->
      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-red-100 rounded-md p-3">
              <svg class="h-6 w-6 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Super Admins</dt>
                <dd class="text-3xl font-semibold text-gray-900"><%= @super_admin_users %></dd>
              </dl>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 px-4 py-3 sm:px-6">
          <div class="text-sm">
            <a href="<%= super_admin_users_path(role: 'super_admin') %>" class="font-medium text-red-600 hover:text-red-500">Manage super admins <span aria-hidden="true">&rarr;</span></a>
          </div>
        </div>
      </div>

      <!-- Active Sellers Card -->
      <div class="bg-white overflow-hidden shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-indigo-100 rounded-md p-3">
              <svg class="h-6 w-6 text-indigo-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 truncate">Active Sellers</dt>
                <dd class="text-3xl font-semibold text-gray-900"><%= User.sellers.count %></dd>
              </dl>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 px-4 py-3 sm:px-6">
          <div class="text-sm">
            <a href="<%= super_admin_users_path(role: 'seller') %>" class="font-medium text-red-600 hover:text-red-500">Manage sellers <span aria-hidden="true">&rarr;</span></a>
          </div>
        </div>
      </div>
    </div>

    <!-- Charts Section -->
    <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">
      <!-- Platform Activity Chart -->
      <div class="bg-white shadow rounded-lg overflow-hidden">
        <div class="px-4 py-5 sm:px-6">
          <h3 class="text-lg leading-6 font-medium text-gray-900">Platform Activity</h3>
          <p class="mt-1 max-w-2xl text-sm text-gray-500">Monthly trends for new users and orders</p>
        </div>
        <div class="px-4 py-5 sm:p-6">
          <div class="h-80">
            <canvas id="platformActivityChart"></canvas>
          </div>
        </div>
      </div>

      <!-- Revenue Chart -->
      <div class="bg-white shadow rounded-lg overflow-hidden">
        <div class="px-4 py-5 sm:px-6">
          <h3 class="text-lg leading-6 font-medium text-gray-900">Monthly Revenue</h3>
          <p class="mt-1 max-w-2xl text-sm text-gray-500">Platform revenue over the last 6 months</p>
        </div>
        <div class="px-4 py-5 sm:p-6">
          <div class="h-80">
            <canvas id="revenueChart"></canvas>
          </div>
        </div>
      </div>
    </div>

    <!-- Activity Tables Section -->
    <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">
      <!-- Recent Users Table -->
      <div class="bg-white shadow rounded-lg overflow-hidden">
        <div class="px-4 py-5 border-b border-gray-200 sm:px-6 flex justify-between items-center">
          <div>
            <h3 class="text-lg leading-6 font-medium text-gray-900">Recent Users</h3>
            <p class="mt-1 text-sm text-gray-500">New user registrations</p>
          </div>
          <a href="<%= super_admin_users_path %>" class="text-sm font-medium text-red-600 hover:text-red-500">View all</a>
        </div>
        <div class="bg-white overflow-hidden">
          <ul class="divide-y divide-gray-200">
            <% @recent_users.each do |user| %>
              <li class="px-4 py-4 sm:px-6 hover:bg-gray-50">
                <a href="<%= super_admin_user_path(user) %>" class="block">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center">
                      <div class="flex-shrink-0">
                        <% if user.profile_picture.attached? %>
                          <%= image_tag user.profile_picture.variant(resize_to_fill: [40, 40]), class: "h-10 w-10 rounded-full" %>
                        <% else %>
                          <span class="inline-block h-10 w-10 rounded-full bg-gray-100 overflow-hidden">
                            <svg class="h-full w-full text-gray-300" fill="currentColor" viewBox="0 0 24 24">
                              <path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" />
                            </svg>
                          </span>
                        <% end %>
                      </div>
                      <div class="ml-4">
                        <div class="text-sm font-medium text-gray-900"><%= user.full_name %></div>
                        <div class="text-sm text-gray-500"><%= user.email %></div>
                      </div>
                    </div>
                    <div class="flex items-center">
                      <% if user.super_admin? %>
                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">
                          Super Admin
                        </span>
                      <% elsif user.admin? %>
                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
                          Admin
                        </span>
                      <% elsif user.seller? %>
                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                          Seller
                        </span>
                      <% else %>
                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">
                          Buyer
                        </span>
                      <% end %>
                      <span class="ml-2 text-xs text-gray-500"><%= time_ago_in_words(user.created_at) %> ago</span>
                    </div>
                  </div>
                </a>
              </li>
            <% end %>
          </ul>
        </div>
      </div>

      <!-- Recent Orders Table -->
      <div class="bg-white shadow rounded-lg overflow-hidden">
        <div class="px-4 py-5 border-b border-gray-200 sm:px-6 flex justify-between items-center">
          <div>
            <h3 class="text-lg leading-6 font-medium text-gray-900">Recent Orders</h3>
            <p class="mt-1 text-sm text-gray-500">Latest transactions on the platform</p>
          </div>
          <a href="<%= admin_payments_path %>" class="text-sm font-medium text-red-600 hover:text-red-500">View all</a>
        </div>
        <div class="bg-white overflow-hidden">
          <ul class="divide-y divide-gray-200">
            <% @recent_orders.each do |order| %>
              <li class="px-4 py-4 sm:px-6 hover:bg-gray-50">
                <a href="<%= admin_payment_path(order) %>" class="block">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center">
                      <div class="flex-shrink-0">
                        <% if order.product.image.attached? %>
                          <%= image_tag order.product.image.variant(resize_to_fill: [40, 40]), class: "h-10 w-10 rounded-full" %>
                        <% else %>
                          <span class="inline-block h-10 w-10 rounded-full bg-gray-100 overflow-hidden">
                            <svg class="h-full w-full text-gray-300" fill="currentColor" viewBox="0 0 24 24">
                              <path d="M24 20.0 24V4h24z" />
                            </svg>
                          </span>