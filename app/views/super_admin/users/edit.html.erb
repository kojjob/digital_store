<div class="p-4 sm:p-6 lg:p-8">
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-2xl font-semibold text-gray-900">Edit User: <%= @user.email %></h1>
      <p class="mt-2 text-sm text-gray-700">Update user details and account status.</p>
    </div>
    <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
      <a href="<%= super_admin_user_path(@user) %>" class="inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 sm:w-auto">
        Cancel
      </a>
    </div>
  </div>

  <div class="mt-8 overflow-hidden bg-white shadow sm:rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <%= form_with model: [:super_admin, @user], local: true do |f| %>
        <div class="space-y-6">
          <div>
            <h3 class="text-lg font-medium leading-6 text-gray-900">User Information</h3>
            <p class="mt-1 text-sm text-gray-500">Update the basic user details.</p>
          </div>

          <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
            <div class="sm:col-span-3">
              <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1">
                <%= f.email_field :email, class: "shadow-sm focus:ring-red-500 focus:border-red-500 block w-full sm:text-sm border-gray-300 rounded-md", disabled: true %>
                <p class="mt-2 text-sm text-gray-500">Email cannot be changed</p>
              </div>
            </div>

            <div class="sm:col-span-3">
              <%= f.label :first_name, class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1">
                <%= f.text_field :first_name, class: "shadow-sm focus:ring-red-500 focus:border-red-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
              </div>
            </div>

            <div class="sm:col-span-3">
              <%= f.label :last_name, class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1">
                <%= f.text_field :last_name, class: "shadow-sm focus:ring-red-500 focus:border-red-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
              </div>
            </div>

            <% unless @user.super_admin? %>
              <div class="sm:col-span-3">
                <div class="flex items-start">
                  <div class="flex items-center h-5">
                    <%= f.check_box :admin, class: "focus:ring-red-500 h-4 w-4 text-red-600 border-gray-300 rounded" %>
                  </div>
                  <div class="ml-3 text-sm">
                    <%= f.label :admin, class: "font-medium text-gray-700" %>
                    <p class="text-gray-500">Grant admin privileges to this user</p>
                  </div>
                </div>
              </div>
            <% end %>

            <div class="sm:col-span-3">
              <div class="flex items-start">
                <div class="flex items-center h-5">
                  <%= f.check_box :active, class: "focus:ring-red-500 h-4 w-4 text-red-600 border-gray-300 rounded" %>
                </div>
                <div class="ml-3 text-sm">
                  <%= f.label :active, class: "font-medium text-gray-700" %>
                  <p class="text-gray-500">If unchecked, the account will be disabled</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-8 flex justify-end">
          <%= f.submit "Update User", class: "ml-3 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
        </div>
      <% end %>
    </div>
  </div>
</div>