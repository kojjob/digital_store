<div class="p-4 sm:p-6 lg:p-8">
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-2xl font-semibold text-gray-900">User Details: <%= @user.email %></h1>
      <p class="mt-2 text-sm text-gray-700">
        Complete user information and related data.
      </p>
    </div>
    <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none space-x-2">
      <a href="<%= super_admin_users_path %>" class="inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 sm:w-auto">
        Back to Users
      </a>
      <% unless @user == current_user || @user.super_admin? %>
        <a href="<%= edit_super_admin_user_path(@user) %>" class="inline-flex items-center justify-center rounded-md border border-transparent bg-red-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 sm:w-auto">
          Edit User
        </a>
      <% end %>
    </div>
  </div>

  <!-- User Profile -->
  <div class="mt-8 overflow-hidden bg-white shadow sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg font-medium leading-6 text-gray-900">User Information</h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">Personal details and account status.</p>
    </div>
    <div class="border-t border-gray-200 px-4 py-5 sm:p-0">
      <dl class="sm:divide-y sm:divide-gray-200">
        <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Profile Picture</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
            <% if @user.profile_picture.attached? %>
              <%= image_tag @user.profile_picture.variant(resize_to_fill: [100, 100]), class: "h-24 w-24 rounded-full" %>
            <% else %>
              <span class="inline-block h-24 w-24 overflow-hidden rounded-full bg-gray-100">
                <svg class="h-full w-full text-gray-300" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
              </span>
            <% end %>
          </dd>
        </div>
        <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Full name</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
            <%= @user.full_name %>
          </dd>
        </div>
        <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Email address</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
            <%= @user.email %>
          </dd>
        </div>
        <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Role</dt>
          <dd class="mt-1 text-sm sm:col-span-2 sm:mt-0">
            <% if @user.super_admin? %>
              <span class="inline-flex rounded-full bg-red-100 px-2 text-xs font-semibold leading-5 text-red-800">Super Admin</span>
            <% elsif @user.admin? %>
              <span class="inline-flex rounded-full bg-indigo-100 px-2 text-xs font-semibold leading-5 text-indigo-800">Admin</span>
              <% unless @user.super_admin? %>
                <%= button_to "Remove Admin Role", toggle_admin_super_admin_user_path(@user), method: :post, class: "ml-2 text-xs text-red-600 hover:text-red-900" %>
              <% end %>
            <% elsif @user.seller? %>
              <span class="inline-flex rounded-full bg-green-100 px-2 text-xs font-semibold leading-5 text-green-800">Seller</span>
              <% unless @user.admin? || @user.super_admin? %>
                <%= button_to "Make Admin", toggle_admin_super_admin_user_path(@user), method: :post, class: "ml-2 text-xs text-indigo-600 hover:text-indigo-900" %>
              <% end %>
            <% else %>
              <span class="inline-flex rounded-full bg-gray-100 px-2 text-xs font-semibold leading-5 text-gray-800">Buyer</span>
              <% unless @user.admin? || @user.super_admin? %>
                <%= button_to "Make Admin", toggle_admin_super_admin_user_path(@user), method: :post, class: "ml-2 text-xs text-indigo-600 hover:text-indigo-900" %>
              <% end %>
            <% end %>
          </dd>
        </div>
        <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Account Status</dt>
          <dd class="mt-1 text-sm sm:col-span-2 sm:mt-0">
            <% if @user.active? %>
              <span class="inline-flex rounded-full bg-green-100 px-2 text-xs font-semibold leading-5 text-green-800">Active</span>
            <% else %>
              <span class="inline-flex rounded-full bg-gray-100 px-2 text-xs font-semibold leading-5 text-gray-800">Inactive</span>
            <% end %>
          </dd>
        </div>
        <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Created At</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
            <%= @user.created_at.strftime("%B %d, %Y at %I:%M %p") %>
            (<%= time_ago_in_words(@user.created_at) %> ago)
          </dd>
        </div>
        <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Last Sign In</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
            <%= @user.last_sign_in_at&.strftime("%B %d, %Y at %I:%M %p") || 'Never' %>
            <%= @user.last_sign_in_at ? "(#{time_ago_in_words(@user.last_sign_in_at)} ago)" : '' %>
          </dd>
        </div>
      </dl>
    </div>
  </div>

  <!-- Impersonate User -->
  <% unless @user == current_user %>
    <div class="mt-8 overflow-hidden bg-white shadow sm:rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg font-medium leading-6 text-red-900">Impersonate User</h3>
        <div class="mt-2 max-w-xl text-sm text-gray-500">
          <p>Sign in as this user to troubleshoot issues or assist them with their account. This action is logged.</p>
        </div>
        <div class="mt-5">
          <%= button_to "Impersonate #{@user.email}", impersonate_super_admin_user_path(@user), method: :post, data: { confirm: "Are you sure you want to impersonate this user? You will be logged in as them until you choose to stop impersonation." }, class: "inline-flex items-center justify-center rounded-md border border-transparent bg-red-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2" %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">
    <!-- Orders -->
    <div class="overflow-hidden bg-white shadow sm:rounded-md">
      <div class="px-4 py-5 sm:px-6">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-medium leading-6 text-gray-900">Orders</h2>
          <a href="<%= admin_payments_path(search: @user.email) %>" class="text-sm font-medium text-red-600 hover:text-red-500">View all</a>
        </div>
      </div>
      <ul role="list" class="divide-y divide-gray-200">
        <% if @orders.any? %>
          <% @orders.each do |order| %>
            <li>
              <a href="<%= admin_payment_path(order) %>" class="block hover:bg-gray-50">
                <div class="px-4 py-4 sm:px-6">
                  <div class="flex items-center justify-between">
                    <p class="truncate text-sm font-medium text-red-600">Order #<%= order.id %></p>
                    <div class="ml-2 flex flex-shrink-0">
                      <p class="inline-flex rounded-full px-2 text-xs font-semibold leading-5 
                          <%= order.status == 'paid' ? 'bg-green-100 text-green-800' : 
                            order.status == 'pending' ? 'bg-yellow-100 text-yellow-800' : 
                            'bg-red-100 text-red-800' %>">
                        <%= order.status.capitalize %>
                      </p>
                    </div>
                  </div>
                  <div class="mt-2 sm:flex sm:justify-between">
                    <div class="sm:flex">
                      <p class="flex items-center text-sm text-gray-500">
                        <svg class="mr-1.5 h-5 w-5 flex-shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                          <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" />
                        </svg>
                        <%= order.product.name %>
                      </p>
                    </div>
                    <div class="mt-2 flex items-center text-sm text-gray-500 sm:mt-0">
                      <svg class="mr-1.5 h-5 w-5 flex-shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                      </svg>
                      <p><%= time_ago_in_words(order.created_at) %> ago</p>
                    </div>
                  </div>
                </div>
              </a>
            </li>
          <% end %>
        <% else %>
          <li class="px-4 py-4 sm:px-6 text-sm text-gray-500 italic">
            No orders found for this user.
          </li>
        <% end %>
      </ul>
    </div>

    <!-- Downloads -->
    <div class="overflow-hidden bg-white shadow sm:rounded-md">
      <div class="px-4 py-5 sm:px-6">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-medium leading-6 text-gray-900">Downloads</h2>
          <a href="<%= admin_downloads_path(search: @user.email) %>" class="text-sm font-medium text-red-600 hover:text-red-500">View all</a>
        </div>
      </div>
      <ul role="list" class="divide-y divide-gray-200">
        <% if @downloads.any? %>
          <% @downloads.each do |download| %>
            <li>
              <a href="<%= admin_download_path(download) %>" class="block hover:bg-gray-50">
                <div class="px-4 py-4 sm:px-6">
                  <div class="flex items-center justify-between">
                    <p class="truncate text-sm font-medium text-red-600"><%= download.product.name %></p>
                    <div class="ml-2 flex flex-shrink-0">
                      <span class="inline-flex rounded-full px-2 text-xs font-semibold leading-5 
                          <%= download.valid_for_download? ? 'bg-green-100 text-green-800' : 
                            download.expired? ? 'bg-red-100 text-red-800' : 
                            download.download_limit_reached? ? 'bg-yellow-100 text-yellow-800' : 
                            'bg-gray-100 text-gray-800' %>">
                          <%= download.valid_for_download? ? 'Active' : 
                            download.expired? ? 'Expired' : 
                            download.download_limit_reached? ? 'Limit Reached' : 
                            'Inactive' %>
                      </span>
                    </div>
                  </div>
                  <div class="mt-2 sm:flex sm:justify-between">
                    <div class="sm:flex">
                      <p class="flex items-center text-sm text-gray-500">
                        <svg class="mr-1.5 h-5 w-5 flex-shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
                        </svg>
                        <%= download.download_count %> / <%= download.download_limit.zero? ? '∞' : download.download_limit %>
                      </p>
                    </div>
                    <div class="mt-2 flex items-center text-sm text-gray-500 sm:mt-0">
                      <svg class="mr-1.5 h-5 w-5 flex-shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                      </svg>
                      <p><%= download.expiration_in_words %></p>
                    </div>
                  </div>
                </div>
              </a>
            </li>
          <% end %>
        <% else %>
          <li class="px-4 py-4 sm:px-6 text-sm text-gray-500 italic">
            No downloads found for this user.
          </li>
        <% end %>
      </ul>
    </div>
  </div>

  <!-- Activity Timeline -->
  <div class="mt-8 overflow-hidden bg-white shadow sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg font-medium leading-6 text-gray-900">User Activity</h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">Recent activities and interactions.</p>
    </div>
    <div class="border-t border-gray-200">
      <% if @activities.any? %>
        <ul role="list" class="divide-y divide-gray-200">
          <% @activities.each do |activity| %>
            <li class="relative pb-10 pl-8">
              <div class="relative flex space-x-3">
                <div>
                  <span class="h-8 w-8 rounded-full bg-blue-500 flex items-center justify-center ring-8 ring-white">
                    <svg class="h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                  </span>
                </div>
                <div class="min-w-0 flex-1 pt-1.5 flex justify-between space-x-4">
                  <div>
                    <p class="text-sm text-gray-500"><%= activity.title %></p>
                    <p class="text-sm text-gray-900"><%= activity.description %></p>
                  </div>
                  <div class="text-right text-sm whitespace-nowrap text-gray-500">
                    <p><%= time_ago_in_words(activity.created_at) %> ago</p>
                  </div>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="px-4 py-4 sm:px-6 text-sm text-gray-500 italic">
          No activity recorded for this user.
        </div>
      <% end %>
    </div>
  </div>
</div>