<div class="bg-white">
  <div class="max-w-7xl mx-auto px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-3xl font-extrabold tracking-tight text-gray-900 sm:text-4xl">Checkout</h1>
      <p class="mt-2 text-gray-500">Complete your purchase</p>
      
      <div class="mt-12">
        <!-- Order Summary -->
        <div class="bg-gray-50 rounded-lg p-6 mb-8">
          <h2 class="text-lg font-medium text-gray-900 mb-4">Order Summary</h2>
          <div class="border-t border-gray-200 pt-4">
            <% @cart.cart_items.each do |item| %>
              <div class="flex justify-between py-2">
                <div>
                  <h3 class="text-sm font-medium text-gray-900"><%= item.product.name %></h3>
                  <p class="text-sm text-gray-500">Qty: <%= item.quantity %></p>
                </div>
                <p class="text-sm font-medium text-gray-900">$<%= sprintf("%.2f", item.price * item.quantity) %></p>
              </div>
            <% end %>
            
            <div class="border-t border-gray-200 pt-4 mt-4">
              <div class="flex justify-between py-2">
                <p class="text-sm text-gray-500">Subtotal</p>
                <p class="text-sm font-medium text-gray-900">$<%= sprintf("%.2f", @cart.total) %></p>
              </div>
              
              <div class="flex justify-between py-2 border-t border-gray-200 mt-2 pt-2">
                <p class="text-base font-medium text-gray-900">Total</p>
                <p class="text-base font-medium text-gray-900">$<%= sprintf("%.2f", @cart.total) %></p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Checkout Form -->
        <%= form_with url: checkout_path, method: :post, class: "space-y-8" do |form| %>
          <div>
            <h2 class="text-lg font-medium text-gray-900 mb-4">Payment Method</h2>
            <div class="space-y-4">
              <div class="flex items-center">
                <%= form.radio_button :payment_method, "stripe", class: "focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300", checked: true %>
                <div class="ml-3 flex items-center">
                  <%= form.label :payment_method_stripe, "Credit Card", class: "block text-sm font-medium text-gray-700 mr-2" %>
                  <div class="flex space-x-2">
                    <svg class="h-6" viewBox="0 0 32 20" fill="none">
                      <rect width="32" height="20" rx="2" fill="#172B85"/>
                      <path d="M12 14H9.5L11 7H13.5L12 14Z" fill="white"/>
                      <path d="M19.3 7.1C18.8 6.9 18.1 6.8 17.3 6.8C15.3 6.8 13.9 7.8 13.9 9.2C13.9 10.3 14.9 10.8 15.6 11.1C16.3 11.4 16.5 11.6 16.5 11.9C16.5 12.3 16 12.5 15.5 12.5C14.8 12.5 14.3 12.4 13.7 12.1L13.4 12L13.1 14.1C13.7 14.3 14.7 14.5 15.7 14.5C17.8 14.5 19.2 13.5 19.2 12C19.2 11.1 18.6 10.4 17.5 9.9C16.8 9.6 16.4 9.3 16.4 9C16.4 8.7 16.7 8.4 17.4 8.4C18 8.4 18.5 8.5 18.8 8.6L19 8.7L19.3 6.8V7.1Z" fill="white"/>
                      <path d="M22.4 11.2C22.6 10.8 23.1 9.3 23.1 9.3C23.1 9.3 23.2 9 23.3 8.8L23.4 9.2C23.4 9.2 23.7 10.8 23.8 11.2H22.4ZM24.3 7H22.7C22.3 7 21.9 7.1 21.7 7.5L19 14H21.1C21.1 14 21.4 13.1 21.5 12.9C21.7 12.9 23.8 12.9 24 12.9C24.1 13.1 24.2 14 24.2 14H26L24.3 7Z" fill="white"/>
                      <path d="M8 7L6 14H8L10 7H8Z" fill="white"/>
                    </svg>
                    <svg class="h-6" viewBox="0 0 32 20" fill="none"> 
                      <rect width="32" height="20" rx="2" fill="#EB001B"/>
                      <circle cx="12" cy="10" r="5" fill="#EB001B"/>
                      <circle cx="20" cy="10" r="5" fill="#F79E1B"/>
                      <path fill-rule="evenodd" clip-rule="evenodd" d="M16 6.5C18 8 19 9.2 19 10.7C19 12.2 18 13.4 16 14.9C14 13.4 13 12.2 13 10.7C13 9.2 14 8 16 6.5Z" fill="#FF5F00"/>
                    </svg>
                  </div>
                </div>
              </div>
              
              <div class="flex items-center">
                <%= form.radio_button :payment_method, "momo", class: "focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300" %>
                <div class="ml-3 flex items-center">
                  <%= form.label :payment_method_momo, "Mobile Money", class: "block text-sm font-medium text-gray-700 mr-2" %>
                  <div class="flex space-x-1">
                    <span class="px-2 py-1 text-xs font-semibold bg-yellow-400 text-black rounded">MTN</span>
                    <span class="px-2 py-1 text-xs font-semibold bg-red-600 text-white rounded">Voda</span>
                    <span class="px-2 py-1 text-xs font-semibold bg-red-500 text-white rounded">Airtel</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <div class="mt-8">
            <%= form.submit "Proceed to Payment", class: "w-full bg-indigo-600 border border-transparent rounded-md shadow-sm py-3 px-4 text-base font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
          </div>
        <% end %>
        
        <div class="mt-8 border-t border-gray-200 pt-6">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-green-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div class="ml-3">
              <p class="text-sm text-gray-500">Your payment is secured with industry-standard encryption.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>