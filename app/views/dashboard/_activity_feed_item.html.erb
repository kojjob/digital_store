<%#
  Activity feed item component
  
  Required local variables:
  - activity: Hash with:
    - icon: String - icon name
    - color: String - color theme
    - title: String - activity title
    - description: String - activity description
    - created_at: DateTime - when the activity occurred
  - is_last: Boolean - whether this is the last item (to control the connecting line)
%>

<li>
  <div class="relative pb-8">
    <% unless is_last %>
      <span class="absolute top-4 left-4 -ml-px h-full w-0.5 bg-gray-200" aria-hidden="true"></span>
    <% end %>
    <div class="relative flex space-x-3">
      <div>
        <span class="h-8 w-8 rounded-full flex items-center justify-center bg-<%= activity[:color] %>-100">
          <%= render 'shared/icon', name: activity[:icon], size: "sm", color: activity[:color] %>
        </span>
      </div>
      <div class="min-w-0 flex-1 pt-1.5 flex justify-between space-x-4">
        <div>
          <p class="text-sm text-gray-900"><%= activity[:title] %></p>
          <p class="text-sm text-gray-500"><%= activity[:description] %></p>
        </div>
        <div class="text-right text-sm whitespace-nowrap text-gray-500">
          <time datetime="<%= activity[:created_at].iso8601 %>"><%= time_ago_in_words(activity[:created_at]) %> ago</time>
        </div>
      </div>
    </div>
  </div>
</li>
