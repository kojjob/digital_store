<%# 
  Recent Reviews Component
  
  Displays recent product reviews.
%>

<div class="bg-white shadow-md rounded-lg overflow-hidden">
  <div class="bg-gradient-to-r from-amber-500 to-amber-600 px-4 py-4">
    <div class="flex items-center justify-between">
      <h3 class="text-lg font-medium text-white">Recent Reviews</h3>
    </div>
  </div>

  <% if @recent_reviews.present? && @recent_reviews.any? %>
    <ul class="divide-y divide-gray-200" data-reviews-target="list">
      <% @recent_reviews.each do |review| %>
        <li class="p-4 hover:bg-gray-50">
          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0">
              <% if review.user && review.user.respond_to?(:avatar) && review.user.avatar.attached? %>
                <%= image_tag review.user.avatar, class: "h-10 w-10 rounded-full object-cover", alt: "User avatar" %>
              <% else %>
                <div class="h-10 w-10 rounded-full bg-gray-300 flex items-center justify-center">
                  <span class="text-white font-medium text-md">
                    <%= review.user ? review.user.email[0].upcase : "?" %>
                  </span>
                </div>
              <% end %>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-gray-900">
                  <%= review.user ? (review.user.respond_to?(:full_name) ? review.user.full_name : review.user.email) : "Anonymous User" %>
                  <span class="text-sm text-gray-500">
                    reviewed
                  </span>
                  <span class="font-medium">
                    <%= review.product.name %>
                  </span>
                </p>
                <p class="text-sm text-gray-500">
                  <%= time_ago_in_words(review.created_at) %> ago
                </p>
              </div>
              <div class="flex items-center mt-1">
                <div class="flex items-center">
                  <% review.rating.to_i.times do %>
                    <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                    </svg>
                  <% end %>
                  <% (5 - review.rating.to_i).times do %>
                    <svg class="w-4 h-4 text-gray-300" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                    </svg>
                  <% end %>
                </div>
                <span class="ml-2 text-sm text-gray-500"><%= review.title %></span>
              </div>
              <div class="mt-2 text-sm text-gray-700">
                <p><%= review.comment %></p>
              </div>
              <% if current_user.seller? && review.product.seller_id == current_user.seller.id && !review.response.present? %>
                <div class="mt-2">
                  <%= link_to edit_review_path(review), class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" do %>
                    Respond to review
                  <% end %>
                </div>
              <% end %>
              <% if review.response.present? %>
                <div class="mt-3 bg-gray-50 p-3 rounded-lg">
                  <div class="flex items-start space-x-3">
                    <div class="flex-shrink-0">
                      <% if review.product.seller && review.product.seller.user && review.product.seller.user.respond_to?(:avatar) && review.product.seller.user.avatar.attached? %>
                        <%= image_tag review.product.seller.user.avatar, class: "h-8 w-8 rounded-full object-cover", alt: "Seller avatar" %>
                      <% else %>
                        <div class="h-8 w-8 rounded-full bg-indigo-600 flex items-center justify-center">
                          <span class="text-white font-medium text-sm">
                            <%= review.product.seller ? review.product.seller.business_name[0].upcase : "S" %>
                          </span>
                        </div>
                      <% end %>
                    </div>
                    <div>
                      <p class="text-sm font-medium text-gray-900">
                        <%= review.product.seller ? review.product.seller.business_name : "Seller" %>
                        <span class="text-xs text-gray-500">responded</span>
                      </p>
                      <p class="text-sm text-gray-700 mt-1"><%= review.response %></p>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
    <div class="bg-gray-50 px-4 py-3 text-right sm:px-6">
      <% if defined?(reviews_path) %>
        <%= link_to "View all reviews", reviews_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
      <% end %>
    </div>
  <% else %>
    <div class="py-6 text-center">
      <div class="mx-auto h-12 w-12 text-gray-400">
        <svg class="h-12 w-12" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
        </svg>
      </div>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No reviews yet</h3>
      <p class="mt-1 text-sm text-gray-500">
        Reviews will appear here as customers provide feedback on products.
      </p>
    </div>
  <% end %>
</div>
