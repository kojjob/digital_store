<div class="min-h-screen bg-gray-50">
  <div class="flex h-screen overflow-hidden">
    <!-- Sidebar -->
    <div class="hidden md:flex md:flex-shrink-0">
      <div class="flex flex-col w-64">
        <!-- Sidebar component -->
        <div class="flex flex-col flex-grow pt-5 pb-4 overflow-y-auto bg-indigo-700">
          <div class="flex items-center flex-shrink-0 px-4">
            <div class="h-10 w-10 rounded-xl bg-indigo-100 flex items-center justify-center mr-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
              </svg>
            </div>
            <span class="text-xl font-bold text-white">DigitalStore</span>
          </div>
          <div class="mt-6 flex-grow flex flex-col">
            <nav class="flex-1 px-2 space-y-1" aria-label="Sidebar">
              <!-- Dashboard -->
              <a href="<%= root_path %>" class="bg-indigo-800 text-white group flex items-center px-2 py-2 text-sm font-medium rounded-md" aria-current="page">
                <div class="mr-3">
                  <%= render 'shared/icon', name: "template", size: "sm", color: "blue" %>
                </div>
                Dashboard
              </a>

              <!-- Products -->
              <a href="<%= products_path if defined?(products_path) %>" class="text-indigo-100 hover:bg-indigo-600 group flex items-center px-2 py-2 text-sm font-medium rounded-md">
                <div class="mr-3">
                  <%= render 'shared/icon', name: "star", size: "sm", color: "amber" %>
                </div>
                Products
              </a>

              <!-- Orders -->
              <a href="<%= orders_path if defined?(orders_path) %>" class="text-indigo-100 hover:bg-indigo-600 group flex items-center px-2 py-2 text-sm font-medium rounded-md">
                <div class="mr-3">
                  <%= render 'shared/icon', name: "cart", size: "sm", color: "green" %>
                </div>
                My Orders
              </a>

              <!-- Wishlist -->
              <a href="<%= wishlist_path if defined?(wishlist_path) %>" class="text-indigo-100 hover:bg-indigo-600 group flex items-center px-2 py-2 text-sm font-medium rounded-md">
                <div class="mr-3">
                  <%= render 'shared/icon', name: "lightning", size: "sm", color: "peach" %>
                </div>
                Wishlist
              </a>

              <!-- Settings -->
              <a href="<%= edit_user_registration_path %>" class="text-indigo-100 hover:bg-indigo-600 group flex items-center px-2 py-2 text-sm font-medium rounded-md">
                <div class="mr-3">
                  <%= render 'shared/icon', name: "user", size: "sm", color: "blue" %>
                </div>
                Settings
              </a>

              <!-- Help -->
              <a href="<%= help_path if defined?(help_path) %>" class="text-indigo-100 hover:bg-indigo-600 group flex items-center px-2 py-2 text-sm font-medium rounded-md">
                <div class="mr-3">
                  <%= render 'shared/icon', name: "search", size: "sm", color: "amber" %>
                </div>
                Help Center
              </a>
            </nav>
          </div>
          <!-- User Profile Section -->
          <div class="flex-shrink-0 flex border-t border-indigo-800 p-4">
            <div class="flex items-center">
              <div>
                <% if current_user.respond_to?(:profile_picture) && current_user.profile_picture.respond_to?(:attached?) && current_user.profile_picture.attached? %>
                  <%= image_tag current_user.profile_picture, class: "h-10 w-10 rounded-full", alt: "#{current_user.full_name}'s profile picture" %>
                <% else %>
                  <div class="h-10 w-10 rounded-full bg-indigo-200 flex items-center justify-center">
                    <span class="text-indigo-800 font-medium">
                      <% if current_user.respond_to?(:first_name) && current_user.respond_to?(:last_name) %>
                        <%= current_user.first_name.first.upcase %><%= current_user.last_name.first.upcase %>
                      <% else %>
                        <%= current_user.email.first.upcase %>
                      <% end %>
                    </span>
                  </div>
                <% end %>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-white"><%= current_user&.full_name || current_user.email %></p>
                <div class="flex items-center text-xs font-medium text-indigo-200 group">
                  <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "group-hover:text-white" %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile menu -->
    <div class="md:hidden fixed inset-0 flex z-40 lg:hidden" role="dialog" aria-modal="true" data-controller="mobile-menu" data-mobile-menu-target="menu" style="display: none;">
      <div class="fixed inset-0 bg-gray-600 bg-opacity-75" aria-hidden="true" data-action="click->mobile-menu#toggle"></div>
      <div class="relative flex-1 flex flex-col max-w-xs w-full pt-5 pb-4 bg-indigo-700">
        <div class="absolute top-0 right-0 -mr-12 pt-2">
          <button type="button" class="ml-1 flex items-center justify-center h-10 w-10 rounded-full focus:outline-none focus:ring-2 focus:ring-inset focus:ring-white" data-action="click->mobile-menu#toggle" aria-label="Close menu">
            <span class="sr-only">Close sidebar</span>
            <svg class="h-6 w-6 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <div class="flex-shrink-0 flex items-center px-4">
          <div class="h-10 w-10 rounded-xl bg-indigo-100 flex items-center justify-center mr-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
            </svg>
          </div>
          <span class="text-xl font-bold text-white">DigitalStore</span>
        </div>
        <div class="mt-5 flex-1 h-0 overflow-y-auto">
          <nav class="px-2 space-y-1" aria-label="Mobile menu">
            <a href="<%= root_path %>" class="bg-indigo-800 text-white group flex items-center px-2 py-2 text-base font-medium rounded-md" aria-current="page">
              <div class="mr-4">
                <%= render 'shared/icon', name: "template", size: "sm", color: "blue" %>
              </div>
              Dashboard
            </a>

            <a href="<%= products_path if defined?(products_path) %>" class="text-indigo-100 hover:bg-indigo-600 group flex items-center px-2 py-2 text-base font-medium rounded-md">
              <div class="mr-4">
                <%= render 'shared/icon', name: "star", size: "sm", color: "amber" %>
              </div>
              Products
            </a>

            <a href="<%= orders_path if defined?(orders_path) %>" class="text-indigo-100 hover:bg-indigo-600 group flex items-center px-2 py-2 text-base font-medium rounded-md">
              <div class="mr-4">
                <%= render 'shared/icon', name: "cart", size: "sm", color: "green" %>
              </div>
              My Orders
            </a>

            <a href="<%= wishlist_path if defined?(wishlist_path) %>" class="text-indigo-100 hover:bg-indigo-600 group flex items-center px-2 py-2 text-base font-medium rounded-md">
              <div class="mr-4">
                <%= render 'shared/icon', name: "lightning", size: "sm", color: "peach" %>
              </div>
              Wishlist
            </a>

            <a href="<%= edit_user_registration_path %>" class="text-indigo-100 hover:bg-indigo-600 group flex items-center px-2 py-2 text-base font-medium rounded-md">
              <div class="mr-4">
                <%= render 'shared/icon', name: "user", size: "sm", color: "blue" %>
              </div>
              Settings
            </a>
            
            <a href="<%= help_path if defined?(help_path) %>" class="text-indigo-100 hover:bg-indigo-600 group flex items-center px-2 py-2 text-base font-medium rounded-md">
              <div class="mr-4">
                <%= render 'shared/icon', name: "search", size: "sm", color: "amber" %>
              </div>
              Help Center
            </a>
            
            <div class="pt-4 pb-3 border-t border-indigo-800">
              <div class="flex items-center px-5">
                <div class="flex-shrink-0">
                  <% if current_user.respond_to?(:profile_picture) && current_user.profile_picture.respond_to?(:attached?) && current_user.profile_picture.attached? %>
                    <%= image_tag current_user.profile_picture, class: "h-10 w-10 rounded-full", alt: "#{current_user.full_name}'s profile picture" %>
                  <% else %>
                    <div class="h-10 w-10 rounded-full bg-indigo-200 flex items-center justify-center">
                      <span class="text-indigo-800 font-medium">
                        <% if current_user.respond_to?(:first_name) && current_user.respond_to?(:last_name) %>
                          <%= current_user.first_name.first.upcase %><%= current_user.last_name.first.upcase %>
                        <% else %>
                          <%= current_user.email.first.upcase %>
                        <% end %>
                      </span>
                    </div>
                  <% end %>
                </div>
                <div class="ml-3">
                  <div class="text-base font-medium text-white"><%= current_user&.full_name || current_user.email %></div>
                </div>
              </div>
              <div class="mt-3 px-2 space-y-1">
                <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "block w-full text-left px-3 py-2 rounded-md text-base font-medium text-indigo-100 hover:text-white hover:bg-indigo-600" %>
              </div>
            </div>
          </nav>
        </div>
      </div>
    </div>

    <!-- Mobile toggle button -->
    <div class="md:hidden flex items-center justify-between p-2 bg-indigo-700 shadow-md">
      <div class="flex items-center">
        <button type="button" class="inline-flex items-center justify-center p-2 rounded-md text-white hover:bg-indigo-600 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-white" data-action="click->mobile-menu#toggle" aria-controls="mobile-menu" aria-expanded="false">
          <span class="sr-only">Open main menu</span>
          <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
        <span class="ml-2 text-xl font-bold text-white">DigitalStore</span>
      </div>
      <div class="relative">
        <button type="button" class="p-1 rounded-full text-white hover:bg-indigo-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" id="notification-dropdown" aria-expanded="false" aria-haspopup="true">
          <span class="sr-only">View notifications</span>
          <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
          </svg>
          <span class="absolute top-0 right-0 block h-2 w-2 rounded-full bg-red-400 ring-2 ring-indigo-700"></span>
        </button>
      </div>
    </div>

    <!-- Main content area -->
    <div class="flex-1 overflow-auto focus:outline-none">
      <div class="py-6">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
          <!-- Page header -->
          <div class="md:flex md:items-center md:justify-between">
            <div class="flex-1 min-w-0">
              <h1 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">Welcome back, <%= current_user.respond_to?(:first_name) ? current_user.first_name : current_user.email.split('@').first %></h1>
              <div class="mt-1 flex flex-col sm:flex-row sm:flex-wrap sm:mt-0 sm:space-x-6">
                <div class="mt-2 flex items-center text-sm text-gray-500">
                  <svg class="flex-shrink-0 mr-1.5 h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                  </svg>
                  <%= Date.today.strftime("%B %d, %Y") %>
                </div>
                <% if @last_login %>
                <div class="mt-2 flex items-center text-sm text-gray-500">
                  <svg class="flex-shrink-0 mr-1.5 h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                  </svg>
                  Last login: <%= @last_login.strftime("%B %d, %Y at %I:%M %p") %>
                </div>
                <% end %>
              </div>
            </div>
            <div class="mt-4 flex md:mt-0 md:ml-4">
              <a href="#" class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                <div class="mr-2">
                  <%= render 'shared/icon', name: "globe", size: "sm", color: "blue" %>
                </div>
                View analytics
              </a>
              <a href="<%= new_product_path if defined?(new_product_path) %>" class="ml-3 inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                <div class="mr-2">
                  <%= render 'shared/icon', name: "plus", size: "sm", color: "green" %>
                </div>
                Add product
              </a>
            </div>
          </div>
        </div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
          <!-- Notification banner -->
          <% if @new_notifications && @new_notifications > 0 %>
          <div class="mt-8 rounded-md bg-indigo-50 p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <%= render 'shared/icon', name: "notification", size: "md", color: "blue" %>
              </div>
              <div class="ml-3 flex-1 md:flex md:justify-between">
                <p class="text-sm text-indigo-700">
                  You have <%= @new_notifications %> new notification<%= @new_notifications > 1 ? 's' : '' %>
                </p>
                <p class="mt-3 text-sm md:mt-0 md:ml-6">
                  <a href="<%= notifications_path if defined?(notifications_path) %>" class="whitespace-nowrap font-medium text-indigo-700 hover:text-indigo-600">View all<span aria-hidden="true"> &rarr;</span></a>
                </p>
              </div>
            </div>
          </div>
          <% end %>

          <!-- Stats cards -->
          <div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
            <!-- Card 1: Revenue -->
            <div class="bg-white overflow-hidden shadow-md rounded-lg transform transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
              <div class="p-5">
                <div class="flex items-center">
                  <div class="flex-shrink-0">
                    <%= render 'shared/icon', name: "lightning", size: "md", color: "blue" %>
                  </div>
                  <div class="ml-5 w-0 flex-1">
                    <dl>
                      <dt class="text-sm font-medium text-gray-500 truncate">Total Revenue</dt>
                      <dd>
                        <div class="text-lg font-medium text-gray-900">
                          <%= number_to_currency(@total_revenue || 24500) %>
                          <% if @revenue_change && @revenue_change > 0 %>
                            <span class="ml-2 text-sm text-green-500">+<%= number_to_percentage(@revenue_change, precision: 1) %></span>
                          <% elsif @revenue_change && @revenue_change < 0 %>
                            <span class="ml-2 text-sm text-red-500"><%= number_to_percentage(@revenue_change, precision: 1) %></span>
                          <% end %>
                        </div>
                      </dd>
                    </dl>
                  </div>
                </div>
              </div>
              <div class="bg-gray-50 px-5 py-3">
                <div class="text-sm">
                  <a href="<%= revenue_report_path if defined?(revenue_report_path) %>" class="font-medium text-indigo-600 hover:text-indigo-900">View details</a>
                </div>
              </div>
            </div>

            <!-- Card 2: Orders -->
            <div class="bg-white overflow-hidden shadow-md rounded-lg transform transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
              <div class="p-5">
                <div class="flex items-center">
                  <div class="flex-shrink-0">
                    <%= render 'shared/icon', name: "cart", size: "md", color: "green" %>
                  </div>
                  <div class="ml-5 w-0 flex-1">
                    <dl>
                      <dt class="text-sm font-medium text-gray-500 truncate">Total Orders</dt>
                      <dd>
                        <div class="text-lg font-medium text-gray-900">
                          <%= @total_orders || 142 %>
                          <% if @orders_change && @orders_change > 0 %>
                            <span class="ml-2 text-sm text-green-500">+<%= number_to_percentage(@orders_change, precision: 1) %></span>
                          <% elsif @orders_change && @orders_change < 0 %>
                            <span class="ml-2 text-sm text-red-500"><%= number_to_percentage(@orders_change, precision: 1) %></span>
                          <% end %>
                        </div>
                      </dd>
                    </dl>
                  </div>
                </div>
              </div>
              <div class="bg-gray-50 px-5 py-3">
                <div class="text-sm">
                  <a href="<%= orders_path if defined?(orders_path) %>" class="font-medium text-indigo-600 hover:text-indigo-900">View all</a>
                </div>
              </div>
            </div>

            <!-- Card 3: Customers -->
            <div class="bg-white overflow-hidden shadow-md rounded-lg transform transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
              <div class="p-5">
                <div class="flex items-center">
                  <div class="flex-shrink-0">
                    <%= render 'shared/icon', name: "user", size: "md", color: "amber" %>
                  </div>
                  <div class="ml-5 w-0 flex-1">
                    <dl>
                      <dt class="text-sm font-medium text-gray-500 truncate">Total Customers</dt>
                      <dd>
                        <div class="text-lg font-medium text-gray-900">
                          <%= @total_customers || 854 %>
                          <% if @customers_change && @customers_change > 0 %>
                            <span class="ml-2 text-sm text-green-500">+<%= number_to_percentage(@customers_change, precision: 1) %></span>
                          <% elsif @customers_change && @customers_change < 0 %>
                            <span class="ml-2 text-sm text-red-500"><%= number_to_percentage(@customers_change, precision: 1) %></span>
                          <% end %>
                        </div>
                      </dd>
                    </dl>
                  </div>
                </div>
              </div>
              <div class="bg-gray-50 px-5 py-3">
                <div class="text-sm">
                  <a href="<%= customers_path if defined?(customers_path) %>" class="font-medium text-indigo-600 hover:text-indigo-900">View all</a>
                </div>
              </div>
            </div>

            <!-- Card 4: Products -->
            <div class="bg-white overflow-hidden shadow-md rounded-lg transform transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
              <div class="p-5">
                <div class="flex items-center">
                  <div class="flex-shrink-0">
                    <%= render 'shared/icon', name: "star", size: "md", color: "peach" %>
                  </div>
                  <div class="ml-5 w-0 flex-1">
                    <dl>
                      <dt class="text-sm font-medium text-gray-500 truncate">Total Products</dt>
                      <dd>
                        <div class="text-lg font-medium text-gray-900">
                          <%= @total_products || 47 %>
                          <% if @products_change && @products_change > 0 %>
                            <span class="ml-2 text-sm text-green-500">+<%= number_to_percentage(@products_change, precision: 1) %></span>
                          <% elsif @products_change && @products_change < 0 %>
                            <span class="ml-2 text-sm text-red-500"><%= number_to_percentage(@products_change, precision: 1) %></span>
                          <% end %>
                        </div>
                      </dd>
                    </dl>
                  </div>
                </div>
              </div>
              <div class="bg-gray-50 px-5 py-3">
                <div class="text-sm">
                  <a href="<%= products_path if defined?(products_path) %>" class="font-medium text-indigo-600 hover:text-indigo-900">View all</a>
                </div>
              </div>
            </div>
          </div>

          <!-- Sales Overview Chart -->
          <div class="mt-8">
            <div class="bg-white shadow-md rounded-lg overflow-hidden">
              <div class="px-6 py-5 border-b border-gray-200">
                <div class="flex items-center justify-between">
                  <h3 class="text-lg leading-6 font-medium text-gray-900">Monthly Sales Overview</h3>
                  <div class="flex space-x-3">
                    <select id="chart-period" class="mt-1 block pl-3 pr-10 py-2 text-sm border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 rounded-md">
                      <option value="30">Last 30 days</option>
                      <option value="90">Last 90 days</option>
                      <option value="365">Last year</option>
                    </select>
                  </div>
                </div>
              </div>
              <div class="px-6 py-6">
                <div class="relative h-80">
                  <%= render 'dashboard/sales_chart' if defined?(render_sales_chart) %>
                  <% unless defined?(render_sales_chart) %>
                    <div class="flex items-center justify-center h-full">
                      <div class="text-center">
                        <div class="mx-auto h-12 w-12 text-gray-400">
                          <%= render 'shared/icon', name: "chart", size: "lg", color: "blue" %>
                        </div>
                        <h3 class="mt-2 text-sm font-medium text-gray-900">No sales data available</h3>
                        <p class="mt-1 text-sm text-gray-500">
                          Start selling to see your sales chart.
                        </p>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>

          <!-- Two-column layout for Recent Activity and Action Items -->
          <div class="mt-8 grid grid-cols-1 gap-5 lg:grid-cols-2">
            <!-- Recent Activity -->
            <div>
              <div class="flex items-center justify-between">
                <h3 class="text-lg leading-6 font-medium text-gray-900">Recent Activity</h3>
                <div class="text-sm">
                  <a href="<%= activity_path if defined?(activity_path) %>" class="font-medium text-indigo-600 hover:text-indigo-900">View all</a>
                </div>
              </div>
              <div class="mt-4 bg-white shadow-md rounded-lg overflow-hidden">
