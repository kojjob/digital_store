<!-- JavaScript for the mobile menu controller -->
<% content_for :page_scripts do %>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof window.Stimulus !== 'undefined') {
      window.Stimulus.register('mobile-menu', class extends window.Stimulus.Controller {
        static targets = ['menu'];
        
        connect() {
          console.log('Mobile menu controller connected');
        }
        
        toggle() {
          const menuElement = this.menuTarget;
          const currentDisplay = window.getComputedStyle(menuElement).display;
          
          if (currentDisplay === 'none') {
            menuElement.style.display = 'flex';
          } else {
            menuElement.style.display = 'none';
          }
        }
      });
    }
  });
</script>
<% end %>