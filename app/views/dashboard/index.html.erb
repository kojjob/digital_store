<%# 
  Dashboard Index View
  
  This is the main dashboard view that serves as the primary interface for users.
  It incorporates a modern design inspired by the provided examples while
  being tailored to our digital_store project models.
%>

<div class="min-h-screen bg-gray-50">
  <div class="flex h-screen overflow-hidden">
    <!-- Sidebar Navigation (Desktop) -->
    <%= render 'dashboard/sidebar' %>

    <!-- Mobile Menu and Toggle -->
    <%= render 'dashboard/mobile_menu' %>

    <!-- Main content area -->
    <div class="flex-1 overflow-auto focus:outline-none" id="main-content">
      <div class="py-6">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
          <!-- Page header -->
          <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6">
            <div class="flex-1 min-w-0">
              <h1 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
                <%= Time.current.hour < 12 ? "Good morning" : (Time.current.hour < 18 ? "Good afternoon" : "Good evening") %>, 
                <%= current_user.respond_to?(:first_name) ? current_user.first_name : current_user.email.split('@').first %>
                <% if current_user.seller? %>
                  <span class="text-sm font-normal text-indigo-600">(Seller)</span>
                <% end %>
              </h1>
              <div class="mt-1 flex flex-col sm:flex-row sm:flex-wrap sm:mt-0 sm:space-x-6">
                <div class="mt-2 flex items-center text-sm text-gray-500">
                  <svg class="flex-shrink-0 mr-1.5 h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                  </svg>
                  <%= Date.today.strftime("%B %d, %Y") %>
                </div>
                <% if @last_login %>
                <div class="mt-2 flex items-center text-sm text-gray-500">
                  <svg class="flex-shrink-0 mr-1.5 h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                  </svg>
                  Last login: <%= @last_login.strftime("%B %d, %Y at %I:%M %p") %>
                </div>
                <% end %>
              </div>
            </div>
            <div class="mt-4 flex md:mt-0 md:ml-4">
              <% if current_user.seller? %>
                <%= link_to sellers_dashboard_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
                  <div class="mr-2">
                    <%= render 'shared/icon', name: "chart", size: "sm", color: "blue" %>
                  </div>
                  View Analytics
                <% end %>
                <%= link_to new_product_path, class: "ml-3 inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
                  <div class="mr-2">
                    <%= render 'shared/icon', name: "plus", size: "sm", color: "white" %>
                  </div>
                  Add Product
                <% end %>
              <% else %>
                <%= link_to become_seller_path, class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
                  <div class="mr-2">
                    <%= render 'shared/icon', name: "store", size: "sm", color: "white" %>
                  </div>
                  Become a Seller
                <% end %>
              <% end %>
            </div>
          </div>
        </div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
          <!-- Notifications -->
          <div id="notifications-container" data-controller="notifications">
            <% if @new_notifications && @new_notifications > 0 %>
              <div class="mt-2 mb-6 rounded-md bg-indigo-50 p-4 animate-fadeIn" data-notifications-target="banner">
                <div class="flex">
                  <div class="flex-shrink-0">
                    <%= render 'shared/icon', name: "notification", size: "md", color: "blue" %>
                  </div>
                  <div class="ml-3 flex-1 md:flex md:justify-between">
                    <p class="text-sm text-indigo-700">
                      You have <%= @new_notifications %> new notification<%= @new_notifications > 1 ? 's' : '' %>
                    </p>
                    <p class="mt-3 text-sm md:mt-0 md:ml-6">
                      <a href="<%= notifications_path if defined?(notifications_path) %>" class="whitespace-nowrap font-medium text-indigo-700 hover:text-indigo-600">View all<span aria-hidden="true"> &rarr;</span></a>
                    </p>
                  </div>
                  <button data-action="notifications#dismiss" class="ml-2 text-indigo-500 hover:text-indigo-700">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                  </button>
                </div>
              </div>
            <% end %>
          </div>
          
          <!-- Quick Actions -->
          <%= render 'dashboard/quick_actions' %>
          
          <!-- Turbo Stream for Dynamic Content Updates -->
          <%= turbo_stream_from "user_#{current_user.id}_dashboard" if current_user %>
          
          <!-- Role-specific Dashboard Content with Turbo Frame -->
          <%= turbo_frame_tag "dashboard_content", target: "_top" do %>
            <% if current_user.seller? %>
              <%= render 'dashboard/seller_dashboard' %>
            <% else %>
              <%= render 'dashboard/buyer_dashboard' %>
            <% end %>
          <% end %>

          <!-- Two Column Layout for Dashboard Components -->
          <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Main Column (2/3 width) -->
            <div class="md:col-span-2 space-y-6">
              <!-- Activity Feed -->
              <%= render 'dashboard/activity_feed' %>
              
              <!-- Recent Reviews -->
              <%= render 'dashboard/recent_reviews' %>
            </div>
            
            <!-- Sidebar Column (1/3 width) -->
            <div class="space-y-6">
              <!-- Action Items -->
              <div class="action-items-container" data-controller="action-items">
                <%= render 'dashboard/action_items' %>
              </div>
              
              <!-- Help & Support -->
              <%= render 'dashboard/help_support' %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Notification Area for JavaScript Notifications -->
<div id="notification-area" class="fixed top-0 right-0 p-4 z-50"></div>

<% content_for :page_scripts do %>
<script>
  // Make action items available to the ActionItemsService
  window.actionItems = <%= raw @action_items.to_json %>;
  
  // Initialize Stimulus controllers
  document.addEventListener('turbo:load', function() {
    // Any additional initialization can go here
  });
</script>
<% end %>
