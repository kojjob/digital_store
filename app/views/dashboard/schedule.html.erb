<% content_for :head do %>
<style>
  /* Force select elements and their options to be visible and properly styled */
  select {
    -webkit-appearance: menulist !important;
    -moz-appearance: menulist !important;
    appearance: menulist !important;
    background-color: #ffffff !important;
    color: #000000 !important;
    font-size: 16px !important;
    opacity: 1 !important;
    border: 3px solid #4f46e5 !important;
    padding: 0.5rem !important;
    /* Remove any custom styling that could interfere */
    background-image: none !important;
  }
  
  /* Ensure dropdown options are visible too */
  select option {
    background-color: #ffffff !important;
    color: #000000 !important;
    font-size: 16px !important;
    padding: 8px !important;
    opacity: 1 !important;
  }
  
  /* Dropdown arrow should be visible in all browsers */
  select::-ms-expand {
    display: inline-block !important;
    color: #4f46e5 !important;
  }
</style>
<% end %>

<% content_for :page_scripts do %>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Add resize event listener for responsive adjustments
    const adjustResponsiveLayout = () => {
      const isMobile = window.innerWidth < 768;
      const calendar = document.querySelector('.calendar-container');
      const eventsList = document.querySelector('.events-list-container');
      
      if (calendar && eventsList) {
        if (isMobile) {
          calendar.classList.add('overflow-x-auto');
          eventsList.classList.add('mt-6');
        } else {
          calendar.classList.remove('overflow-x-auto');
          eventsList.classList.remove('mt-6');
        }
      }
    };
    
    // Call once on load and add listener for window resize
    adjustResponsiveLayout();
    window.addEventListener('resize', adjustResponsiveLayout);
    
    // Global fix for select elements
    const enhanceSelects = () => {
      const allSelects = document.querySelectorAll('select');
      allSelects.forEach(select => {
        // Apply visibility fixes
        select.style.webkitAppearance = 'menulist-button';
        select.style.mozAppearance = 'menulist-button';
        select.style.appearance = 'menulist-button';
        select.style.opacity = '1';
        select.style.visibility = 'visible';
        select.style.display = 'inline-block';
        select.style.backgroundColor = '#ffffff';
        select.style.color = '#000000';
        
        // Apply these styles more aggressively
        setTimeout(() => {
          select.style.opacity = '1';
          select.style.visibility = 'visible';
        }, 100);
      });
    };
    
    // Apply immediately and after a slight delay
    enhanceSelects();
    setTimeout(enhanceSelects, 500);
  });
</script>
<% end %>

<!-- Schedule Dashboard -->
<div class="bg-gray-50 min-h-screen" data-controller="schedule" data-schedule-current-date-value="<%= Date.today.to_s %>">
  <div class="container mx-auto px-4 py-8">
    <!-- Header with breadcrumbs and time period selector -->
