            <h3 class="font-bold text-xl" data-schedule-target="monthTitle"><%= Date.today.strftime("%B %Y") %></h3>
            <div class="flex space-x-2">
              <button 
                class="p-1.5 text-gray-500 hover:text-indigo-600 bg-gray-50 rounded-md hover:bg-gray-100 transition-colors"
                data-action="click->schedule#prevMonth">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
              </button>
              <button 
                class="p-1.5 text-gray-500 hover:text-indigo-600 bg-gray-50 rounded-md hover:bg-gray-100 transition-colors"
                data-action="click->schedule#nextMonth">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </button>
            </div>
          </div>
          
          <!-- Calendar Days Header -->
          <div class="grid grid-cols-7 gap-2 text-center mt-4">
            <% %w(Sun Mon Tue Wed Thu Fri Sat).each do |day| %>
              <div class="text-xs font-medium text-gray-500"><%= day %></div>
            <% end %>
          </div>
          
          <!-- Calendar Days -->
          <div class="grid grid-cols-7 gap-2 text-center mt-2" data-schedule-target="calendarDays">
            <!-- Calendar days will be dynamically rendered by the Stimulus controller -->
          </div>
        </div>
        
        <!-- Consultations/Deliveries List -->
        <div class="bg-white rounded-b-lg border border-gray-100 p-4 shadow-md events-list-container">
          <div class="flex justify-between items-center mb-5">
            <h3 class="font-bold text-xl"><%= current_user.seller? ? "Consultations" : "Deliveries" %></h3>
            <a href="#" class="text-indigo-600 text-sm font-medium hover:text-indigo-800 flex items-center">
              View All
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>
          
          <!-- Meeting Items -->
          <div class="space-y-4" data-schedule-target="meetingList">
            <!-- Meeting items will be dynamically rendered by the Stimulus controller -->
            <div class="text-center py-8 items-loading">
              <div class="animate-pulse flex flex-col items-center">
                <div class="rounded-full bg-gray-200 h-12 w-12 mb-4"></div>
                <div class="h-4 bg-gray-200 rounded w-1/2 mb-2"></div>
                <div class="h-3 bg-gray-200 rounded w-1/3"></div>
              </div>
            </div>
          </div>
          
          <!-- Add New Button -->
          <button 
            class="mt-5 w-full flex items-center justify-center py-2 px-4 border border-dashed border-gray-300 rounded-md text-sm font-medium text-gray-600 hover:text-indigo-600 hover:border-indigo-300 transition-colors"
            data-action="click->schedule#openNewEventModal">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
            <%= current_user.seller? ? "Schedule New Consultation" : "Track New Delivery" %>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- New Event Modal -->
  <div class="fixed inset-0 z-50 overflow-y-auto hidden" data-schedule-target="eventModal">
    <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center">
      <!-- Background overlay -->
      <div class="fixed inset-0 transition-opacity" data-action="click->schedule#closeNewEventModal">
        <div class="absolute inset-0 bg-gray-500 opacity-75"></div>
      </div>

      <!-- Modal content -->
      <div class="inline-block w-full max-w-md p-6 my-8 overflow-hidden text-left align-middle transition-all transform bg-white shadow-xl rounded-lg" 
           role="dialog" aria-modal="true" aria-labelledby="modal-headline">
        <style>
          #eventModal input, 
          #eventModal textarea, 
          #eventModal select {
            border: 3px solid #4f46e5 !important;
            background-color: #ffffff !important;
            padding: 0.75rem !important; 
            color: #000000 !important;
            opacity: 1 !important;
            box-shadow: 0 4px 6px rgba(79, 70, 229, 0.15) !important;
            -webkit-box-shadow: 0 0 0px 1000px #ffffff inset !important;
            -webkit-text-fill-color: #000000 !important;
            font-size: 16px !important;
            font-weight: 500 !important;
          }
          #eventModal select {
            -webkit-appearance: menulist !important;
            -moz-appearance: menulist !important;
            appearance: menulist !important;
            background-image: none !important;
            background-color: #ffffff !important;
            padding-right: 1.5rem !important;
          }
          #eventModal input::placeholder, 
          #eventModal textarea::placeholder {
            color: #718096 !important;
            opacity: 1 !important;
            -webkit-text-fill-color: #718096 !important;
          }
        </style>
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-lg font-medium text-gray-900" id="modal-headline">
            <%= current_user.seller? ? "Schedule New Consultation" : "Track New Delivery" %>
          </h3>
          <button type="button" class="text-gray-400 hover:text-gray-500" data-action="click->schedule#closeNewEventModal">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        
        <form data-action="submit->schedule#createEvent" class="space-y-4">
          <div>
            <label for="event-title" class="block text-sm font-medium text-gray-700">Title</label>
            <input type="text" id="event-title" name="title" data-schedule-target="eventTitle" 
                  class="mt-1 block w-full border-2 border-indigo-500 rounded-md shadow-sm py-3 px-4 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-base"
                  placeholder="Enter event title" required>
          </div>
          
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="event-date" class="block text-sm font-medium text-gray-700">Date</label>
              <input type="date" id="event-date" name="date" data-schedule-target="eventDate"
                    class="mt-1 block w-full border-2 border-indigo-500 rounded-md shadow-sm py-3 px-4 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-base"
                    required>
            </div>
            
            <div>
              <label for="event-time" class="block text-sm font-medium text-gray-700">Time</label>
              <input type="time" id="event-time" name="time" data-schedule-target="eventTime"
                    class="mt-1 block w-full border-2 border-indigo-500 rounded-md shadow-sm py-3 px-4 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-base"
                    required>
            </div>
          </div>
          
          <div>
            <label for="event-duration" class="block text-sm font-medium text-gray-700">Duration</label>
            <select id="event-duration" name="duration" data-schedule-target="eventDuration"
                   class="mt-1 block w-full border-3 border-indigo-500 rounded-md shadow-md py-3 px-4 sm:text-base">
              <option value="30">30 minutes</option>
              <option value="60" selected>1 hour</option>
              <option value="90">1.5 hours</option>
              <option value="120">2 hours</option>
            </select>
          </div>
          
          <div>
            <label for="event-type" class="block text-sm font-medium text-gray-700">Type</label>
            <select id="event-type" name="type" data-schedule-target="eventType"
                   class="mt-1 block w-full border-3 border-indigo-500 rounded-md shadow-md py-3 px-4 sm:text-base">
              <% if current_user.seller? %>
                <option value="demo">Product Demo</option>
                <option value="support">Customer Support</option>
                <option value="customization">Product Customization</option>
                <option value="other">Other</option>
              <% else %>
                <option value="delivery">Product Delivery</option>
                <option value="demo">Product Demo</option>
                <option value="training">Training Session</option>
                <option value="other">Other</option>
              <% end %>
            </select>
          </div>
          
          <div>
            <label for="event-notes" class="block text-sm font-medium text-gray-700">Notes</label>
            <textarea id="event-notes" name="notes" data-schedule-target="eventNotes" rows="3"
                     class="mt-1 block w-full border-2 border-indigo-500 rounded-md shadow-sm py-3 px-4 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-base"
                     placeholder="Add any additional details"></textarea>
          </div>
          
          <div class="pt-4 flex justify-end space-x-3">
            <button type="button" 
                   class="bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
                   data-action="click->schedule#closeNewEventModal">
              Cancel
            </button>
            <button type="submit"
                   class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
              Create
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Toast Notification -->
  <div class="fixed inset-0 flex items-end justify-center px-4 py-6 pointer-events-none sm:p-6 sm:items-start sm:justify-end z-50">
    <div data-schedule-target="toast"
         class="max-w-sm w-full bg-white shadow-lg rounded-lg pointer-events-auto ring-1 ring-black ring-opacity-5 overflow-hidden transform transition-all duration-300 opacity-0 translate-y-2 hidden">
      <div class="p-4">
        <div class="flex items-start">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-green-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="ml-3 w-0 flex-1 pt-0.5">
            <p class="text-sm font-medium text-gray-900" data-schedule-target="toastTitle">Success!</p>
            <p class="mt-1 text-sm text-gray-500" data-schedule-target="toastMessage">Event has been created successfully.</p>
          </div>
          <div class="ml-4 flex-shrink-0 flex">
            <button class="bg-white rounded-md inline-flex text-gray-400 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
                    data-action="click->schedule#hideToast">
              <span class="sr-only">Close</span>
              <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Event Details Modal -->
  <div class="fixed inset-0 z-50 overflow-y-auto hidden" data-schedule-target="eventDetailsModal">
    <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center">
      <!-- Background overlay -->
      <div class="fixed inset-0 transition-opacity" data-action="click->schedule#closeEventDetailsModal">
        <div class="absolute inset-0 bg-gray-500 opacity-75"></div>
      </div>

      <!-- Modal content -->
      <div class="inline-block w-full max-w-md p-6 my-8 overflow-hidden text-left align-middle transition-all transform bg-white shadow-xl rounded-lg" 
           role="dialog" aria-modal="true" aria-labelledby="details-modal-headline">
        <style>
          #eventDetailsModal .event-details-content {
            border: 1px solid #e5e7eb;
            background-color: #f9fafb;
            padding: 0.75rem;
            border-radius: 0.375rem;
          }
        </style>
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-lg font-medium text-gray-900" id="details-modal-headline" data-schedule-target="eventDetailsTitle">
            Event Details
          </h3>
          <button type="button" class="text-gray-400 hover:text-gray-500" data-action="click->schedule#closeEventDetailsModal">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        
        <!-- Event Avatar and Basic Info -->
        <div class="flex items-center mb-6">
          <div class="flex-shrink-0 mr-4" data-schedule-target="eventDetailsAvatar">
            <!-- Avatar will be populated by JS -->
          </div>
          <div>
            <div class="text-sm text-gray-500 mb-1" data-schedule-target="eventDetailsType">Event Type</div>
            <div class="text-sm font-medium flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400 mr-1" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
              </svg>
              <span data-schedule-target="eventDetailsDate">Date</span>
            </div>
            <div class="text-sm font-medium flex items-center mt-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400 mr-1" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
              </svg>
              <span data-schedule-target="eventDetailsTime">Time</span>
            </div>
          </div>
        </div>
        
        <!-- Event Description -->
        <div class="mb-6">
          <h4 class="text-sm font-medium text-gray-700 mb-2">Notes</h4>
          <div class="bg-gray-50 rounded-md p-3 text-sm text-gray-600 event-details-content" data-schedule-target="eventDetailsNotes">
            No additional notes for this event.
          </div>
        </div>
        
        <!-- Action Buttons -->
        <div class="flex justify-between pt-4 border-t border-gray-200">
          <button type="button" 
                 class="text-red-600 hover:text-red-800 text-sm font-medium flex items-center"
                 data-action="click->schedule#deleteEvent">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
            Delete
          </button>
          
          <div class="space-x-3">
            <button type="button" 
                   class="bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
                   data-action="click->schedule#closeEventDetailsModal">
              Close
            </button>
            <button type="button"
                   class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
                   data-action="click->schedule#editEvent">
              Edit
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>