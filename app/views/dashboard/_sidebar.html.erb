<%# 
  Dashboard Sidebar Navigation Component
  
  Redesigned sidebar with enhanced visual elements and improved navigation structure.
  Tailored to the Digital Store project models and functionality.
%>

<!-- Sidebar container -->
<div class="hidden md:flex md:flex-shrink-0">
  <div class="flex flex-col w-64 border-r border-gray-200 bg-white">
    <!-- Logo section -->
    <div class="flex-shrink-0 h-16 px-4 flex items-center border-b border-gray-200">
      <%= link_to root_path, class: "flex items-center" do %>
        <img class="h-8 w-auto" src="<%= asset_path('logo.svg') %>" alt="Digital Store">
        <span class="ml-2 text-xl font-bold text-gray-900">Digital Store</span>
      <% end %>
    </div>
    
    <!-- User profile section -->
    <div class="p-4 border-b border-gray-200">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <% if current_user.respond_to?(:avatar) && current_user.avatar.attached? %>
            <%= image_tag current_user.avatar, class: "h-10 w-10 rounded-full object-cover", alt: "User avatar" %>
          <% else %>
            <div class="h-10 w-10 rounded-full bg-indigo-600 flex items-center justify-center">
              <span class="text-white font-medium text-md">
                <%= current_user.respond_to?(:initials) ? current_user.initials : current_user.email[0].upcase %>
              </span>
            </div>
          <% end %>
        </div>
        <div class="ml-3">
          <p class="text-sm font-medium text-gray-900 truncate">
            <%= current_user.respond_to?(:full_name) ? current_user.full_name : current_user.email %>
          </p>
          <p class="text-xs text-gray-500 truncate">
            <%= current_user.seller? ? "Seller Account" : "Buyer Account" %>
          </p>
        </div>
      </div>
    </div>
    
    <!-- Navigation -->
    <div class="flex-1 flex flex-col overflow-y-auto pt-4">
      <!-- Main Menu -->
      <div class="px-4 mb-6">
        <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
          MAIN MENU
        </h3>
        <nav class="space-y-1">
          <%= link_to dashboard_path, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{current_page?(dashboard_path) ? 'bg-indigo-100 text-indigo-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
            <div class="mr-3">
              <%= render 'shared/icon', name: "dashboard", size: "sm", color: current_page?(dashboard_path) ? "blue" : "gray" %>
            </div>
            Dashboard
          <% end %>
        
          <%= link_to products_path, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{controller_name == 'products' ? 'bg-indigo-100 text-indigo-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
            <div class="mr-3">
              <%= render 'shared/icon', name: "product", size: "sm", color: controller_name == 'products' ? "blue" : "gray" %>
            </div>
            Products
          <% end %>
        
          <%= link_to orders_path, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{controller_name == 'orders' ? 'bg-indigo-100 text-indigo-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
            <div class="mr-3">
              <%= render 'shared/icon', name: "cart", size: "sm", color: controller_name == 'orders' ? "blue" : "gray" %>
            </div>
            Orders
          <% end %>
          
          <% if current_user.seller? %>
            <%= link_to defined?(analytics_path) ? analytics_path : "#", class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{controller_name == 'analytics' ? 'bg-indigo-100 text-indigo-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <div class="mr-3">
                <%= render 'shared/icon', name: "chart", size: "sm", color: controller_name == 'analytics' ? "blue" : "gray" %>
              </div>
              Analytics
            <% end %>
            
            <%= link_to defined?(payments_path) ? payments_path : "#", class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{controller_name == 'payments' ? 'bg-indigo-100 text-indigo-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <div class="mr-3">
                <%= render 'shared/icon', name: "money", size: "sm", color: controller_name == 'payments' ? "blue" : "gray" %>
              </div>
              Payments
            <% end %>
            
            <%= link_to product_questions_path, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{controller_name == 'product_questions' ? 'bg-indigo-100 text-indigo-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <div class="mr-3">
                <%= render 'shared/icon', name: "question", size: "sm", color: controller_name == 'product_questions' ? "blue" : "gray" %>
              </div>
              Product Q&A
              <% if @unanswered_questions_count && @unanswered_questions_count > 0 %>
                <span class="ml-auto inline-flex items-center justify-center h-5 w-5 rounded-full bg-red-100 text-red-800 text-xs font-medium">
                  <%= @unanswered_questions_count %>
                </span>
              <% end %>
            <% end %>
          <% else %>
            <%= link_to defined?(wishlist_path) ? wishlist_path : "#", class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{controller_name == 'wishlists' ? 'bg-indigo-100 text-indigo-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <div class="mr-3">
                <%= render 'shared/icon', name: "heart", size: "sm", color: controller_name == 'wishlists' ? "blue" : "gray" %>
              </div>
              Wishlist
              <% if @wishlist_count && @wishlist_count > 0 %>
                <span class="ml-auto inline-flex items-center justify-center h-5 w-5 rounded-full bg-pink-100 text-pink-800 text-xs font-medium">
                  <%= @wishlist_count %>
                </span>
              <% end %>
            <% end %>
            
            <%= link_to defined?(downloads_path) ? downloads_path : "#", class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{controller_name == 'downloads' ? 'bg-indigo-100 text-indigo-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <div class="mr-3">
                <%= render 'shared/icon', name: "download", size: "sm", color: controller_name == 'downloads' ? "blue" : "gray" %>
              </div>
              Downloads
            <% end %>
          <% end %>
          
          <% if defined?(messages_path) %>
            <%= link_to messages_path, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{controller_name == 'messages' ? 'bg-indigo-100 text-indigo-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <div class="mr-3">
                <%= render 'shared/icon', name: "chat", size: "sm", color: controller_name == 'messages' ? "blue" : "gray" %>
              </div>
              Messages
              <% if @unread_messages_count && @unread_messages_count > 0 %>
                <span class="ml-auto inline-flex items-center justify-center h-5 w-5 rounded-full bg-red-100 text-red-800 text-xs font-medium">
                  <%= @unread_messages_count > 9 ? '9+' : @unread_messages_count %>
                </span>
              <% end %>
            <% end %>
          <% end %>
        </nav>
      </div>
      
      <!-- Settings -->
      <div class="px-4 mb-6">
        <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
          SETTINGS
        </h3>
        <nav class="space-y-1">
          <%= link_to edit_user_registration_path, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{controller_name == 'registrations' ? 'bg-indigo-100 text-indigo-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
            <div class="mr-3">
              <%= render 'shared/icon', name: "user-settings", size: "sm", color: controller_name == 'registrations' ? "blue" : "gray" %>
            </div>
            Account
          <% end %>
          
          <% if current_user.seller? %>
            <%= link_to edit_seller_path(current_user.seller), class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md #{controller_name == 'sellers' && action_name == 'edit' ? 'bg-indigo-100 text-indigo-700' : 'text-gray-700 hover:bg-gray-100'}" do %>
              <div class="mr-3">
                <%= render 'shared/icon', name: "store", size: "sm", color: controller_name == 'sellers' && action_name == 'edit' ? "blue" : "gray" %>
              </div>
              Store Settings
            <% end %>
          <% end %>
          
          <%= link_to defined?(help_path) ? help_path : "#", class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md text-gray-700 hover:bg-gray-100" do %>
            <div class="mr-3">
              <%= render 'shared/icon', name: "help", size: "sm", color: "gray" %>
            </div>
            Help & Support
          <% end %>
        </nav>
      </div>
    </div>
    
    <!-- Bottom section with logout -->
    <div class="flex-shrink-0 p-4 border-t border-gray-200">
      <%= button_to destroy_user_session_path, method: :delete, class: "group flex items-center px-3 py-2 text-sm font-medium rounded-md w-full text-gray-700 hover:bg-gray-100" do %>
        <div class="mr-3">
          <%= render 'shared/icon', name: "logout", size: "sm", color: "gray" %>
        </div>
        Sign out
      <% end %>
    </div>
  </div>
</div>
