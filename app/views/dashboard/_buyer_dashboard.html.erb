<%#
  Buyer-specific dashboard content
%>

<!-- Buyer Stats -->
<div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
  <%= render 'dashboard/stat_card', 
    icon: "cart", 
    color: "blue", 
    title: "Recent Purchases", 
    value: @recent_purchases.count, 
    link_text: "View all", 
    link_path: orders_path 
  %>
  
  <%= render 'dashboard/stat_card', 
    icon: "heart", 
    color: "red", 
    title: "Wishlist Items", 
    value: @wishlist_items.count, 
    link_text: "View all", 
    link_path: defined?(wishlist_path) ? wishlist_path : "#" 
  %>
  
  <%= render 'dashboard/stat_card', 
    icon: "star", 
    color: "amber", 
    title: "Your Reviews", 
    value: @recent_reviews.count, 
    link_text: "View all", 
    link_path: defined?(reviews_path) ? reviews_path : "#" 
  %>
</div>

<!-- Recommended Products -->
<div class="mt-8">
  <div class="flex items-center justify-between">
    <h3 class="text-lg leading-6 font-medium text-gray-900">Recommended for You</h3>
    <div class="text-sm">
      <a href="<%= products_path %>" class="font-medium text-indigo-600 hover:text-indigo-900">View all</a>
    </div>
  </div>
  <div class="mt-4 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
    <% if @recommended_products.present? && @recommended_products.any? %>
      <% @recommended_products.each do |product| %>
        <div class="bg-white overflow-hidden shadow-md rounded-lg transform transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
          <% if product.product_images.any? && product.product_images.first.has_image? %>
            <%= image_tag product.product_images.first.image, class: "w-full h-48 object-cover", alt: product.product_images.first.safe_alt_text %>
          <% elsif product.images.attached? %>
            <%= image_tag product.images.first, class: "w-full h-48 object-cover", alt: "#{product.name} image" %>
          <% else %>
            <div class="w-full h-48 bg-gray-200 flex items-center justify-center">
              <%= render 'shared/icon', name: "image", size: "lg", color: "gray" %>
            </div>
          <% end %>
          <div class="p-4">
            <h4 class="text-lg font-medium text-gray-900"><%= product.name %></h4>
            <p class="mt-1 text-sm text-gray-500"><%= product.description.try(:truncate, 100) || "No description available" %></p>
            <div class="mt-4 flex items-center justify-between">
              <span class="text-lg font-medium text-gray-900"><%= number_to_currency(product.price) %></span>
              <%= link_to "View Details", product_path(product), class: "text-sm font-medium text-indigo-600 hover:text-indigo-900" %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="col-span-3 py-10 text-center bg-white shadow-md rounded-lg overflow-hidden">
        <div class="mx-auto h-12 w-12 text-gray-400">
          <%= render 'shared/icon', name: "search", size: "lg", color: "gray" %>
        </div>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No recommended products</h3>
        <p class="mt-1 text-sm text-gray-500">
          Browse our catalog to find products that match your interests.
        </p>
        <div class="mt-6">
          <%= link_to "Browse Products", products_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Become a Seller CTA -->
<div class="bg-gradient-to-br from-indigo-50 to-blue-50 border border-indigo-100 rounded-lg p-6 mt-8">
  <div class="flex flex-col md:flex-row items-center">
    <div class="md:flex-1 mb-4 md:mb-0 md:mr-6">
      <h3 class="text-lg font-semibold text-indigo-900 mb-2">Start Selling Today</h3>
      <p class="text-indigo-700">Turn your digital creations into profit. Join our marketplace as a seller and reach customers worldwide.</p>
    </div>
    <div>
      <%= link_to "Become a Seller", become_seller_path, class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
    </div>
  </div>
</div>
