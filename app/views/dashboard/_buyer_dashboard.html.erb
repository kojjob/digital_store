<%#
  Buyer-specific dashboard content
  Redesigned with improved visual elements and layout structure.
  Tailored to the Digital Store project with relevant metrics for buyers.
%>

<!-- Buyer Stats -->
<div class="mt-2 mb-6">
  <h2 class="text-xl font-bold text-gray-900 mb-4">Your Activity</h2>
  <p class="text-sm text-gray-600 mb-4">Overview of your account activity</p>
  
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    <%= render 'dashboard/stat_card', 
      icon: "cart", 
      color: "blue", 
      title: "Recent Purchases", 
      value: @recent_purchases&.count || 0, 
      change_note: "Last 30 days",
      link_text: "View all", 
      link_path: orders_path 
    %>
    
    <%= render 'dashboard/stat_card', 
      icon: "heart", 
      color: "red", 
      title: "Wishlist Items", 
      value: @wishlist_items&.count || 0, 
      link_text: "View all", 
      link_path: defined?(wishlist_path) ? wishlist_path : "#" 
    %>
    
    <%= render 'dashboard/stat_card', 
      icon: "star", 
      color: "amber", 
      title: "Your Reviews", 
      value: @recent_reviews&.count || 0, 
      link_text: "View all", 
      link_path: defined?(reviews_path) ? reviews_path : "#" 
    %>
  </div>
</div>

<!-- Recent Purchases -->
<div class="mb-6">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-medium text-gray-900">Recent Purchases</h3>
    <div class="text-sm">
      <a href="<%= orders_path %>" class="font-medium text-indigo-600 hover:text-indigo-900">View all</a>
    </div>
  </div>
  
  <div class="bg-white shadow-md rounded-lg overflow-hidden">
    <% if @recent_purchases.present? && @recent_purchases.any? %>
      <ul class="divide-y divide-gray-200">
        <% @recent_purchases.each do |order| %>
          <li class="p-5">
            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0">
                <% if order.product.product_images.any? %>
                  <%= image_tag order.product.product_images.first.image, class: "h-16 w-16 rounded-md object-cover" %>
                <% else %>
                  <div class="h-16 w-16 rounded-md bg-gray-200 flex items-center justify-center">
                    <svg class="h-8 w-8 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                <% end %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900">
                  <%= order.product.name %>
                </p>
                <p class="text-sm text-gray-500 mt-1">
                  <%= number_to_currency(order.total_amount) %> • <%= order.created_at.strftime("%B %d, %Y") %>
                </p>
                <div class="mt-2 flex items-center">
                  <% status_class = case order.status
                     when 'completed' then 'bg-green-100 text-green-800'
                     when 'paid' then 'bg-blue-100 text-blue-800'
                     when 'processing' then 'bg-yellow-100 text-yellow-800'
                     when 'refunded' then 'bg-red-100 text-red-800'
                     else 'bg-gray-100 text-gray-800'
                     end %>
                  <span class="px-2 py-1 text-xs inline-flex leading-4 font-medium rounded-full <%= status_class %>">
                    <%= order.status.titleize %>
                  </span>
                </div>
              </div>
              <div class="flex-shrink-0 flex space-x-2">
                <% if order.status == "paid" || order.status == "completed" %>
                  <%= link_to order.download_links.any? ? order.download_links.last : "#", class: "inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
                    <svg class="-ml-0.5 mr-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                    Download
                  <% end %>
                <% end %>
                <%= link_to order_path(order), class: "inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
                  Details
                <% end %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="py-10 text-center">
        <div class="mx-auto h-12 w-12 text-gray-400">
          <%= render 'shared/icon', name: "shopping-bag", size: "lg", color: "gray" %>
        </div>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No purchases yet</h3>
        <p class="mt-1 text-sm text-gray-500">
          Start shopping to see your purchases here.
        </p>
        <div class="mt-6">
          <%= link_to products_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
            <svg class="-ml-1 mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3zM16 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM6.5 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3z" />
            </svg>
            Browse Products
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Recommended Products -->
<div class="mb-6">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-medium text-gray-900">Recommended for You</h3>
    <div class="text-sm">
      <a href="<%= products_path %>" class="font-medium text-indigo-600 hover:text-indigo-900">View all</a>
    </div>
  </div>
  
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    <% if @recommended_products.present? && @recommended_products.any? %>
      <% @recommended_products.each do |product| %>
        <div class="bg-white overflow-hidden shadow-md rounded-lg transform transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
          <% if product.product_images.any? %>
            <%= image_tag product.product_images.first.image, class: "w-full h-48 object-cover", alt: product.product_images.first.alt_text || product.name %>
          <% else %>
            <div class="w-full h-48 bg-gray-200 flex items-center justify-center">
              <svg class="h-12 w-12 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
          <% end %>
          <div class="p-4">
            <div class="flex items-center justify-between">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
                <%= product.category&.name || "Digital Product" %>
              </span>
              
              <% if product.average_rating > 0 %>
                <div class="flex items-center">
                  <svg class="h-4 w-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                  </svg>
                  <span class="ml-1 text-sm text-gray-600"><%= product.average_rating.round(1) %></span>
                </div>
              <% end %>
            </div>
            
            <h4 class="mt-2 text-lg font-medium text-gray-900 line-clamp-1"><%= product.name %></h4>
            <p class="mt-1 text-sm text-gray-500 line-clamp-2"><%= product.short_description %></p>
            
            <div class="mt-4 flex items-center justify-between">
              <div>
                <% if product.discounted? %>
                  <span class="text-sm line-through text-gray-500"><%= number_to_currency(product.price) %></span>
                  <span class="ml-2 text-lg font-medium text-gray-900"><%= number_to_currency(product.discounted_price) %></span>
                <% else %>
                  <span class="text-lg font-medium text-gray-900"><%= number_to_currency(product.price) %></span>
                <% end %>
                
                <% if product.discounted? %>
                  <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-rose-100 text-rose-800">
                    <%= product.discount_percentage %>% OFF
                  </span>
                <% end %>
              </div>
              
              <%= link_to product_path(product), class: "inline-flex items-center text-sm font-medium text-indigo-600 hover:text-indigo-900" do %>
                View Details
                <svg class="ml-1 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="col-span-3 py-10 text-center bg-white shadow-md rounded-lg overflow-hidden">
        <div class="mx-auto h-12 w-12 text-gray-400">
          <%= render 'shared/icon', name: "search", size: "lg", color: "gray" %>
        </div>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No recommended products</h3>
        <p class="mt-1 text-sm text-gray-500">
          Browse our catalog to find products that match your interests.
        </p>
        <div class="mt-6">
          <%= link_to "Browse Products", products_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Your Downloads -->
<div class="mb-6">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-medium text-gray-900">Your Downloads</h3>
    <div class="text-sm">
      <a href="<%= defined?(downloads_path) ? downloads_path : '#' %>" class="font-medium text-indigo-600 hover:text-indigo-900">View all</a>
    </div>
  </div>
  
  <div class="bg-white overflow-hidden shadow-md rounded-lg">
    <% if @recent_downloads.present? && @recent_downloads.any? %>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Product</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">File</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Downloads Left</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Expires</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @recent_downloads.each do |download| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div class="flex-shrink-0 h-10 w-10">
                    <% if download.product.product_images.any? %>
                      <%= image_tag download.product.product_images.first.image, class: "h-10 w-10 rounded-md object-cover" %>
                    <% else %>
                      <div class="h-10 w-10 rounded-md bg-gray-200 flex items-center justify-center">
                        <svg class="h-6 w-6 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                      </div>
                    <% end %>
                  </div>
                  <div class="ml-4">
                    <div class="text-sm font-medium text-gray-900"><%= download.product.name %></div>
                    <div class="text-sm text-gray-500"><%= download.order.created_at.strftime("%B %d, %Y") %></div>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900"><%= download.file_name %></div>
                <div class="text-sm text-gray-500"><%= number_to_human_size(download.file_size) %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% downloads_left = download.download_limit - download.download_count %>
                <% status_class = downloads_left > 2 ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= status_class %>">
                  <%= downloads_left %> remaining
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <% days_left = (download.expires_at.to_date - Date.today).to_i %>
                <% if days_left > 0 %>
                  Expires in <%= pluralize(days_left, 'day') %>
                <% else %>
                  <span class="text-red-600">Expired</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                <% if download.download_count < download.download_limit && download.expires_at > Time.current %>
                  <%= link_to download, class: "text-indigo-600 hover:text-indigo-900" do %>
                    Download
                  <% end %>
                <% else %>
                  <span class="text-gray-400">Unavailable</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="py-10 text-center">
        <div class="mx-auto h-12 w-12 text-gray-400">
          <%= render 'shared/icon', name: "download", size: "lg", color: "gray" %>
        </div>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No downloads</h3>
        <p class="mt-1 text-sm text-gray-500">
          Purchase digital products to get download links.
        </p>
        <div class="mt-6">
          <%= link_to "Browse Digital Products", products_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Become a Seller CTA -->
<div class="bg-gradient-to-br from-indigo-50 to-blue-50 border border-indigo-100 rounded-lg p-6 mb-6">
  <div class="flex flex-col md:flex-row items-center">
    <div class="md:flex-1 mb-4 md:mb-0 md:mr-6">
      <h3 class="text-lg font-semibold text-indigo-900 mb-2">Start Selling Today</h3>
      <p class="text-indigo-700 mb-4">Turn your digital creations into profit. Join our marketplace as a seller and reach customers worldwide.</p>
      <ul class="space-y-2 mb-4">
        <li class="flex items-center text-sm text-indigo-700">
          <svg class="h-5 w-5 text-green-500 mr-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          Sell digital products with no inventory
        </li>
        <li class="flex items-center text-sm text-indigo-700">
          <svg class="h-5 w-5 text-green-500 mr-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          Automatic delivery to customers
        </li>
        <li class="flex items-center text-sm text-indigo-700">
          <svg class="h-5 w-5 text-green-500 mr-2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          Detailed analytics and reporting
        </li>
      </ul>
    </div>
    <div>
      <%= link_to become_seller_path, class: "inline-flex items-center px-5 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
        <svg class="-ml-1 mr-3 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
        </svg>
        Become a Seller
      <% end %>
    </div>
  </div>
</div>
