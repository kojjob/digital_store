<%# 
  Activity Feed Component
  
  Displays recent user activity and system events.
%>

<div class="bg-white shadow-md rounded-lg overflow-hidden">
  <div class="bg-gradient-to-r from-indigo-700 to-indigo-600 px-4 py-4">
    <div class="flex items-center justify-between">
      <h3 class="text-lg font-medium text-white">Recent Activity</h3>
      <% if @activities.present? && @activities.any? %>
        <span class="inline-flex items-center justify-center h-6 w-6 rounded-full bg-white text-indigo-700 text-sm font-semibold">
          <%= @activities.size %>
        </span>
      <% end %>
    </div>
  </div>

  <% if @activities.present? && @activities.any? %>
    <div class="flow-root">
      <ul class="-mb-8">
        <% @activities.each do |activity| %>
          <li>
            <div class="relative pb-8">
              <% unless activity == @activities.last %>
                <span class="absolute top-5 left-5 -ml-px h-full w-0.5 bg-gray-200" aria-hidden="true"></span>
              <% end %>
              <div class="relative flex items-start space-x-3">
                <div class="relative">
                  <% case activity.activity_type
                     when 'order_created' %>
                    <div class="h-10 w-10 rounded-full bg-green-100 flex items-center justify-center ring-8 ring-white">
                      <svg class="h-6 w-6 text-green-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                      </svg>
                    </div>
                  <% when 'product_created' %>
                    <div class="h-10 w-10 rounded-full bg-blue-100 flex items-center justify-center ring-8 ring-white">
                      <svg class="h-6 w-6 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                      </svg>
                    </div>
                  <% when 'review_created' %>
                    <div class="h-10 w-10 rounded-full bg-yellow-100 flex items-center justify-center ring-8 ring-white">
                      <svg class="h-6 w-6 text-yellow-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                      </svg>
                    </div>
                  <% when 'payment_received' %>
                    <div class="h-10 w-10 rounded-full bg-green-100 flex items-center justify-center ring-8 ring-white">
                      <svg class="h-6 w-6 text-green-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />
                      </svg>
                    </div>
                  <% when 'account_updated' %>
                    <div class="h-10 w-10 rounded-full bg-indigo-100 flex items-center justify-center ring-8 ring-white">
                      <svg class="h-6 w-6 text-indigo-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                      </svg>
                    </div>
                  <% when 'product_question' %>
                    <div class="h-10 w-10 rounded-full bg-purple-100 flex items-center justify-center ring-8 ring-white">
                      <svg class="h-6 w-6 text-purple-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                    </div>
                  <% else %>
                    <div class="h-10 w-10 rounded-full bg-gray-100 flex items-center justify-center ring-8 ring-white">
                      <svg class="h-6 w-6 text-gray-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                    </div>
                  <% end %>
                </div>
                <div class="min-w-0 flex-1">
                  <div>
                    <div class="text-sm font-medium text-gray-900">
                      <%= activity.title %>
                    </div>
                    <p class="mt-0.5 text-sm text-gray-500">
                      <%= time_ago_in_words(activity.created_at) %> ago
                    </p>
                  </div>
                  <div class="mt-2 text-sm text-gray-700">
                    <p><%= activity.description %></p>
                  </div>
                  <% if activity.actionable? %>
                    <div class="mt-2">
                      <%= link_to activity.action_text || "View", activity.action_url, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
    <div class="bg-gray-50 px-4 py-3 text-right sm:px-6">
      <% if defined?(activity_path) %>
        <%= link_to "View all activity", activity_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
      <% end %>
    </div>
  <% else %>
    <div class="py-6 text-center">
      <div class="mx-auto h-12 w-12 text-gray-400">
        <svg class="h-12 w-12" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No recent activity</h3>
      <p class="mt-1 text-sm text-gray-500">
        Your activity will appear here as you interact with the platform.
      </p>
    </div>
  <% end %>
</div>
