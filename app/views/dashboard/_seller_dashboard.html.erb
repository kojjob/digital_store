<%#
  Seller-specific dashboard content
  Redesigned with improved visual elements and layout structure.
  Tailored to the Digital Store project with relevant metrics.
%>

<!-- Verification Notice -->
<% if current_user.seller? && !current_user.seller.verified? %>
  <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-6 rounded-r-md" data-controller="alert" data-alert-dismissible="true">
    <div class="flex">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-yellow-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="ml-3">
        <p class="text-sm text-yellow-700">
          Your seller account is pending verification. You'll be able to list products once your account is approved.
        </p>
      </div>
      <div class="ml-auto pl-3">
        <div class="-mx-1.5 -my-1.5">
          <button data-action="alert#dismiss" class="inline-flex rounded-md p-1.5 text-yellow-500 hover:bg-yellow-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-yellow-500">
            <span class="sr-only">Dismiss</span>
            <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
<% end %>

<!-- Enhanced Analytics Dashboard -->
<%= render 'dashboard/enhanced_analytics' %>

<div class="mb-6">
  <h2 class="text-xl font-bold text-gray-900 mb-4">Store Performance</h2>
  <p class="text-sm text-gray-600 mb-4">Metrics for your digital products</p>
  
  <!-- Key Performance Stats -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
    <%= render 'dashboard/stat_card', 
      icon: "lightning", 
      color: "blue", 
      title: "Total Revenue", 
      value: number_to_currency(@total_revenue || 0), 
      change_percentage: @revenue_change || 0, 
      change_note: "vs last month",
      link_text: "View details", 
      link_path: defined?(revenue_report_path) ? revenue_report_path : "#" 
    %>
    
    <%= render 'dashboard/stat_card', 
      icon: "cart", 
      color: "green", 
      title: "Total Orders", 
      value: @total_orders || 0, 
      change_percentage: @orders_change || 0, 
      change_note: "vs last month",
      link_text: "View all", 
      link_path: orders_path 
    %>
    
    <%= render 'dashboard/stat_card', 
      icon: "user", 
      color: "amber", 
      title: "Total Customers", 
      value: @total_customers || 0, 
      change_percentage: @customers_change || 0,
      change_note: "vs last month",
      link_text: "View all", 
      link_path: defined?(customers_path) ? customers_path : "#" 
    %>
    
    <%= render 'dashboard/stat_card', 
      icon: "star", 
      color: "pink", 
      title: "Average Rating", 
      value: (@average_rating || 0).to_f.round(1), 
      change_note: "Based on <%= @reviews_count || 0 %> reviews",
      link_text: "View all", 
      link_path: defined?(reviews_path) ? reviews_path : "#" 
    %>
  </div>
</div>

<!-- Store Performance & Customer Activity -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-6">
  <!-- Sales Overview -->
  <div data-controller="chart" data-chart-type="line" data-chart-endpoint="<%= sales_data_path if defined?(sales_data_path) %>">
    <%= render 'dashboard/chart_card', 
      id: 'sales-overview-chart', 
      title: 'Sales Overview', 
      description: 'Revenue trends over time',
      height: '300px',
      show_periods: true
    %>
  </div>
  
  <!-- Order Status -->
  <div data-controller="chart" data-chart-type="doughnut" data-chart-endpoint="<%= order_status_data_path if defined?(order_status_data_path) %>">
    <%= render 'dashboard/chart_card', 
      id: 'order-status-chart', 
      title: 'Order Status', 
      description: 'Current order status distribution',
      height: '300px'
    %>
  </div>
</div>

<!-- Recent Orders -->
<div class="mb-6">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-medium text-gray-900">Recent Orders</h3>
    <div class="text-sm">
      <a href="<%= orders_path %>" class="font-medium text-indigo-600 hover:text-indigo-900">View all</a>
    </div>
  </div>
  
  <div class="bg-white shadow-md rounded-lg overflow-hidden">
    <div class="overflow-x-auto">
      <% if @recent_orders.present? && @recent_orders.any? %>
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Order ID</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Customer</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Product</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @recent_orders.each do |order| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">#<%= order.id %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= order.user.try(:email) || "Unknown Customer" %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <div class="flex items-center">
                    <% if order.product.product_images.any? %>
                      <div class="flex-shrink-0 h-8 w-8 mr-2">
                        <%= image_tag order.product.product_images.first.image, class: "h-8 w-8 rounded object-cover" %>
                      </div>
                    <% end %>
                    <span class="truncate max-w-xs"><%= order.product.try(:name) || "Unknown Product" %></span>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= number_to_currency(order.total_amount) %></td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% status_class = case order.status
                    when 'completed' then 'bg-green-100 text-green-800'
                    when 'paid' then 'bg-blue-100 text-blue-800'
                    when 'processing' then 'bg-yellow-100 text-yellow-800'
                    when 'refunded' then 'bg-red-100 text-red-800'
                    else 'bg-gray-100 text-gray-800'
                    end %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= status_class %>">
                    <%= order.status.try(:titleize) || "Unknown" %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= order.created_at.try(:strftime, "%b %d, %Y") || "Unknown Date" %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <%= link_to order_path(order), class: "text-indigo-600 hover:text-indigo-900" do %>
                    <span>View</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="py-10 text-center">
          <div class="mx-auto h-12 w-12 text-gray-400">
            <%= render 'shared/icon', name: "cart", size: "lg", color: "gray" %>
          </div>
          <h3 class="mt-2 text-sm font-medium text-gray-900">No orders yet</h3>
          <p class="mt-1 text-sm text-gray-500">
            Once you start selling products, your orders will appear here.
          </p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Product Performance -->
<div class="mb-6">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-medium text-gray-900">Product Performance</h3>
    <div class="flex space-x-2">
      <%= link_to new_product_path, class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
        <svg class="-ml-1 mr-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
        </svg>
        Add Product
      <% end %>
    </div>
  </div>
  
  <div class="bg-white shadow-md rounded-lg overflow-hidden">
    <div class="overflow-x-auto">
      <% if @products.present? && @products.any? %>
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Product</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Category</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Sales</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Revenue</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Rating</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @products.each do |product| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="flex-shrink-0 h-10 w-10">
                      <% if product.product_images.any? %>
                        <%= image_tag product.product_images.first.image, class: "h-10 w-10 rounded-md object-cover" %>
                      <% else %>
                        <div class="h-10 w-10 rounded-md bg-gray-200 flex items-center justify-center">
                          <svg class="h-6 w-6 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                          </svg>
                        </div>
                      <% end %>
                    </div>
                    <div class="ml-4">
                      <div class="text-sm font-medium text-gray-900"><%= product.name %></div>
                      <div class="text-sm text-gray-500"><%= number_to_currency(product.price) %></div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= product.category&.name || "Uncategorized" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= product.orders.count %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= number_to_currency(product.orders.sum(:total_amount)) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <% rating = product.average_rating %>
                    <div class="flex items-center">
                      <% 5.times do |i| %>
                        <% if i < rating.floor %>
                          <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                          </svg>
                        <% elsif i == rating.floor && rating % 1 > 0 %>
                          <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                          </svg>
                        <% else %>
                          <svg class="w-4 h-4 text-gray-300" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                          </svg>
                        <% end %>
                      <% end %>
                    </div>
                    <span class="ml-2 text-sm text-gray-500"><%= rating.round(1) %> (<%= product.reviews.count %>)</span>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if product.published? %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                      Published
                    </span>
                  <% else %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">
                      Draft
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <div class="flex space-x-2">
                    <%= link_to edit_product_path(product), class: "text-indigo-600 hover:text-indigo-900" do %>
                      <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                      </svg>
                    <% end %>
                    <%= link_to product_path(product), class: "text-gray-600 hover:text-gray-900" do %>
                      <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="py-10 text-center">
          <div class="mx-auto h-12 w-12 text-gray-400">
            <%= render 'shared/icon', name: "product", size: "lg", color: "gray" %>
          </div>
          <h3 class="mt-2 text-sm font-medium text-gray-900">No products yet</h3>
          <p class="mt-1 text-sm text-gray-500">
            Get started by creating a new product.
          </p>
          <div class="mt-6">
            <%= link_to new_product_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
              <svg class="-ml-1 mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
              </svg>
              Add Product
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Customer Insights -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-6">
  <!-- Top Countries -->
  <div data-controller="chart" data-chart-type="pie" data-chart-endpoint="<%= customer_countries_data_path if defined?(customer_countries_data_path) %>">
    <%= render 'dashboard/chart_card', 
      id: 'customer-countries-chart', 
      title: 'Customer Locations', 
      description: 'Top countries by customer count',
      height: '300px'
    %>
  </div>
  
  <!-- Daily Traffic -->
  <div data-controller="chart" data-chart-type="bar" data-chart-endpoint="<%= daily_traffic_data_path if defined?(daily_traffic_data_path) %>">
    <%= render 'dashboard/chart_card', 
      id: 'daily-traffic-chart', 
      title: 'Daily Traffic', 
      description: 'Store visits by day',
      height: '300px'
    %>
  </div>
</div>

<!-- Unanswered Product Questions -->
<div class="mb-6">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-medium text-gray-900">Unanswered Questions</h3>
    <div class="text-sm">
      <a href="<%= product_questions_path %>" class="font-medium text-indigo-600 hover:text-indigo-900">View all</a>
    </div>
  </div>
  
  <div class="bg-white shadow-md rounded-lg overflow-hidden">
    <% if @unanswered_questions.present? && @unanswered_questions.any? %>
      <ul class="divide-y divide-gray-200">
        <% @unanswered_questions.each do |question| %>
          <li class="p-5">
            <div class="flex items-start space-x-4">
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900">
                  <%= question.product.name %>
                </p>
                <p class="text-sm text-gray-700 mt-1">
                  <%= question.question %>
                </p>
                <div class="mt-2 flex items-center text-sm text-gray-500">
                  <svg class="flex-shrink-0 mr-1.5 h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                  </svg>
                  <span><%= question.user.try(:email) || "Anonymous User" %></span>
                  <span class="mx-1">•</span>
                  <svg class="flex-shrink-0 mr-1.5 h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                  </svg>
                  <span><%= time_ago_in_words(question.created_at) %> ago</span>
                </div>
              </div>
              <div class="flex-shrink-0">
                <%= link_to edit_product_question_path(question), class: "inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
                  Answer
                <% end %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="py-10 text-center">
        <div class="mx-auto h-12 w-12 text-gray-400">
          <%= render 'shared/icon', name: "question", size: "lg", color: "gray" %>
        </div>
        <h3 class="mt-2 text-sm font-medium text-gray-900">No unanswered questions</h3>
        <p class="mt-1 text-sm text-gray-500">
          All customer questions have been answered.
        </p>
      </div>
    <% end %>
  </div>
</div>
