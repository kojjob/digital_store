<%# 
  Quick Actions Component
  
  Provides a set of commonly used actions for quick access.
%>

<div class="mt-6 mb-8" data-controller="quick-actions">
  <h2 class="text-lg font-medium text-gray-900 mb-3">Quick Actions</h2>
  
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
    <% if current_user.seller? %>
      <!-- Seller-specific actions -->
      <%= link_to new_product_path, class: "relative rounded-lg border border-gray-300 bg-white px-6 py-4 shadow-sm flex flex-col items-center space-y-2 hover:border-indigo-500 hover:ring-1 hover:ring-indigo-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all" do %>
        <div class="flex-shrink-0 h-10 w-10 rounded-full bg-indigo-100 flex items-center justify-center">
          <svg class="h-6 w-6 text-indigo-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
          </svg>
        </div>
        <div class="text-center">
          <span class="text-sm font-medium text-gray-900">Add Product</span>
        </div>
      <% end %>
      
      <%= link_to orders_path, class: "relative rounded-lg border border-gray-300 bg-white px-6 py-4 shadow-sm flex flex-col items-center space-y-2 hover:border-indigo-500 hover:ring-1 hover:ring-indigo-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all" do %>
        <div class="flex-shrink-0 h-10 w-10 rounded-full bg-green-100 flex items-center justify-center">
          <svg class="h-6 w-6 text-green-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
        </div>
        <div class="text-center">
          <span class="text-sm font-medium text-gray-900">View Orders</span>
        </div>
      <% end %>
      
      <%= link_to defined?(earnings_path) ? earnings_path : "#", class: "relative rounded-lg border border-gray-300 bg-white px-6 py-4 shadow-sm flex flex-col items-center space-y-2 hover:border-indigo-500 hover:ring-1 hover:ring-indigo-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all" do %>
        <div class="flex-shrink-0 h-10 w-10 rounded-full bg-amber-100 flex items-center justify-center">
          <svg class="h-6 w-6 text-amber-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="text-center">
          <span class="text-sm font-medium text-gray-900">Earnings</span>
        </div>
      <% end %>
      
      <%= link_to defined?(product_questions_path) ? product_questions_path : "#", class: "relative rounded-lg border border-gray-300 bg-white px-6 py-4 shadow-sm flex flex-col items-center space-y-2 hover:border-indigo-500 hover:ring-1 hover:ring-indigo-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all" do %>
        <div class="flex-shrink-0 h-10 w-10 rounded-full bg-purple-100 flex items-center justify-center">
          <svg class="h-6 w-6 text-purple-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div class="text-center">
          <span class="text-sm font-medium text-gray-900">Answer Questions</span>
          <% if @unanswered_questions_count && @unanswered_questions_count > 0 %>
            <span class="absolute top-3 right-3 inline-flex items-center justify-center h-5 w-5 rounded-full bg-red-100 text-red-800 text-xs font-medium">
              <%= @unanswered_questions_count %>
            </span>
          <% end %>
        </div>
      <% end %>
      
      <%= link_to defined?(analytics_path) ? analytics_path : "#", class: "relative rounded-lg border border-gray-300 bg-white px-6 py-4 shadow-sm flex flex-col items-center space-y-2 hover:border-indigo-500 hover:ring-1 hover:ring-indigo-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all" do %>
        <div class="flex-shrink-0 h-10 w-10 rounded-full bg-blue-100 flex items-center justify-center">
          <svg class="h-6 w-6 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
        </div>
        <div class="text-center">
          <span class="text-sm font-medium text-gray-900">Analytics</span>
        </div>
      <% end %>
      
      <%= link_to defined?(messaging_path) ? messaging_path : "#", class: "relative rounded-lg border border-gray-300 bg-white px-6 py-4 shadow-sm flex flex-col items-center space-y-2 hover:border-indigo-500 hover:ring-1 hover:ring-indigo-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all" do %>
        <div class="flex-shrink-0 h-10 w-10 rounded-full bg-teal-100 flex items-center justify-center">
          <svg class="h-6 w-6 text-teal-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
          </svg>
        </div>
        <div class="text-center">
          <span class="text-sm font-medium text-gray-900">Messages</span>
          <% if @unread_messages_count && @unread_messages_count > 0 %>
            <span class="absolute top-3 right-3 inline-flex items-center justify-center h-5 w-5 rounded-full bg-red-100 text-red-800 text-xs font-medium">
              <%= @unread_messages_count %>
            </span>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <!-- Buyer-specific actions -->
      <%= link_to products_path, class: "relative rounded-lg border border-gray-300 bg-white px-6 py-4 shadow-sm flex flex-col items-center space-y-2 hover:border-indigo-500 hover:ring-1 hover:ring-indigo-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all" do %>
        <div class="flex-shrink-0 h-10 w-10 rounded-full bg-indigo-100 flex items-center justify-center">
          <svg class="h-6 w-6 text-indigo-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </div>
        <div class="text-center">
          <span class="text-sm font-medium text-gray-900">Shop Products</span>
        </div>
      <% end %>
      
      <%= link_to orders_path, class: "relative rounded-lg border border-gray-300 bg-white px-6 py-4 shadow-sm flex flex-col items-center space-y-2 hover:border-indigo-500 hover:ring-1 hover:ring-indigo-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all" do %>
        <div class="flex-shrink-0 h-10 w-10 rounded-full bg-green-100 flex items-center justify-center">
          <svg class="h-6 w-6 text-green-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
        </div>
        <div class="text-center">
          <span class="text-sm font-medium text-gray-900">My Orders</span>
        </div>
      <% end %>
      
      <%= link_to defined?(downloads_path) ? downloads_path : "#", class: "relative rounded-lg border border-gray-300 bg-white px-6 py-4 shadow-sm flex flex-col items-center space-y-2 hover:border-indigo-500 hover:ring-1 hover:ring-indigo-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all" do %>
        <div class="flex-shrink-0 h-10 w-10 rounded-full bg-amber-100 flex items-center justify-center">
          <svg class="h-6 w-6 text-amber-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
        </div>
        <div class="text-center">
          <span class="text-sm font-medium text-gray-900">Downloads</span>
        </div>
      <% end %>
      
      <%= link_to defined?(wishlist_path) ? wishlist_path : "#", class: "relative rounded-lg border border-gray-300 bg-white px-6 py-4 shadow-sm flex flex-col items-center space-y-2 hover:border-indigo-500 hover:ring-1 hover:ring-indigo-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all" do %>
        <div class="flex-shrink-0 h-10 w-10 rounded-full bg-red-100 flex items-center justify-center">
          <svg class="h-6 w-6 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
        </div>
        <div class="text-center">
          <span class="text-sm font-medium text-gray-900">Wishlist</span>
          <% if @wishlist_count && @wishlist_count > 0 %>
            <span class="absolute top-3 right-3 inline-flex items-center justify-center h-5 w-5 rounded-full bg-red-100 text-red-800 text-xs font-medium">
              <%= @wishlist_count %>
            </span>
          <% end %>
        </div>
      <% end %>
      
      <%= link_to defined?(messaging_path) ? messaging_path : "#", class: "relative rounded-lg border border-gray-300 bg-white px-6 py-4 shadow-sm flex flex-col items-center space-y-2 hover:border-indigo-500 hover:ring-1 hover:ring-indigo-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all" do %>
        <div class="flex-shrink-0 h-10 w-10 rounded-full bg-teal-100 flex items-center justify-center">
          <svg class="h-6 w-6 text-teal-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
          </svg>
        </div>
        <div class="text-center">
          <span class="text-sm font-medium text-gray-900">Messages</span>
          <% if @unread_messages_count && @unread_messages_count > 0 %>
            <span class="absolute top-3 right-3 inline-flex items-center justify-center h-5 w-5 rounded-full bg-red-100 text-red-800 text-xs font-medium">
              <%= @unread_messages_count %>
            </span>
          <% end %>
        </div>
      <% end %>
      
      <%= link_to edit_user_registration_path, class: "relative rounded-lg border border-gray-300 bg-white px-6 py-4 shadow-sm flex flex-col items-center space-y-2 hover:border-indigo-500 hover:ring-1 hover:ring-indigo-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all" do %>
        <div class="flex-shrink-0 h-10 w-10 rounded-full bg-purple-100 flex items-center justify-center">
          <svg class="h-6 w-6 text-purple-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <div class="text-center">
          <span class="text-sm font-medium text-gray-900">Profile</span>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
