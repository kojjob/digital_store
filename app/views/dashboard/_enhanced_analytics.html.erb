<%# 
  Enhanced Analytics Dashboard Component
  
  This component extends the existing dashboard analytics with a modern design,
  while maintaining compatibility with existing models and controllers.
  It integrates with the current seller_dashboard layout but adds more
  detailed visual metrics inspired by the reference designs.
%>

<div class="mb-8" data-controller="analytics-dashboard">
  <!-- Dashboard Header with User Profile -->
  <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6">
    <div class="flex items-center justify-between w-full">
      <div>
        <h2 class="text-xl font-bold text-gray-900">Earnings Summary</h2>
        <p class="text-sm text-gray-500 mt-1">All the products you have sold</p>
      </div>
      
      <!-- User Profile Section -->
      <div class="ml-auto hidden md:block">
        <%= render 'dashboard/user_profile' %>
      </div>
    </div>
    
    <div class="mt-4 md:mt-0 md:ml-4">
      <div class="inline-flex rounded-md shadow-sm">
        <span class="relative inline-flex items-center px-4 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-700">
          Viewed from
        </span>