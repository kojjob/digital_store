<%#
  Analytics dashboard component for sellers
%>

<div class="mt-8">
  <h2 class="text-lg font-medium text-gray-900 mb-4">Analytics Overview</h2>
  
  <div class="grid grid-cols-1 gap-5 lg:grid-cols-2">
    <!-- Revenue Chart -->
    <%= render 'dashboard/chart_card', 
      id: 'revenue-chart', 
      title: 'Revenue', 
      description: 'Your revenue over time', 
      show_periods: true 
    %>
    
    <!-- Orders Chart -->
    <%= render 'dashboard/chart_card', 
      id: 'orders-chart', 
      title: 'Orders', 
      description: 'Your order volume over time', 
      show_periods: true 
    %>
    
    <!-- Product Performance Chart -->
    <%= render 'dashboard/chart_card', 
      id: 'product-performance-chart', 
      title: 'Product Performance', 
      description: 'Your top-performing products' 
    %>
    
    <!-- Customer Acquisition Chart -->
    <%= render 'dashboard/chart_card', 
      id: 'customer-acquisition-chart', 
      title: 'New Customers', 
      description: 'Customer acquisition over time' 
    %>
  </div>
</div>

<% content_for :page_scripts do %>
<script>
  // Load Chart.js for analytics
  document.addEventListener('DOMContentLoaded', function() {
    // Chart.js scripts will be initialized by charts_service.js
  });
</script>
<% end %>
