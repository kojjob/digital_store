<%# 
  Help & Support Component
  
  Provides quick access to help resources and support options.
%>

<div class="bg-white shadow-md rounded-lg overflow-hidden">
  <div class="bg-gradient-to-r from-teal-500 to-teal-600 px-4 py-4">
    <h3 class="text-lg font-medium text-white">Help & Support</h3>
  </div>
  
  <div class="p-4">
    <div class="space-y-3">
      <div>
        <h4 class="text-md font-medium text-gray-900">Need assistance?</h4>
        <p class="mt-1 text-sm text-gray-500">We're here to help you with any questions or issues you might have.</p>
      </div>
      
      <div class="mt-4 grid grid-cols-1 gap-4">
        <a href="<%= defined?(help_center_path) ? help_center_path : '#' %>" class="block px-4 py-3 bg-gray-50 hover:bg-gray-100 rounded-md transition-colors">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-teal-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-3">
              <h5 class="text-sm font-medium text-gray-900">Knowledge Base</h5>
              <p class="text-xs text-gray-500">Browse our help articles and tutorials</p>
            </div>
          </div>
        </a>
        
        <a href="<%= defined?(support_ticket_path) ? support_ticket_path : '#' %>" class="block px-4 py-3 bg-gray-50 hover:bg-gray-100 rounded-md transition-colors">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-teal-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
              </svg>
            </div>
            <div class="ml-3">
              <h5 class="text-sm font-medium text-gray-900">Contact Support</h5>
              <p class="text-xs text-gray-500">Submit a ticket for technical assistance</p>
            </div>
          </div>
        </a>
        
        <% if current_user.seller? %>
          <a href="<%= defined?(seller_guide_path) ? seller_guide_path : '#' %>" class="block px-4 py-3 bg-gray-50 hover:bg-gray-100 rounded-md transition-colors">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <svg class="h-6 w-6 text-teal-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
              </div>
              <div class="ml-3">
                <h5 class="text-sm font-medium text-gray-900">Seller Guide</h5>
                <p class="text-xs text-gray-500">Tips and best practices for selling</p>
              </div>
            </div>
          </a>
        <% end %>
      </div>
      
      <div class="mt-4 pt-4 border-t border-gray-200">
        <h4 class="text-md font-medium text-gray-900">Popular Help Topics</h4>
        <ul class="mt-2 space-y-2">
          <li>
            <a href="#" class="text-sm text-indigo-600 hover:text-indigo-500">
              How to download purchased products
            </a>
          </li>
          <li>
            <a href="#" class="text-sm text-indigo-600 hover:text-indigo-500">
              Payment methods accepted
            </a>
          </li>
          <li>
            <a href="#" class="text-sm text-indigo-600 hover:text-indigo-500">
              Refund policy and process
            </a>
          </li>
          <li>
            <a href="#" class="text-sm text-indigo-600 hover:text-indigo-500">
              <%= current_user.seller? ? "Seller payout schedule" : "How to contact a seller" %>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>
