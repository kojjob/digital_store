<%= form_with(model: seller, class: "contents") do |form| %>
  <% if seller.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(seller.errors.count, "error") %> prohibited this seller from being saved:</h2>

      <ul class="list-disc ml-6">
        <% seller.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white shadow-md rounded-lg p-6 mb-6">
    <h3 class="text-lg font-semibold border-b pb-3 mb-4">Business Information</h3>
    
    <div class="my-5">
      <%= form.label :business_name, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :business_name, class: ["text-gray-700 block w-full rounded-md border-2 px-3 py-2 mt-2 bg-white", {"border-gray-400 focus:ring-indigo-500 focus:border-indigo-500": seller.errors[:business_name].none?, "border-red-400 focus:ring-red-500 focus:border-red-500": seller.errors[:business_name].any?}], placeholder: "Your business or store name" %>
      <p class="mt-1 text-sm text-gray-500">This will be displayed to customers on your store page.</p>
    </div>

    <div class="my-5">
      <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :description, rows: 4, class: ["text-gray-700 block w-full rounded-md border-2 px-3 py-2 mt-2 bg-white", {"border-gray-400 focus:ring-indigo-500 focus:border-indigo-500": seller.errors[:description].none?, "border-red-400 focus:ring-red-500 focus:border-red-500": seller.errors[:description].any?}], placeholder: "Describe your business, products and what makes you unique" %>
      <p class="mt-1 text-sm text-gray-500">Provide a clear description of what you sell and your business focus.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="my-5">
        <%= form.label :location, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :location, class: ["text-gray-700 block w-full rounded-md border-2 px-3 py-2 mt-2 bg-white", {"border-gray-400 text-gray-700 focus:ring-indigo-500 focus:border-indigo-500": seller.errors[:location].none?, "border-red-400 focus:ring-red-500 focus:border-red-500": seller.errors[:location].any?}], placeholder: "City, Region" %>
      </div>

      <div class="my-5">
        <%= form.label :country, class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :country, options_for_select([["Ghana", "Ghana"], ["Nigeria", "Nigeria"]], seller.country), { include_blank: "Select your country" }, class: ["text-gray-700 block w-full rounded-md border-2 px-3 py-2 mt-2 bg-white", {"border-gray-400 focus:ring-indigo-500 focus:border-indigo-500": seller.errors[:country].none?, "border-red-400 focus:ring-red-500 focus:border-red-500": seller.errors[:country].any?}] %>
      </div>
    </div>

    <div class="my-5">
      <%= form.label :phone_number, class: "block text-sm font-medium text-gray-700" %>
      <%= form.telephone_field :phone_number, class: ["text-gray-700 block w-full rounded-md border-2 px-3 py-2 mt-2 bg-white", {"border-gray-400 focus:ring-indigo-500 focus:border-indigo-500": seller.errors[:phone_number].none?, "border-red-400 focus:ring-red-500 focus:border-red-500": seller.errors[:phone_number].any?}], placeholder: "e.g. +233 20 123 4567" %>
      <p class="mt-1 text-sm text-gray-500">Include country code. This number will be used for verification.</p>
    </div>

    <div class="my-5">
      <%= form.label :business_logo, class: "block text-sm font-medium text-gray-700" %>
      <div class="mt-2 flex items-center">
        <% if seller.business_logo.attached? %>
          <div class="mr-3">
            <%= image_tag seller.business_logo.variant(resize_to_limit: [100, 100]), class: "h-16 w-16 object-cover rounded-md" %>
          </div>
        <% end %>
        <div class="flex flex-col">
          <%= form.file_field :business_logo, accept: "image/*", class: "block text-sm text-gray-500 file:mr-4 file:rounded-md file:border-0 file:bg-indigo-50 file:py-2 file:px-4 file:text-sm file:font-semibold file:text-indigo-700 hover:file:bg-indigo-100" %>
          <p class="mt-1 text-xs text-gray-500">PNG, JPG, GIF up to 2MB</p>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-white shadow-md rounded-lg p-6 mb-6">
    <h3 class="text-lg font-semibold border-b pb-3 mb-4">Payment Information</h3>
    
    <div class="my-5">
      <%= form.label :bank_account_details, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :bank_account_details, rows: 3, class: ["text-gray-700 block w-full rounded-md border-2 px-3 py-2 mt-2 bg-white", {"border-gray-400 focus:ring-indigo-500 focus:border-indigo-500": seller.errors[:bank_account_details].none?, "border-red-400 focus:ring-red-500 focus:border-red-500": seller.errors[:bank_account_details].any?}], placeholder: "Bank name, account number, account name" %>
      <p class="mt-1 text-sm text-gray-500">This information will be used to process your payments.</p>
    </div>

    <div class="my-5">
      <%= form.label :mobile_money_details, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :mobile_money_details, rows: 3, class: ["text-gray-700 block w-full rounded-md border-2 px-3 py-2 mt-2 bg-white", {"border-gray-400 focus:ring-indigo-500 focus:border-indigo-500": seller.errors[:mobile_money_details].none?, "border-red-400 focus:ring-red-500 focus:border-red-500": seller.errors[:mobile_money_details].any?}], placeholder: "Mobile money provider, phone number, name" %>
      <p class="mt-1 text-sm text-gray-500">For mobile money payments (optional).</p>
    </div>
  </div>

  <div class="bg-gradient-to-r from-indigo-100 to-blue-100 shadow-lg rounded-lg p-6 mb-6 border-l-4 border-indigo-600">
    <h3 class="text-lg font-bold text-indigo-800 border-b border-indigo-300 pb-3 mb-4 flex items-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      Important Information
    </h3>
    
    <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-yellow-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <p class="text-sm text-yellow-700">
            <strong>Verification Required:</strong> Your account will need to be verified before you can start selling. This process typically takes 1-2 business days.
          </p>
        </div>
      </div>
    </div>
    
    <div class="my-5">
      <%= form.label :verification_document, class: "block text-sm font-medium text-indigo-700" %>
      <div class="mt-2 bg-white p-3 rounded border border-indigo-200">
        <%= form.file_field :verification_document, accept: ".pdf,.doc,.docx,image/*", class: "block text-sm text-gray-500 file:mr-4 file:rounded-md file:border-0 file:bg-indigo-50 file:py-2 file:px-4 file:text-sm file:font-semibold file:text-indigo-700 hover:file:bg-indigo-100" %>
        <p class="mt-1 text-xs text-indigo-600 font-medium">Upload a business registration document, ID, or other proof (PDF, DOC, or image)</p>
      </div>
    </div>
    
    <div class="my-5">
      <div class="flex items-start mt-6 bg-indigo-50 p-4 rounded-lg border border-indigo-200">
        <div class="flex items-center h-5">
          <input id="terms" name="terms" type="checkbox" class="h-4 w-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500">
        </div>
        <div class="ml-3 text-sm">
          <label for="terms" class="font-medium text-indigo-700">I agree to the <a href="#" class="text-indigo-600 underline hover:text-indigo-800">Terms and Conditions</a> and <a href="#" class="text-indigo-600 underline hover:text-indigo-800">Seller Agreement</a></label>
          <p class="text-indigo-500">By creating a seller account, you agree to our terms of service and seller policies.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="inline mt-6">
    <%= form.submit "Create Seller Account", class: "w-full sm:w-auto rounded-md px-5 py-3 bg-gradient-to-r from-indigo-600 to-blue-600 hover:from-indigo-700 hover:to-blue-700 text-white font-medium cursor-pointer shadow-md transform transition hover:scale-105" %>
    <p class="mt-3 text-sm text-indigo-600 font-medium">Your account will need to be verified before you can start selling.</p>
  </div>
<% end %>
