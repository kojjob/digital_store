<%= form_with(model: product, url: product.persisted? ? update_sellers_product_path(product) : create_sellers_product_path, class: "space-y-8") do |form| %>
  <% if product.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">There were <%= pluralize(product.errors.count, "error") %> with your submission</h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% product.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Basic Information -->
  <div class="bg-white shadow overflow-hidden sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg font-medium leading-6 text-gray-900">Basic Information</h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">Product details and basic information.</p>
    </div>
    <div class="border-t border-gray-200 px-4 py-5 sm:p-6">
      <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
        <div class="sm:col-span-4">
          <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= form.text_field :name, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-2 border-gray-400 bg-white rounded-md" %>
          </div>
        </div>

        <div class="sm:col-span-2">
          <%= form.label :sku, "SKU (Stock Keeping Unit)", class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= form.text_field :sku, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
          </div>
        </div>

        <div class="sm:col-span-3">
          <%= form.label :category_id, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= form.collection_select :category_id, Category.all, :id, :name, 
                { prompt: "Select a category" }, 
                { class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 mt-1 block w-full sm:text-sm border-2 border-gray-400 bg-white rounded-md" } %>
          </div>
        </div>

        <div class="sm:col-span-6">
          <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= form.text_area :description, rows: 4, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
          </div>
          <p class="mt-2 text-sm text-gray-500">Brief description of the product. Markdown formatting is supported.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Pricing & Inventory -->
  <div class="bg-white shadow overflow-hidden sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg font-medium leading-6 text-gray-900">Pricing & Inventory</h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">Manage product pricing and stock levels.</p>
    </div>
    <div class="border-t border-gray-200 px-4 py-5 sm:p-6">
      <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
        <div class="sm:col-span-2">
          <%= form.label :price, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1 relative rounded-md shadow-sm">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <span class="text-gray-500 sm:text-sm">$</span>
            </div>
            <%= form.number_field :price, min: 0, step: 0.01, class: "focus:ring-indigo-500 focus:border-indigo-500 block w-full pl-7 pr-12 sm:text-sm border-2 border-gray-400 bg-white rounded-md" %>
          </div>
        </div>

        <div class="sm:col-span-2">
          <%= form.label :sale_price, "Sale Price (optional)", class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1 relative rounded-md shadow-sm">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <span class="text-gray-500 sm:text-sm">$</span>
            </div>
            <%= form.number_field :sale_price, min: 0, step: 0.01, class: "focus:ring-indigo-500 focus:border-indigo-500 block w-full pl-7 pr-12 sm:text-sm border-gray-300 rounded-md" %>
          </div>
        </div>

        <div class="sm:col-span-2">
          <%= form.label :stock_quantity, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= form.number_field :stock_quantity, min: 0, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Availability -->
  <div class="bg-white shadow overflow-hidden sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg font-medium leading-6 text-gray-900">Availability</h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">Control product visibility and regional availability.</p>
    </div>
    <div class="border-t border-gray-200 px-4 py-5 sm:p-6">
      <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
        <div class="sm:col-span-6">
          <div class="relative flex items-start">
            <div class="flex items-center h-5">
              <%= form.check_box :published, class: "focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded" %>
            </div>
            <div class="ml-3 text-sm">
              <%= form.label :published, class: "font-medium text-gray-700" %>
              <p class="text-gray-500">Make this product visible in the store.</p>
            </div>
          </div>
        </div>

        <div class="sm:col-span-3">
          <div class="relative flex items-start">
            <div class="flex items-center h-5">
              <%= form.check_box :available_in_ghana, class: "focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded" %>
            </div>
            <div class="ml-3 text-sm">
              <%= form.label :available_in_ghana, "Available in Ghana", class: "font-medium text-gray-700" %>
            </div>
          </div>
        </div>

        <div class="sm:col-span-3">
          <div class="relative flex items-start">
            <div class="flex items-center h-5">
              <%= form.check_box :available_in_nigeria, class: "focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded" %>
            </div>
            <div class="ml-3 text-sm">
              <%= form.label :available_in_nigeria, "Available in Nigeria", class: "font-medium text-gray-700" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- SEO Information -->
  <div class="bg-white shadow overflow-hidden sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg font-medium leading-6 text-gray-900">SEO Information (Optional)</h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">Optimize your product for search engines.</p>
    </div>
    <div class="border-t border-gray-200 px-4 py-5 sm:p-6">
      <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
        <div class="sm:col-span-6">
          <%= form.label :meta_title, "Meta Title", class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= form.text_field :meta_title, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
          </div>
          <p class="mt-2 text-sm text-gray-500">Override the default title tag for this product.</p>
        </div>

        <div class="sm:col-span-6">
          <%= form.label :meta_description, "Meta Description", class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= form.text_area :meta_description, rows: 3, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
          </div>
          <p class="mt-2 text-sm text-gray-500">Override the default meta description for this product.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="flex justify-end">
    <%= link_to "Cancel", sellers_products_path, class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
    <%= form.submit class: "ml-3 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
  </div>
<% end %> 