<% content_for :title, "Become a Seller" %>

<div class="bg-gradient-to-b from-gray-50 to-white py-12">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <div class="mb-10 text-center">
        <h1 class="text-3xl md:text-5xl font-bold text-gray-900 mb-4">Become a Seller</h1>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">Join our marketplace and start selling your digital products today. Fill out your business details below to get started.</p>
      </div>
      
      <!-- Important Information Section -->
      <div class="bg-white p-8 rounded-xl shadow-md mb-10 border border-gray-100">
        <div class="Verification Processflex items-center mb-8 border-b pb-4">
          <div class="w-14 h-14 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 mr-5">
            <span class="text-2xl font-bold">i</span>
          </div>
          <div>
            <h2 class="text-2xl font-semibold text-gray-900">Important Information</h2>
            <p class="text-gray-600">Before you begin, make sure you have the following ready:</p>
          </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 px-2">
          <!-- Required Information -->
          <div class="bg-indigo-50 p-6 rounded-lg border border-indigo-100">
            <h3 class="font-semibold text-indigo-800 text-lg mb-4 flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-indigo-600" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              Required Information
            </h3>
            <ul class="space-y-3">
              <li class="flex items-start">
                <span class="flex-shrink-0 h-6 w-6 rounded-full bg-indigo-200 flex items-center justify-center text-indigo-700 mr-3">1</span>
                <span class="text-gray-800 font-medium">Business name and description</span>
              </li>
              <li class="flex items-start">
                <span class="flex-shrink-0 h-6 w-6 rounded-full bg-indigo-200 flex items-center justify-center text-indigo-700 mr-3">2</span>
                <span class="text-gray-800 font-medium">Phone number for verification</span>
              </li>
              <li class="flex items-start">
                <span class="flex-shrink-0 h-6 w-6 rounded-full bg-indigo-200 flex items-center justify-center text-indigo-700 mr-3">3</span>
                <span class="text-gray-800 font-medium">Bank account details for payments</span>
              </li>
              <li class="flex items-start">
                <span class="flex-shrink-0 h-6 w-6 rounded-full bg-indigo-200 flex items-center justify-center text-indigo-700 mr-3">4</span>
                <span class="text-gray-800 font-medium">ID or business registration document</span>
              </li>
            </ul>
          </div>
          
          <!-- Optional Information -->
          <div class="bg-amber-50 p-6 rounded-lg border border-amber-100">
            <h3 class="font-semibold text-amber-800 text-lg mb-4 flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-amber-600" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
              </svg>
              Optional Information
            </h3>
            <ul class="space-y-3">
              <li class="flex items-start">
                <span class="flex-shrink-0 h-6 w-6 rounded-full bg-amber-200 flex items-center justify-center text-amber-700 mr-3">•</span>
                <span class="text-gray-800 font-medium">Business logo</span>
              </li>
              <li class="flex items-start">
                <span class="flex-shrink-0 h-6 w-6 rounded-full bg-amber-200 flex items-center justify-center text-amber-700 mr-3">•</span>
                <span class="text-gray-800 font-medium">Mobile money details (if applicable)</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
      
      <!-- Verification Process Box -->
      <div class="bg-gradient-to-r from-indigo-100 to-blue-50 p-6 rounded-xl border border-indigo-200 mb-10 shadow-sm">
        <div class="flex">
          <div class="flex-shrink-0">
            <div class="h-12 w-12 bg-white rounded-full p-2.5 shadow-sm flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-indigo-600" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
            </div>
          </div>
          <div class="ml-4">
            <h3 class="text-lg font-semibold text-indigo-800">Verification Process</h3>
            <div class="mt-2 text-indigo-700">
              <p>After submitting your application, our team will review your details. This process typically takes 1-2 business days. You'll receive an email notification once your account is approved.</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Form Section -->
      <div class="bg-white p-8 rounded-xl shadow-md mb-8 border border-gray-100">
        <h2 class="text-2xl font-semibold text-gray-900 mb-6 pb-4 border-b">Complete Your Registration</h2>
        <%= render "form", seller: @seller %>
      </div>
      
      <div class="mt-8 text-center">
        <p class="text-gray-600 mb-3">Already have a seller account? <%= link_to "Sign in", new_user_session_path, class: "text-indigo-600 font-medium hover:text-indigo-800" %></p>
        <%= link_to dashboard_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to dashboard
        <% end %>
      </div>
    </div>
  </div>
</div>
