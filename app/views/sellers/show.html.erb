<% content_for :title, "Seller Details" %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl">Showing seller</h1>

  <%= render @seller rescue content_tag(:div, "Error rendering seller details", class: "p-4 bg-red-100 text-red-800 rounded-md") %>

  <% if @seller_products.present? %>
    <div class="mt-8">
      <h2 class="text-2xl font-bold mb-4">Seller Products</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <% @seller_products.each do |product| %>
          <div class="border rounded-md p-4 hover:shadow-md transition-shadow">
            <h3 class="font-medium"><%= product.name %></h3>
            <p class="text-gray-600 text-sm mt-1"><%= truncate(product.description, length: 100) %></p>
            <p class="mt-2 font-bold"><%= number_to_currency(product.price) %></p>
            <%= link_to "View details", product_path(product), class: "mt-2 inline-block text-blue-600 hover:underline" %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="mt-6 flex flex-wrap gap-2">
    <%= link_to "Edit this seller", edit_seller_path(@seller), class: "rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" if can_edit_seller?(@seller) %>
    <%= link_to "Back to sellers", sellers_path, class: "rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
    <% if can_edit_seller?(@seller) %>
      <%= button_to "Delete seller", @seller, method: :delete, class: "rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure? This cannot be undone." } %>
    <% end %>
  </div>
</div>
