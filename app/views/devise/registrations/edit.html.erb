<!-- Settings Page -->
<div class="bg-gray-50 min-h-screen">
  <!-- Page content - positioned below navbar -->
  <div class="pt-10 sm:pt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="md:grid md:grid-cols-12 md:gap-x-8">
      <!-- Settings Navigation Sidebar -->
      <aside class="md:col-span-3">
        <div class="sticky top-24 md:top-28 space-y-4">
          <!-- Profile Card -->
          <div class="bg-white shadow rounded-lg overflow-hidden">
            <div class="p-6">
              <div class="flex items-center space-x-4">
                <div class="flex-shrink-0">
                  <% if resource.has_profile_picture? %>
                    <%= image_tag url_for(resource.profile_picture), class: "h-16 w-16 rounded-full object-cover" %>
                  <% else %>
                    <div class="h-16 w-16 rounded-full bg-indigo-100 flex items-center justify-center">
                      <span class="text-indigo-800 font-medium text-xl">
                        <% if resource.respond_to?(:first_name) && resource.respond_to?(:last_name) && resource.first_name.present? && resource.last_name.present? %>
                          <%= resource.first_name.first.upcase %><%= resource.last_name.first.upcase %>
                        <% elsif resource.email.present? %>
                          <%= resource.email.first.upcase %>
                        <% end %>
                      </span>
                    </div>
                  <% end %>
                </div>
                <div>
                  <h2 class="text-lg font-medium text-gray-900 truncate">
                    <% if resource.respond_to?(:full_name) && !resource.full_name.strip.empty? %>
                      <%= resource.full_name %>
                    <% else %>
                      <%= resource.email %>
                    <% end %>
                  </h2>
                  <p class="text-sm text-gray-500 truncate mt-1">
                    <%= resource.email %>
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Navigation -->
          <nav class="bg-white shadow rounded-lg overflow-hidden" aria-label="Settings" data-controller="settings-nav">
            <div class="py-2">
              <!-- Section: Account -->
              <div class="px-3 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">
                Account
              </div>
              <a href="#profile" class="block px-3 py-2 text-sm font-medium text-indigo-600 bg-indigo-50 border-l-4 border-indigo-600" aria-current="page" data-settings-nav-target="link" data-section="profile">
                Profile
              </a>
              <a href="#security" class="block px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-indigo-50" data-settings-nav-target="link" data-section="security">
                Security
              </a>
              <%= link_to user_sessions_path, class: "block px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-indigo-50" do %>
                <div class="flex items-center justify-between">
                  <span>Active Sessions</span>
                  <span class="bg-indigo-100 text-indigo-800 text-xs px-2 py-0.5 rounded-full">New</span>
                </div>
              <% end %>
              <a href="#notifications" class="block px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-indigo-50" data-settings-nav-target="link" data-section="notifications">
                Notifications
              </a>

              <!-- Section: Billing -->
              <div class="mt-4 px-3 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">
                Billing
              </div>
              <a href="#payment-methods" class="block px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-indigo-50" data-settings-nav-target="link" data-section="payment-methods">
                Payment Methods
              </a>
              <a href="#billing-history" class="block px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-indigo-50" data-settings-nav-target="link" data-section="billing-history">
                Billing History
              </a>
              <a href="#subscriptions" class="block px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-indigo-50" data-settings-nav-target="link" data-section="subscriptions">
                Subscriptions
              </a>

              <!-- Section: Advanced -->
              <div class="mt-4 px-3 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">
                Advanced
              </div>
              <a href="#api-keys" class="block px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-indigo-50" data-settings-nav-target="link" data-section="api-keys">
                API Keys
              </a>
              <a href="#account-data" class="block px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-indigo-50" data-settings-nav-target="link" data-section="account-data">
                Data & Privacy
              </a>
              <a href="#delete-account" class="block px-3 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:bg-indigo-50" data-settings-nav-target="link" data-section="delete-account">
                Delete Account
              </a>
            </div>
          </nav>

          <!-- Back Button -->
          <div class="mt-4 text-center">
            <%= link_to "← Back to Dashboard", root_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
          </div>
        </div>
      </aside>

      <!-- Main Content Area -->
      <main class="mt-8 md:mt-0 md:col-span-9">
        <!-- Display Flash Messages -->
        <% if flash[:notice] %>
          <div class="mb-6 rounded-md bg-green-50 p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-green-800"><%= flash[:notice] %></p>
              </div>
            </div>
          </div>
        <% end %>

        <% if flash[:alert] %>
          <div class="mb-6 rounded-md bg-red-50 p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-red-800"><%= flash[:alert] %></p>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Settings Form Wrapper -->
        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, id: "settings-form", class: "space-y-8", data: { controller: "settings-form" } }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>
          
          <!-- Profile Section -->
          <section id="profile" class="bg-white shadow rounded-lg overflow-hidden" data-settings-nav-target="section">
            <div class="px-6 py-5 border-b border-gray-200">
              <h2 class="text-xl font-medium text-gray-900">Profile Information</h2>
              <p class="mt-1 text-sm text-gray-500">Update your personal information and how others see you on the platform.</p>
            </div>
            <div class="px-6 py-6 space-y-6">
              <!-- Profile Picture -->
              <div>
                <div class="flex flex-col md:flex-row md:items-center">
                  <div class="flex-shrink-0 relative" data-controller="profile-upload">
                    <!-- Current profile picture or initials -->
                    <% if resource.has_profile_picture? %>
                      <%= image_tag url_for(resource.profile_picture), 
                          class: "h-24 w-24 rounded-full object-cover", 
                          data: { profile_upload_target: "currentPhoto" } %>
                    <% else %>
                      <div class="h-24 w-24 rounded-full bg-indigo-100 flex items-center justify-center"
                           data-profile-upload-target="currentPhoto">
                        <span class="text-indigo-800 font-medium text-2xl">
                          <% if resource.respond_to?(:first_name) && resource.respond_to?(:last_name) && resource.first_name.present? && resource.last_name.present? %>
                            <%= resource.first_name.first.upcase %><%= resource.last_name.first.upcase %>
                          <% elsif resource.email.present? %>
                            <%= resource.email.first.upcase %>
                          <% end %>
                        </span>
                      </div>
                    <% end %>
                    
                    <!-- Image preview for newly selected file -->
                    <img src="#" alt="Profile preview" 
                         class="h-24 w-24 rounded-full object-cover absolute top-0 left-0 hidden" 
                         data-profile-upload-target="preview">
                    
                    <div class="mt-4 md:mt-0 md:ml-6 md:pl-0">
                      <div class="relative">
                        <label for="profile_picture_upload" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer">
                          Change photo
                          <%= f.file_field :profile_picture, id: "profile_picture_upload", class: "sr-only", accept: "image/*", data: { profile_upload_target: "input", action: "change->profile-upload#previewImage" } %>
                        </label>
                        <button type="button" class="ml-3 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-red-700 bg-red-50 hover:bg-red-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" data-action="profile-upload#removeImage">
                          Remove
                        </button>
                        <div class="ml-3">
                          <%= f.check_box :remove_profile_picture, 
                                         class: "h-4 w-4 text-red-600 border-gray-300 rounded focus:ring-red-500", 
                                         data: { profile_upload_target: "removeCheckbox" } %>
                          <%= f.label :remove_profile_picture, "Delete current profile picture", class: "ml-2 text-sm text-red-600" %>
                        </div>
                      </div>
                      <p class="mt-2 text-xs text-gray-500" data-profile-upload-target="fileName">
                        <% if resource.has_profile_picture? %>
                          Current: <%= resource.profile_picture.filename %>
                        <% else %>
                          No image selected
                        <% end %>
                      </p>
                      <p class="mt-1 text-xs text-gray-500">
                        JPG, PNG or GIF. 1MB max.
                      </p>
                      
                      <% if current_user.respond_to?(:admin?) && current_user.admin? %>
                      <button type="button" 
                              class="mt-4 text-xs text-gray-500 underline cursor-pointer" 
                              data-action="profile-upload#troubleshoot">
                        Debug profile image
                      </button>
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Name Fields -->
              <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
                <div class="sm:col-span-3">
                  <%= f.label :first_name, class: "block text-sm font-medium text-gray-700" %>
                  <div class="mt-1">
                    <%= f.text_field :first_name, class: "py-2 px-3 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-2 border-gray-400 bg-white rounded-md" %>
                  </div>
                </div>

                <div class="sm:col-span-3">
                  <%= f.label :last_name, class: "block text-sm font-medium text-gray-700" %>
                  <div class="mt-1">
                    <%= f.text_field :last_name, class: "py-2 px-3 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-2 border-gray-400 bg-white rounded-md" %>
                  </div>
                </div>
              </div>

              <!-- Contact Info -->
              <div>
                <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
                <div class="mt-1">
                  <%= f.email_field :email, autocomplete: "email", class: "py-2 px-3 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-2 border-gray-400 bg-white rounded-md" %>
                </div>
                <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
                  <p class="mt-2 text-sm text-yellow-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="inline-block h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                    Currently waiting confirmation for: <%= resource.unconfirmed_email %>
                  </p>
                <% end %>
              </div>

              <!-- Bio/About -->
              <div>
                <label for="about" class="block text-sm font-medium text-gray-700">About</label>
                <div class="mt-1">
                  <textarea id="about" name="user[about]" rows="3" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-2 border-gray-400 bg-white rounded-md" placeholder="Write a few sentences about yourself"><%= resource.respond_to?(:about) ? resource.about : "" %></textarea>
                </div>
                <p class="mt-2 text-sm text-gray-500">Brief description for your profile.</p>
              </div>

              <!-- Save Profile Button -->
              <div class="pt-3">
                <div class="flex justify-end">
                  <button type="submit" name="commit_section" value="profile" class="ml-3 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    Save profile
                  </button>
                </div>
              </div>
            </div>
          </section>

          <!-- Security Section -->
          <section id="security" class="bg-white shadow rounded-lg overflow-hidden hidden" data-settings-nav-target="section">
            <div class="px-6 py-5 border-b border-gray-200">
              <h2 class="text-xl font-medium text-gray-900">Security</h2>
              <p class="mt-1 text-sm text-gray-500">Manage your password and security settings.</p>
            </div>
            <div class="px-6 py-6 space-y-6">
              <!-- Change Password -->
              <div>
                <h3 class="text-lg font-medium text-gray-900">Change Password</h3>
                <p class="mt-1 text-sm text-gray-500">Update your password to keep your account secure.</p>
              </div>

              <div>
                <%= f.label :current_password, "Current Password", class: "block text-sm font-medium text-gray-700" %>
                <div class="mt-1 relative" data-controller="password-toggle">
                  <%= f.password_field :current_password, autocomplete: "current-password", class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-2 border-gray-400 bg-white rounded-md pr-10", placeholder: "Enter your current password", data: { password_toggle_target: "input" } %>
                  <button type="button" class="absolute inset-y-0 right-0 pr-3 flex items-center" data-action="password-toggle#toggle">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" data-password-toggle-target="eyeIcon">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                  </button>
                </div>
              </div>

              <div>
                <%= f.label :password, "New Password", class: "block text-sm font-medium text-gray-700" %>
                <div class="mt-1 relative" data-controller="password-toggle">
                  <%= f.password_field :password, autocomplete: "new-password", class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-2 border-gray-400 bg-white rounded-md pr-10", placeholder: "Enter your new password", data: { password_toggle_target: "input" } %>
                  <button type="button" class="absolute inset-y-0 right-0 pr-3 flex items-center" data-action="password-toggle#toggle">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" data-password-toggle-target="eyeIcon">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                  </button>
                </div>
                <p class="mt-1 text-xs text-gray-500">
                  <% if @minimum_password_length %>
                    At least <%= @minimum_password_length %> characters
                  <% end %>
                </p>
              </div>

              <div>
                <%= f.label :password_confirmation, "Confirm New Password", class: "block text-sm font-medium text-gray-700" %>
                <div class="mt-1 relative" data-controller="password-toggle">
                  <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-2 border-gray-400 bg-white rounded-md pr-10", placeholder: "Confirm your new password", data: { password_toggle_target: "input" } %>
                  <button type="button" class="absolute inset-y-0 right-0 pr-3 flex items-center" data-action="password-toggle#toggle">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" data-password-toggle-target="eyeIcon">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                  </button>
                </div>
              </div>

              <!-- Two-Factor Authentication -->
              <div class="pt-6 border-t border-gray-200">
                <h3 class="text-lg font-medium text-gray-900">Two-Factor Authentication</h3>
                <p class="mt-1 text-sm text-gray-500">Add an extra layer of security to your account.</p>
                
                <div class="mt-4">
                  <button type="button" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    <svg xmlns="http://www.w3.org/2000/svg" class="mr-2 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                    Enable Two-Factor Authentication
                  </button>
                </div>
              </div>

              <!-- Session Management -->
              <div class="pt-6 border-t border-gray-200">
                <div class="flex items-center justify-between">
                  <div>
                    <h3 class="text-lg font-medium text-gray-900">Active Sessions</h3>
                    <p class="mt-1 text-sm text-gray-500">Manage your active sessions and sign out from other devices.</p>
                  </div>
                  <button type="button" class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
                    Sign out all other sessions
                  </button>
                </div>
                
                <div class="mt-4 overflow-hidden bg-white border border-gray-200 rounded-md">
                  <ul role="list" class="divide-y divide-gray-200">
                    <li class="px-4 py-4">
                      <div class="flex items-center justify-between">
                        <div class="flex items-center">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                          </svg>
                          <div class="ml-3">
                            <p class="text-sm font-medium text-gray-900">Current Session (This Device)</p>
                            <p class="text-xs text-gray-500">Last active just now</p>
                          </div>
                        </div>
                        <div class="bg-green-100 px-2 py-1 rounded-full">
                          <p class="text-xs text-green-800">Active</p>
                        </div>
                      </div>
                    </li>
                  </ul>
                </div>
              </div>

              <!-- Save Security Button -->
              <div class="pt-3">
                <div class="flex justify-end">
                  <button type="submit" name="commit_section" value="security" class="ml-3 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    Update security settings
                  </button>
                </div>
              </div>
            </div>
          </section>

          <!-- Notifications Section -->
          <section id="notifications" class="bg-white shadow rounded-lg overflow-hidden hidden" data-settings-nav-target="section">
            <div class="px-6 py-5 border-b border-gray-200">
              <h2 class="text-xl font-medium text-gray-900">Notification Preferences</h2>
              <p class="mt-1 text-sm text-gray-500">Manage how and when you receive notifications.</p>
            </div>
            <div class="px-6 py-6 space-y-8">
              <!-- UI Preferences -->
              <div class="pb-6 border-b border-gray-200">
                <h3 class="text-lg font-medium text-gray-900">UI Preferences</h3>
                <p class="mt-1 text-sm text-gray-500">Customize your viewing experience.</p>
                
                <div class="mt-6" data-controller="dark-mode">
                  <div class="flex items-center justify-between">
                    <span class="flex-grow flex flex-col">
                      <span class="text-sm font-medium text-gray-900" data-dark-mode-target="label">Dark Mode</span>
                      <span class="text-sm text-gray-500">Use a darker color scheme for reduced eye strain in low-light environments.</span>
                    </span>
                    <button type="button" class="relative inline-flex flex-shrink-0 h-6 w-11 border-2 border-transparent rounded-full cursor-pointer transition-colors ease-in-out duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" role="switch" aria-checked="false" data-dark-mode-target="toggle" data-action="click->dark-mode#toggle">
                      <span class="sr-only">Use dark mode</span>
                      <span aria-hidden="true" class="pointer-events-none inline-block h-5 w-5 rounded-full bg-white shadow transform ring-0 transition ease-in-out duration-200 translate-x-0 dark:translate-x-5"></span>
                    </button>
                  </div>
                  <p class="mt-2 text-xs text-gray-500">
                    Dark mode status: <span class="font-medium text-gray-700" data-dark-mode-target="status">Off</span>
                  </p>
                </div>
              </div>
              <!-- Email Notifications -->
              <div>
                <h3 class="text-lg font-medium text-gray-900">Email Notifications</h3>
