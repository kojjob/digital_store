<% content_for :page_scripts do %>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof window.Stimulus !== 'undefined') {
      // Settings navigation controller
      window.Stimulus.register('settings-nav', class extends window.Stimulus.Controller {
        static targets = ['link', 'section'];
        
        connect() {
          console.log('Settings navigation controller connected');
          this.addHashChangeListener();
          this.handleInitialHash();
        }
        
        addHashChangeListener() {
          window.addEventListener('hashchange', this.handleHashChange.bind(this));
        }
        
        handleInitialHash() {
          // Check if there's a hash in the URL
          const hash = window.location.hash;
          if (hash) {
            const sectionId = hash.slice(1);
            this.showSection(sectionId);
          }
        }
        
        handleHashChange() {
          const hash = window.location.hash;
          if (hash) {
            const sectionId = hash.slice(1);
            this.showSection(sectionId);
          }
        }
        
        showSection(sectionId) {
          // Hide all sections
          this.sectionTargets.forEach(section => {
            section.classList.add('hidden');
          });
          
          // Show the selected section
          const selectedSection = document.getElementById(sectionId);
          if (selectedSection) {
            selectedSection.classList.remove('hidden');
          }
          
          // Update active link styles
          this.linkTargets.forEach(link => {
            const linkSectionId = link.getAttribute('data-section');
            
            if (linkSectionId === sectionId) {
              link.classList.add('text-indigo-600', 'bg-indigo-50', 'border-l-4', 'border-indigo-600');
              link.classList.remove('text-gray-700', 'hover:text-indigo-600', 'hover:bg-indigo-50');
              link.setAttribute('aria-current', 'page');
            } else {
              link.classList.remove('text-indigo-600', 'bg-indigo-50', 'border-l-4', 'border-indigo-600');
              link.classList.add('text-gray-700', 'hover:text-indigo-600', 'hover:bg-indigo-50');
              link.removeAttribute('aria-current');
            }
          });
        }
      });
      
      // Password toggle controller
      window.Stimulus.register('password-toggle', class extends window.Stimulus.Controller {
        static targets = ['input', 'eyeIcon'];
        
        connect() {
          console.log('Password toggle controller connected');
        }
        
        toggle() {
          const input = this.inputTarget;
          
          if (input.type === 'password') {
            input.type = 'text';
            this.eyeIconTarget.innerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
              </svg>
            `;
          } else {
            input.type = 'password';
            this.eyeIconTarget.innerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            `;
          }
        }
      });
      
      // Profile upload controller
      window.Stimulus.register('profile-upload', class extends window.Stimulus.Controller {
        static targets = ['input', 'fileName', 'checkbox'];
        
        connect() {
          console.log('Profile upload controller connected');
          // Find the checkbox by name
          this.checkbox = document.querySelector('input[name="user[remove_profile_picture]"]');
        }
        
        previewImage(event) {
          const file = event.target.files[0];
          
          if (file) {
            this.fileNameTarget.textContent = `Selected: ${file.name}`;
            // Uncheck remove checkbox when new file is selected
            if (this.checkbox) this.checkbox.checked = false;
          }
        }
        
        removeImage() {
          this.inputTarget.value = '';
          this.fileNameTarget.textContent = 'No image selected';
          
          // Check the remove checkbox
          if (this.checkbox) this.checkbox.checked = true;
        }
      });
      
      // Delete confirmation controller
      window.Stimulus.register('delete-confirmation', class extends window.Stimulus.Controller {
        static targets = ['input', 'button'];
        
        connect() {
          console.log('Delete confirmation controller connected');
        }
        
        validate(event) {
          const input = event.target;
          const confirmText = 'DELETE MY ACCOUNT';
          
          if (input.value === confirmText) {
            this.buttonTarget.disabled = false;
            this.buttonTarget.classList.remove('opacity-50', 'cursor-not-allowed');
          } else {
            this.buttonTarget.disabled = true;
            this.buttonTarget.classList.add('opacity-50', 'cursor-not-allowed');
          }
        }
        
        confirmDelete(event) {
          const input = this.inputTarget;
          const confirmText = 'DELETE MY ACCOUNT';
          
          if (input.value !== confirmText) {
            event.preventDefault();
            alert('Please type "DELETE MY ACCOUNT" to confirm deletion.');
          }
        }
      });
    }
  });
</script>
<% end %>
