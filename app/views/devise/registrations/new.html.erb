<!-- Sign Up Page -->
<div class="bg-gray-50 min-h-screen">
  <!-- Page content - positioned below navbar -->
  <div class="pt-10 sm:pt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="max-w-md mx-auto">
        <!-- Header -->
        <div class="text-center">
          <h1 class="text-3xl font-bold text-gray-900">Create your account</h1>
          <p class="mt-3 text-gray-500">
            Join DigitalStore to discover and purchase premium digital products
          </p>
        </div>

        <!-- Sign Up Form -->
        <div class="mt-8 bg-white py-8 px-4 shadow sm:rounded-xl sm:px-10">
          <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6", data: { controller: "registration-validation" } }) do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>

            <!-- Name Fields -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <%= f.label :first_name, class: "block text-sm font-medium text-gray-700" %>
                <div class="mt-1">
                  <%= f.text_field :first_name, placeholder: "First name", class: "text-gray-700 appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", data: { registration_validation_target: "firstName", action: "input->registration-validation#validateName" } %>
                </div>
                <p class="mt-1 hidden text-sm text-red-600" data-registration-validation-target="firstNameError"></p>
              </div>

              <div>
                <%= f.label :last_name, class: "block text-sm font-medium text-gray-700" %>
                <div class="mt-1">
                  <%= f.text_field :last_name, placeholder: "Last name", class: "text-gray-700 appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", data: { registration_validation_target: "lastName", action: "input->registration-validation#validateName" } %>
                </div>
                <p class="mt-1 hidden text-sm text-red-600" data-registration-validation-target="lastNameError"></p>
              </div>
            </div>

            <!-- Email Field -->
            <div>
              <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1">
                <%= f.email_field :email, autocomplete: "email", placeholder: "your.email@example.com", class: "text-gray-700 appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", data: { registration_validation_target: "email", action: "input->registration-validation#validateEmail" } %>
              </div>
              <p class="mt-1 hidden text-sm text-red-600" data-registration-validation-target="emailError"></p>
            </div>

            <!-- Password Field -->
            <div>
              <%= f.label :password, class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1 relative">
                <%= f.password_field :password, autocomplete: "new-password", placeholder: "Create a password", class: "text-gray-700 appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", data: { registration_validation_target: "password", action: "input->registration-validation#validatePassword" } %>
                <button type="button" class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400" data-action="click->registration-validation#togglePasswordVisibility">
                  <svg class="h-5 w-5" fill="none" data-registration-validation-target="eyeIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
                  </svg>
                </button>
              </div>
              <div class="mt-2 flex flex-col">
                <div class="flex items-center">
                  <div class="w-full bg-gray-200 rounded-full h-1.5 dark:bg-gray-700 flex" data-registration-validation-target="passwordStrength">
                    <div class="bg-red-500 h-1.5 rounded-full w-0 transition-all duration-300" data-registration-validation-target="passwordStrengthBar"></div>
                  </div>
                  <span class="ml-2 text-xs font-medium" data-registration-validation-target="passwordStrengthText">Weak</span>
                </div>
                <div class="mt-3 grid grid-cols-2 gap-2">
                  <div class="flex items-center text-xs">
                    <svg class="h-3.5 w-3.5 mr-1 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>At least 8 characters</span>
                  </div>
                  <div class="flex items-center text-xs">
                    <svg class="h-3.5 w-3.5 mr-1 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>Uppercase letter</span>
                  </div>
                  <div class="flex items-center text-xs">
                    <svg class="h-3.5 w-3.5 mr-1 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>Lowercase letter</span>
                  </div>
                  <div class="flex items-center text-xs">
                    <svg class="h-3.5 w-3.5 mr-1 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>Number or symbol</span>
                  </div>
                </div>
              </div>
              <p class="mt-1 text-sm text-gray-500" id="password-description">
                <% if @minimum_password_length %>
                  At least <%= @minimum_password_length %> characters
                <% end %>
              </p>
              <p class="mt-1 hidden text-sm text-red-600" data-registration-validation-target="passwordError"></p>
            </div>

            <!-- Password Confirmation Field -->
            <div>
              <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1">
                <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Confirm your password", class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", data: { registration_validation_target: "passwordConfirmation", action: "input->registration-validation#validatePasswordConfirmation" } %>
              </div>
              <p class="mt-1 hidden text-sm text-red-600" data-registration-validation-target="passwordConfirmationError"></p>
            </div>

            <!-- Profile Picture Field -->
            <div>
              <%= f.label :profile_picture, class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1 flex items-center">
                <div data-controller="profile-upload" class="w-full">
                  <div class="flex items-center">
                    <span class="h-12 w-12 rounded-full overflow-hidden bg-gray-100" data-profile-upload-target="preview">
                      <svg class="h-full w-full text-gray-300" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" />
                      </svg>
                    </span>
                    <div class="ml-5 relative flex cursor-pointer">
                      <label for="file-upload" class="relative cursor-pointer bg-white py-2 px-3 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus-within:outline-none focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-indigo-500">
                        <span>Upload a file</span>
                        <%= f.file_field :profile_picture, id: "file-upload", class: "sr-only", accept: "image/*", data: { profile_upload_target: "input", action: "change->profile-upload#displayFileAndPreview" } %>
                      </label>
                      <p class="pl-3 py-2 text-sm text-gray-500" data-profile-upload-target="fileName">No file selected</p>
                    </div>
                  </div>
                  <p class="mt-2 text-xs text-gray-500">PNG, JPG, GIF up to 1MB</p>
                </div>
              </div>
            </div>

            <!-- Terms and Privacy -->
            <div class="mt-6">
              <div class="flex items-start">
                <div class="flex items-center h-5">
                  <input id="terms" name="terms" type="checkbox" required class="focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded">
                </div>
                <div class="ml-3 text-sm">
                  <label for="terms" class="font-medium text-gray-700">I agree to the terms and privacy policy</label>
                  <p class="text-gray-500">By creating an account, you agree to our <a href="#" class="text-indigo-600 hover:text-indigo-500">Terms of Service</a> and <a href="#" class="text-indigo-600 hover:text-indigo-500">Privacy Policy</a>.</p>
                </div>
              </div>
            </div>

            <!-- Submit Button -->
            <div>
              <%= f.submit "Create account", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition duration-150 ease-in-out", data: { action: "click->registration-validation#validateForm" } %>
            </div>
          <% end %>

          <!-- Divider -->
          <div class="mt-6">
            <div class="relative">
              <div class="absolute inset-0 flex items-center">
                <div class="w-full border-t border-gray-300"></div>
              </div>
              <div class="relative flex justify-center text-sm">
                <span class="px-2 bg-white text-gray-500">Already have an account?</span>
              </div>
            </div>

            <div class="mt-6">
              <%= link_to "Sign in instead", new_session_path(resource_name), class: "w-full flex justify-center py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition duration-150 ease-in-out" %>
            </div>
          </div>
        </div>
        
        <!-- Footer Link -->
        <div class="mt-6 text-center">
          <p class="text-xs text-gray-500">
            By creating an account, you agree to our <a href="#" class="underline">Terms of Service</a> and <a href="#" class="underline">Privacy Policy</a>.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<% content_for :page_scripts do %>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof window.Stimulus !== 'undefined') {
      // Registration validation controller
      window.Stimulus.register('registration-validation', class extends window.Stimulus.Controller {
        static targets = [
          'firstName', 'lastName', 'email', 'password', 'passwordConfirmation',
          'firstNameError', 'lastNameError', 'emailError', 'passwordError', 'passwordConfirmationError',
          'eyeIcon', 'passwordStrength', 'passwordStrengthBar', 'passwordStrengthText'
        ];
        
        connect() {
          console.log('Registration validation controller connected');
        }
        
        validateName(event) {
          const input = event.target;
          const errorTarget = input.id === 'user_first_name' ? this.firstNameErrorTarget : this.lastNameErrorTarget;
          
          if (input.value.trim() === '') {
            errorTarget.textContent = 'Name cannot be blank';
            errorTarget.classList.remove('hidden');
          } else {
            errorTarget.classList.add('hidden');
          }
        }
        
        validateEmail(event) {
          const email = event.target.value;
          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          
          if (email.trim() === '') {
            this.emailErrorTarget.textContent = 'Email cannot be blank';
            this.emailErrorTarget.classList.remove('hidden');
          } else if (!emailRegex.test(email)) {
            this.emailErrorTarget.textContent = 'Please enter a valid email address';
            this.emailErrorTarget.classList.remove('hidden');
          } else {
            this.emailErrorTarget.classList.add('hidden');
          }
        }
        
        validatePassword(event) {
          const password = event.target.value;
          
          // Get all the password criteria elements
          const lengthCriterion = document.querySelector('.grid-cols-2 .flex:nth-child(1) svg');
          const uppercaseCriterion = document.querySelector('.grid-cols-2 .flex:nth-child(2) svg');
          const lowercaseCriterion = document.querySelector('.grid-cols-2 .flex:nth-child(3) svg');
          const specialCharCriterion = document.querySelector('.grid-cols-2 .flex:nth-child(4) svg');
          
          // Check each criterion
          const hasMinLength = password.length >= 8;
          const hasUppercase = /[A-Z]+/.test(password);
          const hasLowercase = /[a-z]+/.test(password);
          const hasSpecialChar = /[0-9]+/.test(password) || /[^a-zA-Z0-9]+/.test(password);
          
          // Update visual indicators for each criterion
          this.updateCriterion(lengthCriterion, hasMinLength);
          this.updateCriterion(uppercaseCriterion, hasUppercase);
          this.updateCriterion(lowercaseCriterion, hasLowercase);
          this.updateCriterion(specialCharCriterion, hasSpecialChar);
          
          // Calculate strength
          let strength = 0;
          if (hasMinLength) strength += 25;
          if (hasUppercase) strength += 25;
          if (hasLowercase) strength += 25;
          if (hasSpecialChar) strength += 25;
          
          // Update strength bar with animation
          this.passwordStrengthBarTarget.style.width = strength + '%';
          
          // Update color and text
          this.passwordStrengthBarTarget.classList.remove('bg-red-500', 'bg-yellow-500', 'bg-green-500');
          this.passwordStrengthTextTarget.classList.remove('text-red-500', 'text-yellow-500', 'text-green-500');
          
          if (strength < 30) {
            this.passwordStrengthBarTarget.classList.add('bg-red-500');
            this.passwordStrengthTextTarget.classList.add('text-red-500');
            this.passwordStrengthTextTarget.textContent = 'Weak';
          } else if (strength < 75) {
            this.passwordStrengthBarTarget.classList.add('bg-yellow-500');
            this.passwordStrengthTextTarget.classList.add('text-yellow-600');
            this.passwordStrengthTextTarget.textContent = 'Medium';
          } else {
            this.passwordStrengthBarTarget.classList.add('bg-green-500');
            this.passwordStrengthTextTarget.classList.add('text-green-500');
            this.passwordStrengthTextTarget.textContent = 'Strong';
          }
          
          // Validate password
          if (password.trim() === '') {
            this.passwordErrorTarget.textContent = 'Password cannot be blank';
            this.passwordErrorTarget.classList.remove('hidden');
          } else if (password.length < 8) {
            this.passwordErrorTarget.textContent = 'Password must be at least 8 characters';
            this.passwordErrorTarget.classList.remove('hidden');
          } else {
            this.passwordErrorTarget.classList.add('hidden');
          }
        },
        
        updateCriterion(element, isValid) {
          if (element) {
            if (isValid) {
              element.classList.remove('text-gray-400');
              element.classList.add('text-green-500');
            } else {
              element.classList.remove('text-green-500');
              element.classList.add('text-gray-400');
            }
          }
        },
        
        validatePasswordConfirmation(event) {
          const passwordConfirmation = event.target.value;
          const password = this.passwordTarget.value;
          
          if (passwordConfirmation.trim() === '') {
            this.passwordConfirmationErrorTarget.textContent = 'Please confirm your password';
            this.passwordConfirmationErrorTarget.classList.remove('hidden');
          } else if (passwordConfirmation !== password) {
            this.passwordConfirmationErrorTarget.textContent = 'Passwords do not match';
            this.passwordConfirmationErrorTarget.classList.remove('hidden');
          } else {
            this.passwordConfirmationErrorTarget.classList.add('hidden');
          }
        }
        
        togglePasswordVisibility() {
          const input = this.passwordTarget;
          
          if (input.type === 'password') {
            input.type = 'text';
            this.eyeIconTarget.innerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
              </svg>
            `;
          } else {
            input.type = 'password';
            this.eyeIconTarget.innerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
              </svg>
            `;
          }
        }
        
        validateForm(event) {
          // Trigger all validations
          this.validateName({ target: this.firstNameTarget });
          this.validateName({ target: this.lastNameTarget });
          this.validateEmail({ target: this.emailTarget });
          this.validatePassword({ target: this.passwordTarget });
          this.validatePasswordConfirmation({ target: this.passwordConfirmationTarget });
          
          // Check if any errors are visible
          const errors = [
            this.firstNameErrorTarget,
            this.lastNameErrorTarget,
            this.emailErrorTarget,
            this.passwordErrorTarget,
            this.passwordConfirmationErrorTarget
          ];
          
          const hasErrors = errors.some(error => !error.classList.contains('hidden'));
          
          if (hasErrors) {
            event.preventDefault();
          }
        }
      });
      
      // Profile upload controller
      window.Stimulus.register('profile-upload', class extends window.Stimulus.Controller {
        static targets = ['input', 'fileName', 'preview'];
        
        connect() {
          console.log('Profile upload controller connected');
        }
        
        displayFileAndPreview(event) {
          const file = event.target.files[0];
          
          if (file) {
            this.fileNameTarget.textContent = file.name;
            
            // Display preview image
            const reader = new FileReader();
            reader.onload = (e) => {
              this.previewTarget.innerHTML = `<img src="${e.target.result}" class="h-full w-full object-cover" alt="Profile preview">`;
            };
            reader.readAsDataURL(file);
          } else {
            this.fileNameTarget.textContent = 'No file selected';
            this.previewTarget.innerHTML = `
              <svg class="h-full w-full text-gray-300" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            `;
          }
        }
      });
    }
  });
</script>
<% end %>
